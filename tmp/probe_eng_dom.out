alc(100vh - 200px);*/ /*Change 100px to 200px*/\n                overflow-y: hidden;\n                overflow-x: hidden;\n            }\n\n            .SideMenuListContent {\n                height: 4.5VH;\n            }\n        }\n\n        /*Added by MiaoRu 20211013*/\n        .ttooltip + .tooltip > .tooltip-inner {\n            white-space: pre;\n            max-width: none;\n            text-align: left;\n            background-color: rgb(255, 242, 204);\n            color: black;\n        }\n        /*End Added by MiaoRu 20211013*/\n\n        /*Added by Koh Chin Choong 20211019 - To resolve menu label shown issue in tablet*/\n        .menu-labelname {\n            padding: 0px 3px 0px 0px;\n            font-size: 15px;\n            display: flex;\n            align-items: center;\n            text-decoration: none;\n            margin-bottom: 0px;\n            font-weight: normal !important;\n        }\n\n        .hide-menulabel {\n            /*display: none !important;*/\n        }\n\n\n        #leftNavPanelLastMenu.luna-nav.nav li > a, #leftNavPanelLastMenu.luna-nav.nav li > a:hover {\n            color: black;\n        }\n\n        .SideMenuListContent img {\n            width: 2.7vh;\n        }\n\n        .HideMenu {\n            z-index: -1;\n        }\n\n        .disableMouseEvent {\n            pointer-events: none;\n        }\n\n        .oldpassword-field-icon {\n            margin-left: -25px;\n            margin-top: -23px;\n            position: relative;\n            z-index: 2;\n            width: 5%;\n            margin-right: 5px;\n            float: right;\n        }\n\n        .newpassword-field-icon {\n            margin-left: -25px;\n            margin-top: -23px;\n            position: relative;\n            z-index: 2;\n            width: 5%;\n            margin-right: 5px;\n            float: right;\n        }\n\n        .retypepassword-field-icon {\n            margin-left: -25px;\n            margin-top: -23px;\n            position: relative;\n            z-index: 2;\n            width: 5%;\n            margin-right: 5px;\n            float: right;\n        }\n\n        .passwordhideshow {\n            -webkit-text-security: disc;\n        }\n\n        /*.floatIcon{\n            position:fixed !important;\n            width:50px;\n            height:50px;\n            bottom:20px;\n            right:20px;\n            background-color:#587def;\n            color:#FFF;\n            border-radius:50px;\n            text-align:center;\n            box-shadow: 2px 2px 3px #999;\n            opacity: 1 !important;\n        }\n\n        .floatIcon:hover {\n            background-color: #dbeff5;\n            color: black;\n            cursor: pointer;\n        }\n\n        .my-float{\n            margin-top:16px;\n            font-size: 18px\n        }\n\n        .floatIcon-tooltip {\n          position: relative;\n          display: inline-block;\n          border-bottom: 1px dotted black;\n        }\n\n        .floatIcon-tooltip .floatIcon-tooltiptext {\n          visibility: hidden;\n          width: 80px;\n          bottom: 110%;\n          left: 50%;\n          margin-left: -40px;\n          background-color: black;\n          color: #fff;\n          text-align: center;\n          padding: 5px 0;\n          border-radius: 6px;\n          position: absolute;\n          z-index: 1;\n        }\n\n        .floatIcon-tooltip .floatIcon-tooltiptext::after {\n          content: \" \";\n          position: absolute;\n          top: 100%;\n          left: 50%;\n          margin-left: -5px;\n          border-width: 5px;\n          border-style: solid;\n          border-color: black transparent transparent transparent;\n        }\n\n        .floatIcon-tooltip:hover .floatIcon-tooltiptext {\n          visibility: visible;\n        }*/\n\n        .UpdateProfileDiv > .dropdown-menu {\n            right: 80px;\n        }\n\n            .UpdateProfileDiv > .dropdown-menu > li > a {\n                padding: 10px 20px !important;\n                cursor: pointer;\n            }\n\n        /*.lblProfile:hover {\n            color: grey !important;\n        }\n\n        #UpdateProfile:hover {\n            background-color: grey !important;\n        }*/\n\n        .SideMenuContactUs {\n            width: 45px;\n            height: 45px;\n            background-color: var(--nav-header-color);\n            border-radius: 50px;\n            margin: auto;\n            cursor: pointer;\n            box-shadow: 2px 2px 3px #999;\n            color: white;\n        }\n\n            .SideMenuContactUs:hover {\n                background-color: var(--button-background-color);\n                color: black !important;\n            }\n\n        .scrollbar-primary::-webkit-scrollbar {\n            width: 10px;\n            height: 10px;\n        }\n\n        .scrollbar-primary::-webkit-scrollbar-thumb {\n            border-radius: 10px;\n            -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.1);\n            background-color: #c1c1c1;\n        }\n\n        .badge-counter {\n            position: absolute;\n            transform: scale(.7);\n            transform-origin: top right;\n            right: .25rem;\n            margin-top: -.25rem;\n        }\n\n        .badge-danger {\n            color: #fff;\n            /*background-color: #e74a3b;*/\n            background-color: var(--bs-danger);\n        }\n            \n        .badge-warning {\n            color: #fff; \n            background-color: var(--bs-warning);\n        }\n        .badge-primary {\n            color: #fff; \n            background-color: var(--bs-primary);\n        }\n        .badge-secondary {\n            color: #fff; \n            background-color: var(--bs-secondary);\n        }\n        .badge-info {\n            color: #fff; \n            background-color: var(--bs-info);\n        }\n         .badge-success {\n            color: #fff; \n            background-color: var(--bs-success);\n        }\n        .badge {\n            display: inline-block;\n            padding: .25em .4em;\n            font-size: 75%;\n            font-weight: 700;\n            line-height: 1;\n            text-align: center;\n            white-space: nowrap;\n            vertical-align: baseline;\n            border-radius: .35rem;\n            transition: color .15s ease-in-out,background-color .15s ease-in-out,border-color .15s ease-in-out,box-shadow .15s ease-in-out;\n        }\n        .input_SideMenuSearch:hover,\n        .input_SideMenuSearch:focus {\n            outline: none !important;\n            outline-width: 0 !important;\n            box-shadow: none;\n            -moz-box-shadow: none;\n            -webkit-box-shadow: none;\n        }\n        #sideMenuModal .modal-content {\n            border-radius: 20px;\n            backdrop-filter: blur(8px);\n            padding: 50px;\n            background: -webkit-radial-gradient(left, circle cover, #ffffff 0%, #dcdcdc 80%) !important; \n        }\n\n        #sideMenuModal .modal-content .modal-body {\n            border-radius: 20px; \n        }\n        #sideMenuModal .magamenu-header-wrap, \n        #sideMenuModal .megamenu-body {\n            background: transparent !important; \n        } \n        #sideMenuModal .megamenu-body tr:last-child {\n            border-bottom: none;\n        }\n\n        #sideMenuModal ::-webkit-input-placeholder { /* WebKit, Blink, Edge */\n            color: var(--bs-primary);\n        }\n\n        #sideMenuModal :-moz-placeholder { /* Mozilla Firefox 4 to 18 */\n            color: var(--bs-primary);\n            opacity: 1;\n        }\n\n        #sideMenuModal ::-moz-placeholder { /* Mozilla Firefox 19+ */\n            color: var(--bs-primary);\n            opacity: 1;\n        }\n\n        #sideMenuModal :-ms-input-placeholder { /* Internet Explorer 10-11 */\n            color: var(--bs-primary);\n        }\n\n        #sideMenuModal ::-ms-input-placeholder { /* Microsoft Edge */\n            color: var(--bs-primary);\n        }\n\n        #sideMenuModal ::placeholder { /* Most modern browsers support this now. */\n            color: var(--bs-primary);\n        }\n        .editable-buttons .btn-default.editable-cancel {\n            background-color: var(--bs-danger);\n            border: none;\n        }\n        .editable-buttons .btn-sm {\n            border-radius: 5px !important;\n        }\n    \n    \n    \n\n\n\n\n\n\n    \n\n    \n\n    \n\n    \n\n    \n    \n    \n\n    \n\n    \n\n    \n\n    \n\n    \n    .cke{visibility:hidden;}\n\n    \n    \n\n    \n    \n\n    \n\n    \n\n    \n\n    \n\n    \n\n    \n\n    \n\n         \n\n\n\n\n    \n    \n    \n    \n        \n    \n    \n        \n        \n            \n                \n                    \n                    \n                \n                \n                    \n                        \n                        \n                        \n                        \n                            \n                            \n                            \n                            \n                        \n                    \n\n                \n                \n                    \n                    \n                        \n                            \n                                \n                                    \n                                    SSOC\n                                \n                            \n                        \n                    \n                \n                \n                    Patient: 78160 / ENG CHAI PIN ELYNE XANDRIA (S8570522I)        F : 40 y\n                \n                \n                \n                \n                    \n                        \n                            \n                                \n                            \n                        \n                    \n                    \n                        \n                        \n                        Details\n                        Do Not Show Again This Session\n                    \n                \n\n                \n                    \n                        \n\n    \n    \n\n    \n\n    \n    \n    \n\n    \n        \n            \n                \n                \n                \n\n                \n                \n                \n                \n                \n                \n                RECEPTION\n                \n                \n                \n                    \n                        Vincent\n                        \n                            \n                        \n                    \n                    \n                        Profile\n                        Logout\n                    \n                \n                \n                \n                \n                    \n                        \n                            \n                            0\n                        \n                    \n                    \n                        \n                     No Notification \n                \n            \n        \n    \n\n\n\n\n\n\n\n\n\n\n\n    $(document).ready(function () {\n        $('[data-toggle=\"tooltip\"]').tooltip();\n        insertuserinfo();\n        //$(\"#msgErrorUpdateProfile\").hide();\n        $(\"#msgErrorUpdateProfile\").show();\n\n        var userIcon = decodeURIComponent('%2fusericon%2f004-nurse.png');\n\n        if (userIcon != ''){\n            var src = userIcon + '?queryString=' + Math.floor(Math.random() * 100000000000);\n\n            $('#UserIconDefault').hide();\n            $('#UserIconSpan').show();\n            $('#UserIconImgPath').prop(\"src\", src)\n\n            $(\".UpdateUserInfoSub_panel i\").remove();\n            $(\".UpdateUserInfoSub_panel\").empty();\n            $(\".UpdateUserInfoSub_panel\").append('<img src=\"' + src + '\" style=\"height:30px;width:30px;margin-top: -6px;margin-left: -3px;\">');\n        }\n\n        loadNotification();\n        let trigger = setInterval(function () {\n            //GetSeenUnseenQMsg();\n            //GetPendingAppt();\n            loadNotification();\n        }, 65000);\n\n        CheckQueueRequest();\n        let CheckQueueRequestTimer;\n        if (1.00 > 0) {\n            CheckQueueRequestTimer = setInterval(function() {\n                CheckQueueRequest();\n            }, 60000 * 1.00);\n        } else {\n            CheckQueueRequestTimer = setInterval(function() {\n                CheckQueueRequest();\n            }, 60000);\n        }\n    });\n\n    function insertuserinfo() {\n        var userID = 'Vincent';\n        var fullName = 'Vincent';\n        var mobileno = '';\n        var email = '';\n\n        $('#txtUserID_update').val(userID);\n        $('#txtFullName_update').val(fullName);\n        $('#txtOldPassword_update').val(\"\");\n        $('#txtNewPassword_update').val(\"\");\n        $('#txtReTypePassword_update').val(\"\");\n        $('#txtEmail_update').val(email);\n        $('#txtMobileNo_update').val(mobileno);\n    }\n\n    //Issues key:CAS_WEB_SP-92\n    function logout() {\n        if (getPageName(window.location.pathname) == \"InitCaseNote\") {\n            savetabs_SessionEnd();\n        }\n\n        ClientErrorLog(\"Logout\", \"Function - Logout\", window.location.pathname, \"\");\n\n        checkAP('0', '', '/Authenticate/Logout');\n    }\n\n    function getPageName(url) {\n        var index = url.lastIndexOf(\"/\") + 1;\n        var filenameWithExtension = url.substr(index);\n        var filename = filenameWithExtension.split(\"?\")[0];\n        return filename;\n    }\n\n    //Insert information into erro list\n    function ClientErrorLog(Module_, Function_, Param, Description) {\n\n        var data = { Module_: Module_, Function_: Function_, Param: Param, Description: Description };\n\n        $.ajax({\n            cache: false,\n            url: \"/CaseNote/ClientErrorLog\",\n            data: data,\n            type: \"POST\",\n            data: JSON.stringify(data),\n            contentType: 'application/json; charset=utf-8',\n            success: function (response) {\n            },\n            error: function (xhr, textStatus, error) {\n            }\n        });\n    }\n\n    //$('#btnUpdateProfile').click(function () {\n    //    alert(\"Here\")\n    //    var txtUserID_update = $('#txtUserID_update').val();\n    //    var txtOldPassword_update = $('#txtOldPassword_update').val();\n    //    var txtNewPassword_update = $('#txtNewPassword_update').val();\n    //    var txtReTypePassword_update = $('#txtReTypePassword_update').val();\n    //    var txtEmail_update = $('#txtEmail_update').val();\n    //    var txtMobileNo_update = $('#txtMobileNo_update').val();\n\n    //    if (txtOldPassword_update.length == 0) {\n    //        $(\"#msgErrorUpdateProfile\").text(\"Please key in your old password\");\n    //        $(\"#msgErrorUpdateProfile\").show();\n    //        $('#txtOldPassword_update').focus();\n\n    //    }\n    //    else if (txtNewPassword_update.length == 0) {\n    //        $(\"#msgErrorUpdateProfile\").text(\"Please key in your new password\");\n    //        $(\"#msgErrorUpdateProfile\").show();\n    //        $('#txtNewPassword_update').focus();\n    //    }\n    //    else if (txtReTypePassword_update.length == 0) {\n    //        $(\"#msgErrorUpdateProfile\").text(\"Please key in your retype password\");\n    //        $(\"#msgErrorUpdateProfile\").show();\n    //        $('#txtReTypePassword_update').focus();\n    //    }\n    //    else if (txtNewPassword_update != txtReTypePassword_update) {\n    //        $(\"#msgErrorUpdateProfile\").text(\"Plase re-enter your confirmation password.\");\n    //        $(\"#msgErrorUpdateProfile\").show();\n    //        $('#txtReTypePassword_update').focus();\n    //    }\n    //    else {\n    //        $(\"#msgErrorUpdateProfile\").hide();\n    //        $(\"#msgErrorUpdateProfile\").text(\"\");\n    //        userupdate_post(txtUserID_update, txtOldPassword_update, txtNewPassword_update, txtReTypePassword_update, txtEmail_update, txtMobileNo_update);\n    //    }\n    //});\n\n    //function userupdate_post(txtUserID_update, txtOldPassword_update, txtNewPassword_update, txtReTypePassword_update, txtEmail_update, txtMobileNo_update)\n    //{\n    //    var myData = { txtUserID_update: txtUserID_update, txtOldPassword_update: txtOldPassword_update, txtNewPassword_update: txtNewPassword_update, txtReTypePassword_update: txtReTypePassword_update, txtEmail_update: txtEmail_update, txtMobileNo_update: txtMobileNo_update };\n    //    var encoded = JSON.stringify(myData);\n\n    //    var sign = $.ajax({\n    //        cache: false,\n    //        type: \"POST\",\n    //        data: encoded,\n    //        url: \"/Home/UpdateUserProfile\",\n    //        contentType: \"application/json; charset=utf-8\",\n    //        dataType: \"json\",\n    //        async: false,\n    //        success: function (result) {\n    //            if (result.success) {\n    //                swal({ title: \"\", text: \"Password has been updated\", type: \"success\", type: \"success\", timer: 2000 });\n    //                $('#txtOldPassword_update').val(\"\");\n    //                $('#txtNewPassword_update').val(\"\");\n    //                $('#txtReTypePassword_update').val(\"\");\n    //            } else {\n    //                $(\"#msgErrorUpdateProfile\").text(result.message);\n    //                $(\"#msgErrorUpdateProfile\").show();\n\n    //                if (typeof result.controlId != 'undefined') {\n    //                    if (result.controlId.length > 0) {\n    //                        var control = '#' + result.controlId\n\n    //                        $(control).focus();\n    //                        $(control).focus(function () { $(this).select(); });\n    //                    }\n    //                }\n    //            }\n    //        },\n    //        error: function (xhr, status) {\n\n    //        }\n    //    });\n    //}\n\n    //$(\"#txtOldPassword_update\").keydown(function (e) {\n    //    var code = e.which;\n\n    //    if (code == 13) {\n    //        $('#txtNewPassword_update').focus();\n    //        $(\"#txtNewPassword_update\").focus(function () { $(this).select(); });\n    //        e.Handled = true;\n    //    }\n    //});\n\n    //$(\"#txtNewPassword_update\").keydown(function (e) {\n    //    var code = e.which;\n\n    //    if (code == 13) {\n    //        $('#txtReTypePassword_update').focus();\n    //        $(\"#txtReTypePassword_update\").focus(function () { $(this).select(); });\n    //        e.Handled = true;\n    //    }\n    //});\n\n    //$(\"#txtReTypePassword_update\").keydown(function (e) {\n    //    var code = e.which;\n\n    //    if (code == 13) {\n    //        $('#txtEmail_update').focus();\n    //        $(\"#txtEmail_update\").focus(function () { $(this).select(); });\n    //        e.Handled = true;\n    //    }\n    //});\n\n    //$(\"#txtEmail_update\").keydown(function (e) {\n    //    var code = e.which;\n\n    //    if (code == 13) {\n    //        $('#txtMobileNo_update').focus();\n    //        $(\"#txtMobileNo_update\").focus(function () { $(this).select(); });\n    //        e.Handled = true;\n    //    }\n    //});\n\n    //$(\"#txtMobileNo_update\").keydown(function (e) {\n    //    var code = e.which;\n\n    //    if (code == 13) {\n    //        $('#btnUpdateProfile').focus();\n    //        e.Handled = true;\n    //    }\n    //});\n    function loadNotification() {\n        var TotalUnseenCount;   //Added by Lim Han Yong 20240122 - add no notification to notification\n        var TotalQueueMsgCount; //Added by Lim Han Yong 20240122 - add no notification to notification\n        var pendingApptCount;   //Added by Lim Han Yong 20240122 - add no notification to notification\n        $.ajax({\n            cache: false,\n            url: \"/SMS/GetSeenUnseenQMsg\",\n            type: 'get',\n            async: false,\n            success: function(result) {\n                if (result.success) {\n                    TotalUnseenCount = result.TotalUnseen ; //Added by Lim Han Yong 20240122 - add no notification to notification\n                    TotalQueueMsgCount = result.TotalQueueMsg;  //Added by Lim Han Yong 20240122 - add no notification to notification\n                    if ($(\".notificationDropDown\").find(\".pendingSMSReceived\").length)\n                        $(\".notificationDropDown\").find(\".pendingSMSReceived\").remove();\n\n                    if ($(\".notificationDropDown\").find(\".pendingSMSinQ\").length)\n                        $(\".notificationDropDown\").find(\".pendingSMSinQ\").remove();\n\n                    if (result.TotalUnseen != \"0\" && result.TotalQueueMsg != \"0\") {\n                        //$(\"#lblIncomingMsg\").show();\n                        //$(\"#lblIncomingMsg span.inner\").text(result.TotalUnseen + \" Message Received\");\n                        $(\".notificationDropDown\").append(\"<li class='pendingSMSReceived' onclick='UpdateAcknowledge();'><a>\" + result.TotalUnseen + \" Message Received</a></li>\");\n\n                        //$(\"#lblSMSInQueue\").show();\n                        //$(\"#lblSMSInQueue span.inner\").text(result.TotalQueueMsg + \" Message In Queue\");\n                        $(\".notificationDropDown\").append(\"<li class='pendingSMSinQ' onclick='showInQueue();'><a>\" + result.TotalQueueMsg + \" Message in Queue</a></li>\");\n                    } else if (result.TotalUnseen == \"0\" && result.TotalQueueMsg != \"0\") {\n                        //$(\"#lblIncomingMsg\").hide();\n\n                        //$(\"#lblSMSInQueue\").show();\n                        //$(\"#lblSMSInQueue span.inner\").text(result.TotalQueueMsg + \" Message In Queue\");\n                        $(\".notificationDropDown\").append(\"<li class='pendingSMSinQ' onclick='showInQueue();'><a>\" + result.TotalQueueMsg + \" Message in Queue</a></li>\");\n                        $(\".notificationDropDown\").find(\".pendingSMSReceived\").remove();\n                    } else if (result.TotalUnseen != \"0\" && result.TotalQueueMsg == \"0\") {\n                        //$(\"#lblIncomingMsg\").show();\n                        //$(\"#lblIncomingMsg span.inner\").text(result.TotalUnseen + \" Message Received\");\n\n                        //$(\"#lblSMSInQueue\").hide();\n                        $(\".notificationDropDown\").append(\"<li class='pendingSMSReceived' onclick='UpdateAcknowledge();'><a>\" + result.TotalUnseen + \" Message Received</a></li>\");\n                        $(\".notificationDropDown\").find(\".pendingSMSinQ\").remove();\n                    } else {\n                        $(\".notificationDropDown\").find(\".pendingSMSReceived\").remove();\n                        $(\".notificationDropDown\").find(\".pendingSMSinQ\").remove();\n                    }\n\n                    $.ajax({\n                        cache: false,\n                        url: \"/Appointment/getevents_PendingFromQueue\",\n                        type: 'POST',\n                        async: false,\n                        success: function (result) {\n                            pendingApptCount = result.count;    //Added by Lim Han Yong 20240122 - add no notification to notification\n                            if (result.count > 0) {\n                                if ($(\".notificationDropDown\").find(\".pendingAppt\").length)\n                                    $(\".notificationDropDown\").find(\".pendingAppt\").remove();\n\n                                $(\".notificationDropDown\").append(\"<li class='pendingAppt' onclick='redirectToAppt();'><a>\" + result.count + \" Pending Appointment</a></li>\");\n                            } else {\n                                $(\".notificationDropDown\").find(\".pendingAppt\").remove();\n                            }\n\n                            updateNotificationBadge();\n                        },\n                        error: function (xhr, status) { }\n                    });\n                    //Added by Lim Han Yong 20240122 - add no notification to notification\n                    if (TotalUnseenCount == \"0\" && TotalQueueMsgCount == \"0\" && pendingApptCount == \"0\"){\n                        $(\".notificationDropDown\").find(\".noNotification\").remove();    //Added by Lim Han Yong 20240123 - remove 1st to prevent multiple notification.\n                        $(\".notificationDropDown\").append(\"<p class='noNotification' style='padding: 10px 20px !important;'> No Notification </p>\"); \n                    }\n                    else{\n                        $(\".notificationDropDown\").find(\".noNotification\").remove();\n                    }\n                    //End Added by Lim Han Yong 20240122\n                }\n            },\n            error: function(xhr, status) {}\n        });\n    }\n\n    function CheckQueueRequest() {\n        if ('True' == \"True\" && 'N' == \"Y\") {\n            $.ajax({\n                cache: false,\n                url: \"/QueueLog/CheckQueueRequest\",\n                type: 'post',\n                data: '',\n                async: false,\n                success: function(result) {\n                    if (result.success) {\n                        $(\"#btnEHAQueueRequest\").show();\n                        if ($(\".notificationDropDown\").find(\".pendingQRequest\").length)\n                            $(\".notificationDropDown\").find(\".pendingQRequest\").remove();\n\n                        $(\".notificationDropDown\").append(\"<li class='pendingQRequest' onclick='showEHAQueueRequest();'><a>\" + result.count + \" Pending Queue Request</a></li>\");\n                    } else {\n                        $(\".notificationDropDown\").find(\".pendingQRequest\").remove();\n                    }\n\n                    updateNotificationBadge();\n                },\n                error: function(xhr, status) {}\n            });\n        }\n    }\n\n    function updateNotificationBadge() {\n        $(\".notificationBadge\").html($(\".notificationDropDown\").find(\"li\").length);\n\n        if ($(\".notificationDropDown\").find(\"li\").length > 0) {\n            $(\".notificationBadge\").show();\n            $(\"#NotificationDiv\").css(\"pointer-events\", \"auto\");\n        }\n        else {\n            $(\".notificationBadge\").hide();\n            $(\"#NotificationDiv\").css(\"pointer-events\", \"none\");\n        }\n    }\n\n    function redirectToAppt() {\n        Cookies.set('checkPendingAppointment', 'Y');\n        checkAP(\"02012\", \"\", \"\");\n    }\n\n    function UpdateAcknowledge() {\n        $.ajax({\n            cache: false,\n            url: \"/SMS/UpdateAcknowledge\",\n            type: 'post',\n            data: '',\n            success: function(result) {\n                $(\".notificationDropDown\").find(\".pendingSMSReceived\").remove();\n            },\n            error: function(xhr, status) {}\n        });\n    }\n\n    function showInQueue() {\n        $('.fadeMe').show();\n        $('#smsInQueueModalLabel').text(\"SMS In Queue\");\n        $(\"#smsInQueueModalBody\").load('https://clinicassist.sg:1080/en/SMS/SMSInQueue');\n        $(\"#smsInQueueModal\").modal('show').removeClass(\"fade\");\n    }\n\n    function showEHAQueueRequest() {\n        $(\"#EHAQueueRequestModalBody\").load('https://clinicassist.sg:1080/en/QueueLog/QueueRequest?doctorcount=' + null);\n        $(\"#EHAQueueRequestModal\").modal('show').removeClass(\"fade\");\n    }\n\n                    \n                \n            \n        \n        \n        \n        \n\n            \n            \n            \n            \n\n                \n                \n                    Call Center\n                \n\n                \n\n\n                \n                    \n                        \n  