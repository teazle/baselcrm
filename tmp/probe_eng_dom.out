      ".TabPatientAllergy_MainPanel {\n        display: flex;\n        display: -webkit-flex;\n        height: 100%;\n        flex: 1;\n        margin-bottom: 0;\n        flex-flow: column nowrap;\n    }\n\n    .DisplayBlock {\n        display: block !important;\n    }\n\n    /*Added by Cooper 20180711 - Change to bootstrap datepicker*/\n    .datepicker th {\n        color: #494b54;\n    }\n\n    .datepicker-inline {\n        max-width: 180px;\n    }\n\n    #divPatientAllergyOtherAdd svg path {\n        fill: black;\n    }\n\n    #btnPatientAllergyAdd svg path {\n        fill: black;\n    }\n\n    .nopadding {\n        padding: 0 !important;\n        margin: 0 !important;\n    }\n\n    #setupPatientAllergyModal, #patientAllergyOtherModal{\n        z-index: 1052;\n    }\n\n    #divOtherAllergy {\n        border: none;\n        width: 100%;\n    }\n\n    #divAllergy{\n        border: none;\n        width: 100%;\n    }\n\n\nPlease fix these errors.\n\n\n    \n    \n    \n\n     \n    \n        \n            \n                \n                \n                    \n                        Allergy\n                    \n                \n                \n                \n                    \n                        \n                            \n                                Drug Allergy\n                                \n                                     Add\n                                \n                            \n                        \n                        \n                            \n                                \n                                    Loading...  Code Description Type \n                                \n                            \n                        \n                        \n                            \n                                Non Drug Allergy\n                                \n                                     Add\n                                \n                            \n                        \n                        \n                            \n                                \n                                    \n                                    Loading...  Type Description Onset Date Severity Reaction RemarksDCephalexin 03/02/2026I  DCiprofloxacin03/02/2026I   \n                                \n                            \n                        \n                        \n                            \n                                \n                                    \n                                        G6PD Deficiency\n                                        UNKNOWN\nYES\nNO\n\n                                    \n                                    \n                                         Pregnancy\n                                        Due Date:\n                                        \n                                    \n                                \n                            \n                        \n                        \n                            \n                                Med Notes (Display In QueueLog)\n                                \n                            \n                        \n                        \n                            \n                             \n                        \n\n                        \n                            \n                        \n                    \n                    \n                    \n                        \n                        \n                    \n                \n                \n            \n        \n    \n\n\n\n\n\n\n\n    $(document).ready(function () {\n        var pcno = $('#hfPCNO_tpa').val();\n        if (pcno == ''){\n            if ($(\"#txtPatientNo\").val() != 'NEW'){\n                pcno = $(\"#txtPatientNo\").val();\n            }\n        }\n        var urlPatientAllergystring = 'https://clinicassist.sg:1080/en/Patient/GetPatientAllergy?pcno=' + pcno;\n        if ($(\"#queueDispenseIndex\").is(':visible')) {\n            var patientAllergyDescWidth = 361;\n            var patientAllergyTypeWidth = 78;\n\n            var patientAllergyOtherTypeWidth = 36;\n            var patientAllergyOtherDescWidth = 276;\n            var patientAllergyOtherSeverityWidth = 54;\n            var patientAllergyOtherDateIDWidth = 72;\n            var patientAllergyOtherReactionWidth = 120;\n            var patientAllergyOtherRemarksWidth = 150;\n        }\n        else {\n            patientAllergyDescWidth = 620;\n            patientAllergyTypeWidth = 200;\n\n            patientAllergyOtherTypeWidth = 100;\n            patientAllergyOtherDescWidth = 310;\n            patientAllergyOtherSeverityWidth = 80;\n            patientAllergyOtherDateIDWidth = 100;\n            patientAllergyOtherReactionWidth = 120;\n            patientAllergyOtherRemarksWidth = 150;\n        }\n\n        $(\"#patientAllergyGrid\").jqGrid({\n            url: urlPatientAllergystring,\n            datatype: 'json',\n            mtype: 'Get',\n            colNames: ['', 'Code', 'Description', 'Type'],\n            colModel: [\n                { key: false, name: 'Delete', index: 'Delete', align: 'center', width: 30, sortable: false, formatter: formatRemovePatientAllergy },\n                { key: true, name: 'Code', index: 'Code', width: 300, sortable: false, hidden: true },\n                { key: false, name: 'Description', index: 'Description', width: 620, sortable: false },\n                { key: false, name: 'MIMSType', index: 'MIMSType', width: 200, sortable: false },\n            ],\n            rowNum: -1,\n            //rowList:['All','100','500','1000'], //Commented By Bryan 20200212 - To reduce loading speed (Requested by Peter)\n            //gridview: true, //Commented By Bryan 20200212 - To reduce loading speed (Requested by Peter)\n            width: 'auto',\n            height: 'auto',\n            scrollOffset: 0,\n            hoverrows: false,\n            viewrecords: false,\n            loadError: function (xhr, status, error) {\n            },\n            loadComplete: function () {\n                JqgridLoadComplete(this);\n                var ids = $(\"#patientAllergyGrid\").jqGrid(\"getDataIDs\");\n\n                if (ids.length <= 100)  {\n                    $(\"#patientAllergyGrid tr\").eq(1).trigger(\"click\");\n                }\n\n                var pageURL = $(location).attr(\"href\");\n\n                if (pageURL.toLowerCase().indexOf(\"queuedispense\") > 0)  {\n                    $(\"#patientAllergyGrid\").hideCol(\"Delete\");\n                }\n                reloadDispenseAllergy()\n                checkMedAlertExist()\n            },\n            emptyrecords: 'No records to display',\n            jsonReader: {\n                root: \"rows\",\n                page: \"page\",\n                total: \"total\",\n                records: \"records\",\n                repeatitems: false,\n                Id: \"0\"\n            },\n            shrinkToFit: true,\n            multiselect: false\n        });\n\n        var urlPatientAllergyOtherstring = 'https://clinicassist.sg:1080/en/Patient/GetPatientAllergyOther?pcno=' + pcno;\n\n        $(\"#patientAllergyOtherGrid\").jqGrid({\n            url: urlPatientAllergyOtherstring,\n            datatype: 'json',\n            mtype: 'Get',\n            colNames: ['', 'Type', 'Description', 'Onset Date', 'Severity', 'Reaction', 'Remarks'],\n            colModel: [\n                { key: false, name: 'Delete', index: 'Delete', align: 'center', width: 30, sortable: false, formatter: formatRemovePatientAllergyOther },\n                { key: false, name: 'AllergyType', index: 'AllergyType', width: 100, sortable: false },\n                { key: false, name: 'AllergyDesc', index: 'AllergyDesc', width: 310, sortable: false },\n                { key: false, name: 'DateID', index: 'DateID', width: 100, sortable: false, formatter: 'date', formatoptions: { srcformat: \"d M Y H:i\", newformat: \"d/m/Y\" } },\n                { key: false, name: 'Severity', index: 'Severity', width: 80, sortable: false },\n                { key: false, name: 'Reaction', index: 'Reaction', width: 120, sortable: false },\n                { key: false, name: 'Remarks', index: 'Remarks', width: 150, sortable: false },\n            ],\n            rowNum: 100,\n            //rowList:['All','100','500','1000'], //Commented By Bryan 20200212 - To reduce loading speed (Requested by Peter)\n            //gridview: true, //Commented By Bryan 20200212 - To reduce loading speed (Requested by Peter)\n            width: 'auto',\n            height: 'auto',  \n            scrollOffset: 0,\n            hoverrows: false,\n            viewrecords: false,\n            loadError: function (xhr, status, error) {\n            },\n            loadComplete: function () {\n                JqgridLoadComplete(this);\n                var pageURL = $(location).attr(\"href\");\n\n                if (pageURL.toLowerCase().indexOf(\"queuedispense\") > 0) {\n                    $(\"#patientAllergyOtherGrid\").hideCol(\"Delete\");\n                }\n                reloadDispenseAllergy()\n                checkMedAlertExist()\n            },\n            emptyrecords: 'No records to display',\n            jsonReader: {\n                root: \"rows\",\n                page: \"page\",\n                total: \"total\",\n                records: \"records\",\n                repeatitems: false,\n                Id: \"0\"\n            },\n            shrinkToFit: true,\n            multiselect: false\n        });\n\n        //Added by Cooper 20180711 - Add Pregnancy, Pregnancy Due Date, MetalImplants And Claustrophobia\n        $(\"#PregnancyDueDate\").datepicker({\n            format: 'dd/mm/yyyy',\n            useCurrent: true,\n            todayHighlight: true,\n            autoclose: true\n        }).datepicker();\n\n        $(\"#PregnancyDueDate\").inputmask(\"date\", { \"clearIncomplete\" : true });\n\n        if ($('#chkPregnancy').is(':checked')) {\n            $('#PregnancyDueDate').removeAttr('disabled');\n            $('#PregnancyDueDate').css(\"background-color\", \"\");\n        } else {\n            $('#PregnancyDueDate').attr('disabled', 'disabled');\n            $('#PregnancyDueDate').css(\"background-color\", \"lightgrey\");\n        }\n\n        if ($(\"#tabAllergy\").length > 0) {\n            //remove flex display if under dispense screen as it Not in pop up modal mode\n            $(\".TabPatientAllergy_MainPanel\").addClass(\"DisplayBlock\");\n        }\n\n        var pageURL = $(location).attr(\"href\");\n\n        if (pageURL.toLowerCase().indexOf(\"queuedispense\") > 0) {\n            $(\"#btnPatientAllergyAdd\").hide();\n            $(\"#btnPatientAllergyDelete\").hide();\n            $(\"#btnPatientAllergyAddOther\").hide();\n            $(\"#btnPatientAllergyDeleteOther\").hide();\n            \n            $(\"#btnSavePatientHistory\").hide();\n            $(\"#chkPregnancy\").attr('disabled', 'disabled');\n            $(\"#chkMetalImplants\").attr('disabled', 'disabled');\n            $(\"#chkClaustrophobia\").attr('disabled', 'disabled');\n            $(\"#PregnancyDueDate\").attr('disabled', 'disabled');\n            $(\"#txtPatientG6PD\").attr('disabled', 'disabled');\n            //Adjust size when showing at dispense screen\n            $(\"#RadiologyPregnancyMain\").attr('class', 'col-lg-12');\n            $(\"#divPatientG6PD\").attr('class', 'col-lg-12');\n            $(\"#RadiologyMatalClauMain\").attr('class', 'col-lg-6');\n\n            $(\"#RadiologyPregnancy\").attr('class', 'col-lg-3 col-xl-6');\n            $(\"#RadiologyPregnancyDueDate\").attr('class', 'col-lg-6 col-xl-6');\n            $(\"#RadiologyMetalImplants\").attr('class', 'col-lg-12 col-xl-6');\n            $(\"#RadiologyClaustrophobia\").attr('class', 'col-lg-12 col-xl-6');\n            $(\"#lblPatientG6PD\").attr('class', 'col-lg-3 col-xl-6');\n            $(\"#ddpPatientG6PD\").attr('class', 'col-lg-6 col-xl-6');\n            $(\"#mednotes\").attr('disabled', 'disabled');\n            $(\"#divPatientHitory\").attr('style', 'height:100px');\n\n        }\n        else if (pageURL.toLowerCase().indexOf(\"casenote\") > 0)  {\n            if ($(\"#hfAllergyGotRecord\").val() == \"Y\") {\n                \n            }\n        }\n\n        else if (pageURL.toLowerCase().indexOf(\"casenote\") > 0)  {\n            if ($(\"#hfAllergyGotRecord\").val() == \"Y\") {\n                \n                }\n        }\n        else if (pageURL.toLowerCase().indexOf(\"appointment\") > 0)  {\n            $(\"#btnSavePatientHistory\").hide();\n        }\n        else if (pageURL.toLowerCase().indexOf(\"patient\") > 0 || pageURL.toLowerCase().indexOf(\"queuelog\") > 0) {\n            $(\"#btnSavePatientHistory\").hide();\n        }\n        //$(\"#txtAllergyOtherOnsetDate\").datepicker({ dateFormat: 'dd/mm/yy' });\n        //$(\"#txtAllergyOtherOnsetDate\").inputmask(\"date\", { \"clearIncomplete\" true });\n        if ($('#hfshowNILBtn').val() == 'True') {\n            $('#btnNIL').show();\n            $('#btnNIL').css('pointer-events', 'auto');\n        }\n        else {\n            $('#btnNIL').hide();\n            $('#btnNIL').css('pointer-events', 'none');\n        }\n\n        if ($('#tab-li-Biodata').hasClass('active')) {\n            $(\"#btnSavePatientHistory\").hide();\n        }\n\n        //added by Hao Wen 20211215 | if Not New patient, save old data to check Is there any update during exit\n        if ($('#txtPatientNo').val() != \"\") {\n            oldDataMedAlert = JSON.stringify($('#CreateEditPatientAllergyForm').serializeArray());\n        }\n        //End added by Hao Wen 20211215\n\n        var urlLocation = jQuery(location).attr('href');\n\n        if (urlLocation.indexOf(\"/QueueLog/PatientVisit\") > 0) {\n            var deductHeight = 520;\n\n            if (\"False\" != \"True\")\n                deductHeight = 480;\n\n            $(\"#divAllergy\").css(\"min-height\", ($(window).height() - deductHeight) * 0.4);\n            $(\"#divOtherAllergy\").css(\"min-height\", ($(window).height() - deductHeight) * 0.4);\n            $(\"#mednotes\").css(\"min-height\", ($(window).height() - deductHeight) * 0.2);\n            $(window).on(\"resize\", function () {\n                $(\"#divAllergy\").css(\"min-height\", ($(window).height() - deductHeight) * 0.4);\n                $(\"#divOtherAllergy\").css(\"min-height\", ($(window).height() - deductHeight) * 0.4);\n                $(\"#mednotes\").css(\"min-height\", ($(window).height() - deductHeight) * 0.2);\n            });\n        }\n        else {\n            var deductHeight = 430;\n\n            if (\"False\" != \"True\")\n                deductHeight = 390;\n\n            $(\"#divAllergy\").css(\"min-height\", ($(window).height() - deductHeight) * 0.4);\n            $(\"#divOtherAllergy\").css(\"min-height\", ($(window).height() - deductHeight) * 0.4);\n            $(\"#mednotes\").css(\"min-height\", ($(window).height() - deductHeight) * 0.2);\n            $(window).on(\"resize\", function () {\n                $(\"#divAllergy\").css(\"min-height\", ($(window).height() - deductHeight) * 0.4);\n                $(\"#divOtherAllergy\").css(\"min-height\", ($(window).height() - deductHeight) * 0.4);\n                $(\"#mednotes\").css(\"min-height\", ($(window).height() - deductHeight) * 0.2);\n            });\n        }\n    });\n\n    $(document).ajaxStop(function () {\n        $(\".fadeMe\").hide();\n    });\n\n    function formatRemovePatientAllergy(cellvalue, options, rowObject) {\n        return \"<a onmouseover='' style='cursor: pointer;' onclick='RemovePatientAllergy.call(this, event)' data-toggle='tooltip' data-placement='top' title='Remove Patient Drug Allergy' ><span class='glyphicon glyphicon-trash'></span></a>\";\n    }\n\n    function formatRemovePatientAllergyOther(cellvalue, options, rowObject) {\n        return \"<a onmouseover='' style='cursor: pointer;' onclick='RemovePatientAllergyOther.call(this, event)' data-toggle='tooltip' data-placement='top' title='Remove Patient Non Drug Allergy' ><span class='glyphicon glyphicon-trash'></span></a>\";\n    }\n\n    //Modified by zhaoying 20180327 | AppendModal2Body_Load as centralised modal generate function so does Not replicate modals in different modules, hence same modal will have same look\n    $('#btnPatientAllergyAdd').click(function () {\n        if ($('#hfMIMS').val() == 'True') {\n            $(\".fadeMe\").show();\n            //$(\"#setupPatientAllergyModalBody\").load(\"/Patient/PatientAllergy\");\n            //$(\"#setupPatientAllergyModal\").modal('show').removeClass(\"fade\");\n\n            arrFooterBtnList = [];\n            arrFooterBtnList2 = [];\n\n            var appendDetail = {style:\"max-height:762px;max-width:670px;\", contentType: \"typeComplex\" };\n            var pcno = $('#hfPCNO_tpa').val();\n            if (pcno == ''){\n                if ($(\"#txtPatientNo\").val() != 'NEW'){\n                    pcno = $(\"#txtPatientNo\").val();\n                }\n            }\n            AppendModal2Body_Load(\"setupPatientAllergyModal\", \"MIMS Drug List\", \"/Patient/PatientAllergy?pcno=\" + pcno, arrFooterBtnList, arrFooterBtnList2, appendDetail);\n        }\n        else {\n            swal(\"\", \"You are not subscribe to MIMS.\\n To subscribe, please contact our helpdesk.\", \"warning\");\n        }\n    });\n\n    function RemovePatientAllergy()  {\n        //var selectedPatientAllergyId = jQuery(\"#patientAllergyGrid\").jqGrid('getGridParam', 'selrow');\n        var selectedPatientAllergyId = event.target.closest('tr').id;\n\n        if ($('#hfMIMS').val() == 'True') {\n            if (selectedPatientAllergyId!= null)  {\n                swal({title:   \"\", text: \"Are you sure you want to delete this record?\", type: \"warning\", showCancelButton: true, confirmButtonColor: \"#DD6B55\", cancelButtonText: \"No\", confirmButtonText: \"Yes\", closeOnConfirm: false },\n                    function () {\n                        swal.close();\n                        var pcno = $('#hfPCNO_tpa').val();\n                        if (pcno == ''){\n                            if ($(\"#txtPatientNo\").val() != 'NEW'){\n                                pcno = $(\"#txtPatientNo\").val();\n                            }\n                        }\n                        var Code = jQuery(\"#patientAllergyGrid\").jqGrid('getCell', selectedPatientAllergyId, 'Code');\n                        var Type = jQuery(\"#patientAllergyGrid\").jqGrid('getCell', selectedPatientAllergyId, 'MIMSType');\n                        var urlPatientAllergy = 'https://clinicassist.sg:1080/en/Patient/DeletePatientAllergy?pcno=' + pcno + '&code=' + Code + '&mimstype=' + Type;\n\n                        $.ajax({\n                            cache: false,\n                            url: urlPatientAllergy,\n                            dataType: 'json',\n                            type: 'post',\n                            success: function (result) {\n                                if (result.success)  {\n\n                                    //Added By Bryan 07/02/2020 (retrieving patient allergy count)\n                                    $('#hfPatAllergyCount').val(result.rethasallergycount);\n\n                                    swal.close();\n                                    $('#patientAllergyGrid').trigger('reloadGrid');\n\n                                    //Added By Bryan 07/02/2020 start (check the no allergy checkbox based on patient allergy count)\n                                    var PatientAllergyID = $(\"#patientAllergyGrid\").jqGrid('getDataIDs');\n                                    var PatientAllergyOtherID = $(\"#patientAllergyOtherGrid\").jqGrid('getDataIDs');\n\n                                    //Added By Bryan 07/02/2020 (To check whether AllergyDescription Is 'NIL' or not)\n                                    var patalergyothercount = 0;\n                                    if (PatientAllergyOtherID.length > 0)  {\n                                        for (var i = 0; i < PatientAllergyOtherID.length; i++) {\n                                            var DesName = $('#patientAllergyOtherGrid').getCell(PatientAllergyOtherID[i], 'AllergyDesc');\n                                            if (DesName === \"NIL\")  {\n                                                patalergyothercount = patalergyothercount + 1;\n                                            }\n                                        }\n\n                                        if (PatientAllergyID.length > 0 || (PatientAllergyOtherID.length > 0 && PatientAllergyOtherID.length > patalergyothercount) || $('#hfPatAllergyCount').val() != \"0\")  //Updated By Bryan 07/02/2020 (Check whether allergy exist or not)\n                                        {\n                                            $('#CreateEditPatientForm').find('[name=\"chkAllergy\"]').val('false');\n                                            $(\"#chkPatientAllergy\").prop('checked', false);\n                                        }\n                                        else {\n                                            $('#CreateEditPatientForm').find('[name=\"chkAllergy\"]').val('true');\n                                            $(\"#chkPatientAllergy\").prop('checked', true);\n                                        }\n                                    }\n                                    else {\n                                        if (PatientAllergyID.length > 0 || PatientAllergyOtherID.length > 0 || $('#hfPatAllergyCount').val() != \"0\")  //Updated By Bryan 07/02/2020 (Check whether allergy exist or not)\n                                        {\n                                            $('#CreateEditPatientForm').find('[name=\"chkAllergy\"]').val('false');\n                                            $(\"#chkPatientAllergy\").prop('checked', false);\n                                        }\n                                        else {\n                                            $('#CreateEditPatientForm').find('[name=\"chkAllergy\"]').val('true');\n                                            $(\"#chkPatientAllergy\").prop('checked', true);\n                                        }\n                                    }\n                                    //Added By Bryan 07/02/2020 End\n                                    reloadDispenseAllergy()\n                                    checkMedAlertExist()\n                                }\n                                else {\n                                    swal(\"\", result.message, \"error\");\n                                }\n                            },\n                            error: function (xhr, status) {\n                            }\n                        });\n                    })\n\n            } else {\n                swal(\"\", \"There is no record to delete\");\n            }\n        }\n        else {\n            swal(\"\", \"You are not subscribe to MIMS.\\n To subscribe, please contact our helpdesk.\", \"warning\");\n        }\n    };\n\n    //Modified by zhaoying 20180504\n    $('#btnPatientAllergyAddOther').click(function () {\n        //if ($('#hfMIMS').val() == 'True') {\n        $(\"#ddlAllergyOtherType\").prop(\"selectedIndex\", 0);\n        $(\"#txtAllergyOtherDescription\").val(\"\");\n        $(\"#ddlAllergyOtherSeverity\").prop(\"selectedIndex\", 0);\n        $(\"#txtAllergyOtherOnsetDate\").val(\"\");\n        //document.getElementById(\"patientAllergyOtherModal\").style.zIndex=\"10000\";  //Added by zhaoying | 20180504\n        //$(\"#patientAllergyOtherModal\").modal('show').removeClass(\"fade\");\n\n        arrFooterBtnList = [];\n        arrFooterBtnList2 = [];\n        arrFooterBtnList.push('<input type=\"button\" value=\"OK\" id=\"btnOKAllergyOther\" class=\"btn btn-sm ok-style\" />');\n\n        var appendDetail = {style:\"max-height:400px;max-width:470px;\", contentType: \"typeSimple\", cancelID: \"btnCancelAllergyOther\", footerLayout: \"R\" };\n        var pcno = $('#hfPCNO_tpa').val();\n        if (pcno == ''){\n            if ($(\"#txtPatientNo\").val() != 'NEW'){\n                pcno = $(\"#txtPatientNo\").val();\n            }\n        }\n        AppendModal2Body_Load(\"patientAllergyOtherModal\", \"Allergy Other\", \"/Patient/PatientAllergyOther?pcno=\" + pcno, arrFooterBtnList, arrFooterBtnList2, appendDetail);\n        //}\n        //else {\n        //    swal(\"\", \"You are not subscribe to MIMS.\\n To subscribe, please contact our helpdesk.\", \"warning\");\n        //}\n    });\n\n    function RemovePatientAllergyOther() {\n        //var selectedPatientAllergyOtherId = jQuery(\"#patientAllergyOtherGrid\").jqGrid('getGridParam', 'selrow');\n        var selectedPatientAllergyOtherId = event.target.closest('tr').id;\n\n        //Added by Koh Chin Choong 20190527 - To retrieve current pcno\n        //var id = jQuery(\"#patientGrid\").jqGrid('getGridParam', 'selrow');\n        //var selPcno = jQuery(\"#patientGrid\").jqGrid('getCell', id, 'PCNO');\n        //End Added\n\n        //if ($('#hfMIMS').val() == 'True') {\n        if (selectedPatientAllergyOtherId!= null)  {\n            swal({title:   \"\", text: \"Are you sure you want to delete this record?\", type: \"warning\", showCancelButton: true, confirmButtonColor: \"#DD6B55\", cancelButtonText: \"No\", confirmButtonText: \"Yes\", closeOnConfirm: false },\n                function () {\n                    swal.close();\n                    var pcno = $('#hfPCNO_tpa').val();\n                    if (pcno == ''){\n                        if ($(\"#txtPatientNo\").val() != 'NEW'){\n                            pcno = $(\"#txtPatientNo\").val();\n                        }\n                    }\n                    var Description = jQuery(\"#patientAllergyOtherGrid\").jqGrid('getCell', selectedPatientAllergyOtherId, 'AllergyDesc');\n                    var urlPatientAllergy = 'https://clinicassist.sg:1080/en/Patient/DeletePatientAllergyOther?pcno=' + pcno + '&Description=' + encodeURIComponent(Description); //Added by Daniel 20180807 - Ver 15:No. 50 - Add encodeURIComponent\n\n                    $.ajax({\n                        cache: false,\n                        url: urlPatientAllergy,\n                        dataType: 'json',\n                        type: 'post',\n                        success: function (result) {\n                            if (result.success)  {\n\n                                //Added By Bryan 07/02/2020 (retrieving patient allergy count)\n                                $('#hfPatAllergyCount').val(result.rethasallergyothercount);\n                                swal.close();\n                                $('#patientAllergyOtherGrid').trigger('reloadGrid');\n\n                                //Added By Bryan 07/02/2020 start (check the no allergy checkbox based on patient allergy count)\n                                var PatientAllergyID = $(\"#patientAllergyGrid\").jqGrid('getDataIDs');\n                                var PatientAllergyOtherID = $(\"#patientAllergyOtherGrid\").jqGrid('getDataIDs');\n\n                                //Added By Bryan 07/02/2020 (To check whether AllergyDescription Is 'NIL' or not)\n                                var patalergyothercount = 0;\n                                if (PatientAllergyOtherID.length > 0)  {\n                                    for (var i = 0; i < PatientAllergyOtherID.length; i++) {\n                                        var DesName = $('#patientAllergyOtherGrid').getCell(PatientAllergyOtherID[i], 'AllergyDesc');\n                                        if (DesName === \"NIL\")  {\n                                            patalergyothercount = patalergyothercount + 1;\n                                        }\n                                    }\n\n                                    if (PatientAllergyID.length > 0 || (PatientAllergyOtherID.length > 0 && PatientAllergyOtherID.length > patalergyothercount) || $('#hfPatAllergyCount').val() != \"0\")  //Updated By Bryan 07/02/2020 (Check whether allergy exist or not)\n                                    {\n                                        $('#CreateEditPatientForm').find('[name=\"chkAllergy\"]').val('false');\n                                        $(\"#chkPatientAllergy\").prop('checked', false);\n                                    }\n                                    else {\n                                        $('#CreateEditPatientForm').find('[name=\"chkAllergy\"]').val('true');\n                                        $(\"#chkPatientAllergy\").prop('checked', true);\n                                    }\n                                }\n                                else {\n                                    if (PatientAllergyID.length > 0 || PatientAllergyOtherID.length > 0 || $('#hfPatAllergyCount').val() != \"0\")  //Updated By Bryan 07/02/2020 (Check whether allergy exist or not)\n                                    {\n                                        $('#CreateEditPatientForm').find('[name=\"chkAllergy\"]').val('false');\n                                        $(\"#chkPatientAllergy\").prop('checked', false);\n                                    }\n                                    else {\n                                        $('#CreateEditPatientForm').find('[name=\"chkAllergy\"]').val('true');\n                                        $(\"#chkPatientAllergy\").prop('checked', true);\n                                    }\n                                }\n                                //Added By Bryan 07/02/2020 end\n                                reloadDispenseAllergy()\n                                checkMedAlertExist()\n                            }\n                            else {\n                                swal(\"\", result.message, \"error\");\n                            }\n                        },\n                        error: function (xhr, status) {\n                        }\n                    });\n                })\n\n        } else {\n            swal(\"\", \"There is no record to delete\");\n        }\n        //}\n        //else {\n        //    swal(\"\", \"You are not subscribe to MIMS.\\n To subscribe, please contact our helpdesk.\", \"warning\");\n        //}\n    };\n\n    //Added by Cooper 20180711 - Add Pregnancy, Pregnancy Due Date, MetalImplants and Claustrophobia\n    $(\"#chkPregnancy\").click(function () {\n        if ($(this).is(':checked')) {\n            $('#PregnancyDueDate').removeAttr('disabled');\n            $('#PregnancyDueDate').css(\"background-color\", \"\");\n        } else {\n            $('#PregnancyDueDate').attr('disabled', 'disabled');\n            $('#PregnancyDueDate').css(\"background-color\", \"lightgrey\");\n            $('#PregnancyDueDate').val(\"\");\n        }\n    });\n\n    //Added by Cooper 20180711 - Add Pregnancy, Pregnancy Due Date, MetalImplants and Claustrophobia\n    $('#btnSavePatientHistory').click(function () {\n\n        var chkPregnancy = $(\"#chkPregnancy\").prop('checked')\n        var chkMetalImplants = $('#chkMetalImplants').prop('checked')\n        var chkClaustrophobia = $(\"#chkClaustrophobia\").prop('checked')\n        var PregnancyDueDate = $(\"#PregnancyDueDate\").val();\n        var patientAllergy = $(\"#txtPatientAllergy\").val();\n        var patientG6PD = $(\"#txtPatientG6PD\").val();\n        var mednotes = $(\"#mednotes\").val();\n\n        var pcno = $('#hfPCNO_tpa').val();\n        if (pcno == ''){\n            if ($(\"#txtPatientNo\").val() != 'NEW'){\n                pcno = $(\"#txtPatientNo\").val();\n            }\n        }\n        //Added by NiNi 20190304\n        if (chkPregnancy == true && PregnancyDueDate == '') {\n            swal(\"\", \"Please select Pregnancy Due Date\", \"error\");\n            return;\n        }\n\n        $.ajax({\n            cache: false,\n            url: \"/CaseNote/SaveTabHistory?pPCNo=\" + pcno + \"&QueryType=I16\",\n            data: { \"__RequestVerificationToken\": $('input[name=\"__RequestVerificationToken\"]', $(\"#CreateEditPatientAllergyForm\")).val(), \"Pregnancy\": chkPregnancy, \"PregnancyDue\": PregnancyDueDate, \"MetalImplants\": chkMetalImplants, \"Claustrophobia\": chkClaustrophobia, \"Allergy\": patientAllergy, \"G6PD\": patientG6PD, \"MedNotes\": mednotes },\n            type: \"POST\",\n            success: function (response) {\n                if (response.success)\n                    swal({ title: \"\", text: \"Allergy information is saved.\", type: \"success\", timer: 2000 });\n                else\n                    swal(\"\", \"error in Saving Patient Allergy\", \"error\");\n            },\n            error: function (response) {\n            }\n        });\n    });\n\n    function checkMedAlertExist() {\n        //console.log(\"G6PD: \" + $('#txtPatientG6PD').val());\n        //console.log(\"chkPregnancy: \" + $('#chkPregnancy').prop('checked'));\n        //console.log(\"PregnancyDueDate\" + $('#PregnancyDueDate').val());\n        //console.log(parseInt($('#patientAllergyGrid').jqGrid('getGridParam', 'reccount')) + parseInt($('#patientAllergyOtherGrid').jqGrid('getGridParam', 'reccount')));\n        //console.log($('#txtPatientG6PD').val())\n        //console.log($('#chkPregnancy').prop('checked'))\n        //console.log($('#PregnancyDueDate').val())\n        var allergyCount = parseInt($('#patientAllergyGrid').jqGrid('getGridParam', 'reccount')) + parseInt($('#patientAllergyOtherGrid').jqGrid('getGridParam', 'reccount'));\n        if (allergyCount == 0 && $('#txtPatientG6PD').val() != 'YES' && ($('#chkPregnancy').prop('checked') == false && $('#PregnancyDueDate').val() == '')) { //no alert\n            $(\".nav-item a[tabTarget='MedAlert']\").addClass(\"tab-allergy-no\");\n            $(\".nav-item a[tabTarget='MedAlert']\").attr('style', 'background-color: transparent');\n        }\n        else { //alert\n            $('#Pat-tab-li-Allergy').attr('style', 'background-color: #ff6666 !important');\n            $(\"#tabAllergyCaseNoteID\").css(\"color\", \"#ffffff\");\n            $(\"#tabAllergyCaseNoteID\").css(\"background-color\", \"#ff6666\"); \n            $(\".nav-item a[tabTarget='MedAlert']\").attr('style', 'background-color: #ff6666 !important');\n            $(\"#tabAllergyCaseNoteID\").css(\"color\", \"#ffffff\");\n            $(\"#tabAllergyCaseNoteID\").css(\"background-color\", \"#ff6666\"); \n            $(\".nav-item a[tabTarget='MedAlert']\").addClass(\"tab-allergy-yes\");\n        }\n\n    }\n\n    $(\"#btnNIL\").click(function () {\n        $(\"#txtPatientAllergy\").val(\"NIL\");\n    });\n\n    //Added by HaoWen 20221229 - add CMIS\n    function loadCMIS() {\n        if (true != true) {\n            swal({ title: Cookies.get(\"SWAL_Header_Msg\"), text: Cookies.get(\"SWAL_Body_Msg\"), type: Cookies.get(\"SWAL_Type\"), timer: Cookies.get(\"SWAL_Timer\") });\n            return;\n        } else {\n            $(\".fadeMe\").show();\n            $(\"#tabPatAllergytabCMISContent\").load('https://clinicassist.sg:1080/en/Submission/CMISSubmission?pcno=' + encodeURIComponent($(\"#txtPatientNo\").val()) + \"&pname=\" + encodeURIComponent($(\"#txtPatientPName\").val()) + \"&nric=\" + encodeURIComponent($(\"#txtPatientNRIC\").val()));\n        }\n    };\n    //End added by HaoWen 20221229\n    function reloadDispenseAllergy() {\n        if ((urlLocation.indexOf(\"QueueLog/PatientVisit\") >= 0) && $('#txtDispPCNO').length > 0) {\n            let postDataValues = $(\"#queuePatientAllergyGrid\").jqGrid('getGridParam', 'postData');\n            postDataValues[\"pcno\"] = $('#txtDispPCNO').val();\n            $('#queuePatientAllergyGrid').jqGrid().setGridParam({ postData: postDataValues, page: 1 }).trigger('reloadGrid');\n\n\n            var myData = { pcno: $('#txtDispPCNO').val() };\n            var encoded = JSON.stringify(myData);\n            $.ajax({\n                cache: false,\n                type: \"POST\",\n                url: \"/Patient/GetPatientAllergyInListForm\",\n                data: encoded,\n                contentType: \"application/json; charset=utf-8\",\n                dataType: \"json\",\n                success: function (result) {\n                    if (result.success) {\n                        //Modified by kenneth 2025-11-20 - To display HTML of allergy list \n                        //$(\"#lblPatAllergy\").text(result.AllergyList)\n                        $(\"#lblPatAllergy\").html(result.AllergyList)\n                        $('#lblCNPatAllergy').html(result.AllergyList)\n                    }\n                    else {\n                        swal(\"\", result.message, \"error\");\n                    }\n                },\n                error: function (result) {\n                    swal(\"\", result, \"error\");\n                }\n            });\n\n\n        }\n    }",
