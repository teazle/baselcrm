              Inventory\n                    \n                \n\n                \n                    \n                        \n                            \n                            \n                            \n                        \n                        Finance\n                    \n                \n                \n                \n                \n                    \n                        \n                            \n                            \n                            \n                        \n                        IT Admin\n                    \n                \n\n                \n                    \n                        \n                            \n                            \n                            \n                        \n                        Chart\n                    \n                \n\n                \n                    \n                        \n                            \n                            \n                            \n                        \n                        tCAS\n                    \n                \n\n\n                \n                    \n                        \n                            \n                            \n                            \n                            \n                        \n                        Reports\n                    \n                \n\n                \n                    \n                        \n                            \n                            \n                            \n                            \n                        \n                        Hospital\n                        \n                            \n                            \n                        \n                    \n                    \n                        \n                            \n                                \n                                    \n                                    \n                                    \n                                    \n                                \n                                In-Patient\n                            \n                        \n\n                        \n                            \n                                \n                                    \n                                    \n                                    \n                                \n                                Surgery\n                            \n                        \n\n\n                    \n                \n                \n                    \n                        \n                            \n                            \n                            \n                        \n                        Learning Management\n                    \n                \n\n\n                \n                    \n                        \n                            \n                            \n                            \n                        \n                        Setup\n                    \n                \n\n                \n                \n                    \n                        \n                            \n                            \n                            \n                        \n                        Support/Training\n                    \n                \n                \n\n                \n                \n                    \n                        \n                            \n                            \n                            \n                        \n                        Clock In/Out\n                    \n                \n                \n\n                \n                    \n                        \n                            \n                            \n                            \n                            \n                        \n                        More\n                        \n                            \n                            \n                        \n                    \n                    \n                        \n                            \n                                \n                                    \n                                    \n                                    \n                                    \n                                \n                                HR\n                            \n                        \n\n                        \n                            \n                                \n                                    \n                                    \n                                    \n                                \n                                eHealth Assist\n                            \n                        \n\n                        \n                            Marketing\n                        \n\n                        \n                        \n                            \n                                \n                                    \n                                    \n                                    \n                                    \n                                \n                                Support/Training\n                            \n                        \n                    \n                \n            \n            \n            \n                \n                    \n                    \n                        \n                            \n                        \n                    \n                \n            \n        \n        \n        \n\n        \n            \n                \n\n\n\n\n\n\n\n\n    .mainTabContent {\n        display: none;\n    }\n\n    .patientTabContent {\n        display: none;\n        padding: 10px\n    }\n\n\n    .dropzone {\n        min-height: 400px !important;\n    }\n\n        .dropzone .dz-default.dz-message span {\n            display: block;\n        }\n\n    .btn.btn-info.dropzoneremove_btn {\n        border-radius: 16px !important;\n        height: 19px !important;\n        font-size: 12px;\n        width: 24px;\n        /*margin-top: -5px;*/\n        color: #3da6c5 !important;\n        padding: 0px 0px 2px 0px;\n        background-color: white !important;\n        cursor: pointer;\n    }\n\n    .dropzone .dz-default.dz-message {\n        background-image: none !important;\n        width: auto !important;\n        margin: 0 !important;\n        left: 0 !important;\n        right: 0 !important;\n        text-align: center !important;\n    }\n\n        .dropzone .dz-default.dz-message span {\n            display: block !important;\n        }\n\n    div.table {\n        display: table;\n    }\n\n        div.table .file-row {\n            display: table-row;\n        }\n\n            div.table .file-row > div {\n                display: table-cell;\n                vertical-align: top;\n                border-top: 1px solid #ddd;\n                padding: 8px;\n            }\n\n            div.table .file-row:nth-child(odd) {\n                background: #f9f9f9;\n            }\n\n    \n    .ttooltip + .tooltip > .tooltip-inner {\n        white-space: pre;\n        max-width: none;\n        text-align: left;\n        background-color: rgb(255, 242, 204);\n        color: black;\n    }\n    .mainTabContent .dropdown:hover .dropdown-menu   \n    {\n        display: block;\n    }\n\n    .mainTabContent .dropdown-menu > li > a:hover  \n    {\n        background-color: lightgrey;\n    }\n\n    .selected-row td{\n        background-color: #80cee5 !important;\n        color: black;\n    }\n\n    .ui-state-highlight{\n        color: black !important;\n    }\n\n    .datepicker th {\n        color: black;\n    }\n\n    .datepicker-inline {\n        max-width: 180px;\n    }\n\n    .Icon_EditEdocDate {\n        padding: 0px 10px !important;\n    }\n\n    .Icon_Date {\n        padding: 0px 10px !important;\n    }\n\n    #vitalSignBtn {\n        margin-top: -5px;\n        background-image: linear-gradient(to bottom, #a6f77b 0%,#2dbd6e 50%);\n        border: none;\n        border-radius: 15px 15px;\n        box-shadow: 0px 1px 8px #9c9899;\n        margin-right: 35px;\n        color: white;\n        padding: 4px 20px\n    }\n\n    #vitalSignBtn:hover {\n        transform: scale(1.05);\n        background-image: linear-gradient(to top, #a6f77b 0%,#2dbd6e 50%);       \n    }\n\n\n\n\n    .toggle {\n        --width: 80px;\n        --height: calc(var(--width) / 3);\n        position: relative;\n        display: inline-block;\n        width: var(--width);\n        height: var(--height);\n        box-shadow: 0px 1px 3px rgba(0, 0, 0, 0.3);\n        border-radius: var(--height);\n        cursor: pointer;\n    }\n\n        .toggle input {\n            display: none;\n        }\n\n        .toggle .slider12 {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            border-radius: var(--height);\n            background-color: var(--button-danger-background-color);\n            transition: all 0.3s ease-in-out;\n        }\n\n            .toggle .slider12::before {\n                content: \"\";\n                margin-top: 2px;\n                margin-left: 2.5px;\n                position: absolute;\n                top: 0;\n                left: 0;\n                width: calc(var(--height) * 0.85);\n                height: calc(var(--height) * 0.85);\n                border-radius: calc(var(--height) / 2);\n                background-color: white;\n                box-shadow: 0px 1px 3px rgba(0, 0, 0, 0.3);\n                transition: all 0.3s ease-in-out;\n            }\n\n        .toggle input:checked + .slider12 {\n            background-color: var(--button-success-background-color);\n        }\n\n            .toggle input:checked + .slider12::before {\n                transform: translateX(calc(var(--width) - var(--height)));\n            }\n\n        .toggle .labels {\n            position: absolute;\n            top: 8px;\n            left: 0;\n            width: 100%;\n            height: 50%;\n            font-size: 12px;\n            font-family: sans-serif;\n            transition: all 0.3s ease-in-out;\n            overflow: hidden;\n        }\n\n            .toggle .labels::after {\n                content: \"Hide\";\n                margin-right: 10px;\n                position: absolute;\n                right: 5px;\n                color: white;\n                opacity: 1;\n                text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.4);\n                transition: all 0.3s ease-in-out;\n            }\n\n            .toggle .labels::before {\n                content: \"Show\";\n                margin-left: 10px;\n                position: absolute;\n                left: calc(var(--height) - var(--width) + 2px);\n                color: #ffffff;\n                opacity: 0;\n                text-shadow: 1px 1px 2px rgba(255, 255, 255, 0.4);\n                transition: all 0.3s ease-in-out;\n            }\n\n        .toggle input:checked ~ .labels::after {\n            opacity: 0;\n            transform: translateX(calc(var(--width) - var(--height)));\n        }\n\n        .toggle input:checked ~ .labels::before {\n            opacity: 1;\n            transform: translateX(calc(var(--width) - var(--height)));\n        }\n\n        .datepicker {\n            z-index: 100000;\n        }\n\n\n\n\n    \n        \n            \n            \n            \n                    \n                        Patient Info  \n                    \n\n\n\n            \n        \n        \n            \n\n                \n                    Past Notes \n\n                    \n                            \n                        \n                        \n                    \n                \n\n                \n                    \n                    Call Queue\n                \n\n            \n            \n            \n        \n\n        \n            \n                \n                    \n                    \n                        \n                            Duration - ::\n                        \n                    \n                \n            \n        \n    \n    \n        \n\n            \n\n\n\n    .grid-stack {\n        background: #eee;\n    }\n\n    .grid-stack-item-content {\n        color: #fff;\n        text-align: left;\n        background-color: grey;\n    }\n\n    iframe {\n        display: block;\n        width: 100%;\n        height: 100%;\n    }\n\n\n    .ttooltip + .tooltip > .tooltip-inner {\n        white-space: pre;\n        max-width: none;\n        text-align: left;\n        background-color: rgb(255, 242, 204);\n        color: black;\n    }\n\n    .togglespan {\n        border: none !important;\n        color: #495258;\n    }\n\n    .togglebody-Panel.right-content.patient_right {\n        overflow: auto;\n        width: 100%;\n        /*margin-left: 671px;*/\n        position: relative;\n        transition: margin-left 0.3s ease-out;\n        -webkit-transition: margin-left 0.3s ease-out;\n    }\n\n    .left-hide {\n        left: -50%;\n    }\n\n    .right-full {\n        margin-left: 0;\n    }\n\n    .left-full {\n        width: 99%;\n    }\n\n    .right-hide {\n        visibility: hidden;\n    }\n\n    .patient_right > .patient_toggleright {\n        display: none;\n    }\n\n    a.bg-primary.patient_toggleright {\n        display: none !important;\n    }\n\n        a.bg-primary.patient_toggleright:focus, a.bg-primary.patient_toggleright:hover {\n            background-color: #495258;\n        }\n    /*css Added by Cooper 20180531 #6537*/\n    .locationbutton {\n        background-color: white;\n        border: none;\n        color: black;\n        text-align: center;\n        text-decoration: none;\n        display: inline-block;\n        margin: 4px 2px;\n        -webkit-transition-duration: 0.4s; /* Safari */\n        transition-duration: 0.4s;\n        cursor: pointer;\n        border-radius: 4px;\n        width: 90%;\n    }\n\n        .locationbutton:hover {\n            background-color: #008CBA;\n            color: white;\n        }\n\n    .locationbuttonNormalColor {\n        border: 2px solid #008CBA;\n    }\n\n        .locationbuttonNormalColor:hover {\n            background-color: #008CBA;\n        }\n\n    .locationbuttonDoneColor {\n        border: 2px solid #ffc0db; /*pink*/\n    }\n\n        .locationbuttonDoneColor:hover {\n            background-color: #ffc0db; /*pink*/\n        }\n\n    .dropdown-menu > li > a:hover { /*Added by zhaoying 20190213*/\n        background-color: lightgrey;\n    }\n\n    @media (max-width: 850px) {\n        .right-hide {\n            display: block;\n            visibility: visible;\n        }\n\n        .patient_right > .patient_toggleright {\n            visibility: visible;\n            border-radius: 3px;\n            width: 40px;\n            height: 40px;\n            font-size: 20px;\n            padding: 8px;\n            border: 1px solid rgba(255,255,255,0.5);\n            right: 0;\n            z-index: 3;\n            background-color: #777a7b;\n            display: block;\n            position: fixed;\n            border-top-right-radius: 0;\n            border-bottom-right-radius: 0;\n            text-decoration: none !important;\n            text-align: center;\n        }\n\n        a.bg-primary.patient_toggleright {\n            display: block !important;\n        }\n\n        .patient_right > .patient_toggleright.show {\n            right: 70%;\n        }\n\n        .togglebody-Panel.right-content.patient_right.show {\n            right: 0;\n        }\n\n        .togglebody-Panel.right-content.patient_right {\n            position: fixed !IMPORTANT;\n            top: 50px;\n            right: -100%;\n            height: 85%;\n            width: 70% !important;\n            z-index: 3;\n            background-color: #777a7b;\n        }\n    }\n\n    /*Added by Jason 20210326 - add hover show menu*/\n    .dropup:hover .dropdown-menu {\n        display: block;\n    }\n    /*End added by Jason 20210326*/\n\n    .noBold {\n        font-weight: normal !important;\n    }\n\n    #divPatientGroupDetail a:hover {\n        color: black;\n    }\n\n    #tabHistory_frame .btn-group {\n        display: none;\n    }\n\n    #createEditReferralClinicModal {\n        z-index: 1060;\n    }\n\n    .DocumentList a svg path {\n        fill: black;\n    }\n\n    /*Added by Jason 20211025 - remove border*/\n    .panel-default {\n        border: none;\n    }\n    /*End added by Jason 20211025*/\n\n    .tab-allergy-yes.active {\n        color: white !important;\n    }\n\n        .tab-allergy-yes.active a {\n            color: white !important;\n        }\n\n    .tab-allergy-yes:hover {\n        /*border-bottom: 3px solid #ff6666 !important;*/\n        color: white;\n    }\n\n    .tab-allergy-yes:hover {\n        /*border-bottom: 3px solid #ff6666 !important;*/\n        color: white;\n    }\n\n    .tab-allergy-no:hover {\n    }\n\n        .tab-allergy-no:hover a {\n            color: white;\n        }\n\n    .DocumentList > ul.list-inline > #Pat-tab-li-Allergy:hover > a {\n        background-color: unset;\n    }\n\n    #select2-txtPatientOccupation-container {\n        padding-top: 0px;\n    }\n\n    #select2-txtPatientSPJob-container {\n        padding-top: 0px;\n    }\n\n    .NoPaddingTop {\n        padding-top: 0px !important;\n    }\n\n    #tabList.DocumentList > ul.list-inline > li {\n        border: none;\n        background-color: unset;\n    }\n\n        #tabList.DocumentList > ul.list-inline > li.active {\n            background-color: white !important;\n            box-shadow: -4px -3.5px 4px rgba(58,59,69,.1), 4px -3.5px 4px rgba(58,59,69,.1);\n            border-radius: 7px 7px 0px 0px;\n        }\n\n            #tabList.DocumentList > ul.list-inline > li > a {\n                color: #494b54;\n            }\n\n            #tabList.DocumentList > ul.list-inline > li:hover > a {\n                background-color: unset;\n                color: black;\n            }\n\n            #tabList.DocumentList > ul.list-inline > li.active:hover {\n                box-shadow: -4px -3.5px 4px rgba(58,59,69,.1), 4px -3.5px 4px rgba(58,59,69,.1);\n            }\n\n            #tabList.DocumentList > ul.list-inline > li:hover {\n                box-shadow: none;\n            }\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n \n\n          \n\n\n    \n        \n            \n                \n                Patient Info\n            \n            \n                \n                Patient Info\n            \n        \n    \n\n    \n        \n        \n            \n                \n            \n\n            \n                \n                    \n                    \n                \n            \n\n            \n                \n                    \n\n                    \n                    \n\n                    \n                        \n                            \n                                Biodata\n                            \n                            Med Alert \n                            Pop Up \n                            Family \n                            History\n                            Financial\n                            Tx History\n                                Past Notes\n                            eDoc\n                            Lab / Vital Sign\n                            Appt\n                            Referral\n                            Comm \n                            Delivery\n                            \n                                                    \n                    \n                \n\n\n                \n                    \n                        \n                                \n                                    \n\n\n    /*input[type=\"text\"], select {\n        height: 25px;\n        border-radius: 0;\n    }*/\n\n    .btn-sm-dispense {\n        height: 25px;\n        width: 25px;\n        line-height: 0px;\n        background: #46b8da !important;\n        border: none;\n        cursor: pointer !important;\n        color: white;\n    }\n\n    .jqgridcontainer {\n        border: none;\n    }\n\n    #tabBioData .detailitemboxwrapper_compact150 {\n        width: 150px;\n    }\n\n    html input[disabled] {\n        cursor: not-allowed;\n    }\n\n    .datepicker th {\n        color: black;\n    }\n\n    .datepicker-inline {\n        max-width: 180px;\n    }\n\n    .datepicker-switch {\n        background-color: #A6ACAF;\n        color: black;\n    }\n\n    .datepicker .next, .datepicker .prev {\n        background-color: lightgray;\n        color: black;\n    }\n\n    .datepicker table tr td.today {\n        color: white !important;\n        background-image: linear-gradient(to bottom,#a6acaf,#a6acaf) !important;\n    }\n\n    .datepicker table tr td.active {\n        background-image: linear-gradient(to bottom,#46b8da,#46b8da) !important;\n    }\n\n    #btnMediClaimAddGP svg path {\n        fill: black;\n    }\n\n    /*.panel-heading {\n        font-weight: bold;\n    }*/\n\n    #divPatientGroupDetail a svg path {\n        fill: black;\n    }\n\n    #btnPatientGroupAdd svg path {\n        fill: black;\n    }\n\n    /*#gview_patientConsentGrid {\n        height: 115px;\n    }*/\n\n    /*Added by Chang Ching Ler 20211027 | Resolve font issue at appointment > Add > Patient Summary */\n    /*label {\n        font-size: 12px;\n    }*/\n    /*Added by Chang Ching Ler 20211027 */\n\n    #divVip label {\n        display: flex;\n        align-items: center;\n        margin-right: 10px;\n        height: 25px;\n        margin-bottom: 0px;\n    }\n\n    .patidtooltip + .tooltip > .tooltip-inner {\n        white-space: pre;\n        max-width: none;\n        text-align: left;\n        color: black;\n        border: none !important;\n        background-color: #f3ce8f !important;\n    }\n\n    #divNRICField {\n        /*width: 60vw !important;*/\n        z-index: 1;\n    }\n\n    .patientInfoCustomField {\n        width: calc(100% - 150px);\n    }\n\n    .patientInfoCustomLabel {\n        padding: 0px 0px 5px 1px;\n    }\n\n    .patientTabContent .form-control {\n        padding: 5px;\n    }\n\n    #tabPatientPhoto {\n        width: 200px;\n        height: 169px;\n        background-color: rgba(255, 255, 255, 0.5);\n        margin: auto;\n    }\n\n    #jqgh_patientConsentGrid_Date1, #jqgh_patientConsentGrid_Type {\n        overflow: initial !important;\n        padding-top: 5px !important;\n    }\n\n    #gview_patientConsentGrid .ui-jqgrid-bdiv {\n        overflow: hidden;\n    }\n\n    .sideButton {\n        cursor: pointer;\n        background: var(--button-background-color) !important;\n        padding: 6px 12px;\n        font-size: 13px;\n        font-weight: 500;\n        color: var(--button-font-color);\n        width: 55px;\n        font-family: 'Segoe UI';\n    }\n\n    .customCol {\n        position: relative;\n        float: left;\n    }\n\n    .patientBioDataMainLeftDiv {\n        position: relative;\n        float: left;\n        width: 70%;\n        padding-left: 10px;\n    }\n\n    .patientBioDataMainRightDiv {\n        position: relative;\n        float: left;\n        width: 30%;\n        padding-left: 10px;\n    }\n\n    .funkyradio div {\n        clear: both;\n        overflow: hidden;\n    }\n\n    .funkyradio label {\n        width: 100%;\n        border-radius: 3px;\n        border: 1px solid #D1D3D4;\n        font-weight: normal;\n    }\n\n    .funkyradio input[type=\"radio\"]:empty,\n    .funkyradio input[type=\"checkbox\"]:empty {\n        display: none;\n    }\n\n        .funkyradio input[type=\"radio\"]:empty ~ label,\n        .funkyradio input[type=\"checkbox\"]:empty ~ label {\n            position: relative;\n            line-height: 2.5em;\n            text-indent: 3.25em;\n            /*margin-top: 2em;*/\n            margin-top: 15px;\n            cursor: pointer;\n            -webkit-user-select: none;\n            -moz-user-select: none;\n            -ms-user-select: none;\n            user-select: none;\n        }\n\n            .funkyradio input[type=\"radio\"]:empty ~ label:before,\n            .funkyradio input[type=\"checkbox\"]:empty ~ label:before {\n                position: absolute;\n                display: block;\n                top: 0;\n                bottom: 0;\n                left: 0;\n                content: '';\n                width: 2.5em;\n                background: #D1D3D4;\n                border-radius: 3px 0 0 3px;\n            }\n\n    .funkyradio input[type=\"radio\"]:hover:not(:checked) ~ label,\n    .funkyradio input[type=\"checkbox\"]:hover:not(:checked) ~ label {\n        color: #888;\n    }\n\n        .funkyradio input[type=\"radio\"]:hover:not(:checked) ~ label:before,\n        .funkyradio input[type=\"checkbox\"]:hover:not(:checked) ~ label:before {\n            content: '\\2714';\n            text-indent: .9em;\n            color: #C2C2C2;\n        }\n\n    .funkyradio input[type=\"radio\"]:checked ~ label,\n    .funkyradio input[type=\"checkbox\"]:checked ~ label {\n        color: #777;\n    }\n\n        .funkyradio input[type=\"radio\"]:checked ~ label:before,\n        .funkyradio input[type=\"checkbox\"]:checked ~ label:before {\n            content: '\\2714';\n            text-indent: .9em;\n            color: #333;\n            background-color: #ccc;\n        }\n\n    .funkyradio input[type=\"radio\"]:focus ~ label:before,\n    .funkyradio input[type=\"checkbox\"]:focus ~ label:before {\n        box-shadow: 0 0 0 3px #999;\n    }\n\n    .funkyradio-info input[type=\"radio\"]:checked ~ label:before,\n    .funkyradio-info input[type=\"checkbox\"]:checked ~ label:before {\n        color: #fff;\n        background-color: var(--nav-header-color);\n    }\n\n    .divForeignAdd, .company-form {\n        display: none;\n    }\n\n    #btnPatientAddBrackets {\n        cursor: pointer;\n        background: #46b8da;\n        border: 1px solid #488abb;\n        color: white;\n        border-radius: 0 7px 7px 0 !important;\n    }\n   @media (max-width: 1180px) {\n    .responsive-idtextbox {\n        width: 80% !important;\n    }\n    .responsive-nricbox{\n        min-width:120px;\n    }\n    .responsive-idno2{\n        width:60% !important;\n    }\n    .responsive-patientsex{\n        width:40% !important;\n    }\n    #txtPatientDOB{\n        width:80px !important;\n    }\n    .responsive-photo{\n        margin-left:25px;\n    }\n    .responsive-racelabel{\n        width:19% !important;\n    }\n    .responsive-doblabel{\n        width:33% !important;\n    }\n    .responsive-age{\n        margin-left:19px;\n    }\n    #txtPatientSex{\n        width:60px !important;\n    }\n    #txtPatientRace{\n        width:94% !important;\n    }\n    #txtPatientDocID{\n        width:100% !important;\n    }\n    .responsive-dummyfield,.responsive-vipfield,.responsive-membercheckfield{\n        margin-top:10px;\n    }\n    #txtPatAge{\n       min-width:90px !important;\n    }\n}\n    @media (max-width: 1366px) {\n        #txtPatientDOB{\n            width:85px !important;\n        }\n        #txtPatientRace{\n            width:100% !important;\n        }\n            .responsive-racelabel{\n        width:18% !important;\n    }\n       #txtPatAge{\n         min-width:95px !important;\n       }\n       .responsive-dummyfield,.responsive-vipfield,.responsive-membercheckfield{\n           margin-top:10px;\n       }\n    }\n    /*Added by kenneth 2025-03-18 - to set sortable, preferred / non preferred(normal) notification style*/\n    #divNotifications {\n        border: 1px solid #cccccc;\n        border-radius: 7px;\n        padding: 0 5px;\n        display: flex;\n        flex-direction: row;\n        align-items: center;\n        width: 100%;\n        height: 37px;\n        gap: 5px;\n        cursor: move;\n    }\n    .sortable-item {\n        cursor: move;\n    }\n\n    .preferred-notif {\n        color: var(--button-font-color);\n        border-color: #000000 !important;\n        background-color: #ddffc3 !important;\n        height: 30px;\n        border-radius: 5px !important;\n        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n        font-weight: 500;\n    }\n    .non-preferred-notif {\n        color: var(--button-font-color);\n        border-color: #000000 !important;\n        background-color: white !important;\n        height: 30px;\n        border-radius: 5px !important;\n        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n        font-weight: 500;\n    }\n    /*End Added by kenneth 2025-03-18 */\n        #divNotificationInfo {\n        border-radius: 6px;\n        padding: 10px;\n        position: absolute;\n        z-index: 1;\n        box-shadow: inset 0 0 0 2px rgb(255, 255, 255), 0.3em 0.3em 1em rgba(0, 0, 0, 0.3);\n        background: #fff;\n        color: #000;\n        max-width: 450px;\n        width: max-content;\n        max-height: 400px; \n        overflow-y: auto;\n        overflow-x: hidden;\n        border: 1px solid #b3b4b5;\n        box-sizing: border-box;\n        bottom: 25px;\n        left: 345px;\n        transform: translateX(-75%);\n    }\n\n\n\n\n\n\n        \n\nPlease fix these errors.\n\n    \n    \n    \n    \n    \n    \n    \n        \n        \n        \n        \n        \n        \n        \n        \n        \n        \n        \n        \n        \n        \n        \n        \n        \n\n        \n            \n                \n                \n                    \n                    \n                        Status\n\n                        Active\nInActive\nArchive\n\n                    \n\n                    \n                    \n                        PCNO\n\n                        \n                            \n                            DM \n           