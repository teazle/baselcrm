ame: 'Reference', index: 'Reference', width: 100, sortable: false, align: \"center\" },\n                { key: false, name: 'Results', index: 'Results', width: 450, sortable: false },\n                { key: false, name: 'Clinic', index: 'Clinic', width: 100, sortable: false, align: \"center\" },\n            ],\n            rowNum: 100,\n            scrollrows: true,\n            gridview: true,\n            scroll: true,\n            width: \"100%\",\n            height: \"100%\",\n            hoverrows: false,\n            loadError: function (xhr, status, error) {\n            },\n            loadComplete: function () {\n                JqgridLoadComplete(this);\n                var u = $(\"tbody:first > tr:gt(0)\", this.grid.bDiv);\n                var height = parseInt(this.p.records, 10) * (u.outerHeight() || this.grid.prevRowHeight);\n                $(this).parent().height(height);\n                $(this).closest(\".ui-jqgrid-bdiv\").height($('#Grid_PattabxMC').height() - 50);\n                $(\"#gview_jqGrid_PattabxMC\").find(\".ui-jqgrid-bdiv\").addClass(\"scrollbar-primary\");\n                $(\"#gview_jqGrid_PattabxMC\").find(\".ui-jqgrid-bdiv\").width($(\"#Grid_PattabxMC\").find(\".ui-jqgrid-hdiv\").width() + 10);\n            },\n            emptyrecords: 'No records to display',\n            jsonReader: {\n                root: \"rows\",\n                page: \"page\",\n                total: \"total\",\n                records: \"records\",\n                repeatitems: false,\n                Id: \"0\"\n            },\n            shrinkToFit: false,\n            multiselect: false\n        });\n    }\n\n    function GetVisitHistory(pcno, DateFrom, DateTo) {\n        $(\"#jqGrid_PattabxVisit\").jqGrid({\n            url: \"/CaseNote/GetTxHistoryTabVisit?pcno=\" + pcno + \"&dateFrom=\" + DateFrom + \"&dateTo=\" + DateTo,\n            datatype: 'json',\n            mtype: 'Get',\n            colNames: ['Date', 'Time In', 'Time Out', 'Time Con', 'Doctor', 'SP Code', 'TCU', 'TCU Remarks', 'Paid AMT', 'CR AMT', 'Height', 'Weight', 'Company Code', 'Branch'],\n            colModel: [\n                { key: false, name: 'VQdate', index: 'VQdate', width: 90, sortable: false, formatter: 'date', formatoptions: { srcformat: \"d M Y\", newformat: \"d/m/Y\" } },\n                { key: false, name: 'TimeIn1', index: 'TimeIn1', width: 90, sortable: false, align: \"center\" },\n                { key: false, name: 'TimeOut1', index: 'TimeOut1', width: 90, sortable: false, align: \"center\" },\n                { key: false, name: 'TimeConsult1', index: 'TimeConsult1', width: 90, sortable: false, align: \"center\" },\n                { key: false, name: 'Doctor', index: 'Doctor', width: 70, sortable: false, hidden: true },\n                { key: false, name: 'SPCode', index: 'SPCode', width: 80, sortable: false },\n                { key: false, name: 'TCU', index: 'TCU', width: 60, sortable: false}, //Edited by Shan , 20190215 - To remove TCU/ TCU remarks/ Height/ Weight column\n                { key: false, name: 'TCUREMARK', index: 'TCUREMARK', width: 150, sortable: false },//Edited by Shan , 20190215 - To remove TCU/ TCU remarks/ Height/ Weight column\n                { key: false, name: 'PAIDAMT', index: 'PAIDAMT', width: 100, sortable: false, align: \"right\", formatter: 'currency', formatoptions: {prefix: \"$\", thousandsSeparator: \",\", decimalSeparator: \".\", decimalPlaces: 2 }},  //Edited by Qiu Li 20260102 - add thousand seperator for money\n                { key: false, name: 'CREDITAMT', index: 'CREDITAMT', width: 100, sortable: false, align: \"right\", formatter: 'currency', formatoptions: {prefix: \"$\", thousandsSeparator: \",\", decimalSeparator: \".\", decimalPlaces: 2 }},  //Edited by Qiu Li 20260102 - add thousand seperator for money\n                { key: false, name: 'VHeight', index: 'VHeight', width: 60, sortable: false, align: \"center\", hidden: true },//Edited by Shan , 20190215 - To remove TCU/ TCU remarks/ Height/ Weight column\n                { key: false, name: 'VWeight', index: 'VWeight', width: 60, sortable: false, align: \"center\", hidden: true },//Edited by Shan , 20190215 - To remove TCU/ TCU remarks/ Height/ Weight column\n                { key: false, name: 'TranCoy', index: 'TranCoy', width: 140, sortable: false },\n                { key: false, name: 'Clinic', index: 'Clinic', width: 100, sortable: false, align: \"center\" },\n            ],\n            rowNum: 100,\n            scrollrows: true,\n            gridview: true,\n            scroll: true,\n            width: \"100%\",\n            height: \"100%\",\n            hoverrows: false,\n            rowcontent: true,\n            loadError: function (xhr, status, error) {\n            },\n            loadComplete: function () {\n                //$(\"#jqGrid_PattabxVisit\").jqGrid('setGridWidth', $(\"#Grid_PattabxVisit\").width());\n                JqgridLoadComplete(this);\n                var u = $(\"tbody:first > tr:gt(0)\", this.grid.bDiv);\n                var height = parseInt(this.p.records, 10) * (u.outerHeight() || this.grid.prevRowHeight);\n                $(this).parent().height(height);\n                $(this).closest(\".ui-jqgrid-bdiv\").height($('#Grid_PattabxVisit').height() - 50);\n                $(\"#gview_jqGrid_PattabxVisit\").find(\".ui-jqgrid-bdiv\").addClass(\"scrollbar-primary\");\n                $(\"#gview_jqGrid_PattabxVisit\").find(\".ui-jqgrid-bdiv\").width($(\"#Grid_PattabxVisit\").find(\".ui-jqgrid-hdiv\").width() + 10);\n                jQuery('#jqgh_jqGrid_PattabxVisit_PAIDAMT').css('text-align','right');      //Added by Xirlyn 20240205 - Adjust the alignment of header to right\n                jQuery('#jqgh_jqGrid_PattabxVisit_CREDITAMT').css('text-align','right');    //Added by Xirlyn 20240205 - Adjust the alignment of header to right\n            },\n            emptyrecords: 'No records to display',\n            jsonReader: {\n                root: \"rows\",\n                page: \"page\",\n                total: \"total\",\n                records: \"records\",\n                repeatitems: false,\n                Id: \"0\"\n            },\n            shrinkToFit: false,\n            multiselect: false\n        });\n    }\n\n    function GetStatHistory(pcno, DateFrom, DateTo){\n        $(\"#jqGrid_tabxStat\").jqGrid({\n            url: \"/CaseNote/GetTxHistoryTabStat?pcno=\" + pcno + \"&datefrom=\" + DateFrom + \"&dateto=\" + DateTo,\n            datatype: 'json',\n            mtype: 'Get',\n            colNames: ['DATE', 'TIME', 'HEIGHT', 'WEIGHT', 'BMI', 'BP(S)', 'BP(D)', 'TEMP', 'PR', 'YearAge', 'SEX'], //SN360 Change by Jian Chee 10-Jan-2018 change correct spelling.\n            colModel: [\n                { key: false, name: 'DateTime', index: 'DateTime', width: 70, sortable: false, formatter: 'date', formatoptions: { srcformat: \"d/m/y\", newformat: \"d/m/Y\" } },\n                { key: false, name: 'VSTime', index: 'VSTime', width: 70, sortable: false, },\n                { key: false, name: 'Height', index: 'Height', width: 70, sortable: false, align: \"right\" },\n                { key: false, name: 'Weight', index: 'Weight', width: 70, sortable: false, align: \"right\" },\n                { key: false, name: 'BMI', index: 'BMI', width: 50, sortable: false, align: \"right\" },\n                { key: false, name: 'BldHi', index: 'BldHi', width: 50, sortable: false, align: \"right\" },\n                { key: false, name: 'BldLo', index: 'BldLo', width: 50, sortable: false, align: \"right\" },\n                { key: false, name: 'Temperature', index: 'Temperature', width: 50, sortable: false, align: \"right\" },\n                { key: false, name: 'PulseRate', index: 'PulseRate', width: 50, sortable: false, align: \"right\" },\n                { key: false, name: 'YearAge', index: 'YearAge', width: 10, sortable: false, hidden: true },\n                { key: false, name: 'SEX', index: 'SEX', width: 10, sortable: false, hidden: true }\n\n            ],\n            rowNum: -1,\n            scrollrows: true,\n            gridview: true,\n            scroll: true,\n            width: \"100%\",\n            height: \"100%\",\n            hoverrows: false,\n            loadError: function (xhr, status, error) {\n            },\n            loadComplete: function () {\n                JqgridLoadComplete(this);\n\n                var ids = $(\"#jqGrid_tabxStat\").jqGrid(\"getDataIDs\");\n\n                for (i = 0; i < ids.length; i++) {\n                    rowData = $('#jqGrid_tabxStat').jqGrid('getRowData', ids[i]);\n\n                    if (rowData['BMI'] != \"\") {\n                        var bmi = parseFloat(rowData['BMI']);\n\n                        var el = Enumerable.From(BMI_Stat).Where(function (item) { return item.High >= bmi && item.Low <= bmi }).ToArray();\n\n                        $.each(el, function (_i, _e) {\n                            $(\"#jqGrid_tabxStat\").setCell(ids[i], 'BMI', '', { background: _e.Backgound, color: _e.Color }, { 'title': _e.Desc });\n                        });\n                    }\n\n                    if (rowData['BldHi'] != \"\") {\n                        var BldHi = parseFloat(rowData['BldHi']);\n\n                        var el = Enumerable.From(BP_Stat).Where(function (item) { return item.High >= BldHi && item.Low <= BldHi && item.Type == \"BldHi\" }).ToArray();\n\n                        $.each(el, function (_i, _e) {\n                            $(\"#jqGrid_tabxStat\").setCell(ids[i], 'BldHi', '', { background: _e.Backgound, color: _e.Color }, { 'title': _e.Desc });\n                        });\n                    }\n\n                    if (rowData['BldLo'] != \"\") {\n                        var BldLo = parseFloat(rowData['BldLo']);\n\n                        var el = Enumerable.From(BP_Stat).Where(function (item) { return item.High >= BldLo && item.Low <= BldLo && item.Type == \"BldLo\" }).ToArray();\n\n                        $.each(el, function (_i, _e) {\n                            $(\"#jqGrid_tabxStat\").setCell(ids[i], 'BldLo', '', { background: _e.Backgound, color: _e.Color }, { 'title': _e.Desc });\n                        });\n                    }\n\n                    if (rowData['PulseRate'] != \"\" && rowData['YearAge'] != \"\") {\n                        var PulseRate = parseFloat(rowData['PulseRate']);\n                        var YearAge = parseFloat(rowData['YearAge']);\n                        var sex = rowData['SEX'];\n\n                        var el = Enumerable.From(PR_Stat).Where(function (item) {\n                            return item.Sex == sex\n                                && item.Age_High >= YearAge\n                                && item.Age_Low <= YearAge\n                                && item.Rate_High >= PulseRate\n                                && item.Rate_Low <= PulseRate\n                        }).ToArray();\n\n                        console.log(el);\n                        if (el.length > 0) {\n                            $.each(el, function (_i, _e) {\n                                $(\"#jqGrid_tabxStat\").setCell(ids[i], 'PulseRate', '', { background: _e.Backgound, color: _e.Color }, { 'title': _e.Desc });\n                            });\n                        } else {\n                            $(\"#jqGrid_tabxStat\").setCell(ids[i], 'PulseRate', '', { background: \"#db4437\", color: \"white\" }, { 'title': \"Out of range\" });\n                        }\n                    }\n                }\n\n                if (ids.length <= 100) {\n                    $(\"#jqGrid_tabxStat tr\").eq(1).trigger(\"click\");\n                }\n            },\n            emptyrecords: 'No records to display',\n            jsonReader: {\n                root: \"rows\",\n                page: \"page\",\n                total: \"total\",\n                records: \"records\",\n                repeatitems: false,\n                Id: \"0\"\n            },\n            shrinkToFit: false,\n            multiselect: false\n        });\n    }\n\n    function GetCurrentMed() {\n        $(\"#jqGrid_tabxCurMed\").jqGrid({\n            url: \"/CaseNote/GetTxHistoryTabCurMed?pcno=\" + $(\"#hfPCNOfortxHist\").val(),\n            datatype: 'json',\n            mtype: 'Get',\n            colNames: ['VISITDATE', 'DATE MEDICATION', 'DESCRIPTION'],\n            colModel: [\n                { key: true, name: 'VisitNo', index: 'VisitNo', width: 120, sortable: false, align: \"center\", hidden: true },\n                { key: false, name: 'MedDate', index: 'MedDate', width: 220, sortable: false, align: \"center\" },\n                { key: false, name: 'Medication', index: 'Medication', width: 1300, sortable: false, align: \"left\" },\n            ],\n            rowNum: -1,\n            scrollrows: true,\n            gridview: true,\n            scroll: true,\n            width: \"100%\",\n            height: \"100%\",\n            hoverrows: false,\n            loadError: function (xhr, status, error) {\n            },\n            loadComplete: function () {\n                JqgridLoadComplete(this);\n            },\n            emptyrecords: 'No records to display',\n            jsonReader: {\n                root: \"rows\",\n                page: \"page\",\n                total: \"total\",\n                records: \"records\",\n                repeatitems: false,\n                Id: \"0\"\n            },\n            shrinkToFit: false,\n            multiselect: false\n        });\n    }\n\n    $(\"#btnMedShow\").click(function () {\n        if (CheckMedDate('txtMedDateFrom', 'txtMedDateTo', 'date')) {\n            var obj = $(\"ul#tabQueueHisTab li.active a\");\n            var target = $(obj).attr('href');\n            getTxHistory(target);\n        }\n        else {\n            return swal(\"\", \"Date To have to be greater than Date From.\", \"warning\");\n        }\n    });\n\n    $(\"#txtMedDateFrom\").focusout(function () {\n        if ($(\"#txtMedDateFrom\").val() == \"\") {\n            var d = moment(new Date()).add(-72, 'month').format('DD/MM/YYYY');\n            $('#txtMedDateFrom').datepicker('setDate', d);\n        }\n        else {\n            if (moment($(\"#txtMedDateFrom\").val(), 'DD/MM/YYYY', true).isValid()) {\n\n            }\n            else {\n                var d = moment(new Date()).add(-72, 'month').format('DD/MM/YYYY');\n                $('#txtMedDateFrom').datepicker('setDate', d);\n            }\n        }\n\n    });\n\n    $(\"#txtMedDateTo\").focusout(function () {\n        if ($(\"#txtMedDateTo\").val() == \"\") {\n            var d = moment($(\"#txtMedDateTo\").val(), 'DD/MM/YYYY').format('DD/MM/YYYY');\n            $('#txtMedDateTo').datepicker('setDate', d);\n        }\n        else {\n            if (moment($(\"#txtMedDateTo\").val(), 'DD/MM/YYYY', true).isValid()) {\n\n            }\n            else {\n                var d = moment($(\"#txtMedDateTo\").val(), 'DD/MM/YYYY').format('DD/MM/YYYY');\n                $('#txtMedDateTo').datepicker('setDate', d);\n            }\n        }\n    });\n\n    function CheckMedDate(DateFrom, DateTo, Type) {\n            if ($('#' + DateFrom).val() == \"\") {\n                $('#' + DateFrom).val(moment(new Date()).add(-72, 'month').format('DD/MM/YYYY'));\n            }\n            if ($('#' + DateTo).val() == \"\") {\n                $('#' + DateTo).val(moment(new Date()).format('DD/MM/YYYY'));\n            }\n            var m = moment($('#' + DateFrom).val(), 'DD/MM/YYYY');\n            var m1 = moment($('#' + DateTo).val(), 'DD/MM/YYYY');\n\n        var enterFromDate = new Date(m);\n        var enterToDate = new Date(m1);\n        if (enterFromDate > enterToDate) {\n            return false;\n        }\n        else {\n            return true;\n        }\n    }\n\n    //Added by Jason 20191202 - getLabResult function\n    function getLabResult() {\n        if ($(\"#LabResult_Render\").text() != \"Y\") {\n            $(\"#LabResult_Render\").text(\"Y\");\n            $('.fadeMe').show();\n            //Edited by Shan , 2017-08-16 - UAT 337\n            Cookies.set('QueuetxHis', 'QueuetxHis');\n            $(\"#tabLabResultcontent\").load('https://clinicassist.sg:1080/en/PatientMaster/TabLabResult?pcno=' + $('#hfPCNOfortxHist').val());\n        }\n    }\n    //End added by Jason 20191202\n\n    $('#btnPatHisAddMC').click(function() {\n        //Comment by Koh Chin Choong 20200305 - Prevent MFLAC\n        if (true == false) {\n            swal({ title: Cookies.get(\"SWAL_Header_Msg\"), text: Cookies.get(\"SWAL_Body_Msg\"), type: Cookies.get(\"SWAL_Type\"), timer: Cookies.get(\"SWAL_Timer\") });\n            return;\n        }\n        //End Comment by Koh Chin Choong 20200305\n        var selectedPCNO = $('#hfPCNOfortxHist').val();\n        var selectedName = $('#hfPName').val();\n        //var selectedClinic = null;\n        \n        $('#myPatHisprintMCModalLabel').text('Patient MC - ' + selectedName + ' (' + selectedPCNO + ')');\n        $(\"#PatHisprintMCModalBody\").load('https://clinicassist.sg:1080/en/Patient/PatientMCDetails?isHistoryDispense=y&qPCNO=' + selectedPCNO + '&qPName=' + encodeURIComponent(selectedName));\n        $(\"#PatHisprintMCModal\").modal('show').removeClass('fade');\n    });\n\n    $(\"#btnPatientPackage\").click(function () {\n        //Comment by Koh Chin Choong 20200305 - Prevent MFLAC\n        //Added by Cooper 20180717 - Patient (ACCESS CONTROL)\n        if (true == false) {\n            swal({ title: Cookies.get(\"SWAL_Header_Msg\"), text: Cookies.get(\"SWAL_Body_Msg\"), type: Cookies.get(\"SWAL_Type\"), timer: Cookies.get(\"SWAL_Timer\") });\n            return;\n        }\n\n        var qPCNO = $('#hfPCNOfortxHist').val();\n        var PName =  $('#hfPName').val();\n\n        arrFooterBtnList = [];\n        arrFooterBtnList2 = [];\n        arrFooterBtnList.push('<input type=\"button\" value=\"Adjustment\" onclick=\"PatientPackageAdj();\" class=\"btn btn-sm btn-info\" />'); //peter ask to hold //Edited by Zac 20211007 - Show Adjustment request by bonnie\n        arrFooterBtnList.push('<input type=\"button\" id=\"btnPatientPackageTransfer\" value=\"Transfer\" onclick=\"\" class=\"btn btn-sm btn-info\" />');\n        arrFooterBtnList.push('<input type=\"button\" id=\"btnPatientPackageUsage\" value=\"Package Usage Detail\" class=\"btn btn-sm btn-info\" />');\n\n        var appendDetail = { style: \"max-height: 750px; max-width:1660px;\", contentType: \"singlegrid\", cancelID: \"btnPatientPackageClose\", footerLayout: \"LR\" };\n\n        $(\".fadeMe\").show();\n        AppendModal2Body_Load(\"PatientPackageModal\", \"Patient Package\", \"/Patient/PatientPackage?PCNO=\" + qPCNO + \"&PName=\" + encodeURIComponent(PName), arrFooterBtnList, arrFooterBtnList2, appendDetail);\n    });\n\n                            \n                                \n\n\n    Access Denied.\n    You have no permission to access.\n\n                            \n                        \n                    \n                    \n                        \n                            \n                            \n                                \n\n\n    Access Denied.\n    You have no permission to access.\n\n                            \n                        \n                    \n\n                    \n                        \n                            \n                            \n                                \n\n\n    Access Denied.\n    You have no permission to access.\n\n                            \n                        \n                    \n\n                    \n                        \n                            \n                            \n                                \n\n\n    Access Denied.\n    You have no permission to access.\n\n                            \n                        \n                    \n\n                    \n                        \n                            \n                        \n                    \n\n                    \n                        \n                            \n                            \n                                \n\n\n    Access Denied.\n    You have no permission to access.\n\n                            \n                        \n                    \n                    \n                        \n                            \n                            \n                        \n                    \n                    \n                        \n                            \n                            \n                                \n\n\n    Access Denied.\n    You have no permission to access.\n\n                            \n                        \n                    \n\n                    \n                        \n                            \n                        \n                    \n\n                    \n                        \n                            \n\n    .TabPatientAllergy_MainPanel {\n        display: flex;\n        display: -webkit-flex;\n        height: 100%;\n        flex: 1;\n        margin-bottom: 0;\n        flex-flow: column nowrap;\n    }\n\n    .DisplayBlock {\n        display: block !important;\n    }\n\n    /*Added by Cooper 20180711 - Change to bootstrap datepicker*/\n    .datepicker th {\n        color: #494b54;\n    }\n\n    .datepicker-inline {\n        max-width: 180px;\n    }\n\n    #divPatientAllergyOtherAdd svg path {\n        fill: black;\n    }\n\n    #btnPatientAllergyAdd svg path {\n        fill: black;\n    }\n\n    .nopadding {\n        padding: 0 !important;\n        margin: 0 !important;\n    }\n\n    #setupPatientAllergyModal, #patientAllergyOtherModal{\n        z-index: 1052;\n    }\n\n    #divOtherAllergy {\n        border: none;\n        width: 100%;\n    }\n\n    #divAllergy{\n        border: none;\n        width: 100%;\n    }\n\n\nPlease fix these errors.\n\n\n    \n    \n    \n\n     \n    \n        \n            \n                \n                \n                    \n                        Allergy\n                    \n                \n                \n                \n                    \n                        \n                            \n                                Drug Allergy\n                                \n                                     Add\n                                \n                            \n                        \n                        \n                            \n                                \n                                    Loading...  Code Description Type \n                                \n                            \n                        \n                        \n                            \n                                Non Drug Allergy\n                                \n                                     Add\n                                \n                            \n                        \n                        \n                            \n                                \n                                    \n                                    Loading...  Type Description Onset Date Severity Reaction RemarksDCephalexin 03/02/2026I  DCiprofloxacin03/02/2026I   \n                                \n                            \n                        \n                        \n                            \n                                \n                                    \n                                        G6PD Deficiency\n                                        UNKNOWN\nYES\nNO\n\n                                    \n                                    \n                                         Pregnancy\n                                        Due Date:\n                                        \n                                    \n                                \n                            \n                        \n                        \n                            \n                                Med Notes (Display In QueueLog)\n                                \n                            \n                        \n                        \n                            \n                             \n                        \n\n                        \n                            \n                        \n                    \n                    \n                    \n                        \n                        \n                    \n                \n                \n            \n        \n    \n\n\n\n\n\n\n\n    $(document).ready(function () {\n        var pcno = $('#hfPCNO_tpa').val();\n        if (pcno == ''){\n            if ($(\"#txtPatientNo\").val() != 'NEW'){\n                pcno = $(\"#txtPatientNo\").val();\n            }\n        }\n        var urlPatientAllergystring = 'https://clinicassist.sg:1080/en/Patient/GetPatientAllergy?pcno=' + pcno;\n        if ($(\"#queueDispenseIndex\").is(':visible')) {\n            var patientAllergyDescWidth = 361;\n            var patientAllergyTypeWidth = 78;\n\n            var patientAllergyOtherTypeWidth = 36;\n            var patientAllergyOtherDescWidth = 276;\n            var patientAllergyOtherSeverityWidth = 54;\n            var patientAllergyOtherDateIDWidth = 72;\n            var patientAllergyOtherReactionWidth = 120;\n            var patientAllergyOtherRemarksWidth = 150;\n        }\n        else {\n            patientAllergyDescWidth = 620;\n            patientAllergyTypeWidth = 200;\n\n            patientAllergyOtherTypeWidth = 100;\n            patientAllergyOtherDescWidth = 310;\n            patientAllergyOtherSeverityWidth = 80;\n            patientAllergyOtherDateIDWidth = 100;\n            patientAllergyOtherReactionWidth = 120;\n            patientAllergyOtherRemarksWidth = 150;\n        }\n\n        $(\"#patientAllergyGrid\").jqGrid({\n            url: urlPatientAllergystring,\n            datatype: 'json',\n            mtype: 'Get',\n            colNames: ['', 'Code', 'Description', 'Type'],\n            colModel: [\n                { key: false, name: 'Delete', index: 'Delete', align: 'center', width: 30, sortable: false, formatter: formatRemovePatientAllergy },\n                { key: true, name: 'Code', index: 'Code', width: 300, sortable: false, hidden: true },\n                { key: false, name: 'Description', index: 'Description', width: 620, sortable: false },\n                { key: false, name: 'MIMSType', index: 'MIMSType', width: 200, sortable: false },\n            ],\n            rowNum: -1,\n            //rowList:['All','100','500','1000'], //Commented By Bryan 20200212 - To reduce loading speed (Requested by Peter)\n            //gridview: true, //Commented By Bryan 20200212 - To reduce loading speed (Requested by Peter)\n            width: 'auto',\n            height: 'auto',\n            scrollOffset: 0,\n            hoverrows: false,\n            viewrecords: false,\n            loadError: function (xhr, status, error) {\n            },\n            loadComplete: function () {\n                JqgridLoadComplete(this);\n                var ids = $(\"#patientAllergyGrid\").jqGrid(\"getDataIDs\");\n\n                if (ids.length <= 100)  {\n                    $(\"#patientAllergyGrid tr\").eq(1).trigger(\"click\");\n                }\n\n                var pageURL = $(location).attr(\"href\");\n\n                if (pageURL.toLowerCase().indexOf(\"queuedispense\") > 0)  {\n                    $(\"#patientAllergyGrid\").hideCol(\"Delete\");\n                }\n                reloadDispenseAllergy()\n                checkMedAlertExist()\n            },\n            emptyrecords: 'No records to display',\n            jsonReader: {\n                root: \"rows\",\n                page: \"page\",\n                total: \"total\",\n                records: \"records\",\n                repeatitems: false,\n                Id: \"0\"\n            },\n            shrinkToFit: true,\n            multiselect: false\n        });\n\n        var urlPatientAllergyOtherstring = 'https://clinicassist.sg:1080/en/Patient/GetPatientAllergyOther?pcno=' + pcno;\n\n        $(\"#patientAllergyOtherGrid\").jqGrid({\n            url: urlPatientAllergyOtherstring,\n            datatype: 'json',\n            mtype: 'Get',\n            colNames: ['', 'Type', 'Description', 'Onset Date', 'Severity', 'Reaction', 'Remarks'],\n            colModel: [\n                { key: false, name: 'Delete', index: 'Delete', align: 'center', width: 30, sortable: false, formatter: formatRemovePatientAllergyOther },\n                { key: false, name: 'AllergyType', index: 'AllergyType', width: 100, sortable: false },\n                { key: false, name: 'AllergyDesc', index: 'AllergyDesc', width: 310, sortable: false },\n                { key: false, name: 'DateID', index: 'DateID', width: 100, sortable: false, formatter: 'date', formatoptions: { srcformat: \"d M Y H:i\", newformat: \"d/m/Y\" } },\n                { key: false, name: 'Severity', index: 'Severity', width: 80, sortable: false },\n                { key: false, name: 'Reaction', index: 'Reaction', width: 120, sortable: false },\n                { key: false, name: 'Remarks', index: 'Remarks', width: 150, sortable: false },\n            ],\n            rowNum: 100,\n            //rowList:['All','100','500','1000'], //Commented By Bryan 20200212 - To reduce loading speed (Requested by Peter)\n            //gridview: true, //Commented By Bryan 20200212 - To reduce loading speed (Requested by Peter)\n            width: 'auto',\n            height: 'auto',  \n            scrollOffset: 0,\n            hoverrows: false,\n            viewrecords: false,\n            loadError: function (xhr, status, error) {\n            },\n            loadComplete: function () {\n                JqgridLoadComplete(this);\n                var pageURL = $(location).attr(\"href\");\n\n                if (pageURL.toLowerCase().indexOf(\"queuedispense\") > 0) {\n                    $(\"#patientAllergyOtherGrid\").hideCol(\"Delete\");\n                }\n                reloadDispenseAllergy()\n                checkMedAlertExist()\n            },\n            emptyrecords: 'No records to display',\n            jsonReader: {\n                root: \"rows\",\n                page: \"page\",\n                total: \"total\",\n                records: \"records\",\n                repeatitems: false,\n                Id: \"0\"\n            },\n            shrinkToFit: true,\n            multiselect: false\n        });\n\n        //Added by Cooper 20180711 - Add Pregnancy, Pregnancy Due Date, MetalImplants And Claustrophobia\n        $(\"#PregnancyDueDate\").datepicker({\n            format: 'dd/mm/yyyy',\n            useCurrent: true,\n            todayHighlight: true,\n            autoclose: true\n        }).datepicker();\n\n        $(\"#PregnancyDueDate\").inputmask(\"date\", { \"clearIncomplete\" : true });\n\n        if ($('#chkPregnancy').is(':checked')) {\n            $('#PregnancyDueDate').removeAttr('disabled');\n            $('#PregnancyDueDate').css(\"background-color\", \"\");\n        } else {\n            $('#PregnancyDueDate').attr('disabled', 'disabled');\n            $('#PregnancyDueDate').css(\"background-color\", \"lightgrey\");\n        }\n\n        if ($(\"#tabAllergy\").length > 0) {\n            //remove flex display if under dispense screen as it Not in pop up modal mode\n            $(\".TabPatientAllergy_MainPanel\").addClass(\"DisplayBlock\");\n        }\n\n        var pageURL = $(location).attr(\"href\");\n\n        if (pageURL.toLowerCase().indexOf(\"queuedispense\") > 0) {\n            $(\"#btnPatientAllergyAdd\").hide();\n            $(\"#btnPatientAllergyDelete\").hide();\n            $(\"#btnPatientAllergyAddOther\").hide();\n            $(\"#btnPatientAllergyDeleteOther\").hide();\n            \n            $(\"#btnSavePatientHistory\").hide();\n            $(\"#chkPregnancy\").attr('disabled', 'disabled');\n            $(\"#chkMetalImplants\").attr('disabled', 'disabled');\n            $(\"#chkClaustrophobia\").attr('disabled', 'disabled');\n            $(\"#PregnancyDueDate\").attr('disabled', 'disabled');\n            $(\"#txtPatientG6PD\").attr('disabled', 'disabled');\n            //Adjust size when showing at dispense screen\n            $(\"#RadiologyPregnancyMain\").attr('class', 'col-lg-12');\n            $(\"#divPatientG6PD\").attr('class', 'col-lg-12');\n            $(\"#RadiologyMatalClauMain\").attr('class', 'col-lg-6');\n\n            $(\"#RadiologyPregnancy\").attr('class', 'col-lg-3 col-xl-6');\n            $(\"#RadiologyPregnancyDueDate\").attr('class', 'col-lg-6 col-xl-6');\n            $(\"#RadiologyMetalImplants\").attr('class', 'col-lg-12 col-xl-6');\n            $(\"#RadiologyClaustrophobia\").attr('class', 'col-lg-12 col-xl-6');\n            $(\"#lblPatientG6PD\").attr('class', 'col-lg-3 col-xl-6');\n            $(\"#ddpPatientG6PD\").attr('class', 'col-lg-6 col-xl-6');\n            $(\"#mednotes\").attr('disabled', 'disabled');\n            $(\"#divPatientHitory\").attr('style', 'height:100px');\n\n        }\n        else if (pageURL.toLowerCase().indexOf(\"casenote\") > 0)  {\n            if ($(\"#hfAllergyGotRecord\").val() == \"Y\") {\n                \n            }\n        }\n\n        else if (pageURL.toLowerCase().indexOf(\"casenote\") > 0)  {\n            if ($(\"#hfAllergyGotRecord\").val() == \"Y\") {\n                \n                }\n        }\n        else if (pageURL.toLowerCase().indexOf(\"appointment\") > 0)  {\n            $(\"#btnSavePatientHistory\").hide();\n        }\n        else if (pageURL.toLowerCase().indexOf(\"patient\") > 0 || pageURL.toLowerCase().indexOf(\"queuelog\") > 0) {\n            $(\"#btnSavePatientHistory\").hide();\n        }\n        //$(\"#txtAllergyOtherOnsetDate\").datepicker({ dateFormat: 'dd/mm/yy' });\n        //$(\"#txtAllergyOtherOnsetDate\").inputmask(\"date\", { \"clearIncomplete\" true });\n        if ($('#hfshowNILBtn').val() == 'True') {\n            $('#btnNIL').show();\n            $('#btnNIL').css('pointer-events', 'auto');\n        }\n        else {\n            $('#btnNIL').hide();\n            $('#btnNIL').css('pointer-events', 'none');\n        }\n\n        if ($('#tab-li-Biodata').hasClass('active')) {\n            $(\"#btnSavePatientHistory\").hide();\n        }\n\n        //added by Hao Wen 20211215 | if Not New patient, save old data to check Is there any update during exit\n        if ($('#txtPatientNo').val() != \"\") {\n            oldDataMedAlert = JSON.stringify($('#CreateEditPatientAllergyForm').serializeArray());\n        }\n        //End added by Hao Wen 20211215\n\n        var urlLocation = jQuery(location).attr('href');\n\n        if (urlLocation.indexOf(\"/QueueLog/PatientVisit\") > 0) {\n            var deductHeight = 520;\n\n            if (\"False\" != \"True\")\n                deductHeight = 480;\n\n            $(\"#divAllergy\").css(\"min-height\", ($(window).height() - deductHeight) * 0.4);\n            $(\"#divOtherAllergy\").css(\"min-height\", ($(window).height() - deductHeight) * 0.4);\n            $(\"#mednotes\").css(\"min-height\", ($(window).height() - deductHeight) * 0.2);\n            $(window).on(\"resize\", function () {\n                $(\"#divAllergy\").css(\"min-height\", ($(window).height() - deductHeight) * 0.4);\n                $(\"#divOtherAllergy\").css(\"min-height\", ($(window).height() - deductHeight) * 0.4);\n                $(\"#mednotes\").css(\"min-height\", ($(window).height() - deductHeight) * 0.2);\n            });\n        }\n        else {\n            var deductHeight = 430;\n\n            if (\"False\" != \"True\")\n                deductHeight = 390;\n\n            $(\"#divAllergy\").css(\"min-height\", ($(window).height() - deductHeight) * 0.4);\n            $(\"#divOtherAllergy\").css(\"min-height\", ($(window).height() - deductHeight) * 0.4);\n            $(\"#mednotes\").css(\"min-height\", ($(window).height() - deductHeight) * 0.2);\n            $(window).on(\"resize\", function () {\n                $(\"#divAllergy\").css(\"min-height\", ($(window).height() - deductHeight) * 0.4);\n                $(\"#divOtherAllergy\").css(\"min-height\", ($(window).height() - deductHeight) * 0.4);\n                $(\"#mednotes\").css(\"min-height\", ($(window).height() - deductHeight) * 0.2);\n            });\n        }\n    });\n\n    $(document).ajaxStop(function () {\n        $(\".fadeMe\").hide();\n    });\n\n    function formatRemovePatientAllergy(cellvalue, options, rowObject) {\n        return \"<a onmouseover='' style='cursor: pointer;' onclick='RemovePatientAllergy.call(this, event)' data-toggle='tooltip' data-placement='top' title='Remove Patient Drug Allergy' ><span class='glyphicon glyphicon-trash'></span></a>\";\n    }\n\n    function formatRemovePatientAllergyOther(cellvalue, options, rowObject) {\n        return \"<a onmouseover='' style='cursor: pointer;' onclick='RemovePatientAllergyOther.call(this, event)' data-toggle='tooltip' data-placement='top' title='Remove Patient Non Drug Allergy' ><span class='glyphicon glyphicon-trash'></span></a>\";\n    }\n\n    //Modified by zhaoying 20180327 | AppendModal2Body_Load as centralised modal generate function so does Not replicate modals in different modules, hence same modal will have same look\n    $('#btnPatientAllergyAdd').click(function () {\n        if ($('#hfMIMS').val() == 'True') {\n            $(\".fadeMe\").show();\n            //$(\"#setupPatientAllergyModalBody\").load(\"/Patient/PatientAllergy\");\n            //$(\"#setupPatientAllergyModal\").modal('show').removeClass(\"fade\");\n\n            arrFooterBtnList = [];\n            arrFooterBtnList2 = [];\n\n            var appendDetail = {style:\"max-height:762px;max-width:670px;\", contentType: \"typeComplex\" };\n            var pcno = $('#hfPCNO_tpa').val();\n            if (pcno == ''){\n                if ($(\"#txtPatientNo\").val() != 'NEW'){\n                    pcno = $(\"#txtPatientNo\").val();\n                }\n            }\n            AppendModal2Body_Load(\"setupPatientAllergyModal\", \"MIMS Drug List\", \"/Patient/PatientAllergy?pcno=\" + pcno, arrFooterBtnList, arrFooterBtnList2, appendDetail);\n        }\n        else {\n            swal(\"\", \"You are not subscribe to MIMS.\\n To subscribe, please contact our helpdesk.\", \"warning\");\n        }\n    });\n\n    function RemovePatientAllergy()  {\n        //var selectedPatientAllergyId = jQuery(\"#patientAllergyGrid\").jqGrid('getGridParam', 'selrow');\n        var selectedPatientAllergyId = event.target.closest('tr').id;\n\n        if ($('#hfMIMS').val() == 'True') {\n            if (selectedPatientAllergyId!= null)  {\n                swal({title:   \"\", text: \"Are you sure you want to delete this record?\", type: \"warning\", showCancelButton: true, confirmButtonColor: \"#DD6B55\", cancelButtonText: \"No\", confirmButtonText: \"Yes\", closeOnConfirm: false },\n                    function () {\n                        swal.close();\n                        var pcno = $('#hfPCNO_tpa').val();\n                        if (pcno == ''){\n                            if ($(\"#txtPatientNo\").val() != 'NEW'){\n                                pcno = $(\"#txtPatientNo\").val();\n                            }\n                        }\n                        var Code = jQuery(\"#patientAllergyGrid\").jqGrid('getCell', selectedPatientAllergyId, 'Code');\n                        var Type = jQuery(\"#patientAllergyGrid\").jqGrid('getCell', selectedPatientAllergyId, 'MIMSType');\n                        var urlPatientAllergy = 'https://clinicassist.sg:1080/en/Patient/DeletePatientAllergy?pcno=' + pcno + '&code=' + Code + '&mimstype=' + Type;\n\n                        $.ajax({\n                            cache: false,\n                            url: urlPatientAllergy,\n                            dataType: 'json',\n                            type: 'post',\n                            success: function (result) {\n                                if (result.success)  {\n\n                                    //Added By Bryan 07/02/2020 (retrieving patient allergy count)\n                                    $('#hfPatAllergyCount').val(result.rethasallergycount);\n\n                                    swal.close();\n                                    $('#patientAllergyGrid').trigger('reloadGrid');\n\n                                    //Added By Bryan 07/02/2020 start (check the no allergy checkbox based on patient allergy count)\n                                    var PatientAllergyID = $(\"#patientAllergyGrid\").jqGrid('getDataIDs');\n                                    var PatientAllergyOtherID = $(\"#patientAllergyOtherGrid\").jqGrid('getDataIDs');\n\n                                    //Added By Bryan 07/02/2020 (To check whether AllergyDescription Is 'NIL' or not)\n                                    var patalergyothercount = 0;\n                                    if (PatientAllergyOtherID.length > 0)  {\n                                        for (var i = 0; i < PatientAllergyOtherID.length; i++) {\n                                            var DesName = $('#patientAllergyOtherGrid').getCell(PatientAllergyOtherID[i], 'AllergyDesc');\n                                            if (DesName === \"NIL\")  {\n                                                patalergyothercount = patalergyothercount + 1;\n                                            }\n                                        }\n\n                                        if (PatientAllergyID.length > 0 || (PatientAllergyOtherID.length > 0 && PatientAllergyOtherID.length > patalergyothercount) || $('#hfPatAllergyCount').val() != \"0\")  //Updated By Bryan 07/02/2020 (Check whether allergy exist or not)\n                                        {\n                                            $('#CreateEditPatientForm').find('[name=\"chkAllergy\"]').val('false');\n                                            $(\"#chkPatientAllergy\").prop('checked', false);\n                                        }\n                                        else {\n                                            $('#CreateEditPatientForm').find('[name=\"chkAllergy\"]').val('true');\n                                            $(\"#chkPatientAllergy\").prop('checked', true);\n                                        }\n                                    }\n                                    else {\n                                        if (PatientAllergyID.length > 0 || PatientAllergyOtherID.length > 0 || $('#hfPatAllergyCount').val() != \"0\")  //Updated By Bryan 07/02/2020 (Check whether allergy exist or not)\n                                        {\n                                            $('#CreateEditPatientForm').find('[name=\"chkAllergy\"]').val('false');\n                                            $(\"#chkPatientAllergy\").prop('checked', false);\n                                        }\n                                        else {\n                                            $('#CreateEditPatientForm').find('[name=\"chkAllergy\"]').val('true');\n                                            $(\"#chkPatientAllergy\").prop('checked', true);\n                                        }\n                                    }\n                                    //Added By Bryan 07/02/2020 End\n                                    reloadDispenseAllergy()\n                                    checkMedAlertExist()\n                                }\n                                else {\n                                    swal(\"\", result.message, \"error\");\n                                }\n                            },\n                            error: function (xhr, status) {\n                            }\n                        });\n                    })\n\n            } else {\n                swal(\"\", \"There is no record to delete\");\n            }\n        }\n        else {\n            swal(\"\", \"You are not subscribe to MIMS.\\n To subscribe, please contact our helpdesk.\", \"warning\");\n        }\n    };\n\n    //Modified by zhaoying 20180504\n    $('#btnPatientAllergyAddOther').click(function () {\n        //if ($('#hfMIMS').val() == 'True') {\n        $(\"#ddlAllergyOtherType\").prop(\"selectedIndex\", 0);\n        $(\"#txtAllergyOtherDescription\").val(\"\");\n        $(\"#ddlAllergyOtherSeverity\").prop(\"selectedIndex\", 0);\n        $(\"#txtAllergyOtherOnsetDate\").val(\"\");\n        //document.getElementById(\"patientAllergyOtherModal\").style.zIndex=\"10000\";  //Added by zhaoying | 20180504\n        //$(\"#patientAllergyOtherModal\").modal('show').removeClass(\"fade\");\n\n        arrFooterBtnList = [];\n        arrFooterBtnList2 = [];\n        arrFooterBtnList.push('<input type=\"button\" value=\"OK\" id=\"btnOKAllergyOther\" class=\"btn btn-sm ok-style\" />');\n\n        var appendDetail = {style:\"max-height:400px;max-width:470px;\", contentType: \"typeSimple\", cancelID: \"btnCancelAllergyOther\", footerLayout: \"R\" };\n        var pcno = $('#hfPCNO_tpa').val();\n        if (pcno == ''){\n            if ($(\"#txtPatientNo\").val() != 'NEW'){\n                pcno = $(\"#txtPatientNo\").val();\n            }\n        }\n        AppendModal2Body_Load(\"patientAllergyOtherModal\", \"Allergy Other\", \"/Patient/PatientAllergyOther?pcno=\" + pcno, arrFooterBtnList, arrFooterBtnList2, appendDetail);\n        //}\n        //else {\n        //    swal(\"\", \"You are not subscribe to MIMS.\\n To subscribe, please contact our helpdesk.\", \"warning\");\n        //}\n    });\n\n    function RemovePatientAllergyOther() {\n        //var selectedPatientAllergyOtherId = jQuery(\"#patientAllergyOtherGrid\").jqGrid('getGridParam', 'selrow');\n        var selectedPatientAllergyOtherId = event.target.closest('tr').id;\n\n        //Added by Koh Chin Choong 20190527 - To retrieve current pcno\n        //var id = jQuery(\"#patientGrid\").jqGrid('getGridParam', 'selrow');\n        //var selPcno = jQuery(\"#patientGrid\").jqGrid('getCell', id, 'PCNO');\n        //End Added\n\n        //if ($('#hfMIMS').val() == 'True') {\n        if (selectedPatientAllergyOtherId!= null)  {\n            swal({title:   \"\", text: \"Are you sure you want to delete this record?\", type: \"warning\", showCancelButton: true, confirmButtonColor: \"#DD6B55\", cancelButtonText: \"No\", confirmButtonText: \"Yes\", closeOnConfirm: false },\n                function () {\n                    swal.close();\n                    var pcno = $('#hfPCNO_tpa').val();\n                    if (pcno == ''){\n                        if ($(\"#txtPatientNo\").val() != 'NEW'){\n                            pcno = $(\"#txtPatientNo\").val();\n                        }\n                    }\n                    var Description = jQuery(\"#patientAllergyOtherGrid\").jqGrid('getCell', selectedPatientAllergyOtherId, 'AllergyDesc');\n                    var urlPatientAllergy = 'https://clinicassist.sg:1080/en/Patient/DeletePatientAllergyOther?pcno=' + pcno + '&Description=' + encodeURIComponent(Description); //Added by Daniel 20180807 - Ver 15:No. 50 - Add encodeURIComponent\n\n                    $.ajax({\n                        cache: false,\n                        url: urlPatientAllergy,\n                        dataType: 'json',\n                        type: 'post',\n                        success: function (result) {\n                            if (result.success)  {\n\n                                //Added By Bryan 07/02/2020 (retrieving patient allergy count)\n                                $('#hfPatAllergyCount').val(result.rethasallergyothercount);\n                                swal.close();\n                                $('#patientAllergyOtherGrid').trigger('reloadGrid');\n\n                                //Added By Bryan 07/02/2020 start (check the no allergy checkbox based on patient allergy count)\n                                var PatientAllergyID = $(\"#patientAllergyGrid\").jqGrid('getDataIDs');\n                                var PatientAllergyOtherID = $(\"#patientAllergyOtherGrid\").jqGrid('getDataIDs');\n\n                                //Added By Bryan 07/02/2020 (To check whether AllergyDescription Is 'NIL' or not)\n                                var patalergyothercount = 0;\n                                if (PatientAllergyOtherID.length > 0)  {\n                                    for (var i = 0; i < PatientAllergyOtherID.length; i++) {\n                                        var DesName = $('#patientAllergyOtherGrid').getCell(PatientAllergyOtherID[i], 'AllergyDesc');\n                                        if (DesName === \"NIL\")  {\n                                            patalergyothercount = patalergyothercount + 1;\n                                        }\n                                    }\n\n                                    if (PatientAllergyID.length > 0 || (PatientAllergyOtherID.length > 0 && PatientAllergyOtherID.length > patalergyothercount) || $('#hfPatAllergyCount').val() != \"0\")  //Updated By Bryan 07/02/2020 (Check whether allergy exist or not)\n                                    {\n                                        $('#CreateEditPatientForm').find('[name=\"chkAllergy\"]').val('false');\n                                        $(\"#chkPatientAllergy\").prop('checked', false);\n                                    }\n                                    else {\n                                        $('#CreateEditPatientForm').find('[name=\"chkAllergy\"]').val('true');\n                                        $(\"#chkPatientAllergy\").prop('checked', true);\n                                    }\n                                }\n                                else {\n                                    if (PatientAllergyID.length > 0 || PatientAllergyOtherID.length > 0 || $('#hfPatAllergyCount').val() != \"0\")  //Updated By Bryan 07/02/2020 (Check whether allergy exist or not)\n                                    {\n                                        $('#CreateEditPatientForm').find('[name=\"chkAllergy\"]').val('false');\n                                        $(\"#chkPatientAllergy\").prop('checked', false);\n                                    }\n                                    else {\n                                        $('#CreateEditPatientForm').find('[name=\"chkAllergy\"]').val('true');\n                                        $(\"#chkPatientAllergy\").prop('checked', true);\n                                    }\n                                }\n                                //Added By Bryan 07/02/2020 end\n                                reloadDispenseAllergy()\n                                checkMedAlertExist()\n                            }\n                            else {\n                                swal(\"\", result.message, \"error\");\n                            }\n                        },\n                        error: function (xhr, status) {\n                        }\n                    });\n                })\n\n        } else {\n            swal(\"\", \"There is no record to delete\");\n        }\n        //}\n        //else {\n        //    swal(\"\", \"You are not subscribe to MIMS.\\n To subscribe, please contact our helpdesk.\", \"warning\");\n        //}\n    };\n\n    //Added by Cooper 20180711 - Add Pregnancy, Pregnancy Due Date, MetalImplants and Claustrophobia\n    $(\"#chkPregnancy\").click(function () {\n        if ($(this).is(':checked')) {\n            $('#PregnancyDueDate').removeAttr('disabled');\n            $('#PregnancyDueDate').css(\"background-color\", \"\");\n        } else {\n            $('#PregnancyDueDate').attr('disabled', 'disabled');\n            $('#PregnancyDueDate').css(\"background-color\", \"lightgrey\");\n            $('#PregnancyDueDate').val(\"\");\n        }\n    });\n\n    //Added by Cooper 20180711 - Add Pregnancy, Pregnancy Due Date, MetalImplants and Claustrophobia\n    $('#btnSavePatientHistory').click(function () {\n\n        var chkPregnancy = $(\"#chkPregnancy\").prop('checked')\n        var chkMetalImplants = $('#chkMetalImplants').prop('checked')\n        var chkClaustrophobia = $(\"#chkClaustrophobia\").prop('checked')\n        var PregnancyDueDate = $(\"#PregnancyDueDate\").val();\n        var patientAllergy = $(\"#txtPatientAllergy\").val();\n        var patientG6PD = $(\"#txtPatientG6PD\").val();\n        var mednotes = $(\"#mednotes\").val();\n\n        var pcno = $('#hfPCNO_tpa').val();\n        if (pcno == ''){\n            if ($(\"#txtPatientNo\").val() != 'NEW'){\n                pcno = $(\"#txtPatientNo\").val();\n            }\n        }\n        //Added by NiNi 20190304\n        if (chkPregnancy == true && PregnancyDueDate == '') {\n            swal(\"\", \"Please select Pregnancy Due Date\", \"error\");\n            return;\n        }\n\n        $.ajax({\n            cache: false,\n            url: \"/CaseNote/SaveTabHistory?pPCNo=\" + pcno + \"&QueryType=I16\",\n            data: { \"__RequestVerificationToken\": $('input[name=\"__RequestVerificationToken\"]', $(\"#CreateEditPatientAllergyForm\")).val(), \"Pregnancy\": chkPregnancy, \"PregnancyDue\": PregnancyDueDate, \"MetalImplants\": chkMetalImplants, \"Claustrophobia\": chkClaustrophobia, \"Allergy\": patientAllergy, \"G6PD\": patientG6PD, \"MedNotes\": mednotes },\n            type: \"POST\",\n            success: function (response) {\n                if (response.success)\n                    swal({ title: \"\", text: \"Allergy information is saved.\", type: \"success\", timer: 2000 });\n                else\n                    swal(\"\", \"error in Saving Patient Allergy\", \"error\");\n            },\n            error: function (response) {\n            }\n        });\n    });\n\n    function checkMedAlertExist() {\n        //console.log(\"G6PD: \" + $('#txtPatientG6PD').val());\n        //console.log(\"chkPregnancy: \" + $('#chkPregnancy').prop('checked'));\n        //console.log(\"PregnancyDueDate\" + $('#PregnancyDueDate').val());\n        //console.log(parseInt($('#patientAllergyGrid').jqGrid('getGridParam', 'reccount')) + parseInt($('#patientAllergyOtherGrid').jqGrid('getGridParam', 'reccount')));\n        //console.log($('#txtPatientG6PD').val())\n        //console.log($('#chkPregnancy').prop('checked'))\n        //console.log($('#PregnancyDueDate').val())\n        var allergyCount = parseInt($('#patientAllergyGrid').jqGrid('getGridParam', 'reccount')) + parseInt($('#patientAllergyOtherGrid').jqGrid('getGridParam', 'reccount'));\n        if (allergyCount == 0 && $('#txtPatientG6PD').val() != 'YES' && ($('#chkPregnancy').prop('checked') == false && $('#PregnancyDueDate').val() == '')) { //no alert\n            $(\".nav-item a[tabTarget='MedAlert']\").addClass(\"tab-allergy-no\");\n            $(\".nav-item a[tabTarget='MedAlert']\").attr('style', 'background-color: transparent');\n        }\n        else { //alert\n            $('#Pat-tab-li-Allergy').attr('style', 'background-color: #ff6666 !important');\n            $(\"#tabAllergyCaseNoteID\").css(\"color\", \"#ffffff\");\n            $(\"#tabAllergyCaseNoteID\").css(\"background-color\", \"#ff6666\"); \n            $(\".nav-item a[tabTarget='MedAlert']\").attr('style', 'background-color: #ff6666 !important');\n            $(\"#tabAllergyCaseNoteID\").css(\"color\", \"#ffffff\");\n            $(\"#tabAllergyCaseNoteID\").css(\"background-color\", \"#ff6666\"); \n            $(\".nav-item a[tabTarget='MedAlert']\").addClass(\"tab-allergy-yes\");\n        }\n\n    }\n\n    $(\"#btnNIL\").click(function () {\n        $(\"#txtPatientAllergy\").val(\"NIL\");\n    });\n\n    //Added by HaoWen 20221229 - add CMIS\n    function loadCMIS() {\n        if (true != true) {\n            swal({ title: Cookies.get(\"SWAL_Header_Msg\"), text: Cookies.get(\"SWAL_Body_Msg\"), type: Cookies.get(\"SWAL_Type\"), timer: Cookies.get(\"SWAL_Timer\") });\n            return;\n        } else {\n            $(\".fadeMe\").show();\n            $(\"#tabPatAllergytabCMISContent\").load('https://clinicassist.sg:1080/en/Submission/CMISSubmission?pcno=' + encodeURIComponent($(\"#txtPatientNo\").val()) + \"&pname=\" + encodeURIComponent($(\"#txtPatientPName\").val()) + \"&nric=\" + encodeURIComponent($(\"#txtPatientNRIC\").val()));\n        }\n    };\n    //End added by HaoWen 20221229\n    function reloadDispenseAllergy() {\n        if ((urlLocation.indexOf(\"QueueLog/PatientVisit\") >= 0) && $('#txtDispPCNO').length > 0) {\n            let postDataValues = $(\"#queuePatientAllergyGrid\").jqGrid('getGridParam', 'postData');\n            postDataValues[\"pcno\"] = $('#txtDispPCNO').val();\n            $('#queuePatientAllergyGrid').jqGrid().setGridParam({ postData: postDataValues, page: 1 }).trigger('reloadGrid');\n\n\n            var myData = { pcno: $('#txtDispPCNO').val() };\n            var encoded = JSON.stringify(myData);\n            $.ajax({\n                cache: false,\n                type: \"POST\",\n                url: \"/Patient/GetPatientAllergyInListForm\",\n                data: encoded,\n                contentType: \"application/json; charset=utf-8\",\n                dataType: \"json\",\n                success: function (result) {\n                    if (result.success) {\n                        //Modified by kenneth 2025-11-20 - To display HTML of allergy list \n                        //$(\"#lblPatAllergy\").text(result.AllergyList)\n                        $(\"#lblPatAllergy\").html(result.AllergyList)\n                        $('#lblCNPatAllergy').html(result.AllergyList)\n                    }\n                    else {\n                        swal(\"\", result.message, \"error\");\n                    }\n                },\n                error: function (result) {\n                    swal(\"\", result, \"error\");\n                }\n            });\n\n\n        }\n    }",
      "/*input[type=\"text\"], select {\n        height: 25px;\n        border-radius: 0;\n    }*/\n\n    .btn-sm-dispense {\n        height: 25px;\n        width: 25px;\n        line-height: 0px;\n        background: #46b8da !important;\n        border: none;\n        cursor: pointer !important;\n        color: white;\n    }\n\n    .jqgridcontainer {\n        border: none;\n    }\n\n    #tabBioData .detailitemboxwrapper_compact150 {\n        width: 150px;\n    }\n\n    html input[disabled] {\n        cursor: not-allowed;\n    }\n\n    .datepicker th {\n        color: black;\n    }\n\n    .datepicker-inline {\n        max-width: 180px;\n    }\n\n    .datepicker-switch {\n        background-color: #A6ACAF;\n        color: black;\n    }\n\n    .datepicker .next, .datepicker .prev {\n        background-color: lightgray;\n        color: black;\n    }\n\n    .datepicker table tr td.today {\n        color: white !important;\n        background-image: linear-gradient(to bottom,#a6acaf,#a6acaf) !important;\n    }\n\n    .datepicker table tr td.active {\n        background-image: linear-gradient(to bottom,#46b8da,#46b8da) !important;\n    }\n\n    #btnMediClaimAddGP svg path {\n        fill: black;\n    }\n\n    /*.panel-heading {\n        font-weight: bold;\n    }*/\n\n    #divPatientGroupDetail a svg path {\n        fill: black;\n    }\n\n    #btnPatientGroupAdd svg path {\n        fill: black;\n    }\n\n    /*#gview_patientConsentGrid {\n        height: 115px;\n    }*/\n\n    /*Added by Chang Ching Ler 20211027 | Resolve font issue at appointment > Add > Patient Summary */\n    /*label {\n        font-size: 12px;\n    }*/\n    /*Added by Chang Ching Ler 20211027 */\n\n    #divVip label {\n        display: flex;\n        align-items: center;\n        margin-right: 10px;\n        height: 25px;\n        margin-bottom: 0px;\n    }\n\n    .patidtooltip + .tooltip > .tooltip-inner {\n        white-space: pre;\n        max-width: none;\n        text-align: left;\n        color: black;\n        border: none !important;\n        background-color: #f3ce8f !important;\n    }\n\n    #divNRICField {\n        /*width: 60vw !important;*/\n        z-index: 1;\n    }\n\n    .patientInfoCustomField {\n        width: calc(100% - 150px);\n    }\n\n    .patientInfoCustomLabel {\n        padding: 0px 0px 5px 1px;\n    }\n\n    .patientTabContent .form-control {\n        padding: 5px;\n    }\n\n    #tabPatientPhoto {\n        width: 200px;\n        height: 169px;\n        background-color: rgba(255, 255, 255, 0.5);\n        margin: auto;\n    }\n\n    #jqgh_patientConsentGrid_Date1, #jqgh_patientConsentGrid_Type {\n        overflow: initial !important;\n        padding-top: 5px !important;\n    }\n\n    #gview_patientConsentGrid .ui-jqgrid-bdiv {\n        overflow: hidden;\n    }\n\n    .sideButton {\n        cursor: pointer;\n        background: var(--button-background-color) !important;\n        padding: 6px 12px;\n        font-size: 13px;\n        font-weight: 500;\n        color: var(--button-font-color);\n        width: 55px;\n        font-family: 'Segoe UI';\n    }\n\n    .customCol {\n        position: relative;\n        float: left;\n    }\n\n    .patientBioDataMainLeftDiv {\n        position: relative;\n        float: left;\n        width: 70%;\n        padding-left: 10px;\n    }\n\n    .patientBioDataMainRightDiv {\n        position: relative;\n        float: left;\n        width: 30%;\n        padding-left: 10px;\n    }\n\n    .funkyradio div {\n        clear: both;\n        overflow: hidden;\n    }\n\n    .funkyradio label {\n        width: 100%;\n        border-radius: 3px;\n        border: 1px solid #D1D3D4;\n        font-weight: normal;\n    }\n\n    .funkyradio input[type=\"radio\"]:empty,\n    .funkyradio input[type=\"checkbox\"]:empty {\n        display: none;\n    }\n\n        .funkyradio input[type=\"radio\"]:empty ~ label,\n        .funkyradio input[type=\"checkbox\"]:empty ~ label {\n            position: relative;\n            line-height: 2.5em;\n            text-indent: 3.25em;\n            /*margin-top: 2em;*/\n            margin-top: 15px;\n            cursor: pointer;\n            -webkit-user-select: none;\n            -moz-user-select: none;\n            -ms-user-select: none;\n            user-select: none;\n        }\n\n            .funkyradio input[type=\"radio\"]:empty ~ label:before,\n            .funkyradio input[type=\"checkbox\"]:empty ~ label:before {\n                position: absolute;\n                display: block;\n                top: 0;\n                bottom: 0;\n                left: 0;\n                content: '';\n                width: 2.5em;\n                background: #D1D3D4;\n                border-radius: 3px 0 0 3px;\n            }\n\n    .funkyradio input[type=\"radio\"]:hover:not(:checked) ~ label,\n    .funkyradio input[type=\"checkbox\"]:hover:not(:checked) ~ label {\n        color: #888;\n    }\n\n        .funkyradio input[type=\"radio\"]:hover:not(:checked) ~ label:before,\n        .funkyradio input[type=\"checkbox\"]:hover:not(:checked) ~ label:before {\n            content: '\\2714';\n            text-indent: .9em;\n            color: #C2C2C2;\n        }\n\n    .funkyradio input[type=\"radio\"]:checked ~ label,\n    .funkyradio input[type=\"checkbox\"]:checked ~ label {\n        color: #777;\n    }\n\n        .funkyradio input[type=\"radio\"]:checked ~ label:before,\n        .funkyradio input[type=\"checkbox\"]:checked ~ label:before {\n            content: '\\2714';\n            text-indent: .9em;\n            color: #333;\n            background-color: #ccc;\n        }\n\n    .funkyradio input[type=\"radio\"]:focus ~ label:before,\n    .funkyradio input[type=\"checkbox\"]:focus ~ label:before {\n        box-shadow: 0 0 0 3px #999;\n    }\n\n    .funkyradio-info input[type=\"radio\"]:checked ~ label:before,\n    .funkyradio-info input[type=\"checkbox\"]:checked ~ label:before {\n        color: #fff;\n        background-color: var(--nav-header-color);\n    }\n\n    .divForeignAdd, .company-form {\n        display: none;\n    }\n\n    #btnPatientAddBrackets {\n        cursor: pointer;\n        background: #46b8da;\n        border: 1px solid #488abb;\n        color: white;\n        border-radius: 0 7px 7px 0 !important;\n    }\n   @media (max-width: 1180px) {\n    .responsive-idtextbox {\n        width: 80% !important;\n    }\n    .responsive-nricbox{\n        min-width:120px;\n    }\n    .responsive-idno2{\n        width:60% !important;\n    }\n    .responsive-patientsex{\n        width:40% !important;\n    }\n    #txtPatientDOB{\n        width:80px !important;\n    }\n    .responsive-photo{\n        margin-left:25px;\n    }\n    .responsive-racelabel{\n        width:19% !important;\n    }\n    .responsive-doblabel{\n        width:33% !important;\n    }\n    .responsive-age{\n        margin-left:19px;\n    }\n    #txtPatientSex{\n        width:60px !important;\n    }\n    #txtPatientRace{\n        width:94% !important;\n    }\n    #txtPatientDocID{\n        width:100% !important;\n    }\n    .responsive-dummyfield,.responsive-vipfield,.responsive-membercheckfield{\n        margin-top:10px;\n    }\n    #txtPatAge{\n       min-width:90px !important;\n    }\n}\n    @media (max-width: 1366px) {\n        #txtPatientDOB{\n            width:85px !important;\n        }\n        #txtPatientRace{\n            width:100% !important;\n        }\n            .responsive-racelabel{\n        width:18% !important;\n    }\n       #txtPatAge{\n         min-width:95px !important;\n       }\n       .responsive-dummyfield,.responsive-vipfield,.responsive-membercheckfield{\n           margin-top:10px;\n       }\n    }\n    /*Added by kenneth 2025-03-18 - to set sortable, preferred / non preferred(normal) notification style*/\n    #divNotifications {\n        border: 1px solid #cccccc;\n        border-radius: 7px;\n        padding: 0 5px;\n        display: flex;\n        flex-direction: row;\n        align-items: center;\n        width: 100%;\n        height: 37px;\n        gap: 5px;\n        cursor: move;\n    }\n    .sortable-item {\n        cursor: move;\n    }\n\n    .preferred-notif {\n        color: var(--button-font-color);\n        border-color: #000000 !important;\n        background-color: #ddffc3 !important;\n        height: 30px;\n        border-radius: 5px !important;\n        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n        font-weight: 500;\n    }\n    .non-preferred-notif {\n        color: var(--button-font-color);\n        border-color: #000000 !important;\n        background-color: white !important;\n        height: 30px;\n        border-radius: 5px !important;\n        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n        font-weight: 500;\n    }\n    /*End Added by kenneth 2025-03-18 */\n        #divNotificationInfo {\n        border-radius: 6px;\n        padding: 10px;\n        position: absolute;\n        z-index: 1;\n        box-shadow: inset 0 0 0 2px rgb(255, 255, 255), 0.3em 0.3em 1em rgba(0, 0, 0, 0.3);\n        background: #fff;\n        color: #000;\n        max-width: 450px;\n        width: max-content;\n        max-height: 400px; \n        overflow-y: auto;\n        overflow-x: hidden;\n        border: 1px solid #b3b4b5;\n        box-sizing: border-box;\n        bottom: 25px;\n        left: 345px;\n        transform: translateX(-75%);\n    }\n\n\n\n\n\n\n        \n\nPlease fix these errors.\n\n    \n    \n    \n    \n    \n    \n    \n        \n        \n        \n        \n        \n        \n        \n        \n        \n        \n        \n        \n        \n        \n        \n        \n        \n\n        \n            \n                \n                \n                    \n                    \n                        Status\n\n                        Active\nInActive\nArchive\n\n                    \n\n                    \n                    \n                        PCNO\n\n                        \n                            \n                            DM \n                            DF  \n                        \n                    \n\n                    \n                    \n                        Ref No\n\n                        \n                    \n\n                    \n                    \n                        \n\n                        No Allergy\n                    \n\n                    \n                    \n                        \n\n                        Dummy Patient (No submission to NEHR) \n                    \n\n                    \n                    \n                        \n                        VIP\n                        ...\n                    \n\n                    \n                    \n                        \n\n                        APP Member ID\n\n                        \n                        \n                    \n                \n\n                \n                \n                    \n                    \n                        \n                        \n                            Name\n\n                            \n                        \n\n                        \n                            \n                                Hanyu Pinyin\n                            \n\n                            \n                                \n\n                                \n                                \n                                    \n                                \n                            \n                        \n\n                        \n\n                        \n                        \n                            \n                                ID Type\n\n                                \n                                    \nPINK IC\nBLUE IC/ENTRY PERMIT\nFIN NUMBER\nMALAYSIAN IC\nPASSPORT\nCPF ACCOUNT\nLONG TERM VISIT PASS PLUS\nOTHER IDENTIFICATION\nSINGAPORE BIRTH CERTIFICATE\n\n\n                                    \n                                        \n\n                                        \n                                    \n                                \n                            \n\n                            \n                                N.A\nPASSPORT\nWORK PERMIT\n\n\n                                \n                                    \n\n                                    \n                                        \n                                    \n                                \n                            \n                        \n\n                        \n                        \n                            \n                                Sex\n\n                                \nF\nM\n\n                            \n\n                            \n                                Date of Birth\n\n                                \n                                    \n                                \n\n                                \n                                    Age\n                                    \n                                    \n                                \n                            \n                        \n\n                        \n                        \n                            \n                                Nationality\n                                \n                                    \nSINGAPORE CITIZEN\nAMERICAN\nANGOLAN\nARGENTINIAN\nAUSTRALIAN\nAUSTRIAN\nBAHRAINI\nBANGLADESHI\nBELGIAN\nBHUTANESE\nBRAZILIAN\nBRITISH\nBRUNEIAN\nCAMBODIAN\nCANADIAN\nCHILEAN\nCHINESE\nCOLOMBIAN\nCROATIAN\nCZECH\nDANISH\nEGYPTIAN\nESTONIAN\nESWATINI\nFILIPINO\nFINNISH\nFRENCH\nGERMAN\nGHANAIAN\nGREEK\nHONG KONG\nHUNGARIAN\nINDIAN\nINDONESIAN\nIRISH\nISRAELI\nITALIAN\nJAPANESE\nKAZAKHSTANI\nKITTIAN & NEVISIAN\nKOREAN, SOUTH\nLEBANESE\nMALAYSIAN\nMAURITIAN\nMEXICAN\nMONGOLIAN\nMYANMAR\nNEPALESE\nNETHERLANDS\nNEW ZEALANDER\nNI-VANUATU\nNORWEGIAN\nPAKISTANI\nPOLISH\nPORTUGUESE\nREFUGEE (OTHER THAN XXB)\nREFUGEE (XXB)\nROMANIAN\nRUSSIAN\nSA