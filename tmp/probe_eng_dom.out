Malay\nMandarin\nOthers\nTamil\nTeochew\nThai\n\n                            \n\n                            \n                                Occupation\n\n                                \nBusiness\ndriver\nHOUSEWIFE\nLAWYER\nNONE\nOTHERS\nREPORTER\n\n                            \n                        \n\n                        \n                        \n                            \n                                Country of Birth\n\n                                AFGHANISTAN\nALBANIA\nALGERIA\nAMERICAN SAMOA\nANDORRA\nANGUILLA\nANLA\nANTIGUA\nARGENTINA\nARMENIA\nARUBA\nAUSTRALIA\nAUSTRIA\nAZERBAIJAN\nBAHAMAS\nBAHRAIN\nBANGLADESH\nBARBADOS\nBELARUS\nBELGIUM\nBELIZE\nBENIN\nBERMUDA\nBHUTAN\nBOLIVIA\nBOSNIA-HERZEVINA\nBOTSWANA\nBRAZIL\nBRITISH ANTARCTIC TERRITORY\nBRITISH INDIAN OCEAN TERRITORY\nBRITISH VIRGIN ISLANDS\nBRUNEI\nBULGARIA\nBURKINA FASO\nBURUNDI\nCAMBODIA\nCAMEROON\nCANADA\nCANTON & ENDERBURY ISLANDS\nCAPE VERDE\nCAYMAN ISLANDS\nCENTRAL AFRICAN REPUBLIC\nCHAD\nCHANNEL ISLANDS\nCHILE\nCHINA\nCHRISTMAS ISLAND\nCOCOS KEELING ISLAND\nCOLOMBIA\nCOMOROS\nCONGO\nCOOK ISLANDS\nCOSTA RICA\nCROATIA\nCUBA\nCYPRUS\nCZECH REPUBLIC\nDENMARK\nDJIBOUTI\nDOMINICA\nDOMINICAN REPUBLIC\nEAST TIMOR\nECUADOR\nEGYPT\nEL SALVADOR\nEQUATORIAL GUINEA\nERITREA\nESTONIA\nESWATINI\nETHIOPIA\nFAEROE ISLANDS\nFALKLAND ISLANDS\nFIJI\nFINLAND\nFRANCE\nFRENCH GUIANA\nFRENCH POLYNESIA\nFRENCH SOUTHERN & ANTARCTIC TERRITORIES\nGABON\nGAMBIA\nGAZA\nGEORGIA\nGERMANY\nGHANA\nGIBRALTAR\nGREECE\nGREENLAND\nGRENADA\nGUADELOUPE\nGUAM\nGUATEMALA\nGUERNSEY\nGUINEA\nGUINEA-BISSAU\nGUYANA\nHAITI\nHEARD ISLAND & MCDONALD ISLANDS\nHONDURAS\nHONG KONG\nHONG KONG SAR\nHUNGARY\nICELAND\nINDIA\nINDONESIA\nIRAN\nIRAQ\nIRELAND\nISLE OF MAN\nISRAEL\nITALY\nIVORY COAST\nJAMAICA\nJAPAN\nJOHNSTON ISLAND\nJORDAN\nKAZAKHSTAN\nKENYA\nKIRGHIZIA\nKIRIBATI\nKOREA, NORTH\nKOREA, SOUTH\nKOSOVO\nKUWAIT\nKYRGYZSTAN\nLAOS\nLATVIA\nLEBANON\nLESOTHO\nLIBERIA\nLIBYA\nLIECHTENSTEIN\nLITHUANIA\nLUXEMBOURG\nMACAO\nMACAU SAR\nMACEDONIA\nMADAGASCAR\nMALAWI\nMALAYSIA\nMALDIVES\nMALI\nMALTA\nMARSHALL ISLANDS\nMARTINIQUE\nMAURITANIA\nMAURITIUS\nMAYOTTE\nMEXICO\nMIDWAY ISLANDS\nMOLDOVA\nMONACO\nMONGOLIA\nMONTENEGRO\nMONTSERRAT\nMOROCCO\nMOZAMBIQUE\nMYANMAR\nNAMIBIA\nNAURU\nNEPAL\nNETHERLANDS\nNETHERLANDS ANTILILLES\nNEW CALEDONIA\nNEW ZEALAND\nNICARAGUA\nNIGER\nNIGERIA\nNIUE ISLAND\nNORFOLK ISLAND\nNORWAY\nOMAN\nOTHERS\nPACIFIC ISLAND TRUST TERRITORY\nPAKISTAN\nPALAU\nPALESTINE\nPANAMA\nPANAMA CANAL ZONE\nPAPUA NEW GUINEA\nPARAGUAY\nPERU\nPHILIPPINES\nPITCAIRN ISLAND\nPOLAND\nPORTUGAL\nPUERTO RICO\nQATAR\nREUNION\nROMANIA\nRUSSIA\nRWANDA\nSAMOA\nSAN MARINO\nSAO TOME & PRINCIPE\nSAUDI ARABIA\nSENEGAL\nSERBIA\nSERBIA/MONTENEGRO\nSEYCHELLES\nSIERRA LEONE\nSINGAPORE\nSLOVAK REPUBLIC\nSLOVENIA\nSOLOMON ISLANDS\nSOMALIA\nSOUTH AFRICA\nSPAIN\nSRI LANKA\nST. HELENA\nST. KITTS-NEVIS\nST. LUCIA\nST. PIERRE & MIQUELON\nST. VINCENT\nSUDAN\nSURINAME\nSWEDEN\nSWITZERLAND\nSYRIA\nTAIWAN\nTAJIKISTAN\nTANZANIA\nTHAILAND\nTIMOR\nTO\nTOKELAU ISLANDS\nTONGA\nTRINIDAD & TOBA\nTUNISIA\nTURKEY\nTURKMENISTAN\nTURKS & CAICOS ISLANDS\nTUVALU\nUGANDA\nUKRAINE\nUNITED ARAB EMIRATES\nUNITED KINGDOM\nUNITED STATES\nUNKNOWN\nUPPER VOLTA\nURUGUAY\nUS VIRGIN ISLANDS\nUZBEKISTAN\nVANUATU\nVATICAN CITY STATE\nVENEZUELA\nVIETNAM\nWAKE ISLAND\nWALLIS AND FUTUNA\nWESTERN SAHARA\nYEMEN\nYUSLAVIA\nZAIRE\nZAMBIA\nZIMBABWE\n\n                            \n\n                            \n                                Svc. Provider\n\n                                \nDr David Bako\nDr Lim Heng Hing\nDr. Joseph Sharon Raj [Orthopaedic Practitioner]\nDR. KELVIN TAN [Orthopaedic Surgeon]\nDR. KEVIN YIP [Orthopaedic Surgeon]\nDR. P. ARUL MURUGAN [Orthopaedic Surgeon]\nDr. Tan Kuan Siang [Orthopaedic Practitioner]\nDR. TUNG YU YEE MATHEW [Spine & Neurosurgeon]\nJohn Anthony Tay [Physio]\nJOTHIRAMALINGAM VINOTH [Physio]\nREKHA NIKHIL KUVELKAR [Physio]\nWee Yong [Physio]\n\n                            \n                        \n                    \n\n                    \n                    \n                        \n                            \n\n\n\n    .divProfilePicture {\n        display: flex;\n        justify-content: center;\n        align-items: center;\n        background-color: #f5f5f5;\n        /*border-radius: 50%;*/\n        /*border: 6px double #33333387;*/\n        /*box-shadow: 0 0 10px rgba(0, 0, 0, 0.2);*/\n        overflow: hidden;\n        pointer-events: none;\n    }\n\n\n    #imgPatientPhoto {\n        width: 200px;\n        height: 200px;\n        object-fit: cover;\n        /*border-radius: 50%;*/\n    }\n\n\n\n    \n\n                \n            \n\n\n    $(document).ready(function () {\n        if($('#hfPatitentPhoto').val() == \"\") {\n            $('#hfPatitentPhoto').val(\"/Content/images/blank-profile-picture.png\");\n        }\n        $('#imgPatientPhoto').attr('src', $('#hfPatitentPhoto').val());\n\n        oldDataBiodata = JSON.stringify($('#CreateEditPatientForm').serializeArray());      //Added by Jason 20211022 - get data\n\n        if ($('#hfShowPhoto').val() == \"False\") {\n            $('#imgPatientPhoto').hide();\n        }\n    });\n\n    $(document).ajaxStop(function () {\n        $(\".fadeMe\").hide();\n    });\n\n                        \n                    \n                \n\n                \n                \n                    \n                    \n                        \n                            Blk/Hse No\n\n                            \n                        \n\n                        \n                            Street\n\n                            \n                                \n\n                                ...   \n                            \n                        \n                    \n\n                    \n                    \n                        \n                            Unit\n\n                            \n                        \n\n                        \n                            Building Name\n\n                            \n                        \n                    \n\n                    \n                    \n                        \n                            Postal Code\n\n                            \n                                 \n\n                                      \n                            \n                        \n\n                        \n                            Use Foreign Add\n\n                            \nYes\nNo\n\n                        \n                    \n                    \n                    \n                        \n                            State\n\n                            \n                            \nJohor\nKedah\nKelantan\nMelaka\nNegeri Sembilan\nPahang\nPulau Pinang\nPerak\nPerlis\nSelangor\nTerengganu\nSabah\nSarawak\nWilayah Persekutuan Kuala Lumpur\nWilayah Persekutuan Labuan\nWilayah Persekutuan Putrajaya\nNot Applicable\n                            \n                            \n                        \n\n                        \n                            City\n\n                                                       \n                    \n\n                    \n                    \n                        \n                            Foreign Address\n\n                            \n                        \n\n                        \n\n                        \n\n                        \n                    \n                \n\n                \n                \n                    \n                    \n                        \n                            Mobile No.\n\n                            \n                        \n\n                        \n                            Other Contact\n\n                            \n                        \n                    \n\n                    \n                    \n                        \n                            Tel(H)\n\n                            \n                        \n\n                        \n                            Email\n\n                            \n                        \n                    \n                \n\n                \n                \n                    \n                    Company Information\n\n                    \n                    \n                        Company\n\n                        \n                            \n\n                            \n                            ...\n\n                            \n                            \n\n                        \n                    \n\n                    \n                    \n                        \n                            Emp No\n\n                            \n                        \n\n                        \n                            Department\n\n                            \n                        \n                    \n\n                    \n                    \n                    \n                    \n                    \n                        Co-Payment\n\n                        \n                              \n                            $\n                            \n\n                              \n                            %\n                            \n                        \n                    \n                     \n                \n\n                \n                \n                    \n                    \n                        \n                            \n                                Notification\n\n                                \n                                    \n                                        \n                                    \n                                    Add\n                                \n                            \n\n                            \n                                    \n                                        \n                                    \n                                    SMS\n                                \n                                \n\n                                \n                                    \n                                        \n                                    \n                                    Email\n                                \n                                \n                                    \n                                        \n                                    \n                                    WhatsApp\n                                \n                            \n\n                            \n                                \n                                \n                                    \n                                        \n                                            \n                                                Subscribe to Activate WhatsApp Messaging\n                                            \n                                            To enable automatic WhatsApp message sending, please ensure your clinic has subscribed to SendQuick for the onboarding process and WhatsApp account setup. For any inquiries, you can contact SendQuick at +65 6280 2881, email them at info@sendquick.com, or visit their website at www.sendquick.com.\n                                            Note: When contacting SendQuick to subscribe, please mention that you are a user of Clinic Assist to have the onboarding process fee waived.\n                                            \n                                                For more information, please visit WhatsApp Onboarding Guide.\n                                            \n                                            \n                                        \n                                        \n                                        \n                                            Notification Preference\n                                        \n                                        \n                                            You can drag the notification buttons to reorder them.\n                                            The first notification in the list is considered your preferred notification.\n                                        \n                                        Note:\n                                        \n                                            Currently, only WhatsApp set as the preferred method will trigger automatic messages. Appointment-related messages will be sent automatically when an appointment is added, updated, or canceled, while payment-related messages — including Invoice, Receipt, or MC attachments — will be sent automatically upon successful payment.\n                                            Email and SMS currently do not trigger any automatic messages when set as preferred.\n                                        \n                                    \n                                \n                            \n                        \n\n                        \n                            Consent to receive marketing information\n\n                            \nYes\nNo\n\n                        \n                    \n                \n\n                \n                \n                    \n                    \n                        \n                            Notes\n                        \n\n                        \n                    \n\n                    \n                    \n                        \n                            Group\n\n                            \n                                \n                                    \n                                \n                                Add\n                            \n                        \n\n                        \n                            \n                        \n                    \n\n                    \n                    \n                        Media Source\n\n                        \n\n                    \n\n                    \n                    \n                        Referral\n\n                        \n                             \n                            ...\n                                 \n                        \n                    \n\n                    \n                    \n                        Doctor\n\n                        \nPatient\n\n                    \n\n                    \n                    \n                        Agent\n\n                        \n                            \n                            ...\n                            \n                        \n                    \n                \n\n                \n            \n        \n    \n\n\n    \n        \n            \n                ×\n                Edit Patient NRIC\n            \n            \n                \n                    \n                        \n                            \n                                \n                                    \n                                        \n                                            \n                                                \n                                                    NRIC/FIN/OTHERS\n                                                    \n                                                \n\n                                                \n                                                    New  \n                                                    NRIC/FIN/OTHERS\n                                                    \n                                                \n\n                                                \n                                                    Note: Changing of NRIC will affect NEHR, CHAS, CDMP, NIR, IRIS and CIDC Submission\n                                                \n                                            \n                                        \n                                    \n                                \n                            \n                            \n                                \n                                    \n                                         \n                                        \n                                    \n                                \n                            \n                        \n                    \n                \n            \n        \n    \n\n\n\n\n\n    \n        \n            \n                ×\n                Mobile Profile Uploaded Listing\n            \n            \n                \n                    \n                        \n                            \n                                \n                                    \n                                \n                            \n                        \n                    \n                \n            \n            \n                \n                    \n                    \n                    \n                        \n                    \n                \n            \n        \n    \n\n\n\n\n    \n        \n            \n                ×\n                Edit Patient VIP Link\n            \n            \n                \n                    \n                        \n                            \n                                \n                                    \n                                        \n                                            \n                                                \n                                                    \n                                                \n                                            \n                                        \n                                    \n                                \n                            \n                            \n                                \n                                    \n                                        \n                                        \n                                    \n                                \n                            \n                        \n                    \n                \n            \n        \n    \n\n\n\n\n\n\n\n\n\n\n\n\n\n    var Prefix_Unit = \"\";\n    var List_Xray_Externalprog = [];\n    var Xray_patient_Old = \"\";\n    var prevCellVal_PatMaster = { cellId: undefined, value: undefined }; //Added by Koh Chin Choong 20201223 - For Group Diagnosis by code\n    var OKbtn;      //Added by Jason 20210601 - declare okbtn\n\n    $(document).ajaxStop(function () {\n        $(\".fadeMe\").hide();\n    });\n\n    $(function () {\n        var pcno = $(\"#txtPatientNo\").val();\n        var urlPatientGrpstring = 'https://clinicassist.sg:1080/en/Patient/GetPatientGroupLists?pcno=' + pcno;\n\n        //Modified by zhaoying 20180322 | colmodel width, colnames to lowercase\n        $(\"#patientGroundGrid\").jqGrid({\n            url: urlPatientGrpstring,\n            datatype: 'json',\n            mtype: 'Get',\n            colNames: ['Code', 'Description', 'Created Date',''],\n            colModel: [\n                { key: true, name: 'PatGrpCode', index: 'PatGrpCode', width: 100, sortable: false },\n                { key: false, name: 'Description', index: 'Description', width: 400, sortable: false },\n                { key: false, name: 'CreatedDateString', index: 'CreatedDateString', width: 100, sortable: false },\n                { key: false, name: '', index: '', width: 30, align: 'center', sortable: false, formatter: formatRemovePatientAllergy }\n            ],\n            rowNum: 100,\n            scrollrows: true,\n            gridview: true,\n            scroll: true,\n            width: \"100%\",\n            height: 200,\n            hoverrows: false,\n            loadError: function (xhr, status, error) {\n            },\n            loadComplete: function () {\n                var ids = $(\"#patientGroundGrid\").jqGrid(\"getDataIDs\");\n\n                if (ids.length <= 100) {\n                    $(\"#patientGroundGrid tr\").eq(1).trigger(\"click\");\n                }\n            },\n            emptyrecords: 'No records to display',\n            jsonReader: {\n                root: \"rows\",\n                page: \"page\",\n                total: \"total\",\n                records: \"records\",\n                repeatitems: false,\n                Id: \"0\"\n            },\n            shrinkToFit: false,\n            multiselect: false\n        });\n\n        //loadpatientConsentGrid();\n        loadPatientConsent();\n\n        $(\"#txtPatientUseForAdd\").val() == \"True\" ? $(\".divForeignAdd\").show() : $(\".divForeignAdd\").hide();\n        $(\"#txtPatientUseForAdd\").on(\"change\", function () {\n            $(\"#txtPatientUseForAdd\").val() == \"True\" ? $(\".divForeignAdd\").show() : $(\".divForeignAdd\").hide();\n        });\n    });\n\n    function formatRemovePatientAllergy(cellvalue, options, rowObject) {\n        return \"<a onmouseover='' style='cursor: pointer;' onclick='btnPatientGroupDelete.call(this, event)' data-toggle='tooltip' data-placement='top' title='Remove Patient Drug Allergy' ><span class='glyphicon glyphicon-trash' style='color:red;'></span></a>\";\n    }\n\n    function loadpatientConsentGrid() {\n        $(\"#patientConsentGrid\").GridUnload();\n        var urlPatientConsentstring = 'https://clinicassist.sg:1080/en/Patient/GetPatientConsentLists?pcno=' + $(\"#txtPatientNo\").val();       //Edited by Jason 20211027 - change $(\"#PCNO\").val() to $(\"#txtPatientNo\").val()\n        $(\"#patientConsentGrid\").jqGrid({\n            url: urlPatientConsentstring,\n            datatype: 'json',\n            mtype: 'Get',\n            colNames: ['', 'Date', 'Type'],\n            colModel: [\n                { key: false, name: 'Select1', index: 'Select1', width: 40, sortable: false, formatter: \"checkbox\", align: 'center', editable: true, edittype: 'checkbox', editoptions: { value: \"True:False\" }, formatoptions: { disabled: false } },\n                { key: false, name: 'Date1', index: 'Date1', width: 80, sortable: false, formatter: 'date', formatoptions: { srcformat: 'd/m/Y H:i', newformat: 'd/m/Y' } },\n                { key: false, name: 'Type', index: 'Type', width: 100, sortable: false },\n            ],\n            rowNum: -1,\n            //multiselect: false,\n            //scrollrows: true,\n            //gridview: true,\n            height: \"100%\",\n            width: \"100%\",\n            //scroll: true,\n            //hoverrows: false,\n            //cellEdit: false,\n            //cellsubmit: 'clientArray',\n            scrollOffset: 0,\n            hoverrows: false,\n            viewrecords: false,\n            loadError: function (xhr, status, error) {\n            },\n            loadComplete: function () {\n                //Added by Jason 20211027 - set infoChanged to Y\n                $('#patientConsentGrid').jqGrid('setGridWidth', $(\"#patientConsentGridDiv\").width());\n                $(\"#patientConsentGrid\").find('input[type=checkbox]').change(function () {\n                    infoChanged = \"Y\";\n                });\n                //End added by Jason 20211027\n\n                //$(\"#txtPatientNotes\").height($(\"#patientConsentGridDiv\").height() - 95);\n                //$(window).on(\"resize\", function () {\n                //    $('#patientConsentGrid').jqGrid('setGridWidth', $(\"#patientConsentGridDiv\").width());\n                //});\n            },\n            onSelectRow: function(ids) {\n                var ch =  jQuery(this).find('#'+ids+' input[type=checkbox]').prop('checked');\n                if(ch) {\n                    jQuery(this).find('#'+ids+' input[type=checkbox]').prop('checked',false);\n                } else {\n                    jQuery(this).find('#'+ids+' input[type=checkbox]').prop('checked',true);\n                }\n\n                infoChanged = \"Y\";          //Added by Jason 20211027 - set infoChanged to Y\n            },\n            emptyrecords: 'No records to display',\n            //jsonReader: {\n            //    root: \"rows\",\n            //    page: \"page\",\n            //    total: \"total\",\n            //    records: \"records\",\n            //    repeatitems: false,\n            //    Id: \"0\"\n            //},\n            shrinkToFit: true,\n        });\n    }\n\n\n    function loadPatientConsent() {\n        $.ajax({\n            cache: false,\n            type: \"POST\",\n            url: \"/Patient/GetPatientConsent?pcno=\" + $(\"#txtPatientNo\").val(),\n            contentType: \"application/json; charset=utf-8\",\n            dataType: \"json\",\n            success: function (response) {\n                if (response.success) {\n                    let preferredType = null;\n\n                    $(response.consentList).each(function () {\n                        let item = $(this)[0];\n\n                        if (item.Type === \"SMS\" && item.Select1 === '1') {\n                            $(\"#aNotificationSMS\").show();\n                        } else if (item.Type === \"Email\" && item.Select1 === '1') {\n                            $(\"#aNotificationEmail\").show();\n                        } else if (item.Type === \"WhatsApp\" && item.Select1 === '1') {\n                            $(\"#aNotificationWhatsApp\").show();\n                        }\n\n                        if (item.Preferred === '1') {\n                            preferredType = item.Type;\n                        }\n                    });\n                    debugger\n                    // Move the preferred notification to the beginning\n                    if (preferredType) {\n                        let preferredId = \"#aNotification\" + preferredType;\n                        $(preferredId).prependTo(\"#divNotifications\");\n                    }\n\n                    highlightPreferred();\n                }\n            }\n        });\n    }\n\n    //$(\"#btnDM\").closest(\".modal\").on('hidden.bs.modal', function () {\n    //    $(\".createEditpatientModalFooter\").remove();\n    //})\n\n    //Added by Cooper 20180717 - Patient (ACCESS CONTROL)\n    function SetEditBioContactPermission()\n    {\n        //Do not Hide for Add button\n        if (true == false && $(\"#txtPatientNo\").val().indexOf(\"NEW\") == -1) {  //Added by MiaoRu 20211216 - Do not disable for Add button\n            //if (!checkFP(Cookies.get(\"Pat_Edit_Bio_contact\"))){   //Commented by MiaoRu 20211216 - Do not disable for Add button\n            //Disable column for bio contact\n            $(\"#txtPatientBlkHseNo\").attr('readonly','readonly');\n            $(\"#txtPatientStreet\").attr('readonly','readonly');\n            $(\"#btnStreet\").css(\"pointer-events\", \"none\");\n            $(\"#txtPatientUnitNo\").attr('readonly','readonly');\n            $(\"#txtPatientBuildingName\").attr('readonly','readonly');\n            $(\"#txtPatientPostal\").attr('readonly','readonly');\n            $(\"#btnPostal\").css(\"pointer-events\", \"none\");\n            $(\"#txtPatientTel\").attr('readonly','readonly');\n            $(\"#txtPatientHP\").attr('readonly','readonly');\n            $(\"#txtPatientEmail\").attr('readonly','readonly');\n            $(\"#txtPatientUseForAdd\").attr('readonly','readonly');\n            $(\"#txtPatientTel2\").attr('readonly','readonly');\n            $(\"#txtPatientProvinces\").attr('readonly','readonly');\n            $(\"#txtPatientDistricts\").attr('readonly','readonly');\n\n            $(\"#txtPatientBlkHseNo\").css('background-color', 'lightgrey');\n            $(\"#txtPatientStreet\").css('background-color', 'lightgrey');\n            $(\"#txtPatientUnitNo\").css('background-color', 'lightgrey');\n            $(\"#txtPatientBuildingName\").css('background-color', 'lightgrey');\n            $(\"#txtPatientPostal\").css('background-color', 'lightgrey');\n            $(\"#txtPatientTel\").css('background-color', 'lightgrey');\n            $(\"#txtPatientHP\").css('background-color', 'lightgrey');\n            $(\"#txtPatientEmail\").css('background-color', 'lightgrey');\n            $(\"#txtPatientUseForAdd\").css('background-color', 'lightgrey');\n            $(\"#txtPatientTel2\").css('background-color', 'lightgrey');\n            $(\"#txtPatientProvinces\").css('background-color', 'lightgrey');\n            $(\"#txtPatientDistricts\").css('background-color', 'lightgrey');\n        }\n    }\n\n    //Added by Cooper 20180717 - Patient (ACCESS CONTROL)\n    \n\n    var initCompCode; //Added by zhaoying 20190318\n    $(document).ready(function () {\n        $('.patidtooltip').tooltip();\n        var script = document.createElement(\"SCRIPT\");\n        script.src = 'https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.0/js/select2.min.js';\n        script.type = 'text/javascript';\n        script.onload = function() {\n            var $ = window.jQuery;\n\n            // on first focus (bubbles up to document), open the menu\n            $(document).on('focus', '.select2-selection.select2-selection--single', function (e) {\n                $(this).closest(\".select2-container\").siblings('select:enabled').select2('open');\n            });\n\n            // steal focus during close - only capture once and stop propogation\n            $('select.select2').on('select2:closing', function (e) {\n                $(e.target).data(\"select2\").$selection.one('focus focusin', function (e) {\n                    e.stopPropagation();\n                });\n            });\n        };\n        document.getElementsByTagName(\"head\")[0].appendChild(script);\n\n        $('#btnPatientOk').removeClass(\"btn btn-sm btn-info\").addClass(\"btn btn-sm ok-style\"); //Added by Chang Ching Ler 20191119 | Change color of OK button\n        $('#btnPatientClose').removeClass(\"btn btn-sm btn-info\").addClass(\"btn btn-sm cancel-style\");   //Added by Chang Ching Ler 20191107 | Change color of Cancel button\n\n        //Added by Cooper 20180717 - Patient (ACCESS CONTROL)\n        if($('#patDetModalLabel').text() != \"Add New Patient\"){\n            SetEditBioContactPermission();\n        }\n\n        //LoadPatientGroupDetail();\n\n        if(document.getElementById(\"tabBiodata\") != null) {\n            if (document.getElementById(\"tabBiodata\").getAttribute(\"style\").indexOf(\"pointer-events:\") == -1){    //Edited by Veronica 20211228 - Auto focus when granted edit access right\n                $('#txtPatientPName').focus();\n            }\n        }\n        $(\"#txtPatientDOB\").inputmask(\"date\", { \"clearIncomplete\": true });\n\n        var today = new Date();\n        var dd = today.getDate();\n        var mm = today.getMonth() + 1; //January is 0!\n\n        var yyyy = today.getFullYear();\n        if (dd < 10) {\n            dd = '0' + dd;\n        }\n        if (mm < 10) {\n            mm = '0' + mm;\n        }\n        var today = dd + '/' + mm + '/' + yyyy;\n\n        var txtPatientDOB = $('#txtPatientDOB').val();\n        if (today == txtPatientDOB) {\n            $('#txtPatientDOB').val('');\n        }\n        $(\"#txtPatAge\").val($(\"#hfpatAge\").val());      //Added by Jason 20211102 - set patient age\n\n        getPatientDefaultDetail(\"D\");\n\n        \n        //$(\"#txtAllergyOtherOnsetDate\").datepicker({ dateFormat: 'dd/mm/yy' });\n        //$(\"#txtAllergyOtherOnsetDate\").inputmask(\"date\", { \"clearIncomplete\": true });\n\n        \n        if ($(\"#txtPatientNo\").val() == \"NEW\") {\n            $('#txtPatientNRIC').prop(\"readonly\", \"\");\n            $(\"#txtPatientNRIC\").css('background-color', '#FFFFE1');\n            $('#btnEditPatNRIC').css(\"pointer-events\", \"none\");\n            checkNRIC(); //Added by Koh Chin Choong 20191210\n        }\n        else {\n            $(\"#btnDM\").css(\"display\", \"none\");\n            $(\"#btnDF\").css(\"display\", \"none\");\n            $(\"#txtPatientNo\").css(\"width\", \"150px\");\n            $(\"#txtPatientNo\").css(\"border-radius\", \"7px\");\n            $('#txtPatientNRIC').prop(\"readonly\", \"readonly\");\n            $(\"#txtPatientNRIC\").css('background-color', 'lightgrey');\n        }\n        if($('#txtPatientCompCode').val()!=\"\"){\n            $(\"#showCompanyInfo\").prop('checked',true).change();\n        }\n        else{\n            $(\"#showCompanyInfo\").prop('checked',false).change();\n        }\n\n        function GetTodayDate() {\n            var date = new Date();\n            return Prezero(date.getDate()) + '/' + Prezero(date.getMonth() + 1) + '/' + date.getFullYear()\n        }\n        function Prezero(raw) {\n            if (raw.toString().length == 1) {\n                return \"0\" + raw;\n            }\n            return raw;\n        }\n\n        $('#imgPatientPhoto').css({'width' : '165px' , 'height' : '145px'});\n\n        //added by Hao Wen 20211215 | If not new patient, save old data to check is there any update during exit\n        if ($('#txtPatientNo').val() != \"\") {\n            oldDataBiodata = JSON.stringify($('#CreateEditPatientForm').serializeArray());\n        }\n        //end added by Hao Wen 20211215\n\n        var MedGrp = \"SSOC\";\n        if (MedGrp == \"SMSC\" || MedGrp == \"DEMOSP\" || MedGrp == \"SPTEST1\" || MedGrp == \"SPTESTUI\" || MedGrp == \"SPTESTUI\" || MedGrp == \"TSPPAYDG\" || MedGrp == \"TSPPAY\" || MedGrp == \"SPNEWUI\") {\n            $('#btnVIPlink').css('display', '');\n        }\n        $('#txtPatientNation2 option[value=\"SINGAPORE PR\"]').hide();\n        $('#txtPatientNation2 option[value=\"SINGAPORE PR\"]').prop(\"disabled\", \"disabled\");\n        $('#txtPatientNation2 option[value=\"SINGAPORE CITIZEN\"]').hide();\n        $('#txtPatientNation2 option[value=\"SINGAPORE CITIZEN\"]').prop(\"disabled\", \"disabled\");\n\n        var urlLocation = jQuery(location).attr('href');\n\n        if (urlLocation.indexOf(\"PatientVisit\") < 0) {\n            $(\"#txtPatientNation\").css(\"margin-right\",\"11px\");\n        }\n        //Added by JiunWei 20230317 - Function to check is EHA check memberID function enabled.\n        if ($(\"#txtPatientNo\").val() != \"NEW\") {\n            if (\"True\" == \"True\" && \"N\" == \"Y\") {\n                if (\"N\" == \"Y\") {\n                    $(\"#btnMemberCheck\").hide();\n                    $(\"#lblMemberID\").show();\n                    $(\"#lblMemberID\").html(\"APP Member ID: \" + \"\");\n                    $(\"#btnMemberIDReset\").show();\n                }\n                else {\n                    $(\"#btnMemberCheck\").show();\n                    $(\"#lblMemberID\").hide();\n                    $(\"#btnMemberIDReset\").hide();\n                }\n            }\n            else {\n                $(\"#btnMemberCheck\").hide();\n                $(\"#lblMemberID\").hide();\n                $(\"#btnMemberIDReset\").hide();\n            }\n\n            //if (\"@SiteSession.GetSession(SESSION_NAME.EHAAPI_MemberCheckEnabled)\" == \"Y\") {\n            //   if (\"@ViewData(\"IsEHAMember\")\" != \"Y\")\n            //$('#btnVIPlink').hide();\n            //}\n        }\n        //else {\n        //    $('#btnVIPlink').hide();\n        //}\n         if ('False' == 'True') {\n            $(\"#divCityState\").css('display','flex');\n            $(\"#txtPatientState\").css(\"background\",\"#FFFFE1\");\n            //$(\"#txtPatientPostal\").css(\"background\",\"#FFFFE1\");\n            $(\"#txtPatientCity\").css(\"background\",\"#FFFFE1\");\n            $(\"#txtPatientStreet\").css(\"background\",\"#FFFFFE1\");\n            $(\"#txtPatientHP\").css(\"background\",\"#FFFFFE1\");\n        }\n        $(\"#divNotifications\").sortable({\n            items: \".sortable-item\",\n            cursor: \"move\",\n            axis: \"x\",\n            update: highlightPreferred\n        });\n        $(\"#divNotifications\").disableSelection();\n        highlightPreferred();\n    });\n    function highlightPreferred() {\n        $('.sortable-item').removeClass('preferred-notif');\n        $('.sortable-item').addClass('non-preferred-notif');\n\n        $('.sortable-item:first').removeClass('non-preferred-notif');\n        $('.sortable-item:first').addClass('preferred-notif');\n    }\n    //Added by zhaoying 20190226 | ID type = Pink IC; NRIC= valid pink IC, then auto default Nationaility = Singapore Citizen\n    $('#txtPatientIDTypeCode').on('change', function () {\n        autoDefaultNationality();\n    });\n\n    function autoDefaultNationality() {\n        $('#txtPatientNation option[value=\"SINGAPORE PR\"]').show();\n        $('#txtPatientNation option[value=\"SINGAPORE PR\"]').prop(\"disabled\", \"\");\n        $('#txtPatientNation option[value=\"SINGAPORE CITIZEN\"]').prop(\"disabled\", \"\");\n        $('#txtPatientNation option[value=\"SINGAPORE CITIZEN\"]').show();\n        //if($(\"#txtPatientIDTypeCode option:selected\").val() == 'P'){\n            var data = { IDTypeCode: $(\"#txtPatientIDTypeCode option:selected\").val(), NRIC: $('#txtPatientNRIC').val()};\n            var encoded = JSON.stringify(data);\n\n            if ($(\"#txtPatientIDTypeCode option:selected\").val() == 'B'){\n                $(\"#txtPatientNation\").css(\"width\", \"50%\");\n                $(\"#txtPatientNation2\").prop(\"disabled\", false);\n                $('#Nation2Part').show();\n            }else{\n                $(\"#txtPatientNation\").css(\"width\", \"100%\");\n                $(\"#txtPatientNation2\").prop(\"disabled\", true);\n                $('#Nation2Part').hide();\n            }\n            if($(\"#txtPatientIDTypeCode option:selected\").val() == 'P')\n            {\n                $('#txtPatientNation option[value=\"SINGAPORE CITIZEN\"]').prop(\"selected\", true);\n                $(\"#txtPatientNation\").prop(\"readonly\", true).css(\"background\", \"lightgrey\").css(\"pointer-events\", \"none\");\n            }\n            else if ($(\"#txtPatientIDTypeCode option:selected\").val() == 'B') {\n                $('#txtPatientNation option[value=\"SINGAPORE PR\"]').prop(\"selected\", true);\n                $(\"#txtPatientNation\").prop(\"readonly\", true).css(\"background\", \"lightgrey\").css(\"pointer-events\", \"none\");\n            }\n            else if ($(\"#txtPatientIDTypeCode option:selected\").val() == 'F') {\n                $('#txtPatientNation option[value=\"\"]').prop(\"selected\", true);\n                $(\"#txtPatientNation\").prop(\"readonly\", false).css(\"background\", \"#FFFFE1\").css(\"pointer-events\", \"auto\");\n\n                $('#txtPatientNation option[value=\"SINGAPORE PR\"]').hide();\n                $('#txtPatientNation option[value=\"SINGAPORE CITIZEN\"]').hide();\n                $('#txtPatientNation option[value=\"SINGAPORE PR\"]').prop(\"disabled\", \"disabled\");\n                $('#txtPatientNation option[value=\"SINGAPORE CITIZEN\"]').prop(\"disabled\", \"disabled\");\n\n            }\n            else if ($(\"#txtPatientIDTypeCode option:selected\").val() == 'M') {\n                $('#txtPatientNation option[value=\"MALAYSIAN\"]').prop(\"selected\", true);\n                $(\"#txtPatientNation\").prop(\"readonly\", true).css(\"background\", \"lightgrey\").css(\"pointer-events\", \"none\");\n\n            }\n            else if($(\"#txtPatientIDTypeCode option:selected\").val() == 'PP' || $(\"#txtPatientIDTypeCode option:selected\").val() == 'L' || $(\"#txtPatientIDTypeCode option:selected\").val() == 'X'\n                || $(\"#txtPatientIDTypeCode option:selected\").val() == 'C'){ //Added by Ray 20230215 -- take out Singapore PR/CITIZEN except id type = 'Pink' and 'Blue'\n                $('#txtPatientNation option[value=\"\"]').prop(\"selected\", true);\n                $(\"#txtPatientNation\").prop(\"readonly\", false).css(\"background\", \"#FFFFE1\").css(\"pointer-events\", \"auto\");\n\n                $('#txtPatientNation option[value=\"SINGAPORE PR\"]').hide();\n                $('#txtPatientNation option[value=\"SINGAPORE CITIZEN\"]').hide();\n                $('#txtPatientNation option[value=\"SINGAPORE PR\"]').prop(\"disabled\", \"disabled\");\n                $('#txtPatientNation option[value=\"SINGAPORE CITIZEN\"]').prop(\"disabled\", \"disabled\");\n            }\n            else {\n                $('#txtPatientNation option[value=\"\"]').prop(\"selected\", true);\n                $(\"#txtPatientNation\").prop(\"readonly\", false).css(\"background\", \"#FFFFE1\").css(\"pointer-events\", \"auto\");\n            }\n        //Ended by Ray\n\n            $(\"#txtPatientNation\").trigger(\"change\");\n        //    $.ajax({\n        //        cache: false,\n        //        type: \"POST\",\n        //        url: \"/Patient/checkValidIDTypeJson\",\n        //        data: encoded,\n        //        contentType: \"application/json; charset=utf-8\",\n        //        dataType: \"json\",\n        //        success: function (response) {\n        //            console.log(response);\n        //            if (response.success) {\n        //                if (response.data == true){\n        //                    $('#txtPatientNation option[value=\"SINGAPORE CITIZEN\"]').prop(\"selected\",true);\n        //                }\n        //            }\n        //        }\n        //    });\n        //}\n    }\n    $('#txtPatientNation').on('change', function () {\n        //$(\"#txtPatientCountry\").css(\"background\", \"\");      //Commented by Cheng Yu 20230306 - no need to make country mandatory | Added by Jason 20230224 - default country is not mandatory\n\n        if($(\"#txtPatientNation option:selected\").val() == 'SINGAPORE CITIZEN' || $(\"#txtPatientNation option:selected\").val() == 'SINGAPORE PR' || $(\"#txtPatientNation option:selected\").val() == 'MALAYSIAN')\n        {\n            if($(\"#txtPatientNation option:selected\").val() == 'SINGAPORE CITIZEN')\n            {\n                if ($(\"#txtPatientIDTypeCode option:selected\").val() != 'BC') {     //Edited by Jason 20240627 - allow choose singapore citizen when birth cert\n                    $('#txtPatientIDTypeCode option[value=\"P\"]').prop(\"selected\", true);\n                    $(\"#txtPatientNation\").prop(\"readonly\", true).css(\"background\", \"lightgrey\").css(\"pointer-events\", \"none\");\n                }\n            }\n            else if($(\"#txtPatientNation option:selected\").val() == 'SINGAPORE PR')\n            {\n                if ($(\"#txtPatientIDTypeCode option:selected\").val() != 'BC') {     //Edited by Jason 20240627 - allow choose singapore PR when birth cert\n                    $('#txtPatientIDTypeCode option[value=\"B\"]').prop(\"selected\", true);\n                    $(\"#txtPatientNation\").prop(\"readonly\", true).css(\"background\", \"lightgrey\").css(\"pointer-events\", \"none\");\n                    //$(\"#txtPatientCountry\").css(\"background\", \"#FFFFE1\");       //Commented by Cheng Yu 20230306 - no need to make country mandatory | Added by Jason 20230224 - if Nationality is Singapore PR, country is mandatory\n                }\n            }\n            //Added by Cheng Yu 20230306 - Show nation2 if idtype is blue ic\n            if ($(\"#txtPatientIDTypeCode option:selected\").val() == 'B'){\n                $(\"#txtPatientNation\").css(\"width\", \"50%\");\n                $(\"#txtPatientNation2\").prop(\"disabled\", false);\n                $('#Nation2Part').show();\n            }else{\n                $(\"#txtPatientNation\").css(\"width\", \"100%\");\n                $(\"#txtPatientNation2\").prop(\"disabled\", true);\n                $('#Nation2Part').hide();\n            }\n            //Added by Cheng Yu 20230306\n\n            //else if($(\"#txtPatientNation option:selected\").val() == 'MALAYSIAN')\n            //{\n            //    $('#txtPatientIDTypeCode option[value=\"M\"]').prop(\"selected\", true);\n            //    $(\"#txtPatientNation\").prop(\"readonly\", true).css(\"background\", \"lightgrey\").css(\"pointer-events\", \"none\");\n            //}\n        }\n    });\n    //Added by zhaoying 20180409 | remove modal after hidden\n    $(document).on('click', '#btnPatientClose', function () {\n        $(this).closest(\".modal\").modal('hide');\n        $(this).closest(\".modal\").remove();\n    });\n\n    $(document).keypress(function (event) {\n        var keycode = (event.keyCode ? event.keyCode : event.which);\n\n        if (keycode == 27) {\n            var urlLocation = jQuery(location).attr('href');\n            //Modified by zhaoying 20180117\n            if (urlLocation.indexOf(\"QueueLog\") >= 0) {\n                if ($('#setupCompanyModal').is(':hidden') && $('#setupRefSourceModal').is(':hidden') &&\n                $('#setupAgentModal').is(':hidden') && $('#searchAddressModal').is(':hidden') &&\n                $('#setupPatientGrpModal').is(':hidden') && $('#patientMediPayerModal').is(':hidden') &&\n                    $('#SetupIllnessModal').is(':hidden')) {\n                    $(\"#createPatientFrmQueModal\").modal('hide');\n                }\n            }\n        }\n    });\n\n    function addPatientFrmQueClose() {\n        $(\"#txtQueuePName\").val('');\n        $(\"#VisitType\").focus();\n    }\n\n    $(\"#btnNIL\").click(function () {\n        $(\"#txtPatientAllergy\").val(\"NIL\");\n    });\n\n    $(\"#btnDM\").click(function () {\n        getPatientDefaultDetail(\"DM\");\n    });\n\n    $(\"#btnDF\").click(function () {\n        getPatientDefaultDetail(\"DF\");\n    });\n\n    function GetcopaymentSelectedItem() {\n        var rbcopayment = $('input[name=patientcopayment]:checked').val();\n        if (rbcopayment == \"Amount\") {\n            $(\"#txtPatientCopayPercent\").val(\"0.00\");\n            $(\"#txtPatientCopayCap\").val(\"0.00\");\n\n            $(\"#txtPatientCopayAmt\").prop(\"disabled\", false);\n\n            $(\"#txtPatientCopayPercent\").prop(\"disabled\", true);\n            $(\"#txtPatientCopayCap\").prop(\"disabled\", true);\n        } else {\n            $(\"#txtPatientCopayAmt\").val(\"0.00\");\n\n            $(\"#txtPatientCopayAmt\").prop(\"disabled\", true);\n\n            $(\"#txtPatientCopayPercent\").prop(\"disabled\", false);\n            $(\"#txtPatientCopayCap\").prop(\"disabled\", false);\n        }\n    }\n\n    $(document).ready(function () {\n        var copayAmt = $('#txtPatientCopayAmt').val();\n        var copayPercent = $('#txtPatientCopayPercent').val();\n        var copayCap = $('#txtPatientCopayCap').val();\n\n        if (copayAmt > 0) {\n            $(\"#txtPatientCopayAmt\").prop(\"disabled\", false);\n            $(\"#txtPatientCopayPercent\").prop(\"disabled\", true);\n            $(\"#txtPatientCopayCap\").prop(\"disabled\", true);\n        }\n        else {\n            $('input[name=patientcopayment][value=Percent]').attr('checked', 'checked');\n\n            $(\"#txtPatientCopayAmt\").attr(\"disabled\", \"disabled\");\n            $(\"#txtPatientCopayPercent\").prop(\"disabled\", false);\n            $(\"#txtPatientCopayCap\").prop(\"disabled\", false);\n        }\n\n        var urlLocation = jQuery(location).attr('href');\n\n        if (urlLocation.indexOf(\"Reception\") >= 0) {\n            //$(\"#CreateEditPatientForm :input\").attr(\"disabled\", true);\n\n            //$(\"#CreateEditPatientForm input[type=button]\").attr(\"disabled\", \"disabled\");\n            //$(\"#CreateEditPatientForm span\").unbind('click');\n            //$(\"#btnStreet\").attr(\"disabled\", \"disabled\");\n            //$(\"#btnCompCode\").attr(\"disabled\", \"disabled\");\n            //$(\"#btnRefCode\").attr(\"disabled\", \"disabled\");\n            //$(\"#btnAgentCode\").attr(\"disabled\", \"disabled\");\n            //$(\"#btnPatientClose\").attr(\"disabled\", false);\n            //$(\"#btnEditPatNRIC\").attr(\"disabled\", \"disabled\");\n        }\n\n        $(\"#chkPatientAllergy\").next().val($(\"#chkPatientAllergy\").prop('checked'));\n\n        //Added by Lim Han Yong 20240201 - change background color based on mandatory\n        if ('false' == \"true\"){\n            $(\"#txtPatientLanguageSP\").css(\"background\", \"#FFFFE1\");\n        }\n\n        if ('false' == \"true\"){\n            $(\"#txtPatientMarital\").css(\"background\", \"#FFFFE1\");\n        }\n\n        if ('false' == \"true\"){\n            $(\"#txtPatientNation\").css(\"background\", \"#FFFFE1\");\n        }\n\n        if ('false' == \"true\"){\n            $(\"#txtPatientOccupation\").css(\"background\", \"#FFFFE1\");\n        }\n\n        if ('false' == \"true\"){\n            $(\"#txtPatientRace\").css(\"background\", \"#FFFFE1\");\n        }\n\n        if ('false' == \"true\"){\n            $(\"#txtPatientRefCode\").css(\"background\", \"#FFFFE1\");\n        }\n\n        if ('false' == \"true\"){\n            $(\"#txtPatientAgentCode\").css(\"background\", \"#FFFFE1\");\n        }\n        //End Added by Lim Han Yong 20240201\n\n        //Added by Kenneth 2025-09-18 - Check mandatory HP and address\n        if ('false' == \"true\"){\n            $(\"#txtPatientStreet\").css(\"background\", \"#FFFFE1\");\n            $(\"#txtPatientPostal\").css(\"background\", \"#FFFFE1\");\n        }\n\n        if ('false' == \"true\"){\n            $(\"#txtPatientHP\").css(\"background\", \"#FFFFE1\");\n        }\n        //End Added by Kenneth 2025-09-18 - Check mandatory HP and address\n    });\n\n    $(\"#btnPostal\").click(function () {\n        var myData = { postalCode: $('#txtPatientPostal').val() };\n        var encoded = JSON.stringify(myData);\n\n        $.ajax({\n            cache: false,\n            type: \"POST\",\n            url: \"/Patient/GetPostal\",\n            data: encoded,\n            contentType: \"application/json; charset=utf-8\",\n            dataType: \"json\",\n            success: function (response) {\n                if (response != \"\") {\n                    $(\"#txtPatientBlkHseNo\").val(response.blk);\n                    $(\"#txtPatientStreet\").val(response.street);\n                    $(\"#txtPatientBuildingName\").val(response.building);\n                    $(\"#txtPatientUnitNo\").focusTextToEnd(); //Uncomment back, need to make sure PatientDefaultTable got set the prefix unit.\n                    //$(\"#txtPatientUnitNo\").val(\"#\"); //Added by Jason Khor 20191002 //Comment by Koh Chin Choong 20200103 - Prefix get from PatientDefaultDetail table\n                }\n                else {\n                    $(\"#txtPatientBlkHseNo\").val(\"\");\n                    $(\"#txtPatientStreet\").val(\"\");\n                    $(\"#txtPatientBuildingName\").val(\"\");\n                }\n            },\n            error: function (response) {\n                $(\"#txtPatientBlkHseNo\").focus();\n                swal(\"\", 'Cannot find address.');\n            }\n        });\n    })\n\n    function ValidateNumber(e) {\n        var evt = (e) ? e : window.event;\n        var key = (evt.keyCode) ? evt.keyCode : evt.which;\n        if (key != null) {\n            key = parseInt(key, 10);\n            if ((key < 48 || key > 57) && (key < 96 || key > 105)) {\n                if (!jsIsUserFriendlyChar(key, \"Decimals\")) {\n                    return false;\n                }\n            }\n            else {\n                if (evt.shiftKey) {\n                    return false;\n                }\n            }\n        }\n        return true;\n    }\n\n    function jsIsUserFriendlyChar(val, step) {\n        // Backspace, Tab, Enter, Insert, and Delete\n        if (val == 8 || val == 9 || val == 13 || val == 45 || val == 46) {\n            return true;\n        }\n        // Ctrl, Alt, CapsLock, Home, End, and Arrows\n        if ((val > 16 && val < 21) || (val > 34 && val < 41)) {\n            return true;\n        }\n        if (step == \"Decimals\") {\n            if (val == 190 || val == 110) {\n                return true;\n            }\n        }\n        // The rest\n        return false;\n    }\n\n    $(document).ready(function () {\n        checkFilterQAccess();\n\n        $('#txtPatientUnitNo').on('focus', function () {\n            var txtUnit = document.getElementById('txtPatientUnitNo');\n            if (txtUnit.value == \"\") {\n                txtUnit.value = Prefix_Unit;\n                var length = txtUnit.value.length;\n                txtUnit.setSelectionRange(length, length);\n            }\n        });\n\n\n        if ($('#hfMIMS').val() == 'True') {\n            $('#tab-li-Allergy').show();\n            $('#txtPatientAllergy').prop('disabled', true);\n\n            if ($('#hfshowNILBtn').val() == 'True') {\n                $('#btnNIL').show();\n                $('#btnNIL').css('pointer-events', 'auto');\n            }\n            else{\n                $('#btnNIL').hide();\n                $('#btnNIL').css('pointer-events', 'none');\n            }\n        }\n        else {\n            $('#tab-li-Allergy').hide();\n            $('#txtPatientAllergy').prop('disabled', false);\n            $('#btnNIL').show();\n            $('#btnNIL').css('pointer-events', 'auto');\n        }\n\n        if ($(\"#hfAllergyGotRecord\").val() == \"Y\") {\n            //$(\"#tab-li-Allergy\").css(\"background-color\", \"#ff6666 !important\");\n            $('#tab-li-Allergy').attr('style', 'background-color: #ff6666 !important');\n            $(\"#tabAllergyCaseNoteID\").css(\"color\", \"#ffffff\");\n            $(\"#tabAllergyCaseNoteID\").css(\"background-color\", \"#ff6666\"); \n            $(\"#tab-li-Allergy\").addClass(\"tab-allergy-yes\");\n        }\n        else{\n            //$('#tab-li-Allergy').attr('style', 'background-color: transparent');\n            //$(\"#tabAllergyCaseNoteID\").css(\"color\", \"black\");\n            //$(\"#tabAllergyCaseNoteID\").css(\"background-color\", \"#ffffff\");\n            $(\"#tab-li-Allergy\").addClass(\"tab-allergy-no\");\n        }\n        //  GetCompanybyCode();\n\n        //Added by Jason 20211022 - detect patient info change (BioData)\n        if ($('#txtPatientNo').val() != \"\") {\n            oldDataBiodata = JSON.stringify($('#CreateEditPatientForm').serializeArray());\n        }\n        //End added by Jason 20211022\n    });\n\n    //Start: Uncommented and add checking for Birthday MonthDiff in between 0 to 3 checking - Jack 21082018\n    $('#txtPatientDOB').focusout(function () {\n        if(this.value ==\"\")\n        {\n            return;\n        }\n        var selIDType = $(\"#txtPatientIDTypeCode option:selected\").val();\n\n        var todaysDate = String(moment().format(\"DD MMM YYYY\"));\n        var dateString = $(\"#txtPatientDOB\").val().substring(0, 2) + \" \" + getMonthName(parseInt($(\"#txtPatientDOB\").val().substring(3, 5))) + \" \" + $(\"#txtPatientDOB\").val().substring(6, 10);\n        var patientDOBValue = moment(dateString);\n        var monthDiff = moment(todaysDate).diff(patientDOBValue, 'months', true);\n\n        if ($(\"#txtPatientDOB\").val() != \"\" || $(\"#txtPatientDOB\").val() != null)\n        {\n            patientDOB = $(\"#txtPatientDOB\").val();\n        }\n\n        if (selIDType.toLowerCase()==\"x\" && $(\"#hdVersion\").val()==\"SG\" && ($(\"#txtPatientNRIC\").val() == null || $(\"#txtPatientNRIC\").val() == \"\") && (monthDiff >= 0 && monthDiff <= 3)) //Add MonthDiff in between 0 to 3 checking - Jack 21082018\n        {\n            $(\"#txtPatientNRIC\").val(\"NA\");\n        }\n\n        ageCalculator();        //Added by Jason 20211102 - calculate age\n    });\n    //End: Uncommented and add checking for Birthday MonthDiff in between 0 to 3 checking - Jack 21082018\n\n    $('#txtPatientNRIC').keypress(function (event) {\n        if (event.keyCode == 45 || event.keyCode == 47) {\n            event.preventDefault();\n        }\n    });\n\n    $('#txtPatientNRIC').focusout(function () {\n        checkNRIC();\n    });\n\n    function checkNRIC() {\n        var selectedIDTypeCode = $(\"select[name='IDTypeCode'] option:selected\").val();\n\n        var data = {\n            nric: $('#txtPatientNRIC').val(),\n            //idtypecode: $(\"select[name='IDTypeCode'] option:selected\").val(),     //Comment by Chang Ching Ler 20191108\n            idtypecode: selectedIDTypeCode,\n            pcno: $('#txtPatientNo').val(),\n        };\n\n        var encoded = JSON.stringify(data);\n\n        $.ajax({\n            cache: false,\n            type: \"POST\",\n            url: \"/Patient/CheckNRIC\",\n            data: encoded,\n            contentType: \"application/json; charset=utf-8\",\n            dataType: \"json\",\n            success: function (data) {\n                if (data.success) {\n                    $(\"#txtPatientNRIC\").val(data.message);\n\n                    if (data.data == true){ //Added by zhaoying 20190226 | ID type = Pink IC; NRIC= valid pink IC, then auto default Nationaility = Singapore Citizen\n                        $('#txtPatientNation option[value=\"SINGAPORE CITIZEN\"]').prop(\"selected\",true);\n                    }\n\n                    //Comment by Chang Ching Ler 20191125 | Temporary comment\n                    //if($('#txtPatientNo').val() == \"NEW\") {\n                    //    if(selectedIDTypeCode == 'B' || selectedIDTypeCode == 'P'){ //Added by Chang Ching Ler 20191108 | Check CHAS if the IC is Pink IC or Blue IC\n                    //        CheckCHAS(\"Add\");\n                    //    }\n                    //}\n                    //End Comment by Chang Ching Ler 20191125\n                }\n                else {\n\n                    //swal(\"\", data.message + \"\\nPlease re-enter.\"); //Commented by Cheng Yu 20230301\n                    //Edited by Cheng Yu 20230301 - when click enter nric become empty (Requested by Peter)\n                    swal({title:\"\",text: data.message + \"\\nPlease re-enter.\"},\n                        function(isConfirm){\n                            if(isConfirm){\n                                $(\"#txtPatientNRIC\").val(\"\");\n                            }\n                        });\n                    //End edited by Cheng Yu 20230301\n                    $(\"#txtPatientNRIC\").focus();\n                }\n            },\n            error: function (data) {\n\n            }\n        });\n    }\n\n    $(\"#txtPatientRefNo\").on('input', function () {\n        var start = this.selectionStart,\n            end = this.selectionEnd;\n\n        this.value = this.value.toUpperCase();\n        this.setSelectionRange(start, end);\n    });\n\n    $(\"#txtPatientNRIC\").on('input', function () {\n        var start = this.selectionStart,\n            end = this.selectionEnd;\n\n        this.value = this.value.toUpperCase();\n        this.setSelectionRange(start, end);\n    });\n\n    $(\"#txtPatientPName\").on('input', function () {\n        var start = this.selectionStart,\n            end = this.selectionEnd;\n\n        this.value = this.value.toUpperCase();\n        this.setSelectionRange(start, end);\n    });\n\n    $(\"#txtPatientMotherName\").on('input', function () {\n        var start = this.selectionStart,\n            end = this.selectionEnd;\n\n        this.value = this.value.toUpperCase();\n        this.setSelectionRange(start, end);\n    });\n\n    $(\"#txtPatientMotherNRIC\").on('input', function () {\n        var start = this.selectionStart,\n            end = this.selectionEnd;\n\n        this.value = this.value.toUpperCase();\n        this.setSelectionRange(start, end);\n    });\n\n    $(\"#txtPatientFatherName\").on('input', function () {\n        var start = this.selectionStart,\n            end = this.selectionEnd;\n\n        this.value = this.value.toUpperCase();\n        this.setSelectionRange(start, end);\n    });\n\n    $(\"#txtPatientFatherNRIC\").on('input', function () {\n        var start = this.selectionStart,\n            end = this.selectionEnd;\n\n        this.value = this.value.toUpperCase();\n        this.setSelectionRange(start, end);\n    });\n\n    //Modified by zhaoying 20180327 | AppendModal2Body_Load as centralised modal generate function so does not replicate modals in different modules, hence same modal will have same look\n    $('#btnCompCode').click(function () {\n        $(\".fadeMe\").show();\n\n        arrFooterBtnList = [];\n        arrFooterBtnList2 = [];\n        arrFooterBtnList.push('<input type=\"button\" value=\"Confirm\" id=\"btnSetupCompanyConfirm\" class=\"btn btn-sm ok-style\" />');\n\n        var appendDetail = {style:\"max-height:433px;max-width:885px;\", contentType:\"typeSimple\", cancelID:\"btnSetupCompanyCancel\", footerLayout:\"R\"};\n\n        AppendModal2Body_Load(\"setupCompanyModal\", \"Search Company\", \"/SetupCompany/Index\", arrFooterBtnList, arrFooterBtnList2, appendDetail);\n    });\n\n    $(\"#setupCompanyModal\").on('shown.bs.modal', function () {\n        $('#setupCompanyModalBody').find('#SetupCompanySearchKeyword').focus();\n    });\n\n    $('#setupCompanyModal').on('hidden.bs.modal', function () {\n        $('#setupCompanyModalBody').html('');\n    });\n\n    $(\"#setupAgentModal\").on('shown.bs.modal', function () {\n        $('#setupAgentModalBody').find('#SetupAgentSearchKeyword').focus();\n    });\n\n    $('#setupAgentModal').on('hidden.bs.modal', function () {\n        $('#setupAgentModalBody').html('');\n    });\n\n    $('#btnStreet').click(function () {\n        $(\".fadeMe\").show();\n\n        arrFooterBtnList = [];\n        arrFooterBtnList2 = [];\n        arrFooterBtnList.push('<input type=\"button\" value=\"Confirm\" id=\"btnSearchAddressConfirm\" class=\"btn btn-sm ok-style\" />');\n\n        var appendDetail = {style:\"max-height:441px;max-width:770px;\", contentType:\"complex\", cancelID:\"btnSearchAddressCancel\", footerLayout:\"R\"};\n\n        AppendModal2Body_Load(\"searchAddressModal\", \"Search Address\", \"/SearchAddress/Index\", arrFooterBtnList, arrFooterBtnList2, appendDetail);\n\n    });\n\n    $(\"#searchAddressModal\").on('shown.bs.modal', function () {\n        $('#searchAddressModalBody').find('#SearchAddressKeyword').focus();\n    });\n\n    $('#searchAddressModal').on('hidden.bs.modal', function () {\n        $('#searchAddressModalBody').html('');\n    });\n\n    $('#btnPatientGroupAdd').click(function () {\n        $(\".fadeMe\").show();\n\n        arrFooterBtnList = [];\n        arrFooterBtnList2 = [];\n        arrFooterBtnList.push('<input type=\"button\" value=\"Confirm\" id=\"btnSetupPatientGrpConfirm\" class=\"btn btn-sm ok-style\" />');\n\n        var appendDetail = {style:\"max-height:397px;max-width:871px;\", contentType:\"typeSimple\", cancelID:\"btnSetupPatientGrpCancel\", footerLayout:\"R\"};\n\n        AppendModal2Body_Load(\"setupPatientGrpModal\", \"Group\", \"/SetupPatientGrp/Index?pcno=\" + $('#txtPatientNo').val(), arrFooterBtnList, arrFooterBtnList2, appendDetail); //Modified by zhaoying 20180507 | parsed in $('#txtPatientNo').val()\n    });\n\n    function getGroupList(){\n        $('#txtPatientNo').val()\n\n        $.ajax({\n            cache: false,\n            url: \"Patient/GetGroupList\",\n            datatype: 'json',\n            type: 'post',\n            success: function (result) {\n                if (result.success) {\n                    swal.close();\n                    $('#patientGroundGrid').trigger('reloadGrid');\n                }\n                else {\n                    swal(\"\", result.message, \"error\");\n                }\n            },\n            error: function (xhr, status) {\n            }\n        });\n    }\n\n    function LoadPatientGroupDetail() {\n\n        var pcno = $('#txtPatientNo').val();\n        var urlPatientGrp = 'https://clinicassist.sg:1080/en/Patient/GetPatientGroupListsButton?pcno=' + pcno;\n\n        $.ajax({\n            cache: false,\n            url: urlPatientGrp,\n            datatype: 'json',\n            type: 'post',\n            success: function (result) {\n                if (result.success) {\n                    if(result.message != \"Empty\"){\n                        $.each(result.list, function (i, sp) {\n                            $(\"#divPatientGroupDetail\").append('<a class=\"btn btn-sm btn-info\" title=\"'+ sp.Description +'\" onclick=\"btnPatientGroupDelete(\\''+ sp.PatGrpCode +'\\')\" style=\"cursor:pointer;padding: 4px 15px 3px 5px;border-radius:50px!important;height:30px;background-color: white !important;border: 1px solid black !important; margin: auto 0; color: black !important;\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 512 512\" style=\"height: 16px;margin-bottom: -3px;transform: rotate(45deg);\"><path fill=\"red\" d=\"M256 8C119 8 8 119 8 256s111 248 248 248 248-111 248-248S393 8 256 8zm144 276c0 6.6-5.4 12-12 12h-92v92c0 6.6-5.4 12-12 12h-56c-6.6 0-12-5.4-12-12v-92h-92c-6.6 0-12-5.4-12-12v-56c0-6.6 5.4-12 12-12h92v-92c0-6.6 5.4-12 12-12h56c6.6 0 12 5.4 12 12v92h92c6.6 0 12 5.4 12 12v56z\" /></svg> '+ sp.Description +'</a>&nbsp;');\n                        });\n\n                        $(\"#divPatientGroupDetail\").parent().height($(\"#divPatientGroupDetail\").height() + 5);\n                    }\n                }\n                else {\n                    swal(\"\", result.message, \"error\");\n                }\n            },\n            error: function (xhr, status) {\n            }\n        });\n    };\n\n    function btnPatientGroupDelete(code) {\n\n        swal({ title: \"\", text: \"Are you sure you want to delete this record?\", type: \"warning\", showCancelButton: true, confirmButtonColor: \"#DD6B55\", cancelButtonText: \"No\", confirmButtonText: \"Yes\", closeOnConfirm: false },\n                function () {\n                    swal.close();\n                    var pcno = $('#txtPatientNo').val();\n                    var urlPatientGrp = 'https://clinicassist.sg:1080/en/Patient/DeletePatientGroup?pcno=' + pcno + '&patgrpcode=' + code;\n\n                    $.ajax({\n                        cache: false,\n                        url: urlPatientGrp,\n                        datatype: 'json',\n                        type: 'post',\n                        success: function (result) {\n                            if (result.success) {\n                                swal.close();\n                                $('#divPatientGroupDetail').html('');\n                                LoadPatientGroupDetail()\n                            }\n                            else {\n                                swal(\"\", result.message, \"error\");\n                            }\n                        },\n                        error: function (xhr, status) {\n                        }\n                    });\n                })\n    };\n\n    function addAllNotifications() {\n        $(\"#aNotificationSMS\").show();\n        $(\"#aNotificationEmail\").show();\n        $(\"#aNotificationWhatsApp\").show();\n        highlightPreferred();\n        showNotificationInfo();\n    }\n\n    $(\"#setupPatientGrpModal\").on('shown.bs.modal', function () {\n        $('#setupPatientGrpModalBody').find('#SetupPatientGrpSearchKeyword').focus();\n    });\n\n    $('#setupPatientGrpModal').on('hidden.bs.modal', function () {\n        $('#setupPatientGrpModalBody').html('');\n    });\n\n    //Added by Jin Long 20240201\n    function ResetCompanyInfo(){\n        $('#txtPatientCompCode').val('');\n        $('#txtPatientCompanyDescription').val('');\n        $('#txtPatientEmpNo').val('');\n        $('#txtPatientDepartment').val('');\n        $('#txtPatientCopayAmt').val(0.00);\n        $('#txtPatientCopayPercent').val(0.00);\n        $('#txtPatientCopayCap').val(0.00);\n\n    }\n\n    $(\"#patientMediPayerModal\").on('shown.bs.modal', function () {\n        $('#patientMediPayerModalBody').find('#txtPNameMediPayer').focus();\n    });\n\n    $('#patientMediPayerModal').on('hidden.bs.modal', function () {\n        $('#patientMediPayerModalBody').html('');\n    });\n\n    $(\"#chkVIP\").on(\"click\", function () {\n        if ($(this).prop('checked')) {\n            $('#txtIsVIP').val('true');\n        } else {\n            $('#txtIsVIP').val('false');\n        }\n    });\n\n    $(\"#chkPatientAllergy\").on(\"click\", function () {\n        if ($(this).prop('checked')) {\n            var PatientAllergyID = $(\"#patientAllergyGrid\").jqGrid('getDataIDs');\n            var PatientAllergyOtherID = $(\"#patientAllergyOtherGrid\").jqGrid('getDataIDs');\n\n            if (PatientAllergyID.length > 0 || PatientAllergyOtherID.length > 0) {\n                $('#CreateEditPatientForm').find('[name=\"chkAllergy\"]').val('false');\n                $(\"#chkPatientAllergy\").prop('checked', false);\n                swal(\"\", \"Patient have Allergy!\", \"warning\");\n            }\n\n            $('#CreateEditPatientForm').find('[name=\"chkAllergy\"]').val('true');\n        } else {\n            $('#CreateEditPatientForm').find('[name=\"chkAllergy\"]').val('false');\n        }\n    });\n\n    //Edited by Jason 20210129 - prompt auto populate CHAS before Save Patient and revamp save patient function\n    $(\"#btnPatientOk\").on(\"click\", function (e) {\n        //RemoveEditBioContactDisabled();\n        e.stopImmediatePropagation();\n        OKbtn = $(this);\n        var txtIsVIP = $('#txtIsVIP').val();\n\n        if (txtIsVIP.length == 0) {\n            $('#txtIsVIP').val('false');\n        }\n\n        var href = jQuery(location).attr('href');\n\n        var PatientAllergyID = $(\"#patientAllergyGrid\").jqGrid('getDataIDs');\n        var PatientAllergyOtherID = $(\"#patientAllergyOtherGrid\").jqGrid('getDataIDs');\n\n        if (!($(\"#chkPatientAllergy\").is(\":checked\"))) {\n            if (PatientAllergyID.length <= 0 && PatientAllergyOtherID.length <= 0) {\n                swal(\"\", \"Patient has allergy? If no please tick No Allergy box\", \"warning\");\n                return;\n            }\n        }\n\n        if (PatientAllergyID.length > 0 || PatientAllergyOtherID.length > 0) {\n            $(\"#chkPatientAllergy\").prop('checked', false);\n        }\n\n        $('#txtPatientAllergy').prop('disabled', false);\n        if ($(\"#txtPatientNRIC\").val() == \"\") {\n            swal(\"\", \"Please input patient's NRIC.\", \"warning\");\n            return;\n        }\n\n        if($(\"#txtPatientDOB\").val() == \"\") {\n            swal(\"\", \"Please input patient's date of birth.\", \"warning\");\n            return;\n        }\n\n        savePatient();\n    });\n\n    //Added by zhaoying 20190415 | patientDetUpdatePayType\n    function patientDetUpdatePayType(d, editQueueData){\n        var urlLocation = jQuery(location).attr('href');\n        //Added by Nway 20190806, to add validation whether current selected record have a package data in MHC_Sys before check PayType\n        var visitNo = $('#selectedQPatVisitNo').val();\n        var data = {visitNo : visitNo}\n\n        $.ajax({\n            cache: false,\n            url: \"/QueueLog/CheckExistDispensePackage\",\n            data: JSON.stringify(data),\n            type: 'post',\n            contentType: \"application/json; charset=utf-8\",\n            dataType: \"json\",\n            success: function (result) {\n                if (result.havePackage) {\n                    $(\"#queueLogModal\").modal('hide');\n                    swal(\"\", \"Please remove the package before change Pay Type\", \"warning\");\n                    return false;\n                }\n                else {\n                    $.ajax({\n                        cache: false,\n                        url: \"/QueueLog/chkIsCompany\",\n                        data: JSON.stringify(d),\n                        type: 'post',\n                        contentType: \"application/json; charset=utf-8\",\n                        dataType: \"json\",\n                        success: function (result) {\n                            if (result.success && result.isCompOldPayType==true) { //isCompOldPayType check paytype is already company before can change to another paytype\n                                if(urlLocation.indexOf(\"QueuePayment\") >= 0){\n                                    $('#selectedQPatSlot').val('1');\n                                }\n\n                                if ($('#selectedQPatSlot').val()!=\"0\")\n                                {\n                                    $.ajax({\n                                        cache: false,\n                                        url: \"/QueueLog/UpdatePayType?PreviousPayType=\" + d.oldPayType,\n                                        data: editQueueData,\n                                        type: 'post',\n                                        success: function (result) {\n                                            if (result.success) {\n                                                return true;\n                                            }\n                                            else {\n                                                var queueError = stringToUnOrderlist(result.message);\n                                                swal(\"\",queueError,\"error\");\n                                                return false;\n                                            }\n                                        },\n                                        error: function (xhr, status) {\n                                            return false;\n                                        }\n                                    });\n\n                                    swal({ title: \"\", text: \"Current Visit's Pay Type will be upated from \" + d.oldPayType + \" to \" + editQueueData.PayType + \" \\n\\n NOTE: Modifying the Pay Type might cause a Price difference with the dispensed items if the Company is using a Scheme Price. Any discount apply will be removed.\", type: \"warning\", showCancelButton: false, confirmButtonColor: \"#DD6B55\", cancelButtonText: \"No\", cancelButtonText: \"No\", confirmButtonText: \"Ok\", closeOnConfirm: false },\n                                     function () {\n                                         swal.close();\n                                         switch (true){\n                                             case (urlLocation.indexOf(\"QueueLog\") >= 0):\n                                                 window.setTimeout(function () {$('#queueLogGrid').trigger('reloadGrid', [{ current: true }]), 1000 });\n                                                 break;\n                                             case (urlLocation.indexOf(\"QueuePayment\") >= 0):\n                                                 window.location.reload();\n                                                 break;\n                                             case (urlLocation.indexOf(\"CaseNote\") >= 0):\n                                                 var data = {\n                                                     visitNo: $('#hfVisitNo').val()\n                                                 };\n                                                 $.ajax({\n                                                     cache: false,\n                                                     url: \"/QueueLog/GetQueueByVisit\",\n                                                     data: data,\n                                                     type: 'post',\n                                                     success: function (result) {\n                                                         if (result.success) {\n                                                             $('.patInfoPayType').text(result.queueObj.PayType);\n                                                             $('#lblPayType').attr(\"data-original-title\",result.queueObj.PayTypeDesc);\n                                                             return false;\n                                                         }\n                                                     },\n                                                     error: function (xhr, status) {\n                                                         return false;\n                                                     }\n                                                 });\n                                                 break;\n                                             default:\n                                         }\n\n                                     });\n                                }\n                            }\n                            else{\n                                switch (true){\n                                    case (urlLocation.indexOf(\"QueuePayment\") >= 0):\n                                        window.location.reload();\n                                        break;\n                                    case (urlLocation.indexOf(\"QueueLog\") >= 0):\n                                        $('#queueLogGrid').trigger('reloadGrid', [{ current: true }]);\n                                        break;\n                                    default:\n                                }\n                            }\n                            return true;\n                        },\n                        error: function (xhr, status) {\n                        }\n                    });\n                }\n            }\n        });\n\n    }\n\n    function stringToUnOrderlist(data) {\n        var message;\n        message = data;\n        console.log(\"This is Message: \" + message)\n        var result = message.split(\"%#!\");\n\n        var resultMsg;\n\n        for (var i = 0; i < result.length; i++) {\n            if (i == 0) {\n                resultMsg = \"\\u2022 \" + result[i];\n            } else {\n                resultMsg = resultMsg + \"\\n\\u2022 \" + result[i];\n            }\n        }\n\n        return resultMsg;\n    }\n\n    $('#IdPatientTab').find('a[data-toggle=\"tab\"]').on('shown.bs.tab', function (e) {\n        var target = e.target.attributes.href.value;\n\n        switch (target) {\n            case \"#tabCompany\":\n                $('#txtPatientCompCode').focusTextToEnd();\n                break;\n            case \"#tabRelation\":\n                $('#txtPatientSPName').focusTextToEnd();\n                break;\n            case \"#tabForeignAdd\":\n                $('#txtPatientForeignAdd1').focusTextToEnd();\n                break;\n            case \"#tabPopup\":\n                if (document.getElementById(\"tabPopup\").getAttribute(\"style\").indexOf(\"pointer-events:\") == -1){    //Edited by Chang Ching Ler 20211025 | Auto focus when granted edit access right\n                    $('#txtPatientQueuePopUp').focusTextToEnd();\n                }\n                break;\n            case \"#tabOther\":\n                $('#txtPatientRefCode').focusTextToEnd();\n                break;\n        }\n    });\n\n    $(\"#txtPatientStatus\").keydown(function (e) {\n        var code = e.which;\n    });\n\n    $(\"#txtPatientIDTypeCode\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#txtPatientPName').focus();\n        }\n    });\n\n    $(\"#txtPatientPName\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#txtPatientNRIC').focus();\n        }\n    });\n\n    $(\"#txtPatientNRIC\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#txtPatientSex').focus();\n        }\n    });\n\n    $(\"#txtPatientSex\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#txtPatientRefNo').focus();\n        }\n    });\n\n    $(\"#txtPatientRefNo\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#txtPatientRace').focus();\n        }\n    });\n\n    $(\"#txtPatientRace\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#txtPatientDOB').focus();\n        }\n    });\n\n    $(\"#txtPatientDOB\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#txtPatientCountry').focus();\n        }\n    });\n\n    $(\"#txtPatientCountry\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#txtPatientLanguageSP').focus();\n        }\n    });\n\n    $(\"#txtPatientLanguageSP\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#txtPatientMarital').focus();\n        }\n    });\n\n    $(\"#txtPatientMarital\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#txtPatientOccupation').focus();\n        }\n    });\n\n    $(\"#txtPatientOccupation\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#txtPatientNation').focus();\n        }\n    });\n\n    $(\"#txtPatientNation\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            //$('#txtPatientDocID').focus();    //Commented by Chang Ching Ler 20200211 | Not apply in GP\n            $('#txtPatientBlkHseNo').focus();\n        }\n    });\n\n    $(\"#txtPatientBlkHseNo\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#txtPatientStreet').focus();\n        }\n    });\n\n    $(\"#txtPatientStreet\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#txtPatientUnitNo').focus();\n        }\n    });\n\n    $(\"#txtPatientUnitNo\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#txtPatientBuildingName').focus();\n        }\n    });\n\n    $(\"#txtPatientBuildingName\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#txtPatientProvinces').focus();\n        }\n    });\n\n    $(\"#txtPatientProvinces\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#txtPatientDistricts').focus();\n        }\n    });\n\n    $(\"#txtPatientDistricts\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#txtPatientPostal').focus();\n        }\n    });\n\n    $(\"#txtPatientPostal\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#txtPatientUseForAdd').focus();\n        }\n    });\n\n    $(\"#txtPatientUseForAdd\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#txtPatientTel').focus();\n        }\n    });\n\n    $(\"#txtPatientTel\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#txtPatientTel2').focus();\n        }\n    });\n\n    $(\"#txtPatientTel2\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#txtPatientHP').focus();\n        }\n    });\n\n    $(\"#txtPatientHP\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#txtPatientRemindedBy').focus();\n        }\n    });\n\n    $(\"#txtPatientRemindedBy\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#txtPatientNotifications').focus();\n        }\n    });\n\n    $(\"#txtPatientNotifications\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#txtPatientEmail').focus();\n        }\n    });\n\n    $(\"#txtPatientEmail\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#txtPatientAllergy').focus();\n        }\n    });\n\n    $(\"#txtPatientG6PD\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#txtPatientMediaSource').focus();\n        }\n    });\n\n    $(\"#txtPatientMediaSource\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#btnPatientOk').focus();\n        }\n    });\n\n    $(\"#txtPatientCompCode\").keydown(function (e) {\n\n        var code = e.which;\n\n        if (code == 13) {\n            var patientCompCode = $(this).val();\n\n            if (patientCompCode == '') {\n                window.setTimeout(function () { $('#btnCompCode').focus(), 1000 });\n            } else {\n                txtCompCode_Leave();\n            }\n        }\n    });\n\n    $('#txtPatientCompCode').blur(function () {\n\n        //if ($('#setupCompanyModal').is(':hidden')) { \n        if(initCompCode != $('#txtPatientCompCode').val()){ //Modified by zhaoying 20190318 | check initCompCode != $('#txtPatientCompCode').val() to prevent clear away SubCoy val\n            txtCompCode_Leave();\n        }\n        //}\n    });\n\n    function txtCompCode_Leave() {\n        if ($('#txtPatientCompCode').val().length > 0) {\n            GetCompanybyCode();\n        } else if ($('#txtPatientCompCode').val().length == 0) {\n            $('#txtPatientCompanyDescription').val('');\n\n            getCompPaySchemeList();     //Added by Jason 20200408 - add Company Payment Scheme in Patient Biodata\n        }\n    }\n\n    function GetCompanybyCode() {\n        var data = {\n            CompCode: $('#txtPatientCompCode').val(),\n        };\n        var encoded = JSON.stringify(data);\n\n        $.ajax({\n            cache: false,\n            type: \"POST\",\n            url: \"/Patient/GetCompanyByCode\",\n            data: encoded,\n            contentType: \"application/json; charset=utf-8\",\n            dataType: \"json\",\n            success: function (result) {\n                if (result.success) {\n                    $('#txtPatientCompCode').val(result.companyCode);\n                    $('#txtPatientCompanyDescription').val(result.companyName);\n                    $('#txtPatientEmpNo').focus();\n\n                    getCompPaySchemeList();     //Added by Jason 20200408 - add Company Payment Scheme in Patient Biodata\n                }\n                else {\n                    //$(\"#setupCompanyModalBody\").load(\"/SetupCompany/Index\");\n                    //$(\"#setupCompanyModal\").modal('show').removeClass(\"fade\");\n\n                    //Modified by zhaoying 20180409 | AppendModal2Body_Load as centralised modal generate function so does not replicate modals in different modules, hence same modal will have same look\n                    arrFooterBtnList = [];\n                    arrFooterBtnList2 = [];\n                    arrFooterBtnList.push('<input type=\"button\" value=\"Confirm\" id=\"btnSetupCompanyConfirm\" class=\"btn btn-sm ok-style\" />');\n\n                    var appendDetail = {style:\"max-height:433px;max-width:701px;\", contentType:\"typeSimple\", cancelID:\"btnSetupCompanyCancel\", footerLayout:\"R\"};\n\n                    AppendModal2Body_Load(\"setupCompanyModal\", \"Search Company\", \"/SetupCompany/Index\", arrFooterBtnList, arrFooterBtnList2, appendDetail);\n                }\n            },\n            error: function (data) {\n            }\n        });\n    }\n\n    $(\"#txtPatientEmpNo\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#txtPatientDepartment').focus();\n        }\n    });\n\n    $(\"#txtPatientCopayAmt\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#btnPatientOk').focus();\n        }\n    });\n\n    $(\"#txtPatientCopayPercent\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#txtPatientCopayCap').focus();\n        }\n    });\n\n    $(\"#txtPatientCopayCap\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#btnPatientOk').focus();\n        }\n    });\n\n    $(\"#txtPatientSPName\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#txtPatientSPTel').focus();\n            e.Handled = true;\n        }\n    });\n\n    $(\"#txtPatientSPTel\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#txtPatientSPOff').focus();\n            e.Handled = true;\n        }\n    });\n\n    $(\"#txtPatientSPOff\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#txtPatientSPJob').focus();\n            e.Handled = true;\n        }\n    });\n\n    $(\"#txtPatientSPJob\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#txtPatientMotherName').focus();\n            e.Handled = true;\n        }\n    });\n\n    $(\"#txtPatientMotherName\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#txtPatientMotherNRIC').focus();\n            e.Handled = true;\n        }\n    });\n\n    $(\"#txtPatientMotherNRIC\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#txtPatientMotherTel').focus();\n            e.Handled = true;\n        }\n    });\n\n    $(\"#txtPatientMotherTel\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#txtPatientFatherName').focus();\n            e.Handled = true;\n        }\n    });\n\n    $(\"#txtPatientFatherName\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#txtFatherNRIC').focus();\n            e.Handled = true;\n        }\n    });\n\n    $(\"#txtFatherNRIC\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#txtFatherTel').focus();\n            e.Handled = true;\n        }\n    });\n\n    $(\"#txtFatherTel\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#txtPatientRef1').focus();\n            e.Handled = true;\n        }\n    });\n\n    $(\"#txtPatientRef1\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#txtPatientRef2').focus();\n            e.Handled = true;\n        }\n    });\n\n    $(\"#txtPatientRef2\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#txtPatientRef3').focus();\n            e.Handled = true;\n        }\n    });\n\n    $(\"#txtPatientRef3\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#btnPatientOk').focus();\n            e.Handled = true;\n        }\n    });\n\n    $(\"#txtPatientForeignAdd1\").keydown(function (e) {\n        var code = e.which;\n        if (code == 13) {\n            $('#txtPatientForeignAdd2').focus();\n        }\n    });\n\n    $(\"#txtPatientForeignAdd2\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#txtPatientForeignAdd3').focus();\n        }\n    });\n\n    $(\"#txtPatientForeignAdd3\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#txtPatientForeignAdd4').focus();\n        }\n    });\n\n    $(\"#txtPatientForeignAdd4\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#btnPatientOk').focus();\n        }\n    });\n\n    $('#txtpatientForeignAdd5').keydown(function (e) { });\n\n    $(\"#txtPatientRefCode\").keydown(function (e) {\n        var code = e.which;\n        if (code == 13) {\n            var patientRefCode = $(this).val();\n\n            if (patientRefCode == '') {\n                window.setTimeout(function () { $('#btnRefCode').focus(), 1000 });\n            } else {\n                txtRefCode_Leave($(\"#txtPatientRefCode\").val());\n            }\n        }\n    });\n\n    $('#txtPatientRefCode').blur(function () {\n        \n        //if ($('#setupRefSourceModal').is(':hidden')) {\n        txtRefCode_Leave($('#txtPatientRefCode').val());\n        //}\n    });\n\n    function txtRefCode_Leave(doctor) {\n        if (doctor.length > 0) {\n            GetRefSourcebyRefCode(doctor);\n        }\n        else if (doctor.length == 0) {\n            $('#txtPatientRefDescription').val('');\n            $('#txtPatientRefDoctor').val('');\n            var ddl = document.getElementById(\"ddlPatientRefDoctor\");\n            ddl.length = 0;\n\n            var el = document.createElement(\"option\");\n            el.text = '';\n            el.value = '';\n            ddl.options.add(el)\n        }\n    }\n\n    function GetRefSourcebyRefCode(doctor) {\n        var splitValue = doctor.split(\" |-| \")\n        var refCode = splitValue[0]\n\n        var data = {\n            RefCode: (refCode != '' ? refCode : $('#txtPatientRefCode').val()),\n        };\n        var encoded = JSON.stringify(data);\n\n        if (splitValue.length < 2){\n            doctor = $('#ddlPatientRefDoctor').val()\n        }else{\n            doctor = splitValue[1]\n        }\n\n        $.ajax({\n            cache: false,\n            type: \"POST\",\n            url: \"/Patient/GetSetupRefSourceByCode\",\n            data: encoded,\n            contentType: \"application/json; charset=utf-8\",\n            dataType: \"json\",\n            success: function (result) {\n                if (result.success) {\n                    var doctorList = result.refDoctorList\n\n                    var ddl = document.getElementById(\"ddlPatientRefDoctor\");\n                    ddl.length = 0;\n\n                    var el = document.createElement(\"option\");\n                    el.text = '';\n                    el.value = '';\n                    ddl.options.add(el)\n\n                    if (doctorList.length > 0){\n                        var count = 0\n                        for(var item in result.refDoctorList){\n                            var el = document.createElement(\"option\");\n                            el.text = result.refDoctorList[count].Text;\n                            el.value = result.refDoctorList[count].Value;\n                            ddl.options.add(el)\n\n                            if (doctor != ''){\n                                if (result.refDoctorList[count].Value == doctor)\n                                {\n                                    document.getElementById(\"ddlPatientRefDoctor\").selectedIndex = count + 1;\n                                }\n                            }\n                            else{\n                                document.getElementById(\"ddlPatientRefDoctor\").selectedIndex = 0;\n                            }\n                            count++;\n                        }\n                    }\n\n                    $('#txtPatientRefCode').val(result.refCode);\n                    $('#txtPatientRefDescription').val(result.refDesc);\n\n                    $('#txtPatientRefDoctor').focus();\n                    $('#txtPatientRefDoctor').focus(function () { $(this).select(); });\n                }\n                else {\n                    $(\"#btnRefCode\").trigger('click');\n                }\n\n                if ($(\"#DownloadProfileType\").val() == \"tCAS\") {\n                    var rowID = $(\"#ehaPatientGrid\").find(\"td[title='\" + $(\"#txtPatientNRIC\").val() + \"']\").parent().attr(\"id\");\n                    $(\"#ddlPatientRefDoctor\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowID, 'RefDoctor'));\n                }\n            },\n            error: function (data) {\n            }\n        });\n    }\n    //\n\n    $(\"#txtPatientRefDoctor\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#txtPatientAgentCode').focus();\n        }\n    });\n\n    $(\"#txtPatientAgentCode\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            var patientAgentCode = $(this).val();\n\n            if (patientAgentCode == '') {\n                window.setTimeout(function () { $('#btnAgentCode').focus(), 1000 });\n            } else {\n                txtAgentCode_Leave();\n            }\n        }\n    });\n\n    $('#txtPatientAgentCode').blur(function () {\n        //if ($('#setupAgentModal').is(':hidden')) { \n        txtAgentCode_Leave();\n        //}\n    });\n\n    function txtAgentCode_Leave() {\n        if ($('#txtPatientAgentCode').val().length > 0) {\n            GetSetupAgentByCode();\n        } else if ($('#txtPatientAgentCode').val().length == 0) {\n            $('#txtPatientAgentDescription').val('');\n        }\n    }\n\n    function GetSetupAgentByCode() {\n        var data = {\n            AgentCode: $('#txtPatientAgentCode').val(),\n        };\n        var encoded = JSON.stringify(data);\n\n        $.ajax({\n            cache: false,\n            type: \"POST\",\n            url: \"/Patient/GetSetupAgentByCode\",\n            data: encoded,\n            contentType: \"application/json; charset=utf-8\",\n            dataType: \"json\",\n            success: function (result) {\n                if (result.success) {\n                    $('#txtPatientAgentCode').val(result.agentCode);\n                    $('#txtPatientAgentDescription').val(result.agentDesc);\n                    $('#txtPatientNotes').focus();\n                }\n                else {\n                    //$(\"#setupAgentModalBody\").load(\"/SetupAgent/Index\");\n                    //$(\"#setupAgentModal\").modal('show').removeClass(\"fade\");\n\n                    //Modified by zhaoying 20180409 | AppendModal2Body_Load as centralised modal generate function so does not replicate modals in different modules, hence same modal will have same look\n                    arrFooterBtnList = [];\n                    arrFooterBtnList2 = [];\n                    arrFooterBtnList.push('<input type=\"button\" value=\"Confirm\" id=\"btnSetupAgentConfirm\" class=\"btn btn-sm ok-style\" />');\n\n                    var appendDetail = {style:\"max-height:400px;max-width:907px;\", contentType:\"typeSimple\", cancelID:\"btnSetupAgentCancel\", footerLayout:\"R\"};\n\n                    AppendModal2Body_Load(\"setupAgentModal\", \"Search Agent\", \"/SetupAgent/Index\", arrFooterBtnList, arrFooterBtnList2, appendDetail);\n                }\n            },\n            error: function (data) {\n            }\n        });\n    }\n\n    $(\"#btnAgentCode\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#txtPatientNotes').focus();\n        }\n    });\n\n    function getPatientDefaultDetail(d) {\n\n        var data = { DefaultType: d };\n\n        $.ajax({\n            cache: false,\n            url: \"/Setup/getPatientDefaultDetail\",\n            type: \"POST\",\n            data: JSON.stringify(data),\n            contentType: 'application/json; charset=utf-8',\n            beforeSend: function () {\n            },\n            success: function (response) {\n                console.log(response)\n                if (response.success) {\n\n                    $.each(response.list, function (i, h) {\n\n                        if ($(\"#txtPatientNo\").val() == \"NEW\") { //|| d != \"D\") {\n\n                            $(\"#txtPatientIDTypeCode\").val(h.IDTypeCode);\n                            $(\"#txtPatientSex\").val(h.Sex);\n                            $(\"#txtPatientNation\").val(h.Nation);\n                            $(\"#txtPatientLanguageSP\").val(h.LanguageSP);\n                            $(\"#txtPatientStatus\").val(h.Status);\n                            $(\"#txtPatientMarital\").val(h.Marital);\n                            $(\"#txtPatientCountry\").val(h.Country);\n                            $(\"#txtPatientOccupation\").val(h.Occupation);\n\n                            if (h.VIP.toString() == 'False') {\n                                $(\"#chkVIP\").prop(\"checked\", false);\n                            } else {\n                                $(\"#chkVIP\").prop(\"checked\", true);\n                            }\n                            $(\"#txtPatientRemindedBy\").val(h.RemindedBy);\n                            $(\"#txtPatientRace\").val(h.Race);\n\n                            $(\"#txtPatientCountry\").trigger('change');\n                        }\n                            //Added by zhaoying 20180321 | to allow edit patient (existing patient) able to DM, DF\n                        else if ($(\"#txtPatientNo\").val() != 'NEW' && $(\"#txtPatientNo\").val() != '' && d != 'D') {\n\n                            $(\"#txtPatientIDTypeCode\").val(h.IDTypeCode);\n                            $(\"#txtPatientSex\").val(h.Sex);\n                            $(\"#txtPatientNation\").val(h.Nation);\n                            $(\"#txtPatientLanguageSP\").val(h.LanguageSP);\n                            $(\"#txtPatientStatus\").val(h.Status);\n                            $(\"#txtPatientMarital\").val(h.Marital);\n                            $(\"#txtPatientCountry\").val(h.Country);\n                            $(\"#txtPatientOccupation\").val(h.Occupation);\n\n                            if (h.VIP.toString() == 'False') {\n                                $(\"#chkVIP\").prop(\"checked\", false);\n                            } else {\n                                $(\"#chkVIP\").prop(\"checked\", true);\n                            }\n                            $(\"#txtPatientRemindedBy\").val(h.RemindedBy);\n                            $(\"#txtPatientRace\").val(h.Race);\n\n                            $(\"#txtPatientCountry\").trigger('change');\n                        }\n                        if ($(\"#txtPatientIDTypeCode option:selected\").val() == 'B'){\n                            $(\"#txtPatientNation\").css(\"width\", \"50%\");\n                            $(\"#txtPatientNation2\").prop(\"disabled\", false);\n                            $('#Nation2Part').show();\n                        }else{\n                            $(\"#txtPatientNation\").css(\"width\", \"100%\");\n                            $(\"#txtPatientNation2\").prop(\"disabled\", true);\n                            $('#Nation2Part').hide();\n                        }\n                        //Added by Cheng Yu 20230306\n\n                        //Added by Ray 20230208 --Customize for idtype P,B,F,M to auto select nationality\n                        if($(\"#txtPatientIDTypeCode option:selected\").val() == 'P')\n                        {\n                            $('#txtPatientNation option[value=\"SINGAPORE CITIZEN\"]').prop(\"selected\", true);\n                            $(\"#txtPatientNation\").prop(\"readonly\", true).css(\"background\", \"lightgrey\").css(\"pointer-events\", \"none\");\n                        }\n                        else if ($(\"#txtPatientIDTypeCode option:selected\").val() == 'B') {\n                            $('#txtPatientNation option[value=\"SINGAPORE PR\"]').prop(\"selected\", true);\n                            $(\"#txtPatientNation\").prop(\"readonly\", true).css(\"background\", \"lightgrey\").css(\"pointer-events\", \"none\");\n                        }\n                            //Added by Ray 20230209 --take out check fin number to change nationality\n                            //else if ($(\"#txtPatientIDTypeCode option:selected\").val() == 'F') {\n                            //    $('#txtPatientNation option[value=\"\"]').prop(\"selected\", true);\n                            //    $(\"#txtPatientNation\").prop(\"readonly\", false).css(\"background\", \"#FFFFE1\").css(\"pointer-events\", \"auto\");\n                            //}\n                        else if ($(\"#txtPatientIDTypeCode option:selected\").val() == 'M') {\n                            $('#txtPatientNation option[value=\"MALAYSIAN\"]').prop(\"selected\", true);\n                            $(\"#txtPatientNation\").prop(\"readonly\", true).css(\"background\", \"lightgrey\").css(\"pointer-events\", \"none\");\n\n                        }\n                        else {\n                            $(\"#txtPatientNation\").prop(\"readonly\", false).css(\"background\", \"#FFFFE1\").css(\"pointer-events\", \"auto\");\n                        }\n                        //Ended by Ray\n\n                        $(\"#txtPatientNation\").trigger(\"change\");\n                        if (h.Provinces == 'Y') {\n                            $(\"#divProvinces\").css(\"display\", \"block\");\n                            $(\"#divDistricts\").css(\"display\", \"block\");\n                        }\n                        else {\n                            $(\"#divProvinces\").css(\"display\", \"none\");\n                            $(\"#divDistricts\").css(\"display\", \"none\");\n                        }\n\n                        Prefix_Unit = h.Prefix_Unit;\n\n                    });\n\n\n\n                } else {\n                    swal(\"\", response.message, \"error\");\n                }\n            },\n            error: function (response) {\n                swal('', response, 'error');\n            }\n        });\n    }\n\n    $(\"#txtPatientCountry\").change(function () {\n        if ($(\"#txtPatientCountry\").val() == '') {\n            //$(\"#txtPatientProvinces\").prop(\"disabled\", true);\n            //$(\"#txtPatientDistricts\").prop(\"disabled\", true);\n            $(\"#txtPatientDistricts\").val(\"\");\n\n            $(\"#txtPatientProvinces\").empty().append(\"<option></option>\");\n        }\n        else {\n            //$(\"#txtPatientProvinces\").prop(\"disabled\", false);\n            //$(\"#txtPatientDistricts\").prop(\"disabled\", false);\n            $(\"#txtPatientDistricts\").val(\"\");\n            var data = { country: $(\"#txtPatientCountry\").val() };\n            var encoded = JSON.stringify(data)\n            $.ajax({\n                cache: false,\n                type: \"POST\",\n                data: encoded,\n                url: \"/Patient/GetProvinces\",\n                contentType: \"application/json; charset=utf-8\",\n                dataType: \"json\",\n                success: function (result) {\n                    $(\"#txtPatientProvinces\").empty().append(\"<option></option>\");\n\n                    if (typeof result.desc != 'undefined') {\n                        for (var i = 0; i < result.desc.length; i++) {\n                            $(\"#txtPatientProvinces\").append(\"<option>\" + result.desc[i] + \"</option>\");\n                        }\n                    }\n                }\n            });\n        }\n    });\n\n    function PatientAllergy() {\n        //$('.fadeMe').show();\n        $(\"#tabAllergyContent\").load('https://clinicassist.sg:1080/en/PatientMaster/TabPatientAllergy?pcno=' + $(\"#txtPatientNo\").val());\n    }\n\n    //Added by zhaoying 20190227 | change background color and font color when the Med Alert tab is active or not.\n    $('#PatientCreateEditDocumentList ul li a').click(function () {\n        var allergyCount = parseInt($('#patientAllergyGrid').jqGrid('getGridParam', 'reccount')) + parseInt($('#patientAllergyOtherGrid').jqGrid('getGridParam', 'reccount'));\n        var medAlert;\n        if (allergyCount == 0 && $('#txtPatientG6PD').val() != 'YES' && ($('#chkPregnancy').prop('checked') == false && $('#PregnancyDueDate').val() == '')){\n            medAlert = 'N';\n        }\n        else{\n            medAlert = 'Y';\n        }\n        if ($(this).attr(\"href\") == '#tabAllergy' ){\n            if (medAlert == 'Y' && $(\".nav-item a[tabTarget='MedAlert']\").css('background-color') == 'rgb(255, 102, 102)'){ //red\n                setMedAlertColour('greyYellow');\n            }\n        }\n        else{\n            if (medAlert == 'Y'){ //yellow or red\n                if($('#Pat-tab-li-Allergy a').css('color') == 'rgb(255, 235, 59)' || $(\".nav-item a[tabTarget='MedAlert']\").css('background-color') == 'rgb(255, 102, 102)'){\n                    setMedAlertColour('redBlack');\n                }\n            }\n            else{\n                setMedAlertColour('normalBlack');\n            }\n        }\n        //PatientAllergy();\n    });\n\n    //function PatientPhoto() {\n    //$('.fadeMe').show();\n    //$(\"#tabPatientPhoto\").load('@(Url.Action(\"TabPhoto\", \"PatientMaster\", Nothing, Request.Url.Scheme))?pcno=' + $(\"#txtPatientNo\").val());\n    //}\n\n    //Added by Jian Chee , 20180605 #6547 - if patient id type  = others set default value to nric = \"NA\".\n    $(\"#txtPatientIDTypeCode\").change(function() {\n        var selIDType = $(\"#txtPatientIDTypeCode option:selected\").val();\n\n        //Start: Add MonthDiff in between 0 to 3 checking - Jack 21082018\n        var todaysDate = String(moment().format(\"DD MMM YYYY\"));\n        var dateString = $(\"#txtPatientDOB\").val().substring(0, 2) + \" \" + getMonthName(parseInt($(\"#txtPatientDOB\").val().substring(3, 5))) + \" \" + $(\"#txtPatientDOB\").val().substring(6, 10);\n        var patientDOBValue = moment(dateString);\n        var monthDiff = moment(todaysDate).diff(patientDOBValue, 'months');\n        //End: Add MonthDiff in between 0 to 3 checking - Jack 21082018\n\n        if (selIDType.toLowerCase()==\"x\" && $(\"#hdVersion\").val()==\"SG\" && ($(\"#txtPatientNRIC\").val() == null || $(\"#txtPatientNRIC\").val() == \"\") && (monthDiff >= 0 && monthDiff <= 3)) //Add MonthDiff in between 0 to 3 checking - Jack 21082018\n        {\n            $(\"#txtPatientNRIC\").val(\"NA\");\n        }\n    });\n\n    $('#txtPatientMotherNRIC').focusout(function () {\n        checkParentNRIC(\"Mother\");\n    });\n    $('#txtFatherNRIC').focusout(function () {\n        checkParentNRIC(\"Father\");\n    });\n\n    function checkParentNRIC(type) {\n        var selectedIDTypeCode;\n        var data;\n        if (type==\"Mother\")\n        {\n\n            data = {\n                nric: $('#txtPatientMotherNRIC').val(),\n                idtypecode: $(\"#cboMotherIDTypeCode option:selected\").val()\n            };\n        }\n        else if (type==\"Father\")\n        {\n\n            data = {\n                nric: $('#txtFatherNRIC').val(),\n                idtypecode: $(\"#cboFatherIDTypeCode option:selected\").val()\n            };\n        }\n\n\n        var encoded = JSON.stringify(data);\n\n        $.ajax({\n            cache: false,\n            type: \"POST\",\n            url: \"/Patient/CheckParentNRIC\",\n            data: encoded,\n            contentType: \"application/json; charset=utf-8\",\n            dataType: \"json\",\n            success: function (data) {\n                if (data.success) {\n                    if (type==\"Mother\")\n                    {\n                        $(\"#txtPatientMotherNRIC\").val(data.message);\n                    }\n                    else if (type==\"Father\")\n                    {\n                        $(\"#txtFatherNRIC\").val(data.message);\n                    }\n\n                }\n\n            },\n            error: function (data) {\n\n            }\n        });\n    }\n\n    function FetchPayType(callFrm) {    //Edited by Chang Ching Ler 20210413 | Add parameter to indicate function trigger by which element\n        var url = '/en/QueueLog/FetchPayType';\n        var PDD = $(\"#txtQueuePayType\");\n        var ODD = $('#txtQueuePCNO').val()\n\n        var myEle = document.getElementById(\"txtQueuePCNO\");\n\n        if(myEle){\n            $.getJSON(url, { pcno: ODD }, function (response) {\n                PDD.empty();\n                //Edited by Chang Ching Ler 20210413 | Enabled \"Confirm\" button when finish loop paytype\n                var loopFinish = $.each(response, function (index, item) {\n                    var p = new Option(item.Text, item.Value);\n                    p.selected = item.Selected;\n                    PDD.append(p);\n                });\n\n                if (loopFinish && callFrm == \"patientgrid\") {\n                    $('#btnQueueCreate').prop(\"disabled\", false);\n                }\n                //End Added by Chang Ching Ler 2021041220210413\n            });\n        }\n    }\n\n    $(\"#btnEditPatNRIC\").click(function () {\n        //Comment by Koh Chin Choong 20200213 - Prevent MFLAC\n        if (true == false) {\n            swal({ title: Cookies.get(\"SWAL_Header_Msg\"), text: Cookies.get(\"SWAL_Body_Msg\"), type: Cookies.get(\"SWAL_Type\"), timer: Cookies.get(\"SWAL_Timer\") });\n            return;\n        }\n\n        $('#EditPatNRICModal').modal('show');\n        $('#txtEditPatientNRIC').val($('#txtPatientNRIC').val());\n        $('#NewPatNRIC').val('');\n        //End Comment by Koh Chin Choong 20200213\n\n        //Added by Koh Chin Choong 20200213 - Add Check user function access right\n        //$.ajax({\n        //    cache: false,\n        //    url: \"/Authenticate/CheckUserFunctionAccessRight?FunctionID=\" + Cookies.get(\"Pat_Edit_NRIC\"),\n        //    contentType: 'application/json; charset=utf-8',\n        //    type: \"POST\",\n        //    success: function (response) {\n        //        if (response.success) {\n        //            $('#EditPatNRICModal').modal('show');\n        //            $('#txtEditPatientNRIC').val($('#txtPatientNRIC').val());\n        //            $('#NewPatNRIC').val('');\n        //        }\n        //        else {\n        //            swal({ title: Cookies.get(\"SWAL_Header_Msg\"), text: Cookies.get(\"SWAL_Body_Msg\"), type: Cookies.get(\"SWAL_Type\"), timer: Cookies.get(\"SWAL_Timer\") });\n        //            $('.fadeMe').hide();\n        //        }\n        //    },\n        //    error: function (response) {\n        //        swal({ title: Cookies.get(\"SWAL_Header_Msg\"), text: Cookies.get(\"SWAL_Body_Msg\"), type: Cookies.get(\"SWAL_Type\"), timer: Cookies.get(\"SWAL_Timer\") });\n        //        $('.fadeMe').hide();\n        //    }\n        //});\n        //End Added by Koh Chin Choong 20200213\n    });\n\n    $('#EditPatNRICModal').on('shown.bs.modal', function () {\n        $('.modal-backdrop').remove();  //Added by MiaoRu 20211008\n        $('#NewPatNRIC').focus();\n    });\n\n    // Variable to keep track of SweetAlert instance\n    var isSwalActive = false;\n\n    //Function to show a SweetAlert\n    function showSwal(title, text, icon) {\n        if (isSwalActive) {\n            return; // Prevent showing a new SweetAlert if one is already active\n        }\n\n        isSwalActive = true;\n        swal({\n            title: title,\n            text: text,\n            type: icon,\n            confirmButtonText: \"OK\"\n        }, function () {\n            isSwalActive = false; // Reset the flag when SweetAlert is closed\n        });\n    }\n\n    $('#NewPatNRIC').focusout(function () {\n        checkNewNRIC();\n    });\n\n    $(\"#btnEditPatNRICOk\").click(function () {\n        if ($('#txtEditPatientNRIC').val() == $('#NewPatNRIC').val()) {\n            showSwal(\"\", \"New NRIC can not same with old NRIC\", \"warning\");\n            return;\n        }\n        else if ($('#NewPatNRIC').val() == \"\") {\n            showSwal(\"\", \"New NRIC can not empty\", \"warning\");\n            return;\n        }\n\n        var selectedIDTypeCode = $(\"select[name='IDTypeCode'] option:selected\").val();  //Added by Chang Ching Ler 20191108\n\n        var data = {\n            PCNO: $('#txtPatientNo').val(),\n            newnric: $('#NewPatNRIC').val(),\n            //patNRICType: $(\"select[name='IDTypeCode'] option:selected\").val()\n            patNRICType: selectedIDTypeCode     //Edited by Chang Ching Ler 20191108\n        };\n\n        var encoded = JSON.stringify(data);\n\n        $.ajax({\n            cache: false,\n            type: \"POST\",\n            url: \"/Patient/UpdateOnlyPatientNRIC\",\n            data: encoded,\n            contentType: \"application/json; charset=utf-8\",\n            dataType: \"json\",\n            success: function (result) {\n                if (result.success) {\n                    $('#EditPatNRICModal').modal('hide');\n                    $('#txtPatientNRIC').val($('#NewPatNRIC').val());\n\n                    if (result.data == true){ //Added by zhaoying 20190226 | ID type = Pink IC; NRIC= valid pink IC, then auto default Nationaility = Singapore Citizen\n                        $('#txtPatientNation option[value=\"SINGAPORE CITIZEN\"]').prop(\"selected\",true);\n                    }\n\n                    //Comment by Chang Ching Ler 20191125 | Temporary comment\n                    //if(selectedIDTypeCode == 'B' || selectedIDTypeCode == 'P'){ //Added by Chang Ching Ler 20191108 | Check CHAS if the IC is Pink IC or Blue IC\n                    //    CheckCHAS(\"Add\");\n                    //}\n                    //End Comment by Chang Ching Ler 20191125\n                }\n                else {\n                    var patientError = stringToUnOrderlist(result.message);\n                    showSwal(\"\", patientError, \"warning\");\n                    //$(\"#NewPatNRIC\").focus();\n                }\n            },\n            error: function (data) {\n            }\n        });\n    });\n\n    function checkNewNRIC() {\n        var selectedIDTypeCode = $(\"select[name='IDTypeCode'] option:selected\").val();\n\n        var data = {\n            nric: $('#NewPatNRIC').val(),\n            idtypecode: $(\"select[name='IDTypeCode'] option:selected\").val(),\n            pcno: $('#txtPatientNo').val(),\n        };\n\n        var encoded = JSON.stringify(data);\n\n        $.ajax({\n            cache: false,\n            type: \"POST\",\n            url: \"/Patient/CheckNRIC\",\n            data: encoded,\n            contentType: \"application/json; charset=utf-8\",\n            dataType: \"json\",\n            success: function (data) {\n                if (data.success) {\n                    $(\"#NewPatNRIC\").val(data.message);\n                }\n                else {\n                    showSwal(\"\", data.message, \"warning\");\n                }\n            },\n            error: function (data) {\n\n            }\n        });\n    }\n\n    $(\"#NewPatNRIC\").on('input', function () {\n        var start = this.selectionStart,\n            end = this.selectionEnd;\n\n        this.value = this.value.toUpperCase();\n        this.setSelectionRange(start, end);\n    });\n\n    function getMonthName(monthNum){\n        var monthNames = [\n        \"January\", \"February\", \"March\",\n        \"April\", \"May\", \"June\",\n        \"July\", \"August\", \"September\",\n        \"October\", \"November\", \"December\"\n        ];\n\n        return monthNames[(parseInt(monthNum) - 1)];\n    }\n    function getMonthShortName(monthNum){\n        var monthNames = [\n        \"Jan\", \"Feb\", \"Mar\",\n        \"Apr\", \"May\", \"Jun\",\n        \"Jul\", \"Aug\", \"Sep\",\n        \"Oct\", \"Nov\", \"Dec\"\n        ];\n\n        return monthNames[(parseInt(monthNum) - 1)];\n    }\n\n    $('#txtPatientNotes').keypress(function (event) {\n        if (event.keyCode == 13) {\n            //event.preventDefault();\n        }\n    });\n\n    //Added by Jason 20200408 - get company payment scheme\n    function getCompPaySchemeList() {\n        $.ajax({\n            cache: false,\n            type: \"POST\",\n            url: \"/Patient/getCompPaySchemeList\",\n            data: JSON.stringify({compCode: $(\"#txtPatientCompCode\").val()}),\n            contentType: \"application/json; charset=utf-8\",\n            dataType: \"json\",\n            success: function (response) {\n                if (response.success) {\n                    $(\"#ddlPayScheme\").empty();\n                    $(\"#ddlPayScheme\").append('<option value=\"\"></option>');\n\n                    $.each(response.list, function (i, sp) {\n                        $(\"#ddlPayScheme\").append('<option value=\"' + sp.PayCode +'\">' + sp.PayCode + ' - ' + sp.Description + '</option>');\n                    });\n                }\n                else {\n                    swal(\"\", response.message);\n                }\n            },\n            error: function (data) {\n\n            }\n        });\n    }\n    //End added by Jason 20200408\n\n    function addBracketsToPinYin() {\n        let pinyinName = $(\"#txtPatientHanYuPinYinName\").val();\n\n        if (pinyinName.trim() == \"\") {\n            return;\n        }\n\n        if (pinyinName[0] !== '(' || pinyinName[pinyinName.length - 1] !== ')') {\n            pinyinName = pinyinName.replace(/^\\(|\\)$/g, '');\n\n            $(\"#txtPatientHanYuPinYinName\").val(\"(\" + pinyinName + \")\");\n        }\n    }\n\n    //Added by Chang Ching Ler 20200425 | Get payment scheme's copay infor\n    $('#ddlPayScheme').change(function() {\n        if ($('#ddlPayScheme').val() != \"\"){\n            var myData = { paycode: $('#ddlPayScheme').val(), compcode: $(\"#txtPatientCompCode\").val(), callfrom: \"EditPatient\" }; //Edited by Chang Ching Ler 20200923 | Add callfrom - No need check access right if call from Edit patient > Company tab > Pay Scheme  //Modified by Jason 20200821 - add compcode\n            var encoded = JSON.stringify(myData);\n\n            $.ajax({\n                cache: false,\n                type: \"POST\",\n                url: \"/Company/GetCompanyPayScheme\",\n                contentType: \"application/json; charset=utf-8\",\n                data: encoded,\n                dataType: \"json\",\n                async: false,\n                success: function (response) {\n                    if (response.length > 0) {\n                        var copayAmt = response[0].CopayAmt;\n\n                        if (copayAmt > 0.00) {\n                            $('input[name=patientcopayment][value=Amount]').prop(\"checked\", true);\n                            $(\"#txtPatientCopayAmt\").val(copayAmt);\n                        }\n                        else {\n                            $('input[name=patientcopayment][value=Percent]').prop(\"checked\", true);\n                            $(\"#txtPatientCopayPercent\").val(response[0].CopayPercent);\n                            $(\"#txtPatientCopayCap\").val(response[0].CopayCap);\n                        }\n\n                        GetcopaymentSelectedItem();\n                    }\n                },\n                error: function (xhr, status, error) {\n                    swal(\"\", status + \"\\nError: \" + error + \"\\nError detail: \" + xhr.responseText, \"error\");\n                },\n                complete: function () {\n                }\n            });\n        }\n    });\n    //End Added by Chang Ching Ler 20200425\n\n    //Added by Koh Chin Choong 20200729 - Restrict '<' and '>' symbol\n    $(\"#txtPatientPName\").keydown(function (event) {\n        if ((event.shiftKey && event.keyCode == 191) || (event.shiftKey && event.keyCode == 55)) {\n            event.preventDefault();\n        }\n    });\n    //End Added by Koh Chin Choong 20200729\n\n    //Added by Zac 20211004 - Mobile Download\n    $('#btnEhaDownload').off(\"click\").click(function () {\n        //$.when( ehaPatientDownload() ).done(function() {\n        //    setTimeout(function(){\n        //        var ids = jQuery(\"#ehaPatientGrid\").jqGrid('getDataIDs');\n        //        console.log(ids.length)\n        //        if(ids.length > 0){\n        //            $(\"#ehaPatientModal\").modal('show')\n        //        }\n        //        else{\n        //            swal(\"\", \"No available profile to download\", \"warning\");\n        //        }\n        //    }, 300);\n\n        //});\n        $(\"#ehaPatientGrid\").jqGrid(\"GridUnload\");\n\n        var url = \"/Patient/DownloadProfile\";\n        $(\"#ehaPatientGrid\").jqGrid({\n            url: url,\n            datatype: 'json',\n            mtype: 'Get',\n            colNames: ['ID','Patient Name', 'NRIC', 'Mobile No','','ClinicID','Sex','DOB','','','','','','','','','','BlkHseNo','Street','BuildingName','UnitNo','PCode','Tel1','Email','Allergy','SMSNoti','UseForeignAdd','ForeignAdd1','ForeignAdd2','ForeignAdd3','ForeignAdd4','PhoneNoti','EMsgNoti','EmailNoti','ApptNo', 'FilePath', 'DownloadType'],\n            colModel: [\n                { key: false, name: 'ID', index: 'ID', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'PName', index: 'PName', width: 220, sortable: false},\n                { key: false, name: 'Nric', index: 'Nric', width: 130, sortable: false},\n                { key: false, name: 'hp', index: 'hp', width: 100, sortable: false},\n                { key: false, name: 'Download',index:'Download', width:120,sortable:false, align: 'center', formatter: formatdownload },\n                { key: false, name: 'ClinicID', index: 'ClinicID', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'Sex', index: 'Sex', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'DOB', index: 'DOB', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'race', index: 'race', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'occupation', index: 'occupation', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'Marital', index: 'Marital', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'country', index: 'country', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'nation', index: 'nation', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'hp', index: 'hp', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'notifications', index: 'notifications', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'languageSP', index: 'languageSP', width: 100, sortable: false, hidden: true},\n\n                { key: false, name: 'idTypeCode', index: 'idTypeCode', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'BlkHseNo', index: 'BlkHseNo', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'Street', index: 'Street', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'BuildingName', index: 'BuildingName', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'UnitNo', index: 'UnitNo', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'PCode', index: 'PCode', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'tel', index: 'tel', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'Email', index: 'Email', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'Allergy', index: 'Allergy', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'UseForeignAdd', index: 'UseForeignAdd', width: 100, sortable: false, hidden: true },\n                { key: false, name: 'ForeignAdd1', index: 'ForeignAdd1', width: 100, sortable: false, hidden: true },\n                { key: false, name: 'ForeignAdd2', index: 'ForeignAdd2', width: 100, sortable: false, hidden: true },\n                { key: false, name: 'ForeignAdd3', index: 'ForeignAdd3', width: 100, sortable: false, hidden: true },\n                { key: false, name: 'ForeignAdd4', index: 'ForeignAdd4', width: 100, sortable: false, hidden: true },\n                { key: false, name: 'SMSNoti', index: 'SMSNoti', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'PhoneNoti', index: 'PhoneNoti', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'EMsgNoti', index: 'EMsgNoti', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'EmailNoti', index: 'EmailNoti', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'ApptNo', index: 'ApptNo', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'FilePath', index: 'FilePath', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'DownloadType', index: 'DownloadType', width: 100, sortable: false, hidden: true}\n            ],\n            rowNum: -1,\n            rowList: ['All', '100', '500', '1000'],\n            gridview: true,\n            width: \"auto\",\n            height: \"auto\",\n            scroll: true,\n            loadError: function (xhr, status, error) {\n            },\n            loadComplete: function () {\n                var ele = $(\"#ehaPatientModal\").find(\".ui-jqgrid-bdiv\");\n                $(ele).height(200);\n                $(ele).width($(ele).width() + 16);\n                $(ele).css(\"overflow-x\", \"hidden\");\n\n                var ids = jQuery(\"#ehaPatientGrid\").jqGrid('getDataIDs');\n                if(ids.length > 0){\n                    $(\"#ehaPatientModal\").modal('show')\n                }\n                else{\n                    swal(\"\", \"No available profile to download\", \"warning\");\n                }\n            },\n            jsonReader: {\n                root: \"rows\",\n                page: \"page\",\n                total: \"total\",\n                records: \"records\",\n                repeatitems: false,\n                Id: \"0\"\n            },\n            shrinkToFit: false,\n            multiselect: false\n        });\n    })\n\n\n    $('#ehaPatientModal').on('shown.bs.modal', function () {\n        $('.modal-backdrop').remove();\n    });\n\n    function formatdownload(cellvalue, options, rowObject) {\n        return \"<input style='height:22px;width:100px;background-color: #84d0e6;border:1px solid transparent;border-radius: 4px;border-color: #3da6c5;' type='button' value='Download' onclick=\\\"DownloadEhaPatient_ctrl.call(this, event);\\\" />\";\n    }\n\n    function DownloadEhaPatient_ctrl(rowId) {\n        var rowid = $(this).closest(\"tr.jqgrow\").attr(\"id\");\n\n        $(\"#hfehaPatientNRIC\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'Nric'));\n        $(\"#hfehaPatientMobile\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'hp'));\n        $(\"#hfehaPatientApptNo\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'ApptNo'));\n\n        $(\"#txtPatientPName\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'PName'));\n        $(\"#txtPatientNRIC\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'Nric'));\n        $(\"#txtPatientDOB\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'DOB'));\n        $(\"#txtPatientNation\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'nation').trim());\n        $(\"#txtPatientSex\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'Sex'));\n        $(\"#txtPatientHP\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'hp'));\n        $(\"#txtPatientBlkHseNo\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'BlkHseNo'));\n        $(\"#txtPatientStreet\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'Street'));\n        $(\"#txtPatientBuildingName\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'BuildingName'));\n        $(\"#txtPatientUnitNo\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'UnitNo'));\n        $(\"#txtPatientEmail\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'Email'));\n        $(\"#txtPatientRace\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'race'));\n        $(\"#txtPatientOccupation\").select2(\"val\", $(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'occupation'));\n        $(\"#txtPatientMarital\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'Marital'));\n        $(\"#txtPatientCountry\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'country'));\n        $(\"#txtPatientNotifications\").val(($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'notifications') == \"Y\" ? \"True\" : \"False\"));\n        $(\"#txtPatientIDTypeCode\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'idTypeCode'));\n        $(\"#txtPatientPostal\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'PCode'));\n        $(\"#txtPatientTel\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'tel'));\n        $(\"#txtPatientLanguageSP\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'languageSP'));\n        $(\"#select2-txtPatientOccupation-container\").attr(\"title\",$(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'occupation'));\n        $(\"#PreRegFilePath\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'FilePath'));\n        $(\"#txtPatientUseForAdd\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'UseForeignAdd') == \"Y\" ? \"True\" : \"False\");\n        $(\"#txtPatientForeignAdd1\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'ForeignAdd1'));\n        $(\"#txtPatientForeignAdd2\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'ForeignAdd2'));\n        $(\"#txtPatientForeignAdd3\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'ForeignAdd3'));\n        $(\"#txtPatientForeignAdd4\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'ForeignAdd4'));\n\n        if ($(\"#txtPatientUseForAdd\").val() == \"True\") {\n            $(\"#txtPatientBlkHseNo\").val(\"\");\n            $(\"#txtPatientStreet\").val(\"\");\n            $(\"#txtPatientBuildingName\").val(\"\");\n            $(\"#txtPatientUnitNo\").val(\"\");\n            $(\"#txtPatientPostal\").val(\"\");\n        }\n\n        var allergyStr = $(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'Allergy');\n\n        if (allergyStr != \"No Allergy\") {\n            var data = { Allergy: allergyStr };\n            var encoded = JSON.stringify(data)\n            $.ajax({\n                cache: false,\n                type: \"POST\",\n                data: encoded,\n                url: \"/Patient/InsertAllergy\",\n                contentType: \"application/json; charset=utf-8\",\n                dataType: \"json\",\n                success: function (result) {\n                    if(result.success){\n                        $('#patientAllergyOtherGrid').trigger('reloadGrid');\n\n                        if (allergyStr.trim().length == 0 || allergyStr.trim() == \"NIL\" || allergyStr.trim() == \"No Allergy\") {\n                            $(\"#chkPatientAllergy\").prop('checked', true);\n                            jQuery(\"#patientAllergyOtherGrid\").jqGrid(\"clearGridData\");\n                        }\n                        else {\n                            $(\"#chkPatientAllergy\").prop('checked', false);\n                        }\n                        //if(result.count > 0){\n                        //    $(\"#chkPatientAllergy\").prop('checked', false);\n                        //} else {\n                        //    $(\"#chkPatientAllergy\").prop('checked', true);\n                        //}\n                    }\n                }\n            });\n        }\n        else {\n            $(\"#chkPatientAllergy\").prop('checked', true);\n            jQuery(\"#patientAllergyOtherGrid\").jqGrid(\"clearGridData\");\n        }\n\n        let rows = jQuery(\"#patientConsentGrid\").getDataIDs();\n        for(a=0;a<rows.length;a++)\n        {\n            row=jQuery(\"#patientConsentGrid\").getRowData(rows[a]);\n            if(row[\"Type\"].toUpperCase()==\"PHONE\"){\n                row.Select1 = ($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'PhoneNoti') == \"Y\" ? \"True\" : \"False\");\n            }else if(row[\"Type\"].toUpperCase()==\"SMS\"){\n                row.Select1 = ($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'SMSNoti') == \"Y\" ? \"True\" : \"False\");\n            }else if(row[\"Type\"].toUpperCase()==\"EMSG\"){\n                row.Select1 = ($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'EMsgNoti') == \"Y\" ? \"True\" : \"False\");\n            }else if(row[\"Type\"].toUpperCase()==\"EMAIL\"){\n                row.Select1 = ($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'EmailNoti') == \"Y\" ? \"True\" : \"False\");\n            }\n            $(\"#patientConsentGrid\").setRowData(rows[a],row);\n        }\n        $(\"#IsDownloadProfile\").val(\"Y\");\n\n        if ($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'DownloadType') == \"PreReg\") {\n            $(\"#DownloadProfileType\").val(\"PreReg\");\n        }\n        else {\n            $(\"#DownloadProfileType\").val(\"EHA\");\n        }\n\n        $(this).closest('.modal').modal('hide');\n    }\n    //End Added by Zac 20211004\n\n    //Added by Jason 20211102 - calculate age\n    function ageCalculator() {\n        //var now = new Date(); //Todays Date\n        //var dob = $(\"#txtPatientDOB\").val().split(\"/\");\n        //var age = \"\";\n\n        //var dobDay = dob[0];\n        //var dobMonth = dob[1];\n        //var dobYear = dob[2];\n\n        //var nowDay = now.getDate();\n        //var nowMonth = now.getMonth() + 1;  //jan = 0 so month + 1\n        //var nowYear = now.getFullYear();\n\n        //var ageyear = nowYear - dobYear;\n        //var agemonth = nowMonth - dobMonth;\n        //var ageday = nowDay- dobDay;\n        //if (agemonth <= 0) {\n        //    ageyear--;\n        //    agemonth = (12 + agemonth);\n        //}\n        //if (nowDay < dobDay) {\n        //    agemonth--;\n        //    ageday = 30 + ageday;\n        //}\n\n        //if (ageyear == 0) {\n        //    age = agemonth + \" m\";\n        //} else {\n        //    age = ageyear + \" y\";\n        //}\n        $.ajax({\n            cache: false,\n            type: \"POST\",\n            url: \"/PatientMaster/GetPatAgeByCalculation?DOB=\"+$(\"#txtPatientDOB\").val(),\n            contentType: \"application/json; charset=utf-8\",\n            dataType: \"json\",\n            success: function (result) {\n                if (result.success) {\n                    $(\"#txtPatAge\").val(result.Age);\n                }\n                else {\n                    $(\"#txtPatAge\").val(\"\");\n                    swal(\"\", \"Unable to calculate patient age\", \"error\");\n                }\n            },\n            error: function (data) {\n            }\n        });\n    }\n    //End added by Jason 20211102\n\n    $('#btnRefCode').off(\"click\").click(function () {       //Edited by Jason 20211027 - add off click to prevent multiclick\n        $(\".fadeMe\").show();\n\n        $('#setupRefSourceModalLabel').text(\"Search Referral\");\n        $(\"#setupRefSourceModalBody\").load('https://clinicassist.sg:1080/en/SetupRefSource/Index');\n        AppendModal2Body_Load(\"setupRefSourceModal\", \"Search Referral\", \"/SetupRefSource/Index\", [], [], []);\n    });\n\n    $(\"#setupRefSourceModal\").on('shown.bs.modal', function () {\n        $('#setupRefSourceModalBody').find('#SetupRefSourceSearchKeyword').focus();\n    });\n\n    $('#setupRefSourceModal').on('hidden.bs.modal', function () {\n        $('#setupRefSourceModalBody').html('');\n        $('#setupRefSourceModalBody').empty();\n    });\n\n    $('#btnAgentCode').off(\"click\").click(function () {\n        $(\".fadeMe\").show();\n\n        arrFooterBtnList = [];\n        arrFooterBtnList2 = [];\n        arrFooterBtnList.push('<input type=\"button\" value=\"Confirm\" id=\"btnSetupAgentConfirm\" class=\"btn btn-sm ok-style\" />');\n\n        var appendDetail = { style: \"max-height:400px;max-width:907px;\", contentType: \"typeSimple\", cancelID: \"btnSetupAgentCancel\", footerLayout: \"R\" };\n\n        AppendModal2Body_Load(\"setupAgentModal\", \"Search Agent\", \"/SetupAgent/Index\", arrFooterBtnList, arrFooterBtnList2, appendDetail);\n    });\n\n    $(\"#btnVIPlink\").click(function (){\n        if (true == false) {\n            $(\"#btnEditVIPLinkOk\").css('display','none');\n\n            $(\"#txtVIPLink\").css('background-color', 'lightgrey');\n            $(\"#txtVIPLink\").attr('disabled','disabled');\n        }\n        $(\"#txtVIPLink\").val($(\"#VIPLink\").val());\n        $('#EditVIPLinkModal').modal('show');\n    });\n\n    $(\"#btnEditVIPLinkOk\").click(function (){\n        var viplink = $(\"#txtVIPLink\").val();\n        var pcno = $(\"#txtPatientNo\").val();\n        $.ajax({\n            cache: false,\n            type: \"POST\",\n            url: \"/Patient/UpdatePatientVIPLink?link=\"+viplink +'&pcno='+pcno,\n            contentType: \"application/json; charset=utf-8\",\n            dataType: \"json\",\n            success: function (result) {\n                if (result.success) {\n                    $(\"#VIPLink\").val(viplink);\n                    $('#EditVIPLinkModal').modal('hide');\n                }\n                else {\n                    swal(\"\", result.message, \"error\");\n                }\n            },\n            error: function (data) {\n            }\n        });\n    });\n\n    //$('.DetectEnterKey').keypress(function (e) {\n    //    var key = e.which;\n    //    if(key == 13)  // the enter key code\n    //    {\n    //        var ntabindex = parseFloat(this.getAttribute('tabindex'));\n    //        ntabindex++;\n    //        $('input[tabindex = \"'+ ntabindex +'\"').focus();\n    //        return false;\n    //    }\n    //});\n\n    function checkFilterQAccess() {\n        if (\"N\" == \"Y\") {\n            $(\"#txtPatientHP\").parent().hide();\n            $(\"#txtPatientTel\").parent().hide();\n            $(\"#txtPatientTel2\").parent().hide();\n            $(\"#txtPatientEmail\").parent().hide();\n            $(\"#txtPatientBlkHseNo\").parent().hide();\n            $(\"#txtPatientStreet\").parent().parent().parent().hide();\n            $(\"#txtPatientUnitNo\").parent().hide();\n            $(\"#txtPatientBuildingName\").parent().hide();\n            $(\"#txtPatientPostal\").parent().parent().parent().hide();\n            $(\"#txtPatientUseForAdd\").parent().hide();\n            $(\"#txtPatientForeignAdd1\").parent().hide();\n            $(\"#txtPatientForeignAdd2\").parent().hide();\n            $(\"#txtPatientForeignAdd3\").parent().hide();\n            $(\"#txtPatientForeignAdd4\").parent().hide();\n\n            setTimeout(function() {\n                $(\"#spRegionDiv\").css(\"margin-top\", -110);\n                $(\"#groupRegionDiv\").css(\"margin-top\", -145);\n                $(\"#referralRegionDiv\").css(\"margin-top\", -85);\n                $(\"#doctorDivRegion\").css(\"margin-top\", -35);\n            }, 100);\n        }\n    }\n\n    $(\"#btnSingPassDownload\").click(function() {\n        if ($(\"#txtPatientNo\").val() != \"NEW\") {\n            swal(\"\", \"Only when create new patient will need to use this button.\", \"warning\");\n        }\n        $.ajax({\n            cache: false,\n            url: \"/PatientMaster/GetSPPatient\",   //Modified by Lim Han Yong 20240528 - change Singpass to SP (GovTech block SingPass/CorpPass/Myinfo keyword)\n            type: 'post',\n            success: function (response) {\n                if (response.success) {\n                    if (response.Person == null) {\n                        swal(\"\", \"Please direct the patient to re-scan Clinic SingPass QR and give the patient's details.\", \"warning\");\n                    }\n                    else {\n                        var Person = JSON.parse(response.Person);\n                        //Modified by Cheng Yu 20220909 - if field from singpass has value then need to set the field to readonly\n                        if($(\"#txtPatientPName\").val(Person[0].PName).val() != ''){\n                            $(\"#txtPatientPName\").prop(\"readonly\",true).css(\"background\",\"lightgrey\").css(\"cursor\",\"not-allowed\");\n                        }\n                        if($(\"#txtPatientNRIC\").val(Person[0].NRIC).val() != ''){\n                            $(\"#txtPatientNRIC\").prop(\"readonly\",true).css(\"background\",\"lightgrey\").css(\"cursor\",\"not-allowed\");\n                        }\n                        if($(\"#txtPatientDOB\").val(Person[0].DOB).val() != ''){\n                            $(\"#txtPatientDOB\").prop(\"readonly\",true).css(\"background\",\"lightgrey\").css(\"cursor\",\"not-allowed\").focusout();\n                        }\n                        if($(\"#txtPatientHP\").val(Person[0].HP).val() != ''){\n                            $(\"#txtPatientHP\").prop(\"readonly\",true).css(\"background\",\"lightgrey\").css(\"cursor\",\"not-allowed\");\n                        }\n                        if($(\"#txtPatientBlkHseNo\").val(Person[0].BlkHseNo).val() != ''){\n                            $(\"#txtPatientBlkHseNo\").prop(\"readonly\",true).css(\"background\",\"lightgrey\").css(\"cursor\",\"not-allowed\");\n                        }\n                        if($(\"#txtPatientStreet\").val(Person[0].Street).val() != ''){\n                            $(\"#txtPatientStreet\").prop(\"readonly\",true).css(\"background\",\"lightgrey\").css(\"cursor\",\"not-allowed\");\n                        }\n                        if($(\"#txtPatientUnitNo\").val(Person[0].UnitNo).val() != ''){\n                            $(\"#txtPatientUnitNo\").prop(\"readonly\",true).css(\"background\",\"lightgrey\").css(\"cursor\",\"not-allowed\");\n                        }\n                        if($(\"#txtPatientBuildingName\").val(Person[0].BuildingName).val() != ''){\n                            $(\"#txtPatientBuildingName\").prop(\"readonly\",true).css(\"background\",\"lightgrey\").css(\"cursor\",\"not-allowed\");\n                        }\n                        if($(\"#txtPatientPostal\").val(Person[0].Postal).val() != ''){\n                            $(\"#txtPatientPostal\").prop(\"readonly\",true).css(\"background\",\"lightgrey\").css(\"cursor\",\"not-allowed\");\n                        }\n                        if($(\"#txtPatientEmail\").val(Person[0].Email).val() != ''){\n                            $(\"#txtPatientEmail\").prop(\"readonly\",true).css(\"background\",\"lightgrey\").css(\"cursor\",\"not-allowed\");\n                        }\n                        if($(\"#txtPatientSex\").val(Person[0].Sex).val() && $(\"#txtPatientSex\").val() != ''){\n                            $('#txtPatientSex').attr(\"style\", \"pointer-events: none;width:74.7969px;background:lightgrey;\");\n                            $('#txtPatientSex option:not(:selected)').remove();\n                        }\n                        if($(\"#txtPatientNation\").val(Person[0].Nation).val() && $(\"#txtPatientNation\").val() != ''){\n                            $('#txtPatientNation').attr(\"style\", \"pointer-events: none;width:205.688px;background:lightgrey;\");\n                            $('#txtPatientNation option:not(:selected)').remove();\n                        }\n                        //console.log(Person[0].Country);\n                        if($(\"#txtPatientCountry\").val(Person[0].Country).val() && $(\"#txtPatientCountry\").val() != ''){\n                            $('#txtPatientCountry').attr(\"style\", \"pointer-events: none;width:216.906px;background:lightgrey;\");\n                            $('#txtPatientCountry option:not(:selected)').remove();\n                        }\n                        if($(\"#txtPatientIDTypeCode\").val(Person[0].IDTypeCode).val() && $(\"#txtPatientIDTypeCode\").val() != ''){\n                            $('#txtPatientIDTypeCode').attr(\"style\", \"pointer-events: none;width:209.438px;background:lightgrey;\");\n                            $('#txtPatientIDTypeCode option:not(:selected)').remove();\n                        }\n\n                        var RaceInOptions = $('#txtPatientRace option').filter(function () {\n                            return this.value.toUpperCase() === Person[0].Race;\n                        } ).attr('value');\n\n                        if($(\"#txtPatientRace\").val(RaceInOptions).val() && $(\"#txtPatientRace\").val() != ''){\n                            $('#txtPatientRace').attr(\"style\", \"pointer-events: none;width:149.594px;background:lightgrey;\");\n                            $('#txtPatientRace option:not(:selected)').remove();\n                        }\n                        $(\"#btnPostal\").css(\"pointer-events\", \"none\").unbind(\"click\");\n                        $(\"#btnStreet\").css(\"pointer-events\", \"none\").unbind(\"click\");\n                        //End Modified by Cheng Yu 20220909\n                    }\n                }\n            },\n        });\n    });\n\n    $(\"#btnMemberCheck\").click(function () {\n        if ($(\"#txtPatientNRIC\").val() == \"\" || $(\"#txtPatientHP\").val() == \"\" || $(\"#txtPatientDOB\").val() == \"\"){\n            swal(\"\", \"Please input NRIC/FIN/OTHERS, mobile number and DOB before proceed to create mobile user.\", \"warning\");\n            return;\n        }\n        else {\n            //Added by JiunWei 20230314 - Check if patient is EHA member. If patient is EHA member, retrieve memberID from EHA and update to CASWEB\n            $.ajax({\n                cache: false,\n                url: \"/PatientMaster/CheckIsEHAMember\",\n                //data: '{pcno: \"' + $(\"#txtPatientNo\").val() + '\", nric: \"' + $(\"#txtPatientNRIC\").val() + '\", mobileNo: \"' + $(\"#txtPatientHP\").val() + '\", dob: \"' + $(\"#txtPatientDOB\").val() + '\", idTypeCode: \"' + $(\"#txtPatientIDTypeCode\").val() + '\"}',\n                data: JSON.stringify({\n                    pcno: $(\"#txtPatientNo\").val(),\n                    nric: $(\"#txtPatientNRIC\").val(),\n                    mobileNo: $(\"#txtPatientHP\").val(),\n                    dob: $(\"#txtPatientDOB\").val(),\n                    idTypeCode: $(\"#txtPatientIDTypeCode\").val()\n                }),\n                type: 'post',\n                contentType: \"application/json; charset=utf-8\",\n                dataType: \"json\",\n                success: function (response) {\n                    if (response.success) {\n                        if (!response.isMember) {\n                            arrFooterBtnList = [];\n                            arrFooterBtnList2 = [];\n                            arrFooterBtnList.push('');\n                            arrFooterBtnList2.push('<input type=\"button\" value=\"Copy Link\" id=\"btnMobileCopyLink\" class=\"btn btn-sm ok-style\" style=\"margin-right: 7px\" />');\n                            arrFooterBtnList2.push('<input type=\"button\" value=\"Send SMS\" for=\"S\" class=\"btn btn-sm ok-style btnSendLink\" style=\"margin-right: 7px\" />');\n                            arrFooterBtnList2.push('<input type=\"button\" value=\"Send Email\" for=\"M\" class=\"btn btn-sm ok-style btnSendLink\" />');\n\n                            var appendDetail = { style: \"max-height:154px;max-width:465px;\", cancelID: \"btnCloseMobileModal\", footerLayout: \"LR\" };\n\n                            AppendModal2Body_Load(\"CreateMobileUserModal\", \"Create APP User\", 'https://clinicassist.sg:1080/en/PatientMaster/CreateMobileUser?id=' + $(\"#txtPatientNo\").val(), arrFooterBtnList, arrFooterBtnList2, appendDetail);\n\n                            $(\"#btnCloseMobileModal\").click(function() {\n                                $(this).closest(\".modal\").modal('hide');\n                                $(this).closest(\".modal\").remove();\n                            });\n                        }else{\n                            swal(\"\",\"Member ID found. This patient is an EHA member.\",\"warning\");\n                            $(\"#btnMemberCheck\").hide();\n                            $(\"#lblMemberID\").show();\n                            $(\"#lblMemberID\").html(\"APP Member ID: \" + response.memberID);\n                            $(\"#btnMemberIDReset\").show();\n                        }\n                    }\n                },\n            });\n        }\n    });\n\n    $(\"#btnMemberIDReset\").click(function() {\n        if ($(\"#txtPatientNRIC\").val() == \"\" || $(\"#txtPatientHP\").val() == \"\" || $(\"#txtPatientDOB\").val() == \"\"){\n            swal(\"\", \"Please input NRIC/FIN/OTHERS, mobile number and DOB before proceed to create mobile user.\", \"warning\");\n            return;\n        }\n        else {\n            arrFooterBtnList = [];\n            arrFooterBtnList2 = [];\n            arrFooterBtnList.push('');\n            arrFooterBtnList2.push('<input type=\"button\" value=\"Copy Link\" id=\"btnMobileCopyLink\" class=\"btn btn-sm ok-style\" style=\"margin-right: 7px\" />');\n            arrFooterBtnList2.push('<input type=\"button\" value=\"Send SMS\" for=\"S\" class=\"btn btn-sm ok-style btnSendLink\" style=\"margin-right: 7px\" />');\n            arrFooterBtnList2.push('<input type=\"button\" value=\"Send Email\" for=\"M\" class=\"btn btn-sm ok-style btnSendLink\" />');\n\n            var appendDetail = { style: \"max-height:154px;max-width:465px;\", cancelID: \"btnCloseMobileModal\", footerLayout: \"LR\" };\n\n            AppendModal2Body_Load(\"CreateMobileUserModal\", \"Create APP User\", 'https://clinicassist.sg:1080/en/PatientMaster/CreateMobileUser?id=' + \"78160\", arrFooterBtnList, arrFooterBtnList2, appendDetail);\n\n            $(\"#btnCloseMobileModal\").click(function() {\n                $(this).closest(\".modal\").modal('hide');\n                $(this).closest(\".modal\").remove();\n            });\n        }\n    });\n\n\n    $(\"#showCompanyInfo\").change(function() {\n        if (this.checked) {\n            $(\".company-form\").css(\"display\", \"flex\").hide().fadeIn();\n        }\n        else {\n            $(\".company-form\").fadeOut();\n        }\n    });\n\n    function isLetter(event) {\n        const charCode = (event.which) ? event.which : event.keyCode;\n\n        // Allow backspace, delete, arrow keys (left: 37, right: 39), and space\n        if (charCode === 8 || charCode === 46 || (charCode === 37 && !event.shiftKey) || charCode === 39 || charCode === 32) {\n            return true;\n        }\n\n        // Prevent '%' symbol (Shift + 5 results in '%')\n        if (charCode === 53 && event.shiftKey) {\n            return false;\n        }\n\n        // Allow letters (A-Z, a-z) and specific symbols (parentheses, comma)\n        if ((charCode >= 65 && charCode <= 90) || (charCode >= 97 && charCode <= 122) || charCode === 40 || charCode === 41 || charCode === 44) {\n            return true;\n        }\n\n\n        return false;\n    }\n\n    function validatePaste(event) {\n        const paste = (event.clipboardData || window.clipboardData).getData('text');\n\n        // Regular expression to allow only letters, spaces, brackets, and commas\n        const regex = /^[A-Za-z(),\\s]+$/;\n\n        if (!regex.test(paste)) {\n            event.preventDefault();\n        }\n    }\n\n    function showNotificationInfo() {\n        if ($('#divNotificationInfo').is(':visible')) {\n            $('#divNotificationInfo').hide();\n        } else {\n            if ('False' == 'False') {\n                $('#subscriptionInfo').show();\n            }\n\n            $('#divNotificationInfo').show();\n        }\n    }\n\n    $(document).click(function (event) {\n        var tooltip = $('#divNotificationInfo');\n        var buttonInfo = $('#btnNotificationInfo');\n        var buttonAdd = $('#btnNotificationAdd');\n\n        if (!(tooltip.is(event.target) || tooltip.has(event.target).length > 0 || buttonInfo.is(event.target) || buttonAdd.is(event.target))) {\n            tooltip.hide();\n        }\n    });\n\n                                \n                                \n                                    \n\n\n    Access Denied.\n    You have no permission to access.",
