 MATHEW [Spine & Neurosurgeon]\nJohn Anthony Tay [Physio]\nJOTHIRAMALINGAM VINOTH [Physio]\nREKHA NIKHIL KUVELKAR [Physio]\nWee Yong [Physio]\n\n                            \n                        \n                    \n\n                    \n                    \n                        \n                            \n\n\n\n    .divProfilePicture {\n        display: flex;\n        justify-content: center;\n        align-items: center;\n        background-color: #f5f5f5;\n        /*border-radius: 50%;*/\n        /*border: 6px double #33333387;*/\n        /*box-shadow: 0 0 10px rgba(0, 0, 0, 0.2);*/\n        overflow: hidden;\n        pointer-events: none;\n    }\n\n\n    #imgPatientPhoto {\n        width: 200px;\n        height: 200px;\n        object-fit: cover;\n        /*border-radius: 50%;*/\n    }\n\n\n\n    \n\n                \n            \n\n\n    $(document).ready(function () {\n        if($('#hfPatitentPhoto').val() == \"\") {\n            $('#hfPatitentPhoto').val(\"/Content/images/blank-profile-picture.png\");\n        }\n        $('#imgPatientPhoto').attr('src', $('#hfPatitentPhoto').val());\n\n        oldDataBiodata = JSON.stringify($('#CreateEditPatientForm').serializeArray());      //Added by Jason 20211022 - get data\n\n        if ($('#hfShowPhoto').val() == \"False\") {\n            $('#imgPatientPhoto').hide();\n        }\n    });\n\n    $(document).ajaxStop(function () {\n        $(\".fadeMe\").hide();\n    });\n\n                        \n                    \n                \n\n                \n                \n                    \n                    \n                        \n                            Blk/Hse No\n\n                            \n                        \n\n                        \n                            Street\n\n                            \n                                \n\n                                ...   \n                            \n                        \n                    \n\n                    \n                    \n                        \n                            Unit\n\n                            \n                        \n\n                        \n                            Building Name\n\n                            \n                        \n                    \n\n                    \n                    \n                        \n                            Postal Code\n\n                            \n                                 \n\n                                      \n                            \n                        \n\n                        \n                            Use Foreign Add\n\n                            \nYes\nNo\n\n                        \n                    \n                    \n                    \n                        \n                            State\n\n                            \n                            \nJohor\nKedah\nKelantan\nMelaka\nNegeri Sembilan\nPahang\nPulau Pinang\nPerak\nPerlis\nSelangor\nTerengganu\nSabah\nSarawak\nWilayah Persekutuan Kuala Lumpur\nWilayah Persekutuan Labuan\nWilayah Persekutuan Putrajaya\nNot Applicable\n                            \n                            \n                        \n\n                        \n                            City\n\n                                                       \n                    \n\n                    \n                    \n                        \n                            Foreign Address\n\n                            \n                        \n\n                        \n\n                        \n\n                        \n                    \n                \n\n                \n                \n                    \n                    \n                        \n                            Mobile No.\n\n                            \n                        \n\n                        \n                            Other Contact\n\n                            \n                        \n                    \n\n                    \n                    \n                        \n                            Tel(H)\n\n                            \n                        \n\n                        \n                            Email\n\n                            \n                        \n                    \n                \n\n                \n                \n                    \n                    Company Information\n\n                    \n                    \n                        Company\n\n                        \n                            \n\n                            \n                            ...\n\n                            \n                            \n\n                        \n                    \n\n                    \n                    \n                        \n                            Emp No\n\n                            \n                        \n\n                        \n                            Department\n\n                            \n                        \n                    \n\n                    \n                    \n                    \n                    \n                    \n                        Co-Payment\n\n                        \n                              \n                            $\n                            \n\n                              \n                            %\n                            \n                        \n                    \n                     \n                \n\n                \n                \n                    \n                    \n                        \n                            \n                                Notification\n\n                                \n                                    \n                                        \n                                    \n                                    Add\n                                \n                            \n\n                            \n                                    \n                                        \n                                    \n                                    SMS\n                                \n                                \n\n                                \n                                    \n                                        \n                                    \n                                    Email\n                                \n                                \n                                    \n                                        \n                                    \n                                    WhatsApp\n                                \n                            \n\n                            \n                                \n                                \n                                    \n                                        \n                                            \n                                                Subscribe to Activate WhatsApp Messaging\n                                            \n                                            To enable automatic WhatsApp message sending, please ensure your clinic has subscribed to SendQuick for the onboarding process and WhatsApp account setup. For any inquiries, you can contact SendQuick at +65 6280 2881, email them at info@sendquick.com, or visit their website at www.sendquick.com.\n                                            Note: When contacting SendQuick to subscribe, please mention that you are a user of Clinic Assist to have the onboarding process fee waived.\n                                            \n                                                For more information, please visit WhatsApp Onboarding Guide.\n                                            \n                                            \n                                        \n                                        \n                                        \n                                            Notification Preference\n                                        \n                                        \n                                            You can drag the notification buttons to reorder them.\n                                            The first notification in the list is considered your preferred notification.\n                                        \n                                        Note:\n                                        \n                                            Currently, only WhatsApp set as the preferred method will trigger automatic messages. Appointment-related messages will be sent automatically when an appointment is added, updated, or canceled, while payment-related messages — including Invoice, Receipt, or MC attachments — will be sent automatically upon successful payment.\n                                            Email and SMS currently do not trigger any automatic messages when set as preferred.\n                                        \n                                    \n                                \n                            \n                        \n\n                        \n                            Consent to receive marketing information\n\n                            \nYes\nNo\n\n                        \n                    \n                \n\n                \n                \n                    \n                    \n                        \n                            Notes\n                        \n\n                        \n                    \n\n                    \n                    \n                        \n                            Group\n\n                            \n                                \n                                    \n                                \n                                Add\n                            \n                        \n\n                        \n                            \n                        \n                    \n\n                    \n                    \n                        Media Source\n\n                        \n\n                    \n\n                    \n                    \n                        Referral\n\n                        \n                             \n                            ...\n                                 \n                        \n                    \n\n                    \n                    \n                        Doctor\n\n                        \nPatient\n\n                    \n\n                    \n                    \n                        Agent\n\n                        \n                            \n                            ...",
      "Subscribe to Activate WhatsApp Messaging\n                                            \n                                            To enable automatic WhatsApp message sending, please ensure your clinic has subscribed to SendQuick for the onboarding process and WhatsApp account setup. For any inquiries, you can contact SendQuick at +65 6280 2881, email them at info@sendquick.com, or visit their website at www.sendquick.com.\n                                            Note: When contacting SendQuick to subscribe, please mention that you are a user of Clinic Assist to have the onboarding process fee waived.\n                                            \n                                                For more information, please visit WhatsApp Onboarding Guide.\n                                            \n                                            \n                                        \n                                        \n                                        \n                                            Notification Preference\n                                        \n                                        \n                                            You can drag the notification buttons to reorder them.\n                                            The first notification in the list is considered your preferred notification.\n                                        \n                                        Note:\n                                        \n                                            Currently, only WhatsApp set as the preferred method will trigger automatic messages. Appointment-related messages will be sent automatically when an appointment is added, updated, or canceled, while payment-related messages — including Invoice, Receipt, or MC attachments — will be sent automatically upon successful payment.\n                                            Email and SMS currently do not trigger any automatic messages when set as preferred.",
      "Currently, only WhatsApp set as the preferred method will trigger automatic messages. Appointment-related messages will be sent automatically when an appointment is added, updated, or canceled, while payment-related messages — including Invoice, Receipt, or MC attachments — will be sent automatically upon successful payment.",
      "/*.ui-jqgrid-bdiv {\n        overflow: hidden !important;\n    }*/\n\n    tr.ui-widget-content {\n        border: 1px solid #cccccc;\n    }\n\n    .jqgrow.myAltRowClass > td {\n        background: #d1ead8;\n    }\n\n    .jqgrow.myAltRowClass2 > td {\n        background: #f3cbaf !important;\n    }\n\n    .ui-state-disabled {\n        opacity: inherit !important;\n    }\n\n    table.table-condensed tr th {\n        color: black !important;\n    }\n\n    #tabPastMeds_frame .tab-content { /*Added by zhaoying 20190527*/\n        padding: 0px 0px 0px 0px;\n    }\n     .jqgrow.PrescriptionRowBC td {\n        background: #f3cbaf;\n    }\n\n     .noBold{\n         font-weight: normal !important;\n     }\n\n     .ui-jqgrid tr.jqgrow td {\n        word-wrap: normal !important;\n        white-space: initial !important;\n    }\n\n    #Grid_PattabxAll, #Grid_PattabxMedicine, #Grid_tabxInvestigation, #Grid_PattabxProcedure,\n    #Grid_PattabxDiagnosis, #Grid_PattabxMC, #Grid_PattabxVisit {\n        border: none;\n        /*width: 800px*/\n    }\n\n\n\n\n\n\n\n\n\n    \n        \n            \n                Date From\n                \n                To\n                \n                \n            \n            \n                \n                    All\n                    Medicine\n                    Investigation\n                    Procedure\n                    Diagnosis\n                    \n                    M.C\n                    Visit\n                     Add MC\n                \n\n                \n                    \n                    \n                    Vaccination\n                    \n                    \n                    Prescription\n                \n            \n        \n            \n            \n                \n                         \n                        Loading... Date Grp Description Amount Charge Branch03/02/2026PcrSPECIALIST FIRST CONSULTATION1.00 $120.00SSOC \n                    \n                    \n                        \n                            \n                        \n                    \n                \n                        \n                     \n                        \n                    \n                \n                \n                         \n                        \n                    \n                \n                \n                            \n                        \n                    \n                \n                \n                         \n                        \n                    \n                \n                \n                         \n                        \n                    \n                \n                \n                           \n                        \n                    \n                \n                \n                    \n                        \n                    \n                \n                \n                    \n                        \n                        \n                    \n                \n            \n        \n    \n\n\n\n    var urlLocation = jQuery(location).attr('href');\n\n    $('#tabQueueHisTab a[data-toggle=\"tab\"]').click(function (e) {  //Edited by Xirlyn 20240118 - Enable to auto load data when switching tab\n            var target = $(e.target).attr(\"href\");\n            getTxHistory(target);\n\n        if ((target == '#PattabxMedicine' || target == '#PattabxProcedure' || target == '#PattabxInvestigate')) {\n            if (urlLocation.indexOf(\"QueueDispense/Index\") > 0) {\n                if (target == '#PattabxProcedure') {\n\n                    $(\"#DispenseTxPanelMed\").css(\"display\", \"none\");\n                    var ids = $(\"#jqGrid_PattabxProcedure\").jqGrid(\"getDataIDs\");\n                    if (ids.length > 0) {\n                        $(\"#btnDispenseTxSelectAll\").prop(\"disabled\", false);\n                    }\n                    else {\n                        $(\"#btnDispenseTxSelectAll\").prop(\"disabled\", true);\n                    }\n                    if ($(\"#hdPayType\").val() == \"SFL\") {\n                        $(\"#btnDispenseTxSelectAll\").prop(\"disabled\", true);\n                    }\n                    $(\"#jqGrid_PattabxProcedure\").jqGrid('resetSelection'); //Added by Koh Chin Choong 20201209 - If press procedure tab reset the selection\n                }\n                else if (target == '#PattabxInvestigate') {\n\n                    $(\"#DispenseTxPanelMed\").css(\"display\", \"none\");\n                    var ids = $(\"#jqGrid_tabxInvestigation\").jqGrid(\"getDataIDs\");\n                    if (ids.length > 0) {\n                        $(\"#btnDispenseTxSelectAll\").prop(\"disabled\", false);\n                    }\n                    else {\n                        $(\"#btnDispenseTxSelectAll\").prop(\"disabled\", true);\n                    }\n                    if ($(\"#hdPayType\").val() == \"SFL\") {\n                        $(\"#btnDispenseTxSelectAll\").prop(\"disabled\", true);\n                    }\n                    $(\"#jqGrid_tabxInvestigation\").jqGrid('resetSelection'); //Added by Koh Chin Choong 20201209 - If press investigation tab reset the selection\n                }\n                else if (target == '#PattabxMedicine') {\n                    $(\"#DispenseTxPanelMed\").css(\"display\", \"block\");\n                    GetMedicineHistory($(\"#hfPCNOfortxHist\").val(), $(\"#txtMedDateFrom\").val(), $(\"#txtMedDateTo\").val());\n                    var ids = $(\"#jqGrid_PattabxMedicine\").jqGrid(\"getDataIDs\");\n                    if (ids.length > 0) {\n                        $(\"#btnDispenseTxSelectAll\").prop(\"disabled\", false);\n                    }\n                    else {\n                        $(\"#btnDispenseTxSelectAll\").prop(\"disabled\", true);\n                    }\n                    if ($(\"#hdPayType\").val() == \"SFL\") {\n                        $(\"#btnDispenseTxSelectAll\").prop(\"disabled\", true);\n                    }\n                    $(\"#jqGrid_PattabxMedicine\").jqGrid('resetSelection'); //Added by Koh Chin Choong 20201209 - If press medicine tab reset the selection\n                }\n\n                $(\"#btnDispenseTxSelectAll\").html(\"Select All\");\n                $(\".DispenseTxPanel\").show();\n            }\n        } else {\n            $(\".DispenseTxPanel\").hide();\n        }\n    });\n\n    function DispenseTxSelectAll() {\n        var tab = $(\"#tabQueueHisTab li.active a\").attr(\"href\");\n        var grid = $(\"#jqGrid_PattabxMedicine\");\n\n        if (tab == \"#PattabxMedicine\") {\n            grid = $(\"#jqGrid_PattabxMedicine\");\n        } else if (tab == \"#PattabxInvestigate\") {\n            grid = $(\"#jqGrid_tabxInvestigation\");\n        } else if (tab == \"#PattabxProcedure\") {\n            grid = $(\"#jqGrid_PattabxProcedure\");\n        }\n\n        var ids = $(grid).jqGrid('getGridParam', 'selarrrow');\n\n        if (ids.length > 0) {\n            $(grid).jqGrid('resetSelection');\n            $(\"#btnDispenseTxSelectAll\").html(\"Select All\");\n        } else {\n            $(grid).jqGrid('resetSelection');\n            var ids1 = $(grid).getDataIDs();\n            for (var i = 0, il = ids1.length; i < il; i++) {\n                $(grid).jqGrid('setSelection', ids1[i], true);\n            }\n            $(\"#btnDispenseTxSelectAll\").html(\"Unselect All\");\n        }\n    }\n\n    function RepeatLastVisitOK() {\n        var tab = $(\"#tabQueueHisTab li.active a\").attr(\"href\");\n        if (tab == \"#PattabxMedicine\") {\n            Meds_RepeatLastVisitOK();\n        } else if (tab == \"#PattabxInvestigate\") {\n            InvProc_RepeatLastVisitOK(\"#jqGrid_tabxInvestigation\");\n        } else if (tab == \"#PattabxProcedure\") {\n            InvProc_RepeatLastVisitOK(\"#jqGrid_PattabxProcedure\");\n        }\n    }\n\n    function InvProc_RepeatLastVisitOK(id) {\n        fromTXmsg = [];\n        var grid = $(id);\n        var ids = $(grid).jqGrid('getGridParam', 'selarrrow');\n\n        var i = 0, howManyTimes = ids.length;\n        if (howManyTimes > 0) {\n            function f() {\n                rowData = $(grid).jqGrid('getRowData', ids[i]);\n                if (id == \"#jqGrid_PattabxProcedure\") {\n                    GetProcedurebyProcCode(rowData['MHC_Code'], true);\n                } else {\n                    GetInvestigationbyInvCode(rowData['MHC_Code'], true);\n                }\n\n                i++;\n                if (i < howManyTimes) {\n                    setTimeout(f, 1000);\n                } else {\n\n                    $(grid).jqGrid('resetSelection');\n\n                    setTimeout(\n                      function () {\n                          if (fromTXmsg.length > 0) {\n                              swal(\"\", \"Item(s): \" + fromTXmsg.join(', ') + \" cannot be added from tx, please dispense manually.\", \"warning\");\n                          }\n                      }, (1000));\n                }\n            }\n            f();\n        } else {\n            swal(\"\", \"No item selected\", \"warning\");\n        }\n    }\n\n    var check;\n    function Meds_RepeatLastVisitOK() {\n        var grid = $(\"#jqGrid_PattabxMedicine\");\n        var ids = $(grid).jqGrid('getGridParam', 'selarrrow');\n\n        if (ids.length > 0) {\n            $(grid).jqGrid('resetSelection');\n            console.log(\"loop\");\n            var i = ids.length - 1;\n            (function theLoop(grid, ids, i) {\n                setTimeout(function () {\n                    console.log(i);\n                    var rowData = $(grid).jqGrid('getRowData', ids[i]);\n                    console.log(rowData);\n                    var drugCode = rowData['MHC_Code'];\n                    var drugDesc = rowData['Description'];\n                    console.log(\"drugCode: \" + drugCode);\n                    console.log(\"drugDesc: \" + drugDesc);\n                    var checkDrugMIMS = $(\"#DrugMIMS\").val();\n\n                    if (checkDrugMIMS == 'True') {\n                        $.ajax({\n                            cache: false,\n                            url: \"/QueueDispense/CheckPatientAllergy?pcno=\" + $('#txtPCNO').val() + \"&drugCode=\" + drugCode,\n                            ContentType: \"application/json\",\n                            type: \"POST\",\n                            data: \"\",\n                            success: function (result) {\n                                if (result.success) {\n                                    var delayPromptTime = 0;\n                                    if ($(\".sa-confirm-button-container\").is(\":visible\")) {\n                                        delayPromptTime = 2000;\n                                    }\n                                    setTimeout(function () {\n                                        swal({ title: \"\", text: \"Patient Is allergic to \" + drugDesc + \"!\\n Are you sure you want to prescribe this medicine?\", type: \"warning\", showCancelButton: true, cancelButtonText: \"Continue Dispense\", confirmButtonText: \"Cancel Dispense\", closeOnConfirm: true },\n                                    function (popout) {\n                                        if (!popout) {\n                                            console.log(\"allergy continue dispense\");\n                                            CheckDrugExpiry(rowData, drugCode);\n\n                                            var checkDrugExpiryDoneInterval = setInterval(function () {\n                                                if (checkDrugExpiryDone == true) {\n                                                    clearInterval(checkDrugExpiryDoneInterval);\n                                                    console.log(\"WHAT : \" + i);\n                                                    if (i > 0) {                  // If i > 0, keep going\n                                                        console.log(\"why : \" + i);\n                                                        i = i - 1;\n                                                        theLoop(grid, ids, i);  // Call the loop again\n                                                    }\n                                                }\n                                            }, 0);\n\n                                        }\n                                        else {\n                                            console.log(\"allergy don't continue dispense\");\n                                            console.log(\"WHAT : \" + i);\n                                            if (i > 0) {                  // If i > 0, keep going\n                                                console.log(\"why : \" + i);\n                                                i = i - 1;\n                                                theLoop(grid, ids, i);  // Call the loop again\n                                            }\n                                        }\n                                    })\n                                    }, delayPromptTime);\n                                }\n                                else { //no allergy\n                                    console.log(\"no allergy\");\n                                    CheckDrugExpiry(rowData, drugCode);\n                                    console.log(\"checkDrugExpiryDone: \" + checkDrugExpiryDone);\n                                    var checkDrugExpiryDoneInterval = setInterval(function () {\n                                        if (checkDrugExpiryDone == true) {\n                                            clearInterval(checkDrugExpiryDoneInterval);\n                                            console.log(\"WHAT : \" + i);\n                                            if (i > 0) {                  // If i > 0, keep going\n                                                console.log(\"why : \" + i);\n                                                i = i - 1;\n                                                theLoop(grid, ids, i);  // Call the loop again\n                                            }\n                                        }\n                                    }, 0);\n                                }\n                            }\n                        });\n                    }\n                    else {\n                        CheckDrugExpiry(rowData, drugCode);\n                        var checkDrugExpiryDoneInterval = setInterval(function () {\n                            if (checkDrugExpiryDone == true) {\n                                clearInterval(checkDrugExpiryDoneInterval);\n                                console.log(\"WHAT : \" + i);\n                                if (i > 0) {                  // If i > 0, keep going\n                                    console.log(\"why : \" + i);\n                                    i = i - 1;\n                                    theLoop(grid, ids, i);  // Call the loop again\n                                }\n                            }\n                        }, 0);\n                    }\n                }, 0);\n            })(grid, ids, i);\n        } else {\n            swal(\"\", \"No item selected\", \"warning\");\n        }\n    }\n\n    var checkDrugExpiryDone = false;\n    function CheckDrugExpiry(rowData, drugCode) {\n        checkDrugExpiryDone = false;\n        $.ajax({\n            cache: false,\n            url: \"/QueueDispense/CheckDrugExpiry?drugCode=\" + drugCode + \"&type=\" + rowData['MHC_IsVaccine'],\n            ContentType: \"application/json\",\n            type: \"POST\",\n            data: \"\",\n            success: function (result1) {\n                if (result1.success) {\n                    if (result1.drugExpired == true) { //Expired //Modified by bryan 20190918 - skip validation when it is prescription && rowData['MHC_IsVaccine'] != \"X\"\n                        if (result1.drugExpiredNextAvail == true) {\n                            var delayPromptTime = 0;\n                            if ($(\".sa-confirm-button-container\").is(\":visible\")) {\n                                delayPromptTime = 2000;\n                            }\n                                setTimeout(function () {\n                                    swal({\n                                        title: \"\",\n                                        text: \"Drug expired in \" + drugCode + \"\\n\\nDo you want to update to NEW Batch?\",\n                                        type: \"\",\n                                        showCancelButton: true,\n                                        confirmButtonColor: \"#DD6B55\",\n                                        cancelButtonText: \"No\",\n                                        confirmButtonText: \"Yes\",\n                                        closeOnConfirm: false\n                                    }, function (isConfirm) {\n                                        if (isConfirm) {\n                                            var datarow = {\n                                                Code: drugCode\n                                            };\n                                            var d = { batchExpiry: datarow };\n\n                                            $.ajax({\n                                                cache: false,\n                                                type: \"POST\",\n                                                url: \"/BatchExpiry/UpdateBatchExpiryCompleted\",\n                                                async: true,\n                                                data: JSON.stringify(d),\n                                                contentType: \"application/json; charset=utf-8\",\n                                                dataType: \"json\",\n                                                success: function (result2) {\n                                                    if (result2.success) {\n                                                        swal.close();\n                                                        repeatPastMed(rowData);\n                                                    } else {\n                                                        swal({\n                                                            title: \"\",\n                                                            text: result2.message,\n                                                            type: \"error\",\n                                                            showCancelButton: false,\n                                                            closeOnConfirm: true,\n                                                            closeOnCancel: false\n                                                        }, function (isConfirm) {\n                                                            if (isConfirm) {\n                                                                checkDrugExpiryDone = true;\n                                                            }\n                                                        });\n                                                    }\n                                                },\n                                                error: function (response) {\n                                                    checkDrugExpiryDone = true;\n                                                }\n                                            });\n                                        }\n                                        else {\n                                            swal.close();\n                                            checkDrugExpiryDone = true;\n                                            return;\n                                        }\n                                    });\n                                }, delayPromptTime);\n                        }\n                        else { //next batch unavailable\n                            var delayPromptTime = 0;\n                            if ($(\".sa-confirm-button-container\").is(\":visible\")) {\n                                delayPromptTime = 2000;\n                            }\n                                setTimeout(function () {\n                                    swal({\n                                        title: \"\",\n                                        text: \"\\nDrug expired in\" + drugCode,\n                                        type: \"\",\n                                        showCancelButton: false,\n                                        closeOnConfirm: true,\n                                        closeOnCancel: false\n                                    }, function (isConfirm) {\n                                        if (isConfirm) {\n                                            checkDrugExpiryDone = true;\n                                        }\n                                    });\n                                }, delayPromptTime);\n                                return;\n                        }\n                    }\n                    else { //Not Expired\n                        repeatPastMed(rowData);\n                    }\n                }\n                else {\n                    swal({\n                        title: \"\",\n                        text: result1.message,\n                        type: \"error\",\n                        showCancelButton: false,\n                        closeOnConfirm: true,\n                        closeOnCancel: false\n                    }, function (isConfirm) {\n                        if (isConfirm) {\n                            checkDrugExpiryDone = true;\n                        }\n                    });\n                }\n            }\n        });\n    }\n\n    function repeatPastMed(rowData) {\n        var patMediClaim = $(\"#hdMediClaimStatus\").val();\n        var patCHASClaimable = $(\"#hdIsCHAS\").val();\n\n        var insertLastVisit = {\n            //Get previous visit details\n            VisitNo: rowData['MHC_VisitNo'],\n            Clinic: rowData['Clinic'],\n            ItemNo: rowData['MHC_ItemNo'],\n            //Get current visit details\n            QueueVisitNo: $('#txtVisitNo').val(),\n            QueueClinic: $('#txtClinic').val(),\n            SchemePrice: $('#txtScheme').val(),\n            Type: rowData['MHC_IsVaccine'],\n        };\n\n        $.ajax({\n            cache: false,\n            url: \"/QueueDispense/LookForWhichDrug?isMediClaim=\" + rowData['Medi_Claim'] + '&isCHAS=' + rowData['CHAS_Claim'],\n            async: true,\n            data: insertLastVisit,\n            type: 'post',\n            success: function (result) {\n                if (result.success = true) { //Modified by Bryan 20190918 - skip validation when its prescription && rowData['MHC_IsVaccine'] != \"X\"\n                    console.log(\"hfIsAllowNegativeStock: \" + $('#hfIsAllowNegativeStock').val());\n                    console.log(result.CurrStock);\n                    if ($('#hfIsAllowNegativeStock').val() == \"False\") {\n                        if (typeof result.CurrStock != 'undefined' && parseFloat(result.CurrStock) <= 0) {\n                            console.log(\"to prompt out of stock\");\n                            var delayPromptTime = 0;\n                            if ($(\".sa-confirm-button-container\").is(\":visible\")) {\n                                delayPromptTime = 2000;\n                            }\n\n                                setTimeout(function () {\n                                    swal({\n                                        title: \"\",\n                                        text: \"DRUG OUT OF STOCK\\n\\n\" + result.DrugDesc,\n                                        type: \"warning\",\n                                        showCancelButton: false,\n                                        closeOnConfirm: true,\n                                        closeOnCancel: false\n                                    }, function (isConfirm) {\n                                        if (isConfirm) {\n                                            checkDrugExpiryDone = true;\n                                        }\n                                    });\n                                }, delayPromptTime);\n                            return;\n                        }\n                    }\n                    check = 'check';\n                    promptAfterSelectHistoryDrug(result, result.DrugCode, result.DrugDesc, check);\n                }\n                else {\n                    if (typeof result.message != 'undefined') {\n                        if (result.message.length > 0) {\n                            var delayPromptTime = 0;\n                            if ($(\".sa-confirm-button-container\").is(\":visible\")) {\n                                delayPromptTime = 2000;\n                            }\n                            setTimeout(function () {\n                                swal({\n                                    title: \"\",\n                                    text: result.message,\n                                    type: \"error\",\n                                    showCancelButton: false,\n                                    closeOnConfirm: true,\n                                    closeOnCancel: false\n                                }, function (isConfirm) {\n                                    if (isConfirm) {\n                                        checkDrugExpiryDone = true;\n                                    }\n                                });\n                            }, delayPromptTime);\n                        }\n                    }\n                }\n            },\n            error: function (xhr, status) {\n            },\n            complete: function (data) {\n                $('#queueDispenseGrid').trigger('reloadGrid');\n            }\n        });\n    }\n\n    function promptAfterSelectHistoryDrug(result, drugCode, drugDesc, check){\n        if (typeof result.stockLowLevel != 'undefined' && typeof result.warning != 'undefined') {\n            if (result.stockLowLevel.length > 0) {\n                promptDrugStockLowLevelNWarning(result, drugCode, drugDesc, check);\n            }\n            else if (result.warning.length > 0) {\n                promptDrugWarning(result, drugCode, drugDesc, check);\n            }\n            else {\n                console.log(\"stockLowLevel, warning no length\");\n                swal.close();\n                checkDrugExpiryDone = true;\n            }\n        }\n        else if (typeof result.warning != 'undefined') {\n            promptDrugWarning(result, drugCode, drugDesc, check);\n        }\n        else {\n            console.log(\"lalala\");\n            swal.close();\n            checkDrugExpiryDone = true;\n        }\n    }\n\n    function promptDrugStockLowLevelNWarning(result, drugCode, drugDesc, check) {\n        console.log(\"promptDrugStockLowLevelNWarning\");\n        var delayPromptTime = 0;\n        if ($(\".sa-confirm-button-container\").is(\":visible\")) {\n            delayPromptTime = 2000;\n        }\n        setTimeout(function () {\n            swal({\n                title: \"\",\n                text: result.stockLowLevel,\n                type: \"\",\n                showCancelButton: false,\n                closeOnConfirm: false,\n                closeOnCancel: false\n            }, function (isConfirm) {\n                if (result.warning.length > 0) {\n                    swal({\n                        title: \"\",\n                        text: result.warning,\n                        type: \"\",\n                        showCancelButton: false,\n                        closeOnConfirm: false,\n                        closeOnCancel: false\n                    }, function (isConfirm) {\n                        if (isConfirm) {\n                            swal.close();\n                            checkDrugExpiryDone = true;\n                        }\n                    });\n                }\n                else {\n                    swal.close();\n                    checkDrugExpiryDone = true;\n                }\n            });\n        }, delayPromptTime);\n    }\n\n    function promptDrugWarning(result, drugCode, drugDesc, check) {\n        console.log(\"promptDrugWarning\");\n        var delayPromptTime = 0;\n        if ($(\".sa-confirm-button-container\").is(\":visible\")) {\n            delayPromptTime = 2000;\n        }\n        setTimeout(function () {\n            swal({\n                title: \"\",\n                text: result.warning,\n                type: \"\",\n                showCancelButton: false,\n                closeOnConfirm: false,\n                closeOnCancel: false\n            }, function (isConfirm) {\n                if (isConfirm) {\n                    swal.close();\n                }\n                checkDrugExpiryDone = true;\n            });\n        }, delayPromptTime);\n\n    }\n\n    $(document).ready(function () {\n        //Added by Jason 20191202 - Lab Result (Access Control)\n        if (true == false) {\n            $('#tab-li-LabResult').hide();\n        }\n        //End added by Jason 20191202\n\n        //Added by zhaoying 20190529 | not to show All tab if at Dispense screen\n        var urlLocation = jQuery(location).attr('href');\n        if (urlLocation.indexOf(\"QueueDispense\") >= 0) {\n            $('#tab-li-xAll').css(\"display\", \"none\");\n\n            $(\"#tab-li-xAll\").removeClass(\"active\");\n            $(\"#PattabxAll\").removeClass(\"active\");\n\n            $(\"#tab-li-xMedicine\").addClass(\"active\");\n            $(\"#PattabxMedicine\").addClass(\"active\");\n        }\n\n        //Added by Cooper 20180717 - Patient (ACCESS CONTROL)\n        if (true == false) {\n            $('#tab-li-xMC').hide();\n        }\n        $(\".pat_Biodata_fade\").hide();\n\n        var d = moment(new Date()).add(-72, 'month').format('DD/MM/YYYY');      //Edited by HaoWen 2022-Dec-2 | Change from 2 years (24month) to 6 years (72month)\n        $(\"#txtMedDateFrom\").datepicker({\n            format: 'dd/mm/yyyy',\n            useCurrent: true,\n            todayHighlight: true,\n            autoclose: true,\n            orientation: \"bottom\"\n        }).datepicker('setDate', d);\n\n        var d = moment($(\"#txtMedDateTo\").val(), 'DD/MM/YYYY').format('DD/MM/YYYY');\n        $(\"#txtMedDateTo\").datepicker({\n            format: 'dd/mm/yyyy',\n            useCurrent: true,\n            todayHighlight: true,\n            autoclose: true,\n            orientation: \"bottom\"\n        }).datepicker('setDate', d);\n\n        $(\"#txtMedDateFrom\").inputmask(\"date\", { \"clearIncomplete\": true });\n        $(\"#txtMedDateTo\").inputmask(\"date\", { \"clearIncomplete\": true });\n\n        setTimeout(function () {\n            var obj = $(\"ul#tabQueueHisTab li.active a\");\n            var target = $(obj).attr('href');\n            getTxHistory(target);\n        }, 100);\n\n        if ($(\"#hdPayType\").val() == \"SFL\") {\n            $(\"#btnDispenseTxSelectAll\").prop(\"disabled\", true);\n            $(\"#btnDispenseTx\").prop(\"disabled\", true);\n        }\n\n        //Added by Jason 20211027 - set grid height\n        /*$(\"#Grid_PattabxAll\").css('height', $(window).height() - 250);*/\n        /*$(\"#Grid_PattabxMedicine\").css('height', $(window).height() - 210);*/\n        /*$(\"#Grid_tabxInvestigation\").css('height', $(window).height() - 210);*/\n        /*$(\"#Grid_PattabxProcedure\").css('height', $(window).height() - 210);*/\n        /*$(\"#Grid_PattabxDiagnosis\").css('height', $(window).height() - 210);*/\n        /*$(\"#Grid_PattabxMC\").css('height', $(window).height() - 210);*/\n        /*$(\"#Grid_PattabxVisit\").css('height', $(window).height() - 210);*/\n        //End added by Jason 20211027\n    });\n\n    $(document).ajaxStop(function () {\n        $(\".fadeMe\").hide();\n    });\n\n    function ClearSelection() {\n        $(\"#jqGrid_PattabxMedicine\").jqGrid('resetSelection');\n        $(\"#jqGrid_tabxInvestigation\").jqGrid('resetSelection');\n        $(\"#jqGrid_PattabxProcedure\").jqGrid('resetSelection');\n    }\n\n    function getTxHistory(tab) {\n        $('#btnPatHisAddMC').hide();\n        $('#divDispenseTxPanel').hide();\n        setTimeout(function () {\n            var d = moment($(\"#txtQtxDateFrom\").val(), 'DD/MM/YYYY').format('DD/MM/YYYY');\n            $(\"#txtQtxDateFrom\").datepicker({\n                format: 'dd/mm/yyyy',\n                useCurrent: true,\n                todayHighlight: true,\n                autoclose: true,\n                orientation: \"bottom\"\n            }).datepicker('setDate', d);\n\n            var d = moment($(\"#txtQtxDateTo\").val(), 'DD/MM/YYYY').format('DD/MM/YYYY');\n            $(\"#txtQtxDateTo\").datepicker({\n                format: 'dd/mm/yyyy',\n                useCurrent: true,\n                todayHighlight: true,\n                autoclose: true,\n                orientation: \"bottom\"\n            }).datepicker('setDate', d);\n        }, 100);\n\n        $(\"#txtQtxDateFrom\").inputmask(\"date\", { \"clearIncomplete\": true });\n        $(\"#txtQtxDateTo\").inputmask(\"date\", { \"clearIncomplete\": true });\n\n        if (tab == \"#PattabxMedicine\") {\n            $('#divDispenseTxPanel').show();\n            $(\"#jqGrid_PattabxMedicine\").GridUnload();\n            GetMedicineHistory($(\"#hfPCNOfortxHist\").val(), $(\"#txtMedDateFrom\").val(), $(\"#txtMedDateTo\").val());\n        } else if (tab == \"#PattabxInvestigate\") {\n            $(\"#jqGrid_tabxInvestigation\").GridUnload();\n            GetInvestigationHistory($(\"#hfPCNOfortxHist\").val(), $(\"#txtMedDateFrom\").val(), $(\"#txtMedDateTo\").val());\n\n        } else if (tab == \"#PattabxProcedure\") {\n            $(\"#jqGrid_PattabxProcedure\").GridUnload();\n            GetProcedureHistory($(\"#hfPCNOfortxHist\").val(), $(\"#txtMedDateFrom\").val(), $(\"#txtMedDateTo\").val());\n        } else if (tab == \"#PattabxDiagnosis\") {\n            $(\"#jqGrid_PattabxDiagnosis\").GridUnload();\n            GetDiagnosisHistory($(\"#hfPCNOfortxHist\").val(), $(\"#txtMedDateFrom\").val(), $(\"#txtMedDateTo\").val());\n        } else if (tab == \"#PattabxMC\") {\n            $(\"#jqGrid_PattabxMC\").GridUnload();\n            $('#btnPatHisAddMC').show();\n            GetMCHistory($(\"#hfPCNOfortxHist\").val(), $(\"#txtMedDateFrom\").val(), $(\"#txtMedDateTo\").val());\n        } else if (tab == \"#PattabxVisit\") {\n            $(\"#jqGrid_PattabxVisit\").GridUnload();\n            GetVisitHistory($(\"#hfPCNOfortxHist\").val(), $(\"#txtMedDateFrom\").val(), $(\"#txtMedDateTo\").val());\n        } else if (tab == \"#tabxCurrentMed\") {\n            $(\"#jqGrid_tabxCurMed\").GridUnload();\n            GetCurrentMed();\n        } else if (tab == \"#PattabxAll\") {\n            $(\"#jqGrid_PattabxAll\").GridUnload();\n            GetAllData($(\"#hfPCNOfortxHist\").val(), $(\"#txtMedDateFrom\").val(), $(\"#txtMedDateTo\").val());\n        }\n\n        //Added by Xirlyn 20240123 - Enable to scroll table\n        var x = document.getElementsByClassName(\"ui-jqgrid-bdiv\");\n        for(var i=0;i<x.length;i++){\n            x[i].setAttribute('style', 'overflow-y: auto !important');\n        }\n        //End added by Xirlyn 20240123\n    }\n\n    function GetAllData(pcno, DateFrom, DateTo) {\n        $(\"#jqGrid_PattabxAll\").jqGrid({\n            url: \"/CaseNote/GetTxHistoryTabAll?pcno=\" + pcno + \"&dateFrom=\" + DateFrom + \"&dateTo=\" + DateTo,\n            datatype: 'json',\n            mtype: 'Get',\n            colNames: ['Date', 'Grp', 'Description', 'Amount', 'Charge', 'Branch'],\n            colModel: [\n                { key: false, name: 'Ddate', index: 'Ddate', width: 100, sortable: false, formatter: 'date', formatoptions: { srcformat: \"d M Y\", newformat: \"d/m/Y\" } },\n                { key: false, name: 'Type', index: 'Type', width: 50, sortable: false, align: \"center\" },\n                { key: false, name: 'Description', index: 'Description', width: 600, sortable: false, align: \"left\" },\n                { key: false, name: 'Amount', index: 'Amount', width: 110, sortable: false},\n                { key: false, name: 'Charge', index: 'Charge', width: 110, sortable: false, align: \"right\", formatter: 'currency', formatoptions: {prefix: \"$\", thousandsSeparator: \",\", decimalSeparator: \".\", decimalPlaces: 2 }},   //Edited by Qiu Li 20260102 - add thousand seperator for money\n                { key: false, name: 'Clinic', index: 'Clinic', width: 110, sortable: false, align: \"center\" },\n            ],\n            rowNum: 100,\n            scrollrows: true,\n            gridview: true,\n            scroll: 1,\n            width: \"auto\",\n            height: \"auto\",\n            hoverrows: false,\n            rowcontent: true,\n            loadError: function (xhr, status, error) {\n            },\n            loadComplete: function () {\n                JqgridLoadComplete(this);\n                //$(\"#gview_jqGrid_PattabxAll\").find(\".ui-jqgrid-bdiv\").height($(\"#Grid_PattabxAll\").height() - 30);\n                //$(\"#gview_jqGrid_PattabxAll\").find(\".ui-jqgrid-bdiv\").width($(\"#Grid_PattabxAll\").find(\".ui-jqgrid-hdiv\").width() + 10);\n                //$(\"#gview_jqGrid_PattabxAll\").find(\".ui-jqgrid-bdiv\").addClass(\"scrollbar-primary\");\n                $(\"#jqGrid_PattabxAll > tbody > tr\").each(function() {\n                    if ($(this).find(\"td:eq(1)\").html() == \"I\") {\n                        $(this).find(\"td:eq(1)\").css(\"background-color\", \"#8DB4E3\");\n                        $(this).find(\"td:eq(1)\").html('Ix');\n                    }\n                    else if ($(this).find(\"td:eq(1)\").html() == \"P\") {\n                        $(this).find(\"td:eq(1)\").css(\"background-color\", \"#ffff99\");\n                        $(this).find(\"td:eq(1)\").html('Pcr');\n                    }\n                    else if ($(this).find(\"td:eq(1)\").html() == \"X\") {\n                        $(this).find(\"td:eq(1)\").css(\"background-color\", \"#FAC090\");\n                        $(this).find(\"td:eq(1)\").html('Rx');\n                    }\n                    else if ($(this).find(\"td:eq(1)\").html() == \"M\") {\n                        $(this).find(\"td:eq(1)\").css(\"background-color\", \"#E6B9B8\");\n                        $(this).find(\"td:eq(1)\").html('Med');\n                    }\n                    else if ($(this).find(\"td:eq(1)\").html() == \"L\") {\n                        $(this).find(\"td:eq(1)\").css(\"background-color\", \"#C2D69A\");\n                        $(this).find(\"td:eq(1)\").html('MC');\n                    }\n                });\n\n                var u = $(\"tbody:first > tr:gt(0)\", this.grid.bDiv);\n                var height = parseInt(this.p.records, 10) * (u.outerHeight() || this.grid.prevRowHeight);\n                $(this).parent().height(height);\n                $(this).closest(\".ui-jqgrid-bdiv\").height($('#Grid_PattabxAll').height() - 50); \n                $(\"#gview_jqGrid_PattabxAll\").find(\".ui-jqgrid-bdiv\").addClass(\"scrollbar-primary\");\n                $(\"#gview_jqGrid_PattabxAll\").find(\".ui-jqgrid-bdiv\").width($(\"#Grid_PattabxAll\").find(\".ui-jqgrid-hdiv\").width() + 10);\n            },\n            emptyrecords: 'No records to display',\n            jsonReader: {\n                root: \"rows\",\n                page: \"page\",\n                total: \"total\",\n                records: \"records\",\n                repeatitems: false,\n                Id: \"0\"\n            },\n            shrinkToFit: false,\n            multiselect: false\n        });\n    }\n\n    function GetInvestigationHistory(pcno, DateFrom, DateTo) {\n        $(\"#jqGrid_tabxInvestigation\").jqGrid({\n            url: \"/CaseNote/GetTxHistoryTabInvestigation?pcno=\" + pcno + \"&dateFrom=\" + DateFrom + \"&dateTo=\" + DateTo,\n            datatype: 'json',\n            mtype: 'Get',\n            colNames: ['Date', 'Grp', 'Description', 'Results', 'Branch', 'Lab Company', '', '', '', '', '', '', ''],\n            colModel: [\n                { key: false, name: 'Ddate', index: 'Ddate', width: 90, sortable: false, formatter: 'date', formatoptions: { srcformat: \"d M Y\", newformat: \"d/m/Y\" } },\n                { key: false, name: 'MHC_Type', index: 'MHC_Type', width: 35, sortable: false, align: \"center\", hidden: true },\n                { key: false, name: 'Description', index: 'Description', width: 500, sortable: false, align: \"left\" },\n                { key: false, name: 'Results', index: 'Results', width: 130, sortable: false, },\n                { key: false, name: 'Clinic', index: 'Clinic', width: 110, sortable: false, align: \"center\" },\n                { key: false, name: 'MHC_LabCompany', index: 'MHC_LabCompany', width: 300, sortable: false },\n                { name: 'MHC_VisitNo', index: 'VisitNo', width: 100, sortable: false, hidden: true },\n                { name: 'MHC_Code', index: 'Code', width: 100, sortable: false, hidden: true },\n                { name: 'MHC_TotDispenseCustom', index: 'TotDispenseCustom', width: 120, sortable: false, hidden: true },\n                { name: 'MHC_DispenseCustom', index: 'DispenseCustom', width: 114, sortable: false, hidden: true },\n                { name: 'MHC_FreqCode', index: 'FreqCode', width: 50, sortable: false, hidden: true },\n                { name: 'MHC_DateDispense', index: 'DateDispense', width: 120, sortable: false, hidden: true },\n                { name: 'MHC_ItemNo', index: 'ItemNo', width: 100, hidden: true },\n            ],\n            rowNum: 100,\n            scrollrows: true,\n            gridview: true,\n            scroll: 1,\n            width: \"100%\",\n            height: \"100%\",\n            hoverrows: false,\n            rowcontent: true,\n            loadError: function (xhr, status, error) {\n            },\n            loadComplete: function () {\n                JqgridLoadComplete(this);\n                $(\"#jqGrid_tabxInvestigation\").jqGrid('hideCol', 'cb');\n                setTimeout(function () {\n                    $(\"#Grid_tabxInvestigation\").css(\"display\", \"block\");\n                }, 500);\n\n                var u = $(\"tbody:first > tr:gt(0)\", this.grid.bDiv);\n                var height = parseInt(this.p.records, 10) * (u.outerHeight() || this.grid.prevRowHeight);\n                $(this).parent().height(height);\n                $(this).closest(\".ui-jqgrid-bdiv\").height($('#PattabxInvestigate').height() - 50);\n                $(\"#gview_jqGrid_tabxInvestigation\").find(\".ui-jqgrid-bdiv\").addClass(\"scrollbar-primary\");\n                $(\"#gview_jqGrid_tabxInvestigation\").find(\".ui-jqgrid-bdiv\").width($(\"#PattabxInvestigate\").find(\".ui-jqgrid-hdiv\").width() + 10);\n            },\n            emptyrecords: 'No records to display',\n            jsonReader: {\n                root: \"rows\",\n                page: \"page\",\n                total: \"total\",\n                records: \"records\",\n                repeatitems: false,\n                Id: \"0\"\n            },\n            shrinkToFit: false,\n            multiselect: (urlLocation.indexOf(\"QueueDispense/Index\") > 0) ? true : false\n        });\n\n    }\n\n    function GetMedicineHistory(pcno,DateFrom,DateTo) {\n        $(\"#jqGrid_PattabxMedicine\").jqGrid({\n            url: \"/CaseNote/GetTxHistoryTabMedicine?pcno=\" + pcno + \"&dateFrom=\" + DateFrom + \"&dateTo=\" + DateTo,\n            datatype: 'json',\n            mtype: 'Get',\n            colNames: ['Date', 'Grp', 'Description', 'Prescribed', 'Consumption', 'Vaccination', 'Dosage Type', 'Lot No', '', 'Code', '', '', '', '', '', '', 'Medi_Claim', 'CHAS_Claim', 'Status', 'SufficientStock', 'Branch', 'Precaution'], //Edited by Koh Chin Choong 20201209 - Add SufficientStock\n            colModel: [\n                { key: false, name: 'Ddate', index: 'Ddate', width: 180, sortable: false, formatter: 'date', formatoptions: { srcformat: \"d M Y\", newformat: \"d/m/Y\" } },\n                { key: false, name: 'Type', index: 'Type', width: 35, sortable: false, align: \"center\", hidden: true },\n                { key: false, name: 'Description', index: 'Description', width: 300, sortable: false, align: \"left\" },\n                { key: false, name: 'PRESCRIBED', index: 'Amount', width: 120, sortable: false, align: \"right\" },\n                { key: false, name: 'CONDET', index: 'Charge', width: 240, sortable: false, align: \"left\" },               \n                { key: false, name: 'MHC_Vaccination', index: 'Vaccination', width: 250, sortable: false,hidden: true },\n                { key: false, name: 'MHC_DosageType', index: 'DosageType', width: 100, sortable: false,hidden: true },\n                { key: false, name: 'MHC_LotNo', index: 'LotNo', width: 75, sortable: false,hidden: true},\n                { name: 'MHC_VisitNo', index: 'VisitNo', width: 100, sortable: false, hidden: true },\n                { key: false, name: 'MHC_Code', index: 'Code', width: 130, sortable: false, hidden: false },\n                { name: 'MHC_TotDispenseCustom', index: 'TotDispenseCustom', width: 120, sortable: false, hidden: true },\n                { name: 'MHC_DispenseCustom', index: 'DispenseCustom', width: 114, sortable: false, hidden: true },\n                { name: 'MHC_FreqCode', index: 'FreqCode', width: 50, sortable: false, hidden: true },\n                { name: 'MHC_DateDispense', index: 'DateDispense', width: 120, sortable: false, hidden: true },\n                { name: 'MHC_ItemNo', index: 'ItemNo', width: 100, hidden: true },\n                { name: 'MHC_IsVaccine', index: 'IsVaccine', width: 100, hidden: true },\n                { name: 'Medi_Claim', index: 'Medi_Claim', width: 100, hidden: true },\n                { name: 'CHAS_Claim', index: 'CHAS_Claim', width: 100, hidden: true },\n                { name: 'Status', index: 'Status', width: 100, hidden: true },\n                { name: 'SufficientStock', index: 'SufficientStock', width: 100, hidden: true }, //Added by Koh Chin Choong 20201209 - To use for insufficient stock validation purpose\n                { key: false, name: 'Clinic', index: 'Clinic', sortable: false, width: 160, align: \"center\" },\n                                { \n                                    key: false, name: 'Precaution1', index: 'Precaution1', width: 650, sortable: false , \n                                    formatter: function(cellvalue, options, rowObject) {\n                                        return cellvalue.replace(/-line-/g, \" \");\n                                    }\n                                }\n            ],\n            rowNum: 100,\n            scrollrows: true,\n            gridview: true,\n            scroll: 1,\n            width: \"100%\",\n            height: \"100%\",\n            hoverrows: false,\n            rowcontent: true,\n            loadError: function (xhr, status, error) {\n            },\n            loadComplete: function () {\n                $(\"#jqGrid_PattabxMedicine\").jqGrid('setGridWidth', $(\"#PattabxMedicine\").width());\n                JqgridLoadComplete(this);\n                $(\"#jqGrid_PattabxMedicine\").jqGrid('hideCol', 'cb');\n                var ids = $(\"#jqGrid_PattabxMedicine\").jqGrid(\"getDataIDs\");\n                if (ids.length > 0) {\n                    $(\"#btnDispenseTxSelectAll\").prop(\"disabled\", false);\n                }\n                else {\n                    $(\"#btnDispenseTxSelectAll\").prop(\"disabled\", true);\n                }\n                if ($(\"#hdPayType\").val() == \"SFL\") {\n                    $(\"#btnDispenseTxSelectAll\").prop(\"disabled\", true);\n                }\n                setTimeout(function () {\n                    $(\"#Grid_PattabxMedicine\").css(\"display\", \"block\");\n                    $(\"#PattabxMedicine\").addClass(\"active\");\n                }, 500);\n\n                var u = $(\"tbody:first > tr:gt(0)\", this.grid.bDiv);\n                var height = parseInt(this.p.records, 10) * (u.outerHeight() || this.grid.prevRowHeight);\n                $(this).parent().height(height);\n                $(this).closest(\".ui-jqgrid-bdiv\").height($('#PattabxMedicine').height() - 50);\n                $(\"#gview_jqGrid_PattabxMedicine\").find(\".ui-jqgrid-bdiv\").addClass(\"scrollbar-primary\");\n            },\n\n            onSelectRow: function (rowId) {\n                //added by Jason 20191004 - unselect the row with inactive drug and popup warning\n                var selectedDescription = $(\"#jqGrid_PattabxMedicine\").jqGrid('getCell', rowId, 'Description');\n                var selectedStatus = $(\"#jqGrid_PattabxMedicine\").jqGrid('getCell', rowId, 'Status');\n                var selectedSufficientStock = $(\"#jqGrid_PattabxMedicine\").jqGrid('getCell', rowId, 'SufficientStock'); //Added by Koh Chin Choong 20201209 - For insufficient stock validation purpose\n\n                if (selectedStatus == 'InActive') {\n                    swal('InActive Drug', selectedDescription + ' is InActive', 'warning');\n                    $('#jqGrid_PattabxMedicine').jqGrid('setSelection', rowId, false);\n                }\n                else if (selectedSufficientStock == 'N' && $('#hfIsAllowNegativeStock').val().toUpperCase() == \"FALSE\") { //Added by Koh Chin Choong 20201209 - For insufficient stock validation purpose\n                    swal('Insufficient Stock', selectedDescription, 'warning');\n                    $('#jqGrid_PattabxMedicine').jqGrid('setSelection', rowId, false);\n                }\n            },\n            ondblClickRow: function (rowId) {\n                //added by bryan 20190917 - double click to select all the row with same date\n                //added by Jason 20191004 - unselect the row with inactive drug and popup warning\n                var selectedDate = $(\"#jqGrid_PattabxMedicine\").jqGrid('getCell', rowId, 'Ddate');\n\n                var rowIds = $('#jqGrid_PattabxMedicine').jqGrid('getDataIDs');\n                var temp = jQuery('#jqGrid_PattabxMedicine').jqGrid('getGridParam', 'selarrrow');\n                var selectedStatus = $(\"#jqGrid_PattabxMedicine\").jqGrid('getCell', rowId, 'Status');\n                var inactiveDrug = [];\n                var j = 0;\n\n                //Added by Koh Chin Choong 20201208 - To Stock the insufficient drug detail\n                var insufficientStock = [];\n                var k = 0;\n                //End Added by Koh Chin Choong 20201208\n\n                for (i = 0; i < rowIds.length; i++) {\n                    var selectedDescription = $(\"#jqGrid_PattabxMedicine\").jqGrid('getCell', rowIds[i], 'Description');\n                    var selectedStatus = $(\"#jqGrid_PattabxMedicine\").jqGrid('getCell', rowIds[i], 'Status');\n                    var selectedSufficientStock = $(\"#jqGrid_PattabxMedicine\").jqGrid('getCell', rowIds[i], 'SufficientStock'); //Added by Koh Chin Choong 20201209 - For insufficient stock validation purpose\n                    if (selectedDate == $('#jqGrid_PattabxMedicine').jqGrid('getCell', rowIds[i], 'Ddate')) {\n                            if ($.inArray(rowIds[i], temp) < 0) {\n                                $('#jqGrid_PattabxMedicine').jqGrid('setSelection', rowIds[i], true);\n                                if (selectedStatus == 'InActive') {\n                                    inactiveDrug[j] = selectedDescription;\n                                    j++;\n                                }\n                                else if (selectedSufficientStock == 'N' && $('#hfIsAllowNegativeStock').val().toUpperCase() == \"FALSE\") { //Added by Koh Chin Choong 20201209 - Added selectedSufficientStock, if insufficient stock need to unselect also\n                                    insufficientStock[k] = selectedDescription;\n                                    k++;\n                                }\n                            }\n                    }\n                }\n                //Show message box for n items inactive\n                Array.prototype.unique = function () {\n                    var a = [];\n                    var l = this.length;\n                    for (var i = 0; i < l; i++) {\n                        for (var j = i + 1; j < l; j++) {\n                        // If this[i] is found later in the array\n                        if (this[i] === this[j])\n                            j = ++i;\n                        }\n                        a.push(this[i]);\n                    }\n                    return a;\n                };\n                inactiveDrug = inactiveDrug.unique();\n\n                //Added by Koh Chin Choon 20201209 - Show message box for n items insufficient stock\n                Array.prototype.unique = function () {\n                    var a = [];\n                    var l = this.length;\n                    for (var i = 0; i < l; i++) {\n                        for (var k = i + 1; k < l; k++) {\n                            // If this[i] is found later in the array\n                            if (this[i] === this[k])\n                                k = ++i;\n                        }\n                        a.push(this[i]);\n                    }\n                    return a;\n                };\n                insufficientStock = insufficientStock.unique();\n\n                //Added by Jason 20191023 - HotFix inactive drug\n                if (inactiveDrug != '') {\n                    if (inactiveDrug.toString().indexOf(\",\") > -1) {\n                        swal('InActive Drug', inactiveDrug.toString() + ' are InActive', 'warning');\n                    }\n                    else {\n                        swal('InActive Drug', inactiveDrug.toString() + ' is InActive', 'warning');\n                    }\n                }\n\n                //Added by Koh Chin Choong 20201209 - Display insufficient stock message\n                if (insufficientStock != '') {\n                    swal('Insufficient Stock', insufficientStock.toString(), 'warning');\n                }\n                //End Added by Koh Chin Choong 20201209\n            },\n            emptyrecords: 'No records to display',\n            jsonReader: {\n                root: \"rows\",\n                page: \"page\",\n                total: \"total\",\n                records: \"records\",\n                repeatitems: false,\n                Id: \"0\"\n            },\n            shrinkToFit: true,\n            multiselect: (urlLocation.indexOf(\"QueueDispense/Index\") > 0) ? true : false,\n            rowattr: function (rd) {\n                if (rd.MHC_IsVaccine == \"V\") {\n                    return { \"class\": \"myAltRowClass ui-state-disabled\" };\n                }\n                else if (rd.MHC_IsVaccine == \"X\") {\n                    return { \"class\": \"PrescriptionRowBC\" }; //modified by bryan 20190918 - user able to select prescription row\n                }\n            }\n        });\n    }\n\n    function GetProcedureHistory(pcno, DateFrom, DateTo) {\n        $(\"#jqGrid_PattabxProcedure\").jqGrid({\n            url: \"/CaseNote/GetTxHistoryTabProcedure?pcno=\" + pcno + \"&dateFrom=\" + DateFrom + \"&dateTo=\" + DateTo,\n            datatype: 'json',\n            mtype: 'Get',\n            colNames: ['Date', 'Grp', 'Description', 'Remarks', 'Branch', '', '', '', '', '', '', ''],\n            colModel: [\n                { key: false, name: 'Ddate', index: 'Ddate', width: 90, sortable: false, formatter: 'date', formatoptions: { srcformat: \"d M Y\", newformat: \"d/m/Y\" } },\n                { key: false, name: 'MHC_Type', index: 'MHC_Type', width: 35, sortable: false, align: \"center\", hidden: true },\n                { key: false, name: 'Description', index: 'Description', width: 550, sortable: false, align: \"left\" },\n                { key: false, name: 'Results', index: 'Results', width: 200, sortable: false },\n                { key: false, name: 'Clinic', index: 'Clinic', width: 110, sortable: false, align: \"center\" },\n                { name: 'MHC_VisitNo', index: 'VisitNo', width: 100, sortable: false, hidden: true },\n                { name: 'MHC_Code', index: 'Code', width: 100, sortable: false, hidden: true },\n                { name: 'MHC_TotDispenseCustom', index: 'TotDispenseCustom', width: 120, sortable: false, hidden: true },\n                { name: 'MHC_DispenseCustom', index: 'DispenseCustom', width: 114, sortable: false, hidden: true },\n                { name: 'MHC_FreqCode', index: 'FreqCode', width: 50, sortable: false, hidden: true },\n                { name: 'MHC_DateDispense', index: 'DateDispense', width: 120, sortable: false, hidden: true },\n                { name: 'MHC_ItemNo', index: 'ItemNo', width: 100, hidden: true },\n            ],\n            rowNum: 100,\n            scrollrows: 1,\n            gridview: true,\n            scroll: true,\n            width: \"100%\",\n            height: \"100%\",\n            hoverrows: false,\n            rowcontent: true,\n            loadError: function (xhr, status, error) {\n            },\n            loadComplete: function () {\n                JqgridLoadComplete(this);\n                $(\"#jqGrid_PattabxProcedure\").jqGrid('hideCol', 'cb');\n                setTimeout(function () {\n                    $(\"#Grid_PattabxProcedure\").css(\"display\", \"block\");\n                }, 500);\n\n                var u = $(\"tbody:first > tr:gt(0)\", this.grid.bDiv);\n                var height = parseInt(this.p.records, 10) * (u.outerHeight() || this.grid.prevRowHeight);\n                $(this).parent().height(height);\n                $(this).closest(\".ui-jqgrid-bdiv\").height($('#Grid_PattabxProcedure').height() - 50);\n                $(\"#gview_jqGrid_PattabxProcedure\").find(\".ui-jqgrid-bdiv\").addClass(\"scrollbar-primary\");\n                $(\"#gview_jqGrid_PattabxProcedure\").find(\".ui-jqgrid-bdiv\").width($(\"#Grid_PattabxProcedure\").find(\".ui-jqgrid-hdiv\").width() + 10);\n            },\n            emptyrecords: 'No records to display',\n            jsonReader: {\n                root: \"rows\",\n                page: \"page\",\n                total: \"total\",\n                records: \"records\",\n                repeatitems: false,\n                Id: \"0\"\n            },\n            shrinkToFit: false,\n            multiselect: (urlLocation.indexOf(\"QueueDispense/Index\") > 0) ? true : false\n        });\n    }\n\n    function GetDiagnosisHistory(pcno, DateFrom, DateTo) {\n        $(\"#jqGrid_PattabxDiagnosis\").jqGrid({\n            url: \"/CaseNote/GetTxHistoryTabDiagnosis?pcno=\" + pcno + \"&dateFrom=\" + DateFrom + \"&dateTo=\" + DateTo,\n            datatype: 'json',\n            mtype: 'Get',\n            colNames: ['Date','State', 'Code', 'Description', 'Branch'],\n            colModel: [\n                { key: false, name: 'Ddate', index: 'Ddate', width: 90, sortable: false, formatter: 'date', formatoptions: { srcformat: \"d M Y\", newformat: \"d/m/Y\" } },\n                { key: false, name: 'State', index: 'State', width: 100, sortable: false, align: \"left\"},\n                { key: false, name: 'Code', index: 'Code', width: 100, sortable: false, align: \"left\" },\n                { key: false, name: 'Description', index: 'Description', width: 550, sortable: false, align: \"left\" },\n                { key: false, name: 'Clinic', index: 'Clinic', width: 110, sortable: false, align: \"center\" },\n            ],\n            rowNum: 100,\n            scrollrows: true,\n            gridview: true,\n            scroll: true,\n            width: \"100%\",\n            height: \"100%\",\n            hoverrows: false,\n            rowcontent: true,\n            loadError: function (xhr, status, error) {\n                JqgridLoadComplete(this);\n            },\n            loadComplete: function () {\n                JqgridLoadComplete(this);\n\n                if ('N' == \"N\") {\n                    $('#jqGrid_PattabxDiagnosis').hideCol(\"State\");\n                }\n                else {\n                    $('#jqGrid_PattabxDiagnosis').showCol(\"State\");\n                }\n\n                var u = $(\"tbody:first > tr:gt(0)\", this.grid.bDiv);\n                var height = parseInt(this.p.records, 10) * (u.outerHeight() || this.grid.prevRowHeight);\n                $(this).parent().height(height);\n                $(this).closest(\".ui-jqgrid-bdiv\").height($('#Grid_PattabxDiagnosis').height() - 50);\n                $(\"#gview_jqGrid_PattabxDiagnosis\").find(\".ui-jqgrid-bdiv\").addClass(\"scrollbar-primary\");\n                $(\"#gview_jqGrid_PattabxDiagnosis\").find(\".ui-jqgrid-bdiv\").width($(\"#Grid_PattabxDiagnosis\").find(\".ui-jqgrid-hdiv\").width() + 10);\n            },\n            emptyrecords: 'No records to display',\n            jsonReader: {\n                root: \"rows\",\n                page: \"page\",\n                total: \"total\",\n                records: \"records\",\n                repeatitems: false,\n                Id: \"0\"\n            },\n            shrinkToFit: true,\n            multiselect: false\n        });\n    }\n\n    function GetMCHistory(pcno, DateFrom, DateTo) {\n        $(\"#jqGrid_PattabxMC\").jqGrid({\n            url: \"/CaseNote/GetTxHistoryTabMC?pcno=\" + pcno + \"&dateFrom=\" + DateFrom + \"&dateTo=\" + DateTo,\n            datatype: 'json',\n            mtype: 'Get',\n            colNames: ['Consult Date', 'Grp', 'Description', 'Days', 'From', 'To', 'REF NO', 'Remarks', 'Branch'],\n            colModel: [\n                { key: false, name: 'Ddate', index: 'Ddate', width: 110, sortable: false, formatter: 'date', formatoptions: { srcformat: \"d M Y\", newformat: \"d/m/Y\" } },\n                { key: false, name: 'Type', index: 'Type', width: 35, sortable: false, align: \"center\", hidden: true },\n                { key: false, name: 'Description', index: 'Description', width: 320, sortable: false, align: \"left\" },\n                { key: false, name: 'MCDay', index: 'MCDay', width: 50, sortable: false, align: \"center\" },\n                { key: false, name: 'DateFrom', index: 'DateFrom', width: 100, sortable: false, formatter: 'date', formatoptions: { srcformat: \"d M Y\", newformat: \"d/m/Y\" } },\n                { key: false, name: 'DateTo', index: 'DateTo', width: 100, sortable: false, formatter: 'date', formatoptions: { srcformat: \"d M Y\", newformat: \"d/m/Y\" } },\n                { key: false, name: 'Reference', index: 'Reference', width: 100, sortable: false, align: \"center\" },\n                { key: false, name: 'Results', index: 'Results', width: 450, sortable: false },\n                { key: false, name: 'Clinic', index: 'Clinic', width: 100, sortable: false, align: \"center\" },\n            ],\n            rowNum: 100,\n            scrollrows: true,\n            gridview: true,\n            scroll: true,\n            width: \"100%\",\n            height: \"100%\",\n            hoverrows: false,\n            loadError: function (xhr, status, error) {\n            },\n            loadComplete: function () {\n                JqgridLoadComplete(this);\n                var u = $(\"tbody:first > tr:gt(0)\", this.grid.bDiv);\n                var height = parseInt(this.p.records, 10) * (u.outerHeight() || this.grid.prevRowHeight);\n                $(this).parent().height(height);\n                $(this).closest(\".ui-jqgrid-bdiv\").height($('#Grid_PattabxMC').height() - 50);\n                $(\"#gview_jqGrid_PattabxMC\").find(\".ui-jqgrid-bdiv\").addClass(\"scrollbar-primary\");\n                $(\"#gview_jqGrid_PattabxMC\").find(\".ui-jqgrid-bdiv\").width($(\"#Grid_PattabxMC\").find(\".ui-jqgrid-hdiv\").width() + 10);\n            },\n            emptyrecords: 'No records to display',\n            jsonReader: {\n                root: \"rows\",\n                page: \"page\",\n                total: \"total\",\n                records: \"records\",\n                repeatitems: false,\n                Id: \"0\"\n            },\n            shrinkToFit: false,\n            multiselect: false\n        });\n    }\n\n    function GetVisitHistory(pcno, DateFrom, DateTo) {\n        $(\"#jqGrid_PattabxVisit\").jqGrid({\n            url: \"/CaseNote/GetTxHistoryTabVisit?pcno=\" + pcno + \"&dateFrom=\" + DateFrom + \"&dateTo=\" + DateTo,\n            datatype: 'json',\n            mtype: 'Get',\n            colNames: ['Date', 'Time In', 'Time Out', 'Time Con', 'Doctor', 'SP Code', 'TCU', 'TCU Remarks', 'Paid AMT', 'CR AMT', 'Height', 'Weight', 'Company Code', 'Branch'],\n            colModel: [\n                { key: false, name: 'VQdate', index: 'VQdate', width: 90, sortable: false, formatter: 'date', formatoptions: { srcformat: \"d M Y\", newformat: \"d/m/Y\" } },\n                { key: false, name: 'TimeIn1', index: 'TimeIn1', width: 90, sortable: false, align: \"center\" },\n                { key: false, name: 'TimeOut1', index: 'TimeOut1', width: 90, sortable: false, align: \"center\" },\n                { key: false, name: 'TimeConsult1', index: 'TimeConsult1', width: 90, sortable: false, align: \"center\" },\n                { key: false, name: 'Doctor', index: 'Doctor', width: 70, sortable: false, hidden: true },\n                { key: false, name: 'SPCode', index: 'SPCode', width: 80, sortable: false },\n                { key: false, name: 'TCU', index: 'TCU', width: 60, sortable: false}, //Edited by Shan , 20190215 - To remove TCU/ TCU remarks/ Height/ Weight column\n                { key: false, name: 'TCUREMARK', index: 'TCUREMARK', width: 150, sortable: false },//Edited by Shan , 20190215 - To remove TCU/ TCU remarks/ Height/ Weight column\n                { key: false, name: 'PAIDAMT', index: 'PAIDAMT', width: 100, sortable: false, align: \"right\", formatter: 'currency', formatoptions: {prefix: \"$\", thousandsSeparator: \",\", decimalSeparator: \".\", decimalPlaces: 2 }},  //Edited by Qiu Li 20260102 - add thousand seperator for money\n                { key: false, name: 'CREDITAMT', index: 'CREDITAMT', width: 100, sortable: false, align: \"right\", formatter: 'currency', formatoptions: {prefix: \"$\", thousandsSeparator: \",\", decimalSeparator: \".\", decimalPlaces: 2 }},  //Edited by Qiu Li 20260102 - add thousand seperator for money\n                { key: false, name: 'VHeight', index: 'VHeight', width: 60, sortable: false, align: \"center\", hidden: true },//Edited by Shan , 20190215 - To remove TCU/ TCU remarks/ Height/ Weight column\n                { key: false, name: 'VWeight', index: 'VWeight', width: 60, sortable: false, align: \"center\", hidden: true },//Edited by Shan , 20190215 - To remove TCU/ TCU remarks/ Height/ Weight column\n                { key: false, name: 'TranCoy', index: 'TranCoy', width: 140, sortable: false },\n                { key: false, name: 'Clinic', index: 'Clinic', width: 100, sortable: false, align: \"center\" },\n            ],\n            rowNum: 100,\n            scrollrows: true,\n            gridview: true,\n            scroll: true,\n            width: \"100%\",\n            height: \"100%\",\n            hoverrows: false,\n            rowcontent: true,\n            loadError: function (xhr, status, error) {\n            },\n            loadComplete: function () {\n                //$(\"#jqGrid_PattabxVisit\").jqGrid('setGridWidth', $(\"#Grid_PattabxVisit\").width());\n                JqgridLoadComplete(this);\n                var u = $(\"tbody:first > tr:gt(0)\", this.grid.bDiv);\n                var height = parseInt(this.p.records, 10) * (u.outerHeight() || this.grid.prevRowHeight);\n                $(this).parent().height(height);\n                $(this).closest(\".ui-jqgrid-bdiv\").height($('#Grid_PattabxVisit').height() - 50);\n                $(\"#gview_jqGrid_PattabxVisit\").find(\".ui-jqgrid-bdiv\").addClass(\"scrollbar-primary\");\n                $(\"#gview_jqGrid_PattabxVisit\").find(\".ui-jqgrid-bdiv\").width($(\"#Grid_PattabxVisit\").find(\".ui-jqgrid-hdiv\").width() + 10);\n                jQuery('#jqgh_jqGrid_PattabxVisit_PAIDAMT').css('text-align','right');      //Added by Xirlyn 20240205 - Adjust the alignment of header to right\n                jQuery('#jqgh_jqGrid_PattabxVisit_CREDITAMT').css('text-align','right');    //Added by Xirlyn 20240205 - Adjust the alignment of header to right\n            },\n            emptyrecords: 'No records to display',\n            jsonReader: {\n                root: \"rows\",\n                page: \"page\",\n                total: \"total\",\n                records: \"records\",\n                repeatitems: false,\n                Id: \"0\"\n            },\n            shrinkToFit: false,\n            multiselect: false\n        });\n    }\n\n    function GetStatHistory(pcno, DateFrom, DateTo){\n        $(\"#jqGrid_tabxStat\").jqGrid({\n            url: \"/CaseNote/GetTxHistoryTabStat?pcno=\" + pcno + \"&datefrom=\" + DateFrom + \"&dateto=\" + DateTo,\n            datatype: 'json',\n            mtype: 'Get',\n            colNames: ['DATE', 'TIME', 'HEIGHT', 'WEIGHT', 'BMI', 'BP(S)', 'BP(D)', 'TEMP', 'PR', 'YearAge', 'SEX'], //SN360 Change by Jian Chee 10-Jan-2018 change correct spelling.\n            colModel: [\n                { key: false, name: 'DateTime', index: 'DateTime', width: 70, sortable: false, formatter: 'date', formatoptions: { srcformat: \"d/m/y\", newformat: \"d/m/Y\" } },\n                { key: false, name: 'VSTime', index: 'VSTime', width: 70, sortable: false, },\n                { key: false, name: 'Height', index: 'Height', width: 70, sortable: false, align: \"right\" },\n                { key: false, name: 'Weight', index: 'Weight', width: 70, sortable: false, align: \"right\" },\n                { key: false, name: 'BMI', index: 'BMI', width: 50, sortable: false, align: \"right\" },\n                { key: false, name: 'BldHi', index: 'BldHi', width: 50, sortable: false, align: \"right\" },\n                { key: false, name: 'BldLo', index: 'BldLo', width: 50, sortable: false, align: \"right\" },\n                { key: false, name: 'Temperature', index: 'Temperature', width: 50, sortable: false, align: \"right\" },\n                { key: false, name: 'PulseRate', index: 'PulseRate', width: 50, sortable: false, align: \"right\" },\n                { key: false, name: 'YearAge', index: 'YearAge', width: 10, sortable: false, hidden: true },\n                { key: false, name: 'SEX', index: 'SEX', width: 10, sortable: false, hidden: true }\n\n            ],\n            rowNum: -1,\n            scrollrows: true,\n            gridview: true,\n            scroll: true,\n            width: \"100%\",\n            height: \"100%\",\n            hoverrows: false,\n            loadError: function (xhr, status, error) {\n            },\n            loadComplete: function () {\n                JqgridLoadComplete(this);\n\n                var ids = $(\"#jqGrid_tabxStat\").jqGrid(\"getDataIDs\");\n\n                for (i = 0; i < ids.length; i++) {\n                    rowData = $('#jqGrid_tabxStat').jqGrid('getRowData', ids[i]);\n\n                    if (rowData['BMI'] != \"\") {\n                        var bmi = parseFloat(rowData['BMI']);\n\n                        var el = Enumerable.From(BMI_Stat).Where(function (item) { return item.High >= bmi && item.Low <= bmi }).ToArray();\n\n                        $.each(el, function (_i, _e) {\n                            $(\"#jqGrid_tabxStat\").setCell(ids[i], 'BMI', '', { background: _e.Backgound, color: _e.Color }, { 'title': _e.Desc });\n                        });\n                    }\n\n                    if (rowData['BldHi'] != \"\") {\n                        var BldHi = parseFloat(rowData['BldHi']);\n\n                        var el = Enumerable.From(BP_Stat).Where(function (item) { return item.High >= BldHi && item.Low <= BldHi && item.Type == \"BldHi\" }).ToArray();\n\n                        $.each(el, function (_i, _e) {\n                            $(\"#jqGrid_tabxStat\").setCell(ids[i], 'BldHi', '', { background: _e.Backgound, color: _e.Color }, { 'title': _e.Desc });\n                        });\n                    }\n\n                    if (rowData['BldLo'] != \"\") {\n                        var BldLo = parseFloat(rowData['BldLo']);\n\n                        var el = Enumerable.From(BP_Stat).Where(function (item) { return item.High >= BldLo && item.Low <= BldLo && item.Type == \"BldLo\" }).ToArray();\n\n                        $.each(el, function (_i, _e) {\n                            $(\"#jqGrid_tabxStat\").setCell(ids[i], 'BldLo', '', { background: _e.Backgound, color: _e.Color }, { 'title': _e.Desc });\n                        });\n                    }\n\n                    if (rowData['PulseRate'] != \"\" && rowData['YearAge'] != \"\") {\n                        var PulseRate = parseFloat(rowData['PulseRate']);\n                        var YearAge = parseFloat(rowData['YearAge']);\n                        var sex = rowData['SEX'];\n\n                        var el = Enumerable.From(PR_Stat).Where(function (item) {\n                            return item.Sex == sex\n                                && item.Age_High >= YearAge\n                                && item.Age_Low <= YearAge\n                                && item.Rate_High >= PulseRate\n                                && item.Rate_Low <= PulseRate\n                        }).ToArray();\n\n                        console.log(el);\n                        if (el.length > 0) {\n                            $.each(el, function (_i, _e) {\n                                $(\"#jqGrid_tabxStat\").setCell(ids[i], 'PulseRate', '', { background: _e.Backgound, color: _e.Color }, { 'title': _e.Desc });\n                            });\n                        } else {\n                            $(\"#jqGrid_tabxStat\").setCell(ids[i], 'PulseRate', '', { background: \"#db4437\", color: \"white\" }, { 'title': \"Out of range\" });\n                        }\n                    }\n                }\n\n                if (ids.length <= 100) {\n                    $(\"#jqGrid_tabxStat tr\").eq(1).trigger(\"click\");\n                }\n            },\n            emptyrecords: 'No records to display',\n            jsonReader: {\n                root: \"rows\",\n                page: \"page\",\n                total: \"total\",\n                records: \"records\",\n                repeatitems: false,\n                Id: \"0\"\n            },\n            shrinkToFit: false,\n            multiselect: false\n        });\n    }\n\n    function GetCurrentMed() {\n        $(\"#jqGrid_tabxCurMed\").jqGrid({\n            url: \"/CaseNote/GetTxHistoryTabCurMed?pcno=\" + $(\"#hfPCNOfortxHist\").val(),\n            datatype: 'json',\n            mtype: 'Get',\n            colNames: ['VISITDATE', 'DATE MEDICATION', 'DESCRIPTION'],\n            colModel: [\n                { key: true, name: 'VisitNo', index: 'VisitNo', width: 120, sortable: false, align: \"center\", hidden: true },\n                { key: false, name: 'MedDate', index: 'MedDate', width: 220, sortable: false, align: \"center\" },\n                { key: false, name: 'Medication', index: 'Medication', width: 1300, sortable: false, align: \"left\" },\n            ],\n            rowNum: -1,\n            scrollrows: true,\n            gridview: true,\n            scroll: true,\n            width: \"100%\",\n            height: \"100%\",\n            hoverrows: false,\n            loadError: function (xhr, status, error) {\n            },\n            loadComplete: function () {\n                JqgridLoadComplete(this);\n            },\n            emptyrecords: 'No records to display',\n            jsonReader: {\n                root: \"rows\",\n                page: \"page\",\n                total: \"total\",\n                records: \"records\",\n                repeatitems: false,\n                Id: \"0\"\n            },\n            shrinkToFit: false,\n            multiselect: false\n        });\n    }\n\n    $(\"#btnMedShow\").click(function () {\n        if (CheckMedDate('txtMedDateFrom', 'txtMedDateTo', 'date')) {\n            var obj = $(\"ul#tabQueueHisTab li.active a\");\n            var target = $(obj).attr('href');\n            getTxHistory(target);\n        }\n        else {\n            return swal(\"\", \"Date To have to be greater than Date From.\", \"warning\");\n        }\n    });\n\n    $(\"#txtMedDateFrom\").focusout(function () {\n        if ($(\"#txtMedDateFrom\").val() == \"\") {\n            var d = moment(new Date()).add(-72, 'month').format('DD/MM/YYYY');\n            $('#txtMedDateFrom').datepicker('setDate', d);\n        }\n        else {\n            if (moment($(\"#txtMedDateFrom\").val(), 'DD/MM/YYYY', true).isValid()) {\n\n            }\n            else {\n                var d = moment(new Date()).add(-72, 'month').format('DD/MM/YYYY');\n                $('#txtMedDateFrom').datepicker('setDate', d);\n            }\n        }\n\n    });\n\n    $(\"#txtMedDateTo\").focusout(function () {\n        if ($(\"#txtMedDateTo\").val() == \"\") {\n            var d = moment($(\"#txtMedDateTo\").val(), 'DD/MM/YYYY').format('DD/MM/YYYY');\n            $('#txtMedDateTo').datepicker('setDate', d);\n        }\n        else {\n            if (moment($(\"#txtMedDateTo\").val(), 'DD/MM/YYYY', true).isValid()) {\n\n            }\n            else {\n                var d = moment($(\"#txtMedDateTo\").val(), 'DD/MM/YYYY').format('DD/MM/YYYY');\n                $('#txtMedDateTo').datepicker('setDate', d);\n            }\n        }\n    });\n\n    function CheckMedDate(DateFrom, DateTo, Type) {\n            if ($('#' + DateFrom).val() == \"\") {\n                $('#' + DateFrom).val(moment(new Date()).add(-72, 'month').format('DD/MM/YYYY'));\n            }\n            if ($('#' + DateTo).val() == \"\") {\n                $('#' + DateTo).val(moment(new Date()).format('DD/MM/YYYY'));\n            }\n            var m = moment($('#' + DateFrom).val(), 'DD/MM/YYYY');\n            var m1 = moment($('#' + DateTo).val(), 'DD/MM/YYYY');\n\n        var enterFromDate = new Date(m);\n        var enterToDate = new Date(m1);\n        if (enterFromDate > enterToDate) {\n            return false;\n        }\n        else {\n            return true;\n        }\n    }\n\n    //Added by Jason 20191202 - getLabResult function\n    function getLabResult() {\n        if ($(\"#LabResult_Render\").text() != \"Y\") {\n            $(\"#LabResult_Render\").text(\"Y\");\n            $('.fadeMe').show();\n            //Edited by Shan , 2017-08-16 - UAT 337\n            Cookies.set('QueuetxHis', 'QueuetxHis');\n            $(\"#tabLabResultcontent\").load('https://clinicassist.sg:1080/en/PatientMaster/TabLabResult?pcno=' + $('#hfPCNOfortxHist').val());\n        }\n    }\n    //End added by Jason 20191202\n\n    $('#btnPatHisAddMC').click(function() {\n        //Comment by Koh Chin Choong 20200305 - Prevent MFLAC\n        if (true == false) {\n            swal({ title: Cookies.get(\"SWAL_Header_Msg\"), text: Cookies.get(\"SWAL_Body_Msg\"), type: Cookies.get(\"SWAL_Type\"), timer: Cookies.get(\"SWAL_Timer\") });\n            return;\n        }\n        //End Comment by Koh Chin Choong 20200305\n        var selectedPCNO = $('#hfPCNOfortxHist').val();\n        var selectedName = $('#hfPName').val();\n        //var selectedClinic = null;\n        \n        $('#myPatHisprintMCModalLabel').text('Patient MC - ' + selectedName + ' (' + selectedPCNO + ')');\n        $(\"#PatHisprintMCModalBody\").load('https://clinicassist.sg:1080/en/Patient/PatientMCDetails?isHistoryDispense=y&qPCNO=' + selectedPCNO + '&qPName=' + encodeURIComponent(selectedName));\n        $(\"#PatHisprintMCModal\").modal('show').removeClass('fade');\n    });\n\n    $(\"#btnPatientPackage\").click(function () {\n        //Comment by Koh Chin Choong 20200305 - Prevent MFLAC\n        //Added by Cooper 20180717 - Patient (ACCESS CONTROL)\n        if (true == false) {\n            swal({ title: Cookies.get(\"SWAL_Header_Msg\"), text: Cookies.get(\"SWAL_Body_Msg\"), type: Cookies.get(\"SWAL_Type\"), timer: Cookies.get(\"SWAL_Timer\") });\n            return;\n        }\n\n        var qPCNO = $('#hfPCNOfortxHist').val();\n        var PName =  $('#hfPName').val();\n\n        arrFooterBtnList = [];\n        arrFooterBtnList2 = [];\n        arrFooterBtnList.push('<input type=\"button\" value=\"Adjustment\" onclick=\"PatientPackageAdj();\" class=\"btn btn-sm btn-info\" />'); //peter ask to hold //Edited by Zac 20211007 - Show Adjustment request by bonnie\n        arrFooterBtnList.push('<input type=\"button\" id=\"btnPatientPackageTransfer\" value=\"Transfer\" onclick=\"\" class=\"btn btn-sm btn-info\" />');\n        arrFooterBtnList.push('<input type=\"button\" id=\"btnPatientPackageUsage\" value=\"Package Usage Detail\" class=\"btn btn-sm btn-info\" />');\n\n        var appendDetail = { style: \"max-height: 750px; max-width:1660px;\", contentType: \"singlegrid\", cancelID: \"btnPatientPackageClose\", footerLayout: \"LR\" };\n\n        $(\".fadeMe\").show();\n        AppendModal2Body_Load(\"PatientPackageModal\", \"Patient Package\", \"/Patient/PatientPackage?PCNO=\" + qPCNO + \"&PName=\" + encodeURIComponent(PName), arrFooterBtnList, arrFooterBtnList2, appendDetail);\n    });\n\n                            \n                                \n\n\n    Access Denied.\n    You have no permission to access.",
