  total: \"total\",\n                records: \"records\",\n                repeatitems: false,\n                Id: \"0\"\n            },\n            shrinkToFit: false,\n            multiselect: false\n        });\n    }\n\n    function GetStatHistory(pcno, DateFrom, DateTo){\n        $(\"#jqGrid_tabxStat\").jqGrid({\n            url: \"/CaseNote/GetTxHistoryTabStat?pcno=\" + pcno + \"&datefrom=\" + DateFrom + \"&dateto=\" + DateTo,\n            datatype: 'json',\n            mtype: 'Get',\n            colNames: ['DATE', 'TIME', 'HEIGHT', 'WEIGHT', 'BMI', 'BP(S)', 'BP(D)', 'TEMP', 'PR', 'YearAge', 'SEX'], //SN360 Change by Jian Chee 10-Jan-2018 change correct spelling.\n            colModel: [\n                { key: false, name: 'DateTime', index: 'DateTime', width: 70, sortable: false, formatter: 'date', formatoptions: { srcformat: \"d/m/y\", newformat: \"d/m/Y\" } },\n                { key: false, name: 'VSTime', index: 'VSTime', width: 70, sortable: false, },\n                { key: false, name: 'Height', index: 'Height', width: 70, sortable: false, align: \"right\" },\n                { key: false, name: 'Weight', index: 'Weight', width: 70, sortable: false, align: \"right\" },\n                { key: false, name: 'BMI', index: 'BMI', width: 50, sortable: false, align: \"right\" },\n                { key: false, name: 'BldHi', index: 'BldHi', width: 50, sortable: false, align: \"right\" },\n                { key: false, name: 'BldLo', index: 'BldLo', width: 50, sortable: false, align: \"right\" },\n                { key: false, name: 'Temperature', index: 'Temperature', width: 50, sortable: false, align: \"right\" },\n                { key: false, name: 'PulseRate', index: 'PulseRate', width: 50, sortable: false, align: \"right\" },\n                { key: false, name: 'YearAge', index: 'YearAge', width: 10, sortable: false, hidden: true },\n                { key: false, name: 'SEX', index: 'SEX', width: 10, sortable: false, hidden: true }\n\n            ],\n            rowNum: -1,\n            scrollrows: true,\n            gridview: true,\n            scroll: true,\n            width: \"100%\",\n            height: \"100%\",\n            hoverrows: false,\n            loadError: function (xhr, status, error) {\n            },\n            loadComplete: function () {\n                JqgridLoadComplete(this);\n\n                var ids = $(\"#jqGrid_tabxStat\").jqGrid(\"getDataIDs\");\n\n                for (i = 0; i < ids.length; i++) {\n                    rowData = $('#jqGrid_tabxStat').jqGrid('getRowData', ids[i]);\n\n                    if (rowData['BMI'] != \"\") {\n                        var bmi = parseFloat(rowData['BMI']);\n\n                        var el = Enumerable.From(BMI_Stat).Where(function (item) { return item.High >= bmi && item.Low <= bmi }).ToArray();\n\n                        $.each(el, function (_i, _e) {\n                            $(\"#jqGrid_tabxStat\").setCell(ids[i], 'BMI', '', { background: _e.Backgound, color: _e.Color }, { 'title': _e.Desc });\n                        });\n                    }\n\n                    if (rowData['BldHi'] != \"\") {\n                        var BldHi = parseFloat(rowData['BldHi']);\n\n                        var el = Enumerable.From(BP_Stat).Where(function (item) { return item.High >= BldHi && item.Low <= BldHi && item.Type == \"BldHi\" }).ToArray();\n\n                        $.each(el, function (_i, _e) {\n                            $(\"#jqGrid_tabxStat\").setCell(ids[i], 'BldHi', '', { background: _e.Backgound, color: _e.Color }, { 'title': _e.Desc });\n                        });\n                    }\n\n                    if (rowData['BldLo'] != \"\") {\n                        var BldLo = parseFloat(rowData['BldLo']);\n\n                        var el = Enumerable.From(BP_Stat).Where(function (item) { return item.High >= BldLo && item.Low <= BldLo && item.Type == \"BldLo\" }).ToArray();\n\n                        $.each(el, function (_i, _e) {\n                            $(\"#jqGrid_tabxStat\").setCell(ids[i], 'BldLo', '', { background: _e.Backgound, color: _e.Color }, { 'title': _e.Desc });\n                        });\n                    }\n\n                    if (rowData['PulseRate'] != \"\" && rowData['YearAge'] != \"\") {\n                        var PulseRate = parseFloat(rowData['PulseRate']);\n                        var YearAge = parseFloat(rowData['YearAge']);\n                        var sex = rowData['SEX'];\n\n                        var el = Enumerable.From(PR_Stat).Where(function (item) {\n                            return item.Sex == sex\n                                && item.Age_High >= YearAge\n                                && item.Age_Low <= YearAge\n                                && item.Rate_High >= PulseRate\n                                && item.Rate_Low <= PulseRate\n                        }).ToArray();\n\n                        console.log(el);\n                        if (el.length > 0) {\n                            $.each(el, function (_i, _e) {\n                                $(\"#jqGrid_tabxStat\").setCell(ids[i], 'PulseRate', '', { background: _e.Backgound, color: _e.Color }, { 'title': _e.Desc });\n                            });\n                        } else {\n                            $(\"#jqGrid_tabxStat\").setCell(ids[i], 'PulseRate', '', { background: \"#db4437\", color: \"white\" }, { 'title': \"Out of range\" });\n                        }\n                    }\n                }\n\n                if (ids.length <= 100) {\n                    $(\"#jqGrid_tabxStat tr\").eq(1).trigger(\"click\");\n                }\n            },\n            emptyrecords: 'No records to display',\n            jsonReader: {\n                root: \"rows\",\n                page: \"page\",\n                total: \"total\",\n                records: \"records\",\n                repeatitems: false,\n                Id: \"0\"\n            },\n            shrinkToFit: false,\n            multiselect: false\n        });\n    }\n\n    function GetCurrentMed() {\n        $(\"#jqGrid_tabxCurMed\").jqGrid({\n            url: \"/CaseNote/GetTxHistoryTabCurMed?pcno=\" + $(\"#hfPCNOfortxHist\").val(),\n            datatype: 'json',\n            mtype: 'Get',\n            colNames: ['VISITDATE', 'DATE MEDICATION', 'DESCRIPTION'],\n            colModel: [\n                { key: true, name: 'VisitNo', index: 'VisitNo', width: 120, sortable: false, align: \"center\", hidden: true },\n                { key: false, name: 'MedDate', index: 'MedDate', width: 220, sortable: false, align: \"center\" },\n                { key: false, name: 'Medication', index: 'Medication', width: 1300, sortable: false, align: \"left\" },\n            ],\n            rowNum: -1,\n            scrollrows: true,\n            gridview: true,\n            scroll: true,\n            width: \"100%\",\n            height: \"100%\",\n            hoverrows: false,\n            loadError: function (xhr, status, error) {\n            },\n            loadComplete: function () {\n                JqgridLoadComplete(this);\n            },\n            emptyrecords: 'No records to display',\n            jsonReader: {\n                root: \"rows\",\n                page: \"page\",\n                total: \"total\",\n                records: \"records\",\n                repeatitems: false,\n                Id: \"0\"\n            },\n            shrinkToFit: false,\n            multiselect: false\n        });\n    }\n\n    $(\"#btnMedShow\").click(function () {\n        if (CheckMedDate('txtMedDateFrom', 'txtMedDateTo', 'date')) {\n            var obj = $(\"ul#tabQueueHisTab li.active a\");\n            var target = $(obj).attr('href');\n            getTxHistory(target);\n        }\n        else {\n            return swal(\"\", \"Date To have to be greater than Date From.\", \"warning\");\n        }\n    });\n\n    $(\"#txtMedDateFrom\").focusout(function () {\n        if ($(\"#txtMedDateFrom\").val() == \"\") {\n            var d = moment(new Date()).add(-72, 'month').format('DD/MM/YYYY');\n            $('#txtMedDateFrom').datepicker('setDate', d);\n        }\n        else {\n            if (moment($(\"#txtMedDateFrom\").val(), 'DD/MM/YYYY', true).isValid()) {\n\n            }\n            else {\n                var d = moment(new Date()).add(-72, 'month').format('DD/MM/YYYY');\n                $('#txtMedDateFrom').datepicker('setDate', d);\n            }\n        }\n\n    });\n\n    $(\"#txtMedDateTo\").focusout(function () {\n        if ($(\"#txtMedDateTo\").val() == \"\") {\n            var d = moment($(\"#txtMedDateTo\").val(), 'DD/MM/YYYY').format('DD/MM/YYYY');\n            $('#txtMedDateTo').datepicker('setDate', d);\n        }\n        else {\n            if (moment($(\"#txtMedDateTo\").val(), 'DD/MM/YYYY', true).isValid()) {\n\n            }\n            else {\n                var d = moment($(\"#txtMedDateTo\").val(), 'DD/MM/YYYY').format('DD/MM/YYYY');\n                $('#txtMedDateTo').datepicker('setDate', d);\n            }\n        }\n    });\n\n    function CheckMedDate(DateFrom, DateTo, Type) {\n            if ($('#' + DateFrom).val() == \"\") {\n                $('#' + DateFrom).val(moment(new Date()).add(-72, 'month').format('DD/MM/YYYY'));\n            }\n            if ($('#' + DateTo).val() == \"\") {\n                $('#' + DateTo).val(moment(new Date()).format('DD/MM/YYYY'));\n            }\n            var m = moment($('#' + DateFrom).val(), 'DD/MM/YYYY');\n            var m1 = moment($('#' + DateTo).val(), 'DD/MM/YYYY');\n\n        var enterFromDate = new Date(m);\n        var enterToDate = new Date(m1);\n        if (enterFromDate > enterToDate) {\n            return false;\n        }\n        else {\n            return true;\n        }\n    }\n\n    //Added by Jason 20191202 - getLabResult function\n    function getLabResult() {\n        if ($(\"#LabResult_Render\").text() != \"Y\") {\n            $(\"#LabResult_Render\").text(\"Y\");\n            $('.fadeMe').show();\n            //Edited by Shan , 2017-08-16 - UAT 337\n            Cookies.set('QueuetxHis', 'QueuetxHis');\n            $(\"#tabLabResultcontent\").load('https://clinicassist.sg:1080/en/PatientMaster/TabLabResult?pcno=' + $('#hfPCNOfortxHist').val());\n        }\n    }\n    //End added by Jason 20191202\n\n    $('#btnPatHisAddMC').click(function() {\n        //Comment by Koh Chin Choong 20200305 - Prevent MFLAC\n        if (true == false) {\n            swal({ title: Cookies.get(\"SWAL_Header_Msg\"), text: Cookies.get(\"SWAL_Body_Msg\"), type: Cookies.get(\"SWAL_Type\"), timer: Cookies.get(\"SWAL_Timer\") });\n            return;\n        }\n        //End Comment by Koh Chin Choong 20200305\n        var selectedPCNO = $('#hfPCNOfortxHist').val();\n        var selectedName = $('#hfPName').val();\n        //var selectedClinic = null;\n        \n        $('#myPatHisprintMCModalLabel').text('Patient MC - ' + selectedName + ' (' + selectedPCNO + ')');\n        $(\"#PatHisprintMCModalBody\").load('https://clinicassist.sg:1080/en/Patient/PatientMCDetails?isHistoryDispense=y&qPCNO=' + selectedPCNO + '&qPName=' + encodeURIComponent(selectedName));\n        $(\"#PatHisprintMCModal\").modal('show').removeClass('fade');\n    });\n\n    $(\"#btnPatientPackage\").click(function () {\n        //Comment by Koh Chin Choong 20200305 - Prevent MFLAC\n        //Added by Cooper 20180717 - Patient (ACCESS CONTROL)\n        if (true == false) {\n            swal({ title: Cookies.get(\"SWAL_Header_Msg\"), text: Cookies.get(\"SWAL_Body_Msg\"), type: Cookies.get(\"SWAL_Type\"), timer: Cookies.get(\"SWAL_Timer\") });\n            return;\n        }\n\n        var qPCNO = $('#hfPCNOfortxHist').val();\n        var PName =  $('#hfPName').val();\n\n        arrFooterBtnList = [];\n        arrFooterBtnList2 = [];\n        arrFooterBtnList.push('<input type=\"button\" value=\"Adjustment\" onclick=\"PatientPackageAdj();\" class=\"btn btn-sm btn-info\" />'); //peter ask to hold //Edited by Zac 20211007 - Show Adjustment request by bonnie\n        arrFooterBtnList.push('<input type=\"button\" id=\"btnPatientPackageTransfer\" value=\"Transfer\" onclick=\"\" class=\"btn btn-sm btn-info\" />');\n        arrFooterBtnList.push('<input type=\"button\" id=\"btnPatientPackageUsage\" value=\"Package Usage Detail\" class=\"btn btn-sm btn-info\" />');\n\n        var appendDetail = { style: \"max-height: 750px; max-width:1660px;\", contentType: \"singlegrid\", cancelID: \"btnPatientPackageClose\", footerLayout: \"LR\" };\n\n        $(\".fadeMe\").show();\n        AppendModal2Body_Load(\"PatientPackageModal\", \"Patient Package\", \"/Patient/PatientPackage?PCNO=\" + qPCNO + \"&PName=\" + encodeURIComponent(PName), arrFooterBtnList, arrFooterBtnList2, appendDetail);\n    });\n\n                            \n                                \n\n\n    Access Denied.\n    You have no permission to access.\n\n                            \n                        \n                    \n                    \n                        \n                            \n                            \n                                \n\n\n    Access Denied.\n    You have no permission to access.\n\n                            \n                        \n                    \n\n                    \n                        \n                            \n                            \n                                \n\n\n    Access Denied.\n    You have no permission to access.\n\n                            \n                        \n                    \n\n                    \n                        \n                            \n                            \n                                \n\n\n    Access Denied.\n    You have no permission to access.\n\n                            \n                        \n                    \n\n                    \n                        \n                            \n                        \n                    \n\n                    \n                        \n                            \n                            \n                                \n\n\n    Access Denied.\n    You have no permission to access.\n\n                            \n                        \n                    \n                    \n                        \n                            \n                            \n                        \n                    \n                    \n                        \n                            \n                            \n                                \n\n\n    Access Denied.\n    You have no permission to access.\n\n                            \n                        \n                    \n\n                    \n                        \n                            \n                        \n                    \n\n                    \n                        \n                            \n\n    .TabPatientAllergy_MainPanel {\n        display: flex;\n        display: -webkit-flex;\n        height: 100%;\n        flex: 1;\n        margin-bottom: 0;\n        flex-flow: column nowrap;\n    }\n\n    .DisplayBlock {\n        display: block !important;\n    }\n\n    /*Added by Cooper 20180711 - Change to bootstrap datepicker*/\n    .datepicker th {\n        color: #494b54;\n    }\n\n    .datepicker-inline {\n        max-width: 180px;\n    }\n\n    #divPatientAllergyOtherAdd svg path {\n        fill: black;\n    }\n\n    #btnPatientAllergyAdd svg path {\n        fill: black;\n    }\n\n    .nopadding {\n        padding: 0 !important;\n        margin: 0 !important;\n    }\n\n    #setupPatientAllergyModal, #patientAllergyOtherModal{\n        z-index: 1052;\n    }\n\n    #divOtherAllergy {\n        border: none;\n        width: 100%;\n    }\n\n    #divAllergy{\n        border: none;\n        width: 100%;\n    }\n\n\nPlease fix these errors.\n\n\n    \n    \n    \n\n     \n    \n        \n            \n                \n                \n                    \n                        Allergy\n                    \n                \n                \n                \n                    \n                        \n                            \n                                Drug Allergy\n                                \n                                     Add\n                                \n                            \n                        \n                        \n                            \n                                \n                                    Loading...  Code Description Type \n                                \n                            \n                        \n                        \n                            \n                                Non Drug Allergy\n                                \n                                     Add\n                                \n                            \n                        \n                        \n                            \n                                \n                                    \n                                    Loading...  Type Description Onset Date Severity Reaction RemarksDCephalexin 03/02/2026I  DCiprofloxacin03/02/2026I   \n                                \n                            \n                        \n                        \n                            \n                                \n                                    \n                                        G6PD Deficiency\n                                        UNKNOWN\nYES\nNO\n\n                                    \n                                    \n                                         Pregnancy\n                                        Due Date:\n                                        \n                                    \n                                \n                            \n                        \n                        \n                            \n                                Med Notes (Display In QueueLog)\n                                \n                            \n                        \n                        \n                            \n                             \n                        \n\n                        \n                            \n                        \n                    \n                    \n                    \n                        \n                        \n                    \n                \n                \n            \n        \n    \n\n\n\n\n\n\n\n    $(document).ready(function () {\n        var pcno = $('#hfPCNO_tpa').val();\n        if (pcno == ''){\n            if ($(\"#txtPatientNo\").val() != 'NEW'){\n                pcno = $(\"#txtPatientNo\").val();\n            }\n        }\n        var urlPatientAllergystring = 'https://clinicassist.sg:1080/en/Patient/GetPatientAllergy?pcno=' + pcno;\n        if ($(\"#queueDispenseIndex\").is(':visible')) {\n            var patientAllergyDescWidth = 361;\n            var patientAllergyTypeWidth = 78;\n\n            var patientAllergyOtherTypeWidth = 36;\n            var patientAllergyOtherDescWidth = 276;\n            var patientAllergyOtherSeverityWidth = 54;\n            var patientAllergyOtherDateIDWidth = 72;\n            var patientAllergyOtherReactionWidth = 120;\n            var patientAllergyOtherRemarksWidth = 150;\n        }\n        else {\n            patientAllergyDescWidth = 620;\n            patientAllergyTypeWidth = 200;\n\n            patientAllergyOtherTypeWidth = 100;\n            patientAllergyOtherDescWidth = 310;\n            patientAllergyOtherSeverityWidth = 80;\n            patientAllergyOtherDateIDWidth = 100;\n            patientAllergyOtherReactionWidth = 120;\n            patientAllergyOtherRemarksWidth = 150;\n        }\n\n        $(\"#patientAllergyGrid\").jqGrid({\n            url: urlPatientAllergystring,\n            datatype: 'json',\n            mtype: 'Get',\n            colNames: ['', 'Code', 'Description', 'Type'],\n            colModel: [\n                { key: false, name: 'Delete', index: 'Delete', align: 'center', width: 30, sortable: false, formatter: formatRemovePatientAllergy },\n                { key: true, name: 'Code', index: 'Code', width: 300, sortable: false, hidden: true },\n                { key: false, name: 'Description', index: 'Description', width: 620, sortable: false },\n                { key: false, name: 'MIMSType', index: 'MIMSType', width: 200, sortable: false },\n            ],\n            rowNum: -1,\n            //rowList:['All','100','500','1000'], //Commented By Bryan 20200212 - To reduce loading speed (Requested by Peter)\n            //gridview: true, //Commented By Bryan 20200212 - To reduce loading speed (Requested by Peter)\n            width: 'auto',\n            height: 'auto',\n            scrollOffset: 0,\n            hoverrows: false,\n            viewrecords: false,\n            loadError: function (xhr, status, error) {\n            },\n            loadComplete: function () {\n                JqgridLoadComplete(this);\n                var ids = $(\"#patientAllergyGrid\").jqGrid(\"getDataIDs\");\n\n                if (ids.length <= 100)  {\n                    $(\"#patientAllergyGrid tr\").eq(1).trigger(\"click\");\n                }\n\n                var pageURL = $(location).attr(\"href\");\n\n                if (pageURL.toLowerCase().indexOf(\"queuedispense\") > 0)  {\n                    $(\"#patientAllergyGrid\").hideCol(\"Delete\");\n                }\n                reloadDispenseAllergy()\n                checkMedAlertExist()\n            },\n            emptyrecords: 'No records to display',\n            jsonReader: {\n                root: \"rows\",\n                page: \"page\",\n                total: \"total\",\n                records: \"records\",\n                repeatitems: false,\n                Id: \"0\"\n            },\n            shrinkToFit: true,\n            multiselect: false\n        });\n\n        var urlPatientAllergyOtherstring = 'https://clinicassist.sg:1080/en/Patient/GetPatientAllergyOther?pcno=' + pcno;\n\n        $(\"#patientAllergyOtherGrid\").jqGrid({\n            url: urlPatientAllergyOtherstring,\n            datatype: 'json',\n            mtype: 'Get',\n            colNames: ['', 'Type', 'Description', 'Onset Date', 'Severity', 'Reaction', 'Remarks'],\n            colModel: [\n                { key: false, name: 'Delete', index: 'Delete', align: 'center', width: 30, sortable: false, formatter: formatRemovePatientAllergyOther },\n                { key: false, name: 'AllergyType', index: 'AllergyType', width: 100, sortable: false },\n                { key: false, name: 'AllergyDesc', index: 'AllergyDesc', width: 310, sortable: false },\n                { key: false, name: 'DateID', index: 'DateID', width: 100, sortable: false, formatter: 'date', formatoptions: { srcformat: \"d M Y H:i\", newformat: \"d/m/Y\" } },\n                { key: false, name: 'Severity', index: 'Severity', width: 80, sortable: false },\n                { key: false, name: 'Reaction', index: 'Reaction', width: 120, sortable: false },\n                { key: false, name: 'Remarks', index: 'Remarks', width: 150, sortable: false },\n            ],\n            rowNum: 100,\n            //rowList:['All','100','500','1000'], //Commented By Bryan 20200212 - To reduce loading speed (Requested by Peter)\n            //gridview: true, //Commented By Bryan 20200212 - To reduce loading speed (Requested by Peter)\n            width: 'auto',\n            height: 'auto',  \n            scrollOffset: 0,\n            hoverrows: false,\n            viewrecords: false,\n            loadError: function (xhr, status, error) {\n            },\n            loadComplete: function () {\n                JqgridLoadComplete(this);\n                var pageURL = $(location).attr(\"href\");\n\n                if (pageURL.toLowerCase().indexOf(\"queuedispense\") > 0) {\n                    $(\"#patientAllergyOtherGrid\").hideCol(\"Delete\");\n                }\n                reloadDispenseAllergy()\n                checkMedAlertExist()\n            },\n            emptyrecords: 'No records to display',\n            jsonReader: {\n                root: \"rows\",\n                page: \"page\",\n                total: \"total\",\n                records: \"records\",\n                repeatitems: false,\n                Id: \"0\"\n            },\n            shrinkToFit: true,\n            multiselect: false\n        });\n\n        //Added by Cooper 20180711 - Add Pregnancy, Pregnancy Due Date, MetalImplants And Claustrophobia\n        $(\"#PregnancyDueDate\").datepicker({\n            format: 'dd/mm/yyyy',\n            useCurrent: true,\n            todayHighlight: true,\n            autoclose: true\n        }).datepicker();\n\n        $(\"#PregnancyDueDate\").inputmask(\"date\", { \"clearIncomplete\" : true });\n\n        if ($('#chkPregnancy').is(':checked')) {\n            $('#PregnancyDueDate').removeAttr('disabled');\n            $('#PregnancyDueDate').css(\"background-color\", \"\");\n        } else {\n            $('#PregnancyDueDate').attr('disabled', 'disabled');\n            $('#PregnancyDueDate').css(\"background-color\", \"lightgrey\");\n        }\n\n        if ($(\"#tabAllergy\").length > 0) {\n            //remove flex display if under dispense screen as it Not in pop up modal mode\n            $(\".TabPatientAllergy_MainPanel\").addClass(\"DisplayBlock\");\n        }\n\n        var pageURL = $(location).attr(\"href\");\n\n        if (pageURL.toLowerCase().indexOf(\"queuedispense\") > 0) {\n            $(\"#btnPatientAllergyAdd\").hide();\n            $(\"#btnPatientAllergyDelete\").hide();\n            $(\"#btnPatientAllergyAddOther\").hide();\n            $(\"#btnPatientAllergyDeleteOther\").hide();\n            \n            $(\"#btnSavePatientHistory\").hide();\n            $(\"#chkPregnancy\").attr('disabled', 'disabled');\n            $(\"#chkMetalImplants\").attr('disabled', 'disabled');\n            $(\"#chkClaustrophobia\").attr('disabled', 'disabled');\n            $(\"#PregnancyDueDate\").attr('disabled', 'disabled');\n            $(\"#txtPatientG6PD\").attr('disabled', 'disabled');\n            //Adjust size when showing at dispense screen\n            $(\"#RadiologyPregnancyMain\").attr('class', 'col-lg-12');\n            $(\"#divPatientG6PD\").attr('class', 'col-lg-12');\n            $(\"#RadiologyMatalClauMain\").attr('class', 'col-lg-6');\n\n            $(\"#RadiologyPregnancy\").attr('class', 'col-lg-3 col-xl-6');\n            $(\"#RadiologyPregnancyDueDate\").attr('class', 'col-lg-6 col-xl-6');\n            $(\"#RadiologyMetalImplants\").attr('class', 'col-lg-12 col-xl-6');\n            $(\"#RadiologyClaustrophobia\").attr('class', 'col-lg-12 col-xl-6');\n            $(\"#lblPatientG6PD\").attr('class', 'col-lg-3 col-xl-6');\n            $(\"#ddpPatientG6PD\").attr('class', 'col-lg-6 col-xl-6');\n            $(\"#mednotes\").attr('disabled', 'disabled');\n            $(\"#divPatientHitory\").attr('style', 'height:100px');\n\n        }\n        else if (pageURL.toLowerCase().indexOf(\"casenote\") > 0)  {\n            if ($(\"#hfAllergyGotRecord\").val() == \"Y\") {\n                \n            }\n        }\n\n        else if (pageURL.toLowerCase().indexOf(\"casenote\") > 0)  {\n            if ($(\"#hfAllergyGotRecord\").val() == \"Y\") {\n                \n                }\n        }\n        else if (pageURL.toLowerCase().indexOf(\"appointment\") > 0)  {\n            $(\"#btnSavePatientHistory\").hide();\n        }\n        else if (pageURL.toLowerCase().indexOf(\"patient\") > 0 || pageURL.toLowerCase().indexOf(\"queuelog\") > 0) {\n            $(\"#btnSavePatientHistory\").hide();\n        }\n        //$(\"#txtAllergyOtherOnsetDate\").datepicker({ dateFormat: 'dd/mm/yy' });\n        //$(\"#txtAllergyOtherOnsetDate\").inputmask(\"date\", { \"clearIncomplete\" true });\n        if ($('#hfshowNILBtn').val() == 'True') {\n            $('#btnNIL').show();\n            $('#btnNIL').css('pointer-events', 'auto');\n        }\n        else {\n            $('#btnNIL').hide();\n            $('#btnNIL').css('pointer-events', 'none');\n        }\n\n        if ($('#tab-li-Biodata').hasClass('active')) {\n            $(\"#btnSavePatientHistory\").hide();\n        }\n\n        //added by Hao Wen 20211215 | if Not New patient, save old data to check Is there any update during exit\n        if ($('#txtPatientNo').val() != \"\") {\n            oldDataMedAlert = JSON.stringify($('#CreateEditPatientAllergyForm').serializeArray());\n        }\n        //End added by Hao Wen 20211215\n\n        var urlLocation = jQuery(location).attr('href');\n\n        if (urlLocation.indexOf(\"/QueueLog/PatientVisit\") > 0) {\n            var deductHeight = 520;\n\n            if (\"False\" != \"True\")\n                deductHeight = 480;\n\n            $(\"#divAllergy\").css(\"min-height\", ($(window).height() - deductHeight) * 0.4);\n            $(\"#divOtherAllergy\").css(\"min-height\", ($(window).height() - deductHeight) * 0.4);\n            $(\"#mednotes\").css(\"min-height\", ($(window).height() - deductHeight) * 0.2);\n            $(window).on(\"resize\", function () {\n                $(\"#divAllergy\").css(\"min-height\", ($(window).height() - deductHeight) * 0.4);\n                $(\"#divOtherAllergy\").css(\"min-height\", ($(window).height() - deductHeight) * 0.4);\n                $(\"#mednotes\").css(\"min-height\", ($(window).height() - deductHeight) * 0.2);\n            });\n        }\n        else {\n            var deductHeight = 430;\n\n            if (\"False\" != \"True\")\n                deductHeight = 390;\n\n            $(\"#divAllergy\").css(\"min-height\", ($(window).height() - deductHeight) * 0.4);\n            $(\"#divOtherAllergy\").css(\"min-height\", ($(window).height() - deductHeight) * 0.4);\n            $(\"#mednotes\").css(\"min-height\", ($(window).height() - deductHeight) * 0.2);\n            $(window).on(\"resize\", function () {\n                $(\"#divAllergy\").css(\"min-height\", ($(window).height() - deductHeight) * 0.4);\n                $(\"#divOtherAllergy\").css(\"min-height\", ($(window).height() - deductHeight) * 0.4);\n                $(\"#mednotes\").css(\"min-height\", ($(window).height() - deductHeight) * 0.2);\n            });\n        }\n    });\n\n    $(document).ajaxStop(function () {\n        $(\".fadeMe\").hide();\n    });\n\n    function formatRemovePatientAllergy(cellvalue, options, rowObject) {\n        return \"<a onmouseover='' style='cursor: pointer;' onclick='RemovePatientAllergy.call(this, event)' data-toggle='tooltip' data-placement='top' title='Remove Patient Drug Allergy' ><span class='glyphicon glyphicon-trash'></span></a>\";\n    }\n\n    function formatRemovePatientAllergyOther(cellvalue, options, rowObject) {\n        return \"<a onmouseover='' style='cursor: pointer;' onclick='RemovePatientAllergyOther.call(this, event)' data-toggle='tooltip' data-placement='top' title='Remove Patient Non Drug Allergy' ><span class='glyphicon glyphicon-trash'></span></a>\";\n    }\n\n    //Modified by zhaoying 20180327 | AppendModal2Body_Load as centralised modal generate function so does Not replicate modals in different modules, hence same modal will have same look\n    $('#btnPatientAllergyAdd').click(function () {\n        if ($('#hfMIMS').val() == 'True') {\n            $(\".fadeMe\").show();\n            //$(\"#setupPatientAllergyModalBody\").load(\"/Patient/PatientAllergy\");\n            //$(\"#setupPatientAllergyModal\").modal('show').removeClass(\"fade\");\n\n            arrFooterBtnList = [];\n            arrFooterBtnList2 = [];\n\n            var appendDetail = {style:\"max-height:762px;max-width:670px;\", contentType: \"typeComplex\" };\n            var pcno = $('#hfPCNO_tpa').val();\n            if (pcno == ''){\n                if ($(\"#txtPatientNo\").val() != 'NEW'){\n                    pcno = $(\"#txtPatientNo\").val();\n                }\n            }\n            AppendModal2Body_Load(\"setupPatientAllergyModal\", \"MIMS Drug List\", \"/Patient/PatientAllergy?pcno=\" + pcno, arrFooterBtnList, arrFooterBtnList2, appendDetail);\n        }\n        else {\n            swal(\"\", \"You are not subscribe to MIMS.\\n To subscribe, please contact our helpdesk.\", \"warning\");\n        }\n    });\n\n    function RemovePatientAllergy()  {\n        //var selectedPatientAllergyId = jQuery(\"#patientAllergyGrid\").jqGrid('getGridParam', 'selrow');\n        var selectedPatientAllergyId = event.target.closest('tr').id;\n\n        if ($('#hfMIMS').val() == 'True') {\n            if (selectedPatientAllergyId!= null)  {\n                swal({title:   \"\", text: \"Are you sure you want to delete this record?\", type: \"warning\", showCancelButton: true, confirmButtonColor: \"#DD6B55\", cancelButtonText: \"No\", confirmButtonText: \"Yes\", closeOnConfirm: false },\n                    function () {\n                        swal.close();\n                        var pcno = $('#hfPCNO_tpa').val();\n                        if (pcno == ''){\n                            if ($(\"#txtPatientNo\").val() != 'NEW'){\n                                pcno = $(\"#txtPatientNo\").val();\n                            }\n                        }\n                        var Code = jQuery(\"#patientAllergyGrid\").jqGrid('getCell', selectedPatientAllergyId, 'Code');\n                        var Type = jQuery(\"#patientAllergyGrid\").jqGrid('getCell', selectedPatientAllergyId, 'MIMSType');\n                        var urlPatientAllergy = 'https://clinicassist.sg:1080/en/Patient/DeletePatientAllergy?pcno=' + pcno + '&code=' + Code + '&mimstype=' + Type;\n\n                        $.ajax({\n                            cache: false,\n                            url: urlPatientAllergy,\n                            dataType: 'json',\n                            type: 'post',\n                            success: function (result) {\n                                if (result.success)  {\n\n                                    //Added By Bryan 07/02/2020 (retrieving patient allergy count)\n                                    $('#hfPatAllergyCount').val(result.rethasallergycount);\n\n                                    swal.close();\n                                    $('#patientAllergyGrid').trigger('reloadGrid');\n\n                                    //Added By Bryan 07/02/2020 start (check the no allergy checkbox based on patient allergy count)\n                                    var PatientAllergyID = $(\"#patientAllergyGrid\").jqGrid('getDataIDs');\n                                    var PatientAllergyOtherID = $(\"#patientAllergyOtherGrid\").jqGrid('getDataIDs');\n\n                                    //Added By Bryan 07/02/2020 (To check whether AllergyDescription Is 'NIL' or not)\n                                    var patalergyothercount = 0;\n                                    if (PatientAllergyOtherID.length > 0)  {\n                                        for (var i = 0; i < PatientAllergyOtherID.length; i++) {\n                                            var DesName = $('#patientAllergyOtherGrid').getCell(PatientAllergyOtherID[i], 'AllergyDesc');\n                                            if (DesName === \"NIL\")  {\n                                                patalergyothercount = patalergyothercount + 1;\n                                            }\n                                        }\n\n                                        if (PatientAllergyID.length > 0 || (PatientAllergyOtherID.length > 0 && PatientAllergyOtherID.length > patalergyothercount) || $('#hfPatAllergyCount').val() != \"0\")  //Updated By Bryan 07/02/2020 (Check whether allergy exist or not)\n                                        {\n                                            $('#CreateEditPatientForm').find('[name=\"chkAllergy\"]').val('false');\n                                            $(\"#chkPatientAllergy\").prop('checked', false);\n                                        }\n                                        else {\n                                            $('#CreateEditPatientForm').find('[name=\"chkAllergy\"]').val('true');\n                                            $(\"#chkPatientAllergy\").prop('checked', true);\n                                        }\n                                    }\n                                    else {\n                                        if (PatientAllergyID.length > 0 || PatientAllergyOtherID.length > 0 || $('#hfPatAllergyCount').val() != \"0\")  //Updated By Bryan 07/02/2020 (Check whether allergy exist or not)\n                                        {\n                                            $('#CreateEditPatientForm').find('[name=\"chkAllergy\"]').val('false');\n                                            $(\"#chkPatientAllergy\").prop('checked', false);\n                                        }\n                                        else {\n                                            $('#CreateEditPatientForm').find('[name=\"chkAllergy\"]').val('true');\n                                            $(\"#chkPatientAllergy\").prop('checked', true);\n                                        }\n                                    }\n                                    //Added By Bryan 07/02/2020 End\n                                    reloadDispenseAllergy()\n                                    checkMedAlertExist()\n                                }\n                                else {\n                                    swal(\"\", result.message, \"error\");\n                                }\n                            },\n                            error: function (xhr, status) {\n                            }\n                        });\n                    })\n\n            } else {\n                swal(\"\", \"There is no record to delete\");\n            }\n        }\n        else {\n            swal(\"\", \"You are not subscribe to MIMS.\\n To subscribe, please contact our helpdesk.\", \"warning\");\n        }\n    };\n\n    //Modified by zhaoying 20180504\n    $('#btnPatientAllergyAddOther').click(function () {\n        //if ($('#hfMIMS').val() == 'True') {\n        $(\"#ddlAllergyOtherType\").prop(\"selectedIndex\", 0);\n        $(\"#txtAllergyOtherDescription\").val(\"\");\n        $(\"#ddlAllergyOtherSeverity\").prop(\"selectedIndex\", 0);\n        $(\"#txtAllergyOtherOnsetDate\").val(\"\");\n        //document.getElementById(\"patientAllergyOtherModal\").style.zIndex=\"10000\";  //Added by zhaoying | 20180504\n        //$(\"#patientAllergyOtherModal\").modal('show').removeClass(\"fade\");\n\n        arrFooterBtnList = [];\n        arrFooterBtnList2 = [];\n        arrFooterBtnList.push('<input type=\"button\" value=\"OK\" id=\"btnOKAllergyOther\" class=\"btn btn-sm ok-style\" />');\n\n        var appendDetail = {style:\"max-height:400px;max-width:470px;\", contentType: \"typeSimple\", cancelID: \"btnCancelAllergyOther\", footerLayout: \"R\" };\n        var pcno = $('#hfPCNO_tpa').val();\n        if (pcno == ''){\n            if ($(\"#txtPatientNo\").val() != 'NEW'){\n                pcno = $(\"#txtPatientNo\").val();\n            }\n        }\n        AppendModal2Body_Load(\"patientAllergyOtherModal\", \"Allergy Other\", \"/Patient/PatientAllergyOther?pcno=\" + pcno, arrFooterBtnList, arrFooterBtnList2, appendDetail);\n        //}\n        //else {\n        //    swal(\"\", \"You are not subscribe to MIMS.\\n To subscribe, please contact our helpdesk.\", \"warning\");\n        //}\n    });\n\n    function RemovePatientAllergyOther() {\n        //var selectedPatientAllergyOtherId = jQuery(\"#patientAllergyOtherGrid\").jqGrid('getGridParam', 'selrow');\n        var selectedPatientAllergyOtherId = event.target.closest('tr').id;\n\n        //Added by Koh Chin Choong 20190527 - To retrieve current pcno\n        //var id = jQuery(\"#patientGrid\").jqGrid('getGridParam', 'selrow');\n        //var selPcno = jQuery(\"#patientGrid\").jqGrid('getCell', id, 'PCNO');\n        //End Added\n\n        //if ($('#hfMIMS').val() == 'True') {\n        if (selectedPatientAllergyOtherId!= null)  {\n            swal({title:   \"\", text: \"Are you sure you want to delete this record?\", type: \"warning\", showCancelButton: true, confirmButtonColor: \"#DD6B55\", cancelButtonText: \"No\", confirmButtonText: \"Yes\", closeOnConfirm: false },\n                function () {\n                    swal.close();\n                    var pcno = $('#hfPCNO_tpa').val();\n                    if (pcno == ''){\n                        if ($(\"#txtPatientNo\").val() != 'NEW'){\n                            pcno = $(\"#txtPatientNo\").val();\n                        }\n                    }\n                    var Description = jQuery(\"#patientAllergyOtherGrid\").jqGrid('getCell', selectedPatientAllergyOtherId, 'AllergyDesc');\n                    var urlPatientAllergy = 'https://clinicassist.sg:1080/en/Patient/DeletePatientAllergyOther?pcno=' + pcno + '&Description=' + encodeURIComponent(Description); //Added by Daniel 20180807 - Ver 15:No. 50 - Add encodeURIComponent\n\n                    $.ajax({\n                        cache: false,\n                        url: urlPatientAllergy,\n                        dataType: 'json',\n                        type: 'post',\n                        success: function (result) {\n                            if (result.success)  {\n\n                                //Added By Bryan 07/02/2020 (retrieving patient allergy count)\n                                $('#hfPatAllergyCount').val(result.rethasallergyothercount);\n                                swal.close();\n                                $('#patientAllergyOtherGrid').trigger('reloadGrid');\n\n                                //Added By Bryan 07/02/2020 start (check the no allergy checkbox based on patient allergy count)\n                                var PatientAllergyID = $(\"#patientAllergyGrid\").jqGrid('getDataIDs');\n                                var PatientAllergyOtherID = $(\"#patientAllergyOtherGrid\").jqGrid('getDataIDs');\n\n                                //Added By Bryan 07/02/2020 (To check whether AllergyDescription Is 'NIL' or not)\n                                var patalergyothercount = 0;\n                                if (PatientAllergyOtherID.length > 0)  {\n                                    for (var i = 0; i < PatientAllergyOtherID.length; i++) {\n                                        var DesName = $('#patientAllergyOtherGrid').getCell(PatientAllergyOtherID[i], 'AllergyDesc');\n                                        if (DesName === \"NIL\")  {\n                                            patalergyothercount = patalergyothercount + 1;\n                                        }\n                                    }\n\n                                    if (PatientAllergyID.length > 0 || (PatientAllergyOtherID.length > 0 && PatientAllergyOtherID.length > patalergyothercount) || $('#hfPatAllergyCount').val() != \"0\")  //Updated By Bryan 07/02/2020 (Check whether allergy exist or not)\n                                    {\n                                        $('#CreateEditPatientForm').find('[name=\"chkAllergy\"]').val('false');\n                                        $(\"#chkPatientAllergy\").prop('checked', false);\n                                    }\n                                    else {\n                                        $('#CreateEditPatientForm').find('[name=\"chkAllergy\"]').val('true');\n                                        $(\"#chkPatientAllergy\").prop('checked', true);\n                                    }\n                                }\n                                else {\n                                    if (PatientAllergyID.length > 0 || PatientAllergyOtherID.length > 0 || $('#hfPatAllergyCount').val() != \"0\")  //Updated By Bryan 07/02/2020 (Check whether allergy exist or not)\n                                    {\n                                        $('#CreateEditPatientForm').find('[name=\"chkAllergy\"]').val('false');\n                                        $(\"#chkPatientAllergy\").prop('checked', false);\n                                    }\n                                    else {\n                                        $('#CreateEditPatientForm').find('[name=\"chkAllergy\"]').val('true');\n                                        $(\"#chkPatientAllergy\").prop('checked', true);\n                                    }\n                                }\n                                //Added By Bryan 07/02/2020 end\n                                reloadDispenseAllergy()\n                                checkMedAlertExist()\n                            }\n                            else {\n                                swal(\"\", result.message, \"error\");\n                            }\n                        },\n                        error: function (xhr, status) {\n                        }\n                    });\n                })\n\n        } else {\n            swal(\"\", \"There is no record to delete\");\n        }\n        //}\n        //else {\n        //    swal(\"\", \"You are not subscribe to MIMS.\\n To subscribe, please contact our helpdesk.\", \"warning\");\n        //}\n    };\n\n    //Added by Cooper 20180711 - Add Pregnancy, Pregnancy Due Date, MetalImplants and Claustrophobia\n    $(\"#chkPregnancy\").click(function () {\n        if ($(this).is(':checked')) {\n            $('#PregnancyDueDate').removeAttr('disabled');\n            $('#PregnancyDueDate').css(\"background-color\", \"\");\n        } else {\n            $('#PregnancyDueDate').attr('disabled', 'disabled');\n            $('#PregnancyDueDate').css(\"background-color\", \"lightgrey\");\n            $('#PregnancyDueDate').val(\"\");\n        }\n    });\n\n    //Added by Cooper 20180711 - Add Pregnancy, Pregnancy Due Date, MetalImplants and Claustrophobia\n    $('#btnSavePatientHistory').click(function () {\n\n        var chkPregnancy = $(\"#chkPregnancy\").prop('checked')\n        var chkMetalImplants = $('#chkMetalImplants').prop('checked')\n        var chkClaustrophobia = $(\"#chkClaustrophobia\").prop('checked')\n        var PregnancyDueDate = $(\"#PregnancyDueDate\").val();\n        var patientAllergy = $(\"#txtPatientAllergy\").val();\n        var patientG6PD = $(\"#txtPatientG6PD\").val();\n        var mednotes = $(\"#mednotes\").val();\n\n        var pcno = $('#hfPCNO_tpa').val();\n        if (pcno == ''){\n            if ($(\"#txtPatientNo\").val() != 'NEW'){\n                pcno = $(\"#txtPatientNo\").val();\n            }\n        }\n        //Added by NiNi 20190304\n        if (chkPregnancy == true && PregnancyDueDate == '') {\n            swal(\"\", \"Please select Pregnancy Due Date\", \"error\");\n            return;\n        }\n\n        $.ajax({\n            cache: false,\n            url: \"/CaseNote/SaveTabHistory?pPCNo=\" + pcno + \"&QueryType=I16\",\n            data: { \"__RequestVerificationToken\": $('input[name=\"__RequestVerificationToken\"]', $(\"#CreateEditPatientAllergyForm\")).val(), \"Pregnancy\": chkPregnancy, \"PregnancyDue\": PregnancyDueDate, \"MetalImplants\": chkMetalImplants, \"Claustrophobia\": chkClaustrophobia, \"Allergy\": patientAllergy, \"G6PD\": patientG6PD, \"MedNotes\": mednotes },\n            type: \"POST\",\n            success: function (response) {\n                if (response.success)\n                    swal({ title: \"\", text: \"Allergy information is saved.\", type: \"success\", timer: 2000 });\n                else\n                    swal(\"\", \"error in Saving Patient Allergy\", \"error\");\n            },\n            error: function (response) {\n            }\n        });\n    });\n\n    function checkMedAlertExist() {\n        //console.log(\"G6PD: \" + $('#txtPatientG6PD').val());\n        //console.log(\"chkPregnancy: \" + $('#chkPregnancy').prop('checked'));\n        //console.log(\"PregnancyDueDate\" + $('#PregnancyDueDate').val());\n        //console.log(parseInt($('#patientAllergyGrid').jqGrid('getGridParam', 'reccount')) + parseInt($('#patientAllergyOtherGrid').jqGrid('getGridParam', 'reccount')));\n        //console.log($('#txtPatientG6PD').val())\n        //console.log($('#chkPregnancy').prop('checked'))\n        //console.log($('#PregnancyDueDate').val())\n        var allergyCount = parseInt($('#patientAllergyGrid').jqGrid('getGridParam', 'reccount')) + parseInt($('#patientAllergyOtherGrid').jqGrid('getGridParam', 'reccount'));\n        if (allergyCount == 0 && $('#txtPatientG6PD').val() != 'YES' && ($('#chkPregnancy').prop('checked') == false && $('#PregnancyDueDate').val() == '')) { //no alert\n            $(\".nav-item a[tabTarget='MedAlert']\").addClass(\"tab-allergy-no\");\n            $(\".nav-item a[tabTarget='MedAlert']\").attr('style', 'background-color: transparent');\n        }\n        else { //alert\n            $('#Pat-tab-li-Allergy').attr('style', 'background-color: #ff6666 !important');\n            $(\"#tabAllergyCaseNoteID\").css(\"color\", \"#ffffff\");\n            $(\"#tabAllergyCaseNoteID\").css(\"background-color\", \"#ff6666\"); \n            $(\".nav-item a[tabTarget='MedAlert']\").attr('style', 'background-color: #ff6666 !important');\n            $(\"#tabAllergyCaseNoteID\").css(\"color\", \"#ffffff\");\n            $(\"#tabAllergyCaseNoteID\").css(\"background-color\", \"#ff6666\"); \n            $(\".nav-item a[tabTarget='MedAlert']\").addClass(\"tab-allergy-yes\");\n        }\n\n    }\n\n    $(\"#btnNIL\").click(function () {\n        $(\"#txtPatientAllergy\").val(\"NIL\");\n    });\n\n    //Added by HaoWen 20221229 - add CMIS\n    function loadCMIS() {\n        if (true != true) {\n            swal({ title: Cookies.get(\"SWAL_Header_Msg\"), text: Cookies.get(\"SWAL_Body_Msg\"), type: Cookies.get(\"SWAL_Type\"), timer: Cookies.get(\"SWAL_Timer\") });\n            return;\n        } else {\n            $(\".fadeMe\").show();\n            $(\"#tabPatAllergytabCMISContent\").load('https://clinicassist.sg:1080/en/Submission/CMISSubmission?pcno=' + encodeURIComponent($(\"#txtPatientNo\").val()) + \"&pname=\" + encodeURIComponent($(\"#txtPatientPName\").val()) + \"&nric=\" + encodeURIComponent($(\"#txtPatientNRIC\").val()));\n        }\n    };\n    //End added by HaoWen 20221229\n    function reloadDispenseAllergy() {\n        if ((urlLocation.indexOf(\"QueueLog/PatientVisit\") >= 0) && $('#txtDispPCNO').length > 0) {\n            let postDataValues = $(\"#queuePatientAllergyGrid\").jqGrid('getGridParam', 'postData');\n            postDataValues[\"pcno\"] = $('#txtDispPCNO').val();\n            $('#queuePatientAllergyGrid').jqGrid().setGridParam({ postData: postDataValues, page: 1 }).trigger('reloadGrid');\n\n\n            var myData = { pcno: $('#txtDispPCNO').val() };\n            var encoded = JSON.stringify(myData);\n            $.ajax({\n                cache: false,\n                type: \"POST\",\n                url: \"/Patient/GetPatientAllergyInListForm\",\n                data: encoded,\n                contentType: \"application/json; charset=utf-8\",\n                dataType: \"json\",\n                success: function (result) {\n                    if (result.success) {\n                        //Modified by kenneth 2025-11-20 - To display HTML of allergy list \n                        //$(\"#lblPatAllergy\").text(result.AllergyList)\n                        $(\"#lblPatAllergy\").html(result.AllergyList)\n                        $('#lblCNPatAllergy').html(result.AllergyList)\n                    }\n                    else {\n                        swal(\"\", result.message, \"error\");\n                    }\n                },\n                error: function (result) {\n                    swal(\"\", result, \"error\");\n                }\n            });\n\n\n        }\n    }\n\n                        \n                    \n                    \n                        \n                            \n                        \n                    \n                    \n                        \n                            \n                        \n                    \n                    \n                        \n                            \n                        \n                    \n                    \n                        \n                            \n                        \n                    \n\n                    \n                        \n                            \n                        \n                    \n                    \n                        \n                            \n                        \n                    \n                \n                \n                    \n                        \n                        \n                        \n                            \n                            \n                        \n                    \n                \n            \n        \n    \n\n\n\n\n    \n        \n            \n                ×\n                \n            \n            \n            \n        \n    \n\n\n\n\n\n    \n    \n        \n            \n                ×\n                Add to Case Note\n            \n            \n            \n        \n    \n\n\n\n\n        \n            \n                \n                    ×\n                    Send Report via Email\n                \n                \n                    \n                        \n                            Email Address\n                        \n                        \n                            \n                            \n                                Save as Patient Email\n                            \n                        \n                    \n                \n                \n                    Send Email\n                    Close\n                \n            \n        \n\n\n\n    \n        \n            \n                ×\n                \n            \n            \n            \n        \n    \n\n\n\n    \n        \n            \n                ×       \n                Lab Result\n            \n            \n            \n        \n    \n\n\n\n    \n        \n            \n                ×\n                Medical History\n            \n            \n            \n        \n    \n\n\n\n\n\n\n\n    \n        \n            \n                \n                    ×\n                \n                Search Agent\n            \n            \n        \n    \n\n\n\n    \n        \n            \n                ×\n                Edit Patient VIP Link\n            \n            \n                \n                    \n                        \n                            \n                                \n                                    \n                                        \n                                            \n                                                \n                                                    \n                                                \n                                            \n                                        \n                                    \n                                \n                            \n                            \n                                \n                                    \n                                        \n                                        \n                                    \n                                \n                            \n                        \n                    \n                \n            \n        \n    \n\n\n\n    \n        \n            \n                ×\n                Mobile Profile Uploaded Listing\n            \n            \n                \n                    \n                        \n\n                            \n                                \n                                    \n                                        \n                                            \n                                                \n                                            \n                                        \n                                    \n                                \n                            \n                            \n                                \n                                    \n                                        \n                                    \n                                \n                            \n                        \n                    \n                \n            \n        \n    \n\n\n\n    \n        \n            \n                ×\n                \n            \n            \n                \n            \n        \n    \n\n\n\n    //var txtsearchKeyword = $('#SearchKeyword').val();\n    var selectedEditClinic = \"SSOC\";\n    var currHighlighted = 'InitLoad'; //Added by Chang Ching Ler 20200526 | Resolve issue - Prevent always retrieve first patient's infor after edit patient\n    var timeout_SearchPatient = null;       //Added by Jason 20210126 - Set timer to trigger searching when finish typing\n    var calendarModal_Height = \"690px\"; //Added by Chang Ching Ler 20210423 | Patient infor > Appt tab\n    //var lstNotBioTab = [\"tabHistory\", \"tabFinancial\", \"tabPastMeds\", \"tabPastNotes\", \"tabLabResult\", \"tabPatientComm\",\"tabAppt\"];\n    var lstNotBioTab = [\"tabHistory\", \"tabFinancial\", \"tabPastMeds\", \"tabPastNotes\", \"tabLabResult\", \"tabPatientComm\",\"tabAppt\",\"tabPatEDoc\"];\n    //Added by Jason 20211022 - detect patient info change\n    var infoChanged = \"N\";\n    var oldDataBiodata;\n    var oldDataMedAlert;\n    var oldDataPopup;\n    var oldDataFamily;\n    var oldDataHistory;\n    var oldDataBirth;\n    var oldDataConsent = [];\n    var newDataBiodata;\n    var newDataMedAlert;\n    var newDataPopup;\n    var newDataFamily;\n    var newDataHistory;\n    var newDataBirth;\n    var newDataConsent = [];\n    var hiddenDataArray = []; // Added by Jia Yi\n    var eDocUploadFolder = \"\";   //Added by Xirlyn 20260202 - eDoc Upload folder name\n    var LasteDocTab = \"\";    //Added by Xirlyn 20260202 - add edoc to visit note tab\n\n    //End added by Jason 20211022\n    var newVitalSignToggled = 0;\n    var patientEditBioFlag = true; //Added by Koh Chin Choong 20211101 - For store check access flag, so will no need check again later\n\n    $(document).on('click', '.pull_to_left', function (e) {\n        if (!$(\".left-content\").hasClass(\"left-hide\")) {\n            setTimeout(function(){\n                document.getElementById(\"patientdetailsright\").style.width = \"100%\";\n                document.getElementById(\"patientdetailsright\").style.marginLeft = \"0px\";\n                $(\".left-content\").addClass(\"left-hide\");\n            }, 100);\n        }\n    });\n\n    $(document).on('click', '.pull_to_right', function (e) {\n        if ($(\".left-content\").hasClass(\"left-hide\")) {\n            setTimeout(function(){\n                document.getElementById(\"patientdetailsright\").style.marginLeft = \"671px\";\n                $(\".left-content\").removeClass(\"left-hide\")\n                $(\".left-content\").addClass(\"left-full\");\n                $(\".right-content\").addClass(\"right-full\");\n            }, 100);\n        }\n    });\n\n    $(document).ajaxStop(function () {\n        $(\".fadeMe\").hide();\n    });\n\n    $(document).ready(function () {\n        //$(\".visitnote-right-div\").hide();\n        //$(\".fadeMe\").show();\n        //Added by Koh Chin Choong 20211101 - For store check access flag, so will no need check again later\n        var patBioFP = true;\n        var patFinFP = true;\n        var patTxHisFP = true;\n        var patMedHisFP = true;\n        var patCommFP = true;\n        var patCaseNoteFP = true;\n        var patPatChartFP = true;\n        //End Added by Koh Chin Choong 20211101\n        updateContentHeight();\n\n        if ($('#hdmode').val() == 'Q')\n        {\n            $('#Pat-tab-li-History').hide();\n            $('#Pat-tab-li-PastMeds').hide();\n            $('#Pat-tab-li-LabResult').hide();\n        }else{\n            $('#Pat-tab-li-History').show();\n            $('#Pat-tab-li-PastMeds').show();\n            $('#Pat-tab-li-LabResult').show();\n        }\n\n\n        //Added by JIUNWEI 20220321 - To display PCNO, PName, NRIC, Gender, Age and Language spoken on modal header\n        if ($(\"#patDetModalLabel\").text() != \"Add New Patient\")\n            $(\"#patDetModalLabel\").html(\"78160\" + \" / \" + \"ENG CHAI PIN ELYNE XANDRIA\" + \" (\" + \"S8570522I\" + \")<span style=\\\"margin-left: 20px\\\"></span>\" + \"F\" + \" / \" + '40 y' + \"<span style=\\\"margin-left: 20px\\\"></span>L: \" + 'English');\n        //End Added by JIUNWEI 20220321\n\n        //Added by JIUNWEI 20220822 - To hide functions if filterQ = Y\n        checkPatientModuleAccess();\n\n        //Added by JIUNWEI 20220329 - Hide all tab except past note tab if page type is PastCaseNote\n        if ($(\"#hfPageType\").val() == \"PastCaseNote\") {\n            $(\".DocumentList\").parent().hide();\n            patientTabToggle('tabPastNotes');\n            $(\"#Pat-tab-li-PastNotes\").click();\n            $(\"#tabBiodata\").removeClass(\"active\");\n            $(\"#tabPastNotes\").addClass(\"active\");\n        }\n        else {\n            if (true == false) {\n                //$('#Pat-tab-li-Biodata').hide();\n                patBioFP = false;//Added by Koh Chin Choong 20211101 - For store check access flag, so will no need check again later\n            }\n            else if(true == true && true == false){\n                $(\"#tabBiodata\").css(\"pointer-events\",\"none\")\n            }\n\n            if (true == false) {\n                //$('#Pat-tab-li-PatientFamily').hide();\n            }\n            else if(true == true && true == false){\n                $(\"#tabPatientFamily\").css(\"pointer-events\",\"none\")\n            }\n\n            if (true == false) {\n                //$('#Pat-tab-li-Financial').hide();\n                patFinFP = false;//Added by Koh Chin Choong 20211101 - For store check access flag, so will no need check again later\n            }\n\n            if (true == false) {\n                //$('#Pat-tab-li-PastMeds').hide();\n                patTxHisFP = false; //Added by Koh Chin Choong 20211101 - For store check access flag, so will no need check again later\n            }\n\n            if (true == false) {\n                //$('#Pat-tab-li-History').hide();\n                patMedHisFP = false; //Added by Koh Chin Choong 20211101 - For store check access flag, so will no need check again later\n            }\n\n            if (true == false) {\n                //$('#Pat-tab-li-Appt').hide();\n            }\n\n            if (true == false) {\n                //$('#Pat-tab-li-Vaccination').hide();\n            }\n\n            if (true == false) {\n                //$('#Pat-tab-li-PatientComm').hide();\n                patCommFP = false; //Added by Koh Chin Choong 20211101 - For store check access flag, so will no need check again later\n            }\n\n            if (true == false || isFromPatientSearch == \"N\") {\n                //$('#Pat-tab-li-PastNotes').hide();\n                patCaseNoteFP = false; //Added by Koh Chin Choong 20211101 - For store check access flag, so will no need check again later\n            }\n\n            if (true == false){\n                //$('#Pat-tab-li-LabResult').hide();\n                patPatChartFP = false; //Added by Koh Chin Choong 20211101 - For store check access flag, so will no need check again later\n            }\n\n            if($('#hfPCNO').val() == \"\"){\n                $('#Pat-tab-li-Financial').hide();\n                $('#Pat-tab-li-PastNotes').hide();\n                $('#Pat-tab-li-PastMeds').hide();\n                $('#Pat-tab-li-History').hide();    //Added by Chang Ching Ler 20211020 | No need show when adding new patient\n                $('#Pat-tab-li-Referral').hide();\n                $('#Pat-tab-li-LabResult').hide();\n                $('#Pat-tab-li-PatientComm').hide();\n                $('#Pat-tab-li-Appt').hide();\n                $('#tab-li-PatCaseNoteAccess').hide();\n                $('#Pat-tab-li-LongTermDrug').hide();\n            } else {\n                //Added by Chang Ching Ler 20211025 | Not allow to edit if not granted access right\n                if (typeof accessViewOnly !== 'undefined' && accessViewOnly) {\n                    $(\"#tabBiodata, #tabAllergy, #tabPopup, #tabPatientFamily, #tabBirth\").css(\"pointer-events\", \"none\");\n                    patientEditBioFlag = false;\n                } else {\n                    if (true == false){\n                        patientEditBioFlag = false; //Added by Koh Chin Choong 20211101 - For store check access flag, so will no need check again later\n                    }\n                }\n                //End Added by Chang Ching Ler 20211025\n            }\n\n            if ('False' == \"False\") {    //Added by Chang Ching Ler 20200706 | Available if radiology features turned on\n                $(\"#hrefPatientLabLabel2\").hide();\n            }\n\n            PatientAllergy();\n            //patientTabToggle('tabPatientFamily');\n            //patientTabToggle('tabPopup');\n            //patientTabToggle('tabHistory');\n\n            \n            patientTabToggle('tabBiodata'); //Moved to here because biodata tab need be last load page. so the 'Profile Downlaod' button will appear due to the tab change checking.\n\n            if ($('#hfEHADownload').val() == 'Y' && $('#hfPCNO').val() == \"\"){\n                $('#btnEhaDownload').show();\n            }\n            else\n            {\n                $('#btnEhaDownload').hide();\n            }\n\n            var MedGrp = \"SSOC\";\n            if ($('#hfPCNO').val() == \"\"){\n                $(\"#btnExpressReg\").css(\"display\",\"none\");\n            }\n            else\n            {\n                if ((MedGrp == 'SMSC' || MedGrp == 'DEMOSP' || MedGrp == 'SPTEST'|| MedGrp == 'SPTEST1' || MedGrp == 'SUPPORTSP' || MedGrp == 'CMI'|| MedGrp == 'SPTEST1DG'|| MedGrp == \"SPTESTUI\" || MedGrp == \"SPNEWUI\"|| MedGrp == \"SPNEWUIDG\"|| MedGrp == \"TSPPAY\") && \"N\" == \"N\") {\n                    $(\"#btnExpressReg\").css(\"display\",\"block\");\n                }\n            }\n\n            var urlLocation = jQuery(location).attr('href');\n            if (urlLocation.toLowerCase().indexOf(\"casenote\") >= 0){\n                $(\"#divPatientWrap\").removeClass(\"NoPaddingTop\");\n            }\n\n            if ($(\"#patDetModalLabel\").html() == \"Add New Patient\" || $('#hfPCNO').val() == \"\") {   //Edited by Lim Han Yong 20240531 - Need show when adding new patient\n                if ('True' == 'True') {     //Edited by Jason 20221220 - change viewdata to sitesession\n                    $('#btnSingPassDownload').show();\n                }\n                else {\n                    $('#btnSingPassDownload').hide();\n                }\n            }\n            else {\n                $('#btnSingPassDownload').hide();\n            }\n\n            if ((urlLocation.toLowerCase().indexOf(\"patientvisit\") >= 0) && ($(\"#liVisit\").length > 0 && $(\"#liPayment\").length > 0)){ // Hide Past Notes when user accessing from QueueLog\n                $(\"#Pat-tab-li-PastNotes\").hide();\n            }\n        }\n    });\n\n    $(window).on('resize', function() {\n        updateContentHeight();\n    });\n\n    function updateContentHeight() {\n        if ($(\"#index2body\").parent().hasClass(\"modal-body\")) {\n            $(\".tab-content.content-tab.scrollbar-primary\").css(\"height\", \"calc(100vh - 140px)\");\n        }\n        else {\n            if ($('#IdPatientTab')[0].scrollWidth > $('#IdPatientTab')[0].clientWidth) {\n                $(\".tab-content.content-tab.scrollbar-primary\").css(\"height\", \"calc(100vh - 190px)\");\n            }\n            else {\n                $(\".tab-content.content-tab.scrollbar-primary\").css(\"height\", \"calc(100vh - 180px)\");\n            }\n        }\n    }\n\n    $(\"#createEditpatientModal\").on('shown.bs.modal', function () {\n        $('#createEditpantientModalBody').find(\"#txtPatientIDTypeCode\").focus();\n    });\n\n    $('#createEditpatientModal').on('hidden.bs.modal', function () {\n        $('#createEditpantientModalBody').html('');\n    });\n\n    $('#printMCModal').on('shown.bs.modal', function () {\n        $('#txtVisitDate').focus();\n    });\n\n    $('#printMCModal').on('hidden.bs.modal', function () {\n        $('#printMCModalBody').html('');\n    });\n\n    $('#AnnoHisModal').on('hidden.bs.modal', function () {\n        $('#AnnoHisModalBody').html('');\n    });\n\n    $('#createPatientFrmQueModal').on('hidden.bs.modal', function () {\n        $('#createPatientFrmQueModalBody').html('');\n    });\n\n    $('#labResultModal').on('hidden.bs.modal', function () {\n        $('#createPatientFrmQueModalBody').html('');\n    });\n\n    $('#labResultModal').on('hidden.bs.modal', function () {\n        $('#labResultModalBody').html('');\n\n        //Edited by Chang Ching Ler 20210921 | Refresh tab \"By Date\" and \"By Details\"\n        if ($('a[href=\"#tabByDate\"]').closest(\"li\").hasClass('active')) {\n            GetData();\n        } else  {\n            getLabDetailsResult();\n        }\n        //End Edited by Chang Ching Ler 20210921\n    });\n    $.ajaxSetup({\n        cache: false\n    });\n\n    $(document).keypress(function (event) {\n        var keycode = (event.keyCode ? event.keyCode : event.which);\n\n        if (keycode == 27) {\n            if ($('#setupCompanyModal').is(':hidden') && $('#setupRefSourceModal').is(':hidden') &&\n                $('#setupAgentModal').is(':hidden') && $('#searchAddressModal').is(':hidden') &&\n                $('#setupPatientGrpModal').is(':hidden') && $('#patientMediPayerModal').is(':hidden')) {\n                $(\"#createEditpatientModal\").modal('hide');\n            }\n        }\n    });\n\n    $('#promptPastReceiptModal').on('hidden.bs.modal', function () {\n        $('#promptPastReceiptModalBody').html('');\n    });\n\n    $(\"#invPatientPaymentModal\").on('shown.bs.modal', function () {\n        $(this).find('#txtInvPaymentDate').focus();\n    });\n\n    $('#invPatientPaymentModal').on('hidden.bs.modal', function () {\n        $('#invPatientPaymentModalBody').html('');\n    });\n\n    $(\"#invCreditNoteModal\").on('shown.bs.modal', function () {\n        $(this).find('#txtRemarks').focus();\n    });\n\n    $('#invCreditNoteModal').on('hidden.bs.modal', function () {\n        $('#invCreditNoteModalBody').html('');\n    });\n\n    $(\"#invDebitNoteModal\").on('shown.bs.modal', function () {\n        $(this).find('#txtRemarks').focus();\n    });\n\n    $('#invDebitNoteModal').on('hidden.bs.modal', function () {\n        $('#invDebitNoteModalBody').html('');\n    });\n\n    $('#searchInvestigationModal').on('hidden.bs.modal', function () {\n        $('#searchInvestigationModalBody').html('');\n    });\n\n\n    $('#searchProcedureModal').on('hidden.bs.modal', function () {\n        $('#searchProcedureModalBody').html('');\n    });\n\n\n    $(\"#searchDrugModal\").on('shown.bs.modal', function () {\n        $('#SearchDrugKeyword').focus();\n    });\n\n    $('#searchDrugModal').on('hidden.bs.modal', function () {\n        $('#searchDrugModalBody').html('');\n    });\n\n    $(\"#searchPastTreatModal\").on('shown.bs.modal', function () {\n        $(this).find('#SearchKeyword').focus();\n    });\n\n    $(\"#searchPastTreatModal\").on('hidden.bs.modal', function () {\n        $('#searchPastTreatModalBody').html('');\n    });\n\n    $('#promptInvoiceModal').on('hidden.bs.modal', function () {\n        $('#promptInvoiceModalBody').html('');\n    });\n\n    $(\"#invPatientVoidModal\").on('shown.bs.modal', function () {\n        $(this).find('#txtVoidRemark').focus();\n\n    });\n\n    $('#invPatientVoidModal').on('hidden.bs.modal', function () {\n        $('#invPatientVoidModalBody').html('');\n\n    });\n\n    $(\"#reportStatementModal\").on('shown.bs.modal', function () {\n        $('#ddlMonth').focus();\n        $('#ddlMonth').focus(function () { $(this).select(); });\n    });\n\n    $('#reportStatementModal').on('hidden.bs.modal', function () {\n        $('#reportStatementModalBody').html('');\n    });\n\n    $(\"#reportListingModal\").on('shown.bs.modal', function () {\n        $('#txtDateFrom').focus();\n        $('#txtDateFrom').focus(function () { $(this).select(); });\n    });\n\n    $('#reportListingModal').on('hidden.bs.modal', function () {\n        $('#reportListingModalBody').html('');\n    });\n\n    $(\"#invTransferToCompModal\").on('shown.bs.modal', function () {\n        $(this).find('#txtPatientCompCode').focus();\n    });\n\n    $('#invTransferToCompModal').on('hidden.bs.modal', function () {\n        $('#invTransferToCompModalBody').html('');\n    });\n\n    $('#searchCompanyModal').on('hidden.bs.modal', function () {\n        $('#searchCompanyModalBody').html('');\n    });\n\n    $('#queueHisCaseNoteModal').on('hidden.bs.modal', function () {\n        if($('#queueHisCaseNoteModal').hasClass('in')){\n\n        }else{\n            $(\"#myqueueHisCaseNoteModalLabel\").text(\"Add to Case Note\");\n            $(\"#queueHisCaseNoteModalDialog\").css(\"max-width\", \"none\");\n            $('#queueHisCaseNoteModalBody').html('');\n        }\n\n    });\n\n    function patientTabToggle(type){\n        var selectedPName = $('#hfPName').val();\n        var selectedEditClinic = $('#hfClinic').val();\n\n        if (lstNotBioTab.includes(type)){   //Not select bio-data related tab\n            $('#btnEhaDownload').hide();\n            $('#btnPatientSave').hide();\n            $('#btnExpressReg').hide();\n        } else if (patientEditBioFlag) {    //Select bio-data related tab & not view only & granted edit access right\n            if (type == \"tabBiodata\"){\n                if($('#hfEHADownload').val() == \"Y\"){\n                    var MedGrp = \"SSOC\";\n                    if ($('#hfPCNO').val() == \"\"){\n                        $('#btnEhaDownload').show();\n                        $(\"#btnExpressReg\").css(\"display\",\"none\");\n                    }\n                    else\n                    {\n                        if ((MedGrp == 'SMSC' || MedGrp == 'DEMOSP' || MedGrp == 'SPTEST'|| MedGrp == 'SPTEST1' || MedGrp == 'SUPPORTSP' || MedGrp == 'CMI'|| MedGrp == 'SPTEST1DG'|| MedGrp == \"SPTESTUI\" || MedGrp == \"SPNEWUI\"|| MedGrp == \"SPNEWUIDG\"|| MedGrp == \"TSPPAY\") && \"N\" == \"N\") {\n                            $(\"#btnExpressReg\").css(\"display\",\"block\");\n                        }\n                    }\n                }\n            } else {\n                $('#btnEhaDownload').hide();\n                $('#btnExpressReg').hide();\n            }\n\n            if (type != \"tabHistory\") {\n                $('#btnPatientSave').show();\n            }\n        }\n        //Added by Cheng Yu 20211217 - if is not tab past note, then remove print button\n        if(type != $('#tabPastNotes').val()){\n            $('#btnPast').hide();\n        }\n        //End Added by Cheng Yu 20211217\n        var PCNO = \"78160\"\n        LoadPatientDetails(PCNO,selectedPName,selectedEditClinic,type,1);\n        $(\"#btnHidePatientInfoVSDiv\").click();\n    }\n\n    function LoadPatientDetails(selectedPCNO,selectedPName,selectedEditClinic,type,sel_id) {\n        $(\"#bioTabBtn\").show();\n        $(\"#financialTabBtn\").hide();\n        $(\".tab-content.content-tab.scrollbar-primary\").css(\"border-radius\", \"10px\");\n\n        if(type == \"tabBiodata\"){\n            $(\"#bioTabBtn\").show();\n            $(\".tab-content.content-tab.scrollbar-primary\").css(\"border-radius\", \"0 10px 10px 10px\");\n            if( $('#tabBiodata_frame').is(':empty') ) {\n                if (true == false) {\n                    $('#tabBiodata_frame').css('display','none')\n                    $('#tabBiodata_frame_AD').css('display','')\n                }\n                \n            }\n            if ('N' == 'Y') {\n                if( $('#tabTreatmentInfo_frame').is(':empty') ) {\n                    $(\"#tabTreatmentInfo_frame\").load('https://clinicassist.sg:1080/en/PatientMaster/TabTreatmentInfo?pcno=' + selectedPCNO);\n                }\n                if( $('#tabPaymentInfo_frame').is(':empty') ) {\n                    $(\"#tabPaymentInfo_frame\").load('https://clinicassist.sg:1080/en/PatientMaster/TabPaymentInfo?pcno=' + selectedPCNO);\n                }\n            }\n        } else if(type == \"tabPastMeds\"){\n            $(\"#bioTabBtn\").hide();\n            if (true == false) {\n                $('#tabPastMeds_frame').css('display','none')\n                $('#tabPastMeds_frame_AD').css('display','')\n            }\n            else\n            {\n                $(\"#tabPastMeds_frame\").load('https://clinicassist.sg:1080/en/PatientMaster/TabtxHistory?qpcno=' + selectedPCNO);\n            }\n        }else if(type == \"tabPastNotes\"){\n            $(\"#bioTabBtn\").hide();\n            if (true == false) {\n                $('#tabPastNotes_frame').css('display','none')\n                $('#tabPastNotes_frame_AD').css('display','')\n                return;\n            }\n            else\n            {\n                $('#tabPastNotes_frame').empty();\n                $('#btnPast').show();        //Added by Cheng Yu 20211217 - if is not tab past note, then remove print button\n                if($(\"#hfIsSpecialty\").val() == \"Y\"){\n                    $('#tabPastNotes_frame').load('https://clinicassist.sg:1080/en/Patient/PastPatientDetails?pcno=' + selectedPCNO + '&from=PatientMaster');\n                }\n                else{\n                    //$('#tabPastNotes_frame').load('https://clinicassist.sg:1080/en/PatientMaster/TabCaseNoteList?qVisitNo=0&qPCNO=' + selectedPCNO + '&qCreatedBy=&qDate1=&qDate2=&Search=');\n                    $('#tabPastNotes_frame').load('https://clinicassist.sg:1080/en/Patient/PastPatientDetails?pcno=' + selectedPCNO + '&from=PatientMaster');\n                }\n            }\n        }else if(type == \"tabAppt\"){\n            $(\"#bioTabBtn\").hide();\n            if (true == false) {\n                $('#tabAppt_frame').css('display','none')\n                $('#tabAppt_frame_AD').css('display','')\n            }\n            if( $('#tabAppt_frame').is(':empty') ) {\n                $(\"#tabAppt_frame\").load('https://clinicassist.sg:1080/en/Appointment/ViewApptDet?PCNO=' + selectedPCNO + '&PName=' + encodeURIComponent(selectedPName) + '&clinic=' + selectedEditClinic);\n            }\n\n        }else if(type == \"tabVaccination\"){\n            $(\"#bioTabBtn\").hide();\n            if (true == false) {\n                $('#tabVaccination_frame').css('display','none')\n                $('#tabVaccination_frame_AD').css('display','')\n            }\n            else\n            {\n                $(\"#tabVaccination_frame\").load('https://clinicassist.sg:1080/en/Queuelog/QueueVacc?qpcno=' + selectedPCNO);\n            }\n        }else if(type == \"tabFinancial\"){\n            $(\"#bioTabBtn\").hide();\n            if (true == false) {\n                $('#tabFinancial_frame').css('display','none')\n                $('#tabFinancial_frame_AD').css('display','')\n            }\n            else\n            {\n                $(\".fadeMe\").show();\n                $(\"#tabFinancial_frame\").load('https://clinicassist.sg:1080/en/PatientMaster/Financial?PCNO=' + selectedPCNO);\n                //$(\"#tabFinancial_frame\").load('https://clinicassist.sg:1080/en/InvoicePatient/Index?PCNO=' + selectedPCNO + '&pname=' + encodeURIComponent(selectedPName));\n                $(\"#bioTabBtn\").hide();         //Added by Xirlyn 20240117 - To hide default button\n                $(\"#financialTabBtn\").show();   //Added by Xirlyn 20240117 - To display financial button\n            }\n\n        }else if(type == \"tabPatientDeliveryAdd\"){\n            $(\"#bioTabBtn\").hide();\n            $(\"#tabPatientDeliveryAdd_frame\").load('https://clinicassist.sg:1080/en/PatientMaster/DeliveryAdd?PCNO=' + selectedPCNO + '&frm=patient');\n        }\n        else if(type == \"tabLabResult\"){\n            $(\"#bioTabBtn\").hide();\n            if (true == false) {\n                $('#tabLabResult_frame').css('display','none')\n                $('#tabLabResult_frame_AD').css('display','')\n            }\n            else\n            {\n                $(\"#tabLabResult_frame\").load('https://clinicassist.sg:1080/en/PatientMaster/TabLabResult?pcno=' + selectedPCNO);\n            }\n        }else if(type == \"tabReferral\"){\n            $(\"#bioTabBtn\").hide();\n            $(\"#tabReferral_frame\").load('https://clinicassist.sg:1080/en/PatientMaster/QueueReferral?PCNO=' + selectedPCNO+'&pname=' + encodeURIComponent(selectedPName));\n        }else if (type == \"tabHistory\") {\n            $(\"#bioTabBtn\").hide();\n            if (true == false) {\n                $('#tabHistory_frame').css('display','none')\n                $('#tabHistory_frame_AD').css('display','')\n            }\n            else\n            {\n                $(\"#tabHistory_frame\").load('https://clinicassist.sg:1080/en/CaseNote/TabHistory?pcno=' + selectedPCNO);\n                //$('#btnSaveTabHis').hide();   //Commented by Chang Ching Ler 20211020 | Show \"Save History\" at patient master\n                $('#btnHistoryCancel').hide();\n                $('#btnPatientSave').hide();        //Edited by Jason 20211022 - hide save button\n            }\n        }else if(type == \"tabPatientComm\"){ //Added by Michael 20180226\n            $(\"#bioTabBtn\").hide();\n            if (true == false) {\n                $('#tabPatientComm_frame').css('display','none')\n                $('#tabPatientComm_frame_AD').css('display','')\n            }\n            else\n            {\n                $(\"#tabPatientComm_frame\").load('https://clinicassist.sg:1080/en/PatientComm/Index2?pcno=' + selectedPCNO);\n            }\n        }else if(type == \"tabPatientFamily\"){ //Added by NiNi 21-Jun-2019\n            $(\"#bioTabBtn\").show();\n            if (true == false) {\n                $('#tabPatientFamily_frame').css('display','none')\n                $('#tabPatientFamily_frame_AD').css('display','')\n            }\n            else\n            {\n                if( $('#tabPatientFamily_frame').is(':empty') ) {\n                    $(\"#tabPatientFamily_frame\").load('https://clinicassist.sg:1080/en/Patient/FamilyMembers?pcno=' + selectedPCNO);\n                }\n            }\n        }else if(type == \"tabPopup\"){\n            $(\"#bioTabBtn\").show();\n            if( $('#tabPopup_frame').is(':empty') ) {\n                $(\"#tabPopup_frame\").load('https://clinicassist.sg:1080/en/PatientMaster/TabPopup?pcno=' + selectedPCNO);\n            }\n        }\n        else if (type == \"tabBirth\") {\n            $(\"#bioTabBtn\").show();\n            if ($('#tabBirth_frame').is(':empty')) {\n                $(\"#tabBirth_frame\").load('https://clinicassist.sg:1080/en/PatientMaster/TabPatientBirth?pcno=' + selectedPCNO);\n            }\n        }\n        else if (type == \"tabTreatmentInfo\") {\n            $(\"#bioTabBtn\").show();\n            if( $('#tabTreatmentInfo_frame').is(':empty') ) {\n                $(\"#tabTreatmentInfo_frame\").load('https://clinicassist.sg:1080/en/PatientMaster/TabTreatmentInfo?pcno=' + selectedPCNO);\n            }\n        }else if(type == \"tabPaymentInfo\"){\n            if( $('#tabPaymentInfo_frame').is(':empty') ) {\n                $(\"#tabPaymentInfo_frame\").load('https://clinicassist.sg:1080/en/PatientMaster/TabPaymentInfo?pcno=' + selectedPCNO);\n            }\n        }else if(type == \"tabLongTermDrug\"){\n            if( $('#tabLongTermDrug_frame').is(':empty') ) {\n                $(\"#tabLongTermDrug_frame\").load('https://clinicassist.sg:1080/en/PatientMaster/TabLongTermDrug?pcno=' + selectedPCNO);\n            }\n        }\n        else if (type == \"tabPatEDoc\") {\n            $(\"#bioTabBtn\").hide();\n            if ($('#tabPatEDoc_frame').is(':empty')) {\n                $(\"#tabPatEDoc_frame\").load('https://clinicassist.sg:1080/en/CaseNote/eDoc?qPCNO=' +$('#hfPCNO').val()+ '&qVisitNo=0' + '&qDate1=');\n            }\n        }\n    }\n\n    function updateTogglePanelValue(value){\n        $('#hdPatientTogglePanel').val(value);\n        if (true == true) {\n            patientTabToggle('tabBiodata');\n        }\n        else if (true == true){\n            patientTabToggle('tabFinancial');\n        }\n        else if (true == true){\n            patientTabToggle('tabPastMeds');\n        }\n        else if (true == true){\n            patientTabToggle('tabAppt');\n        }\n        else if (true == true){\n            patientTabToggle('tabVaccination');\n        }\n        else if (true == true){\n            patientTabToggle('tabPatientFamily');\n        }\n        else{\n            patientTabToggle('tabReferral');\n        }\n    }\n\n    //Start: Add Add or Update Template Action - Chee Yong 27082018\n    $(\"#btnSetupRefTemplateOK_QueueLog\").click(function () {\n        var trans = $(\"#cTitle_QueueLog\").text();\n        var type;\n        var oldcode;\n        if (trans.indexOf(\"New\") >= 0) {\n            type = 'I';\n            oldcode = \"\";\n        }\n        else {\n            oldcode = jQuery(\"#reftempGrid\").jqGrid('getGridParam', 'selrow');\n            type = 'U';\n        }\n        var code = $(\"#txtCode\").val();\n        var desc = $(\"#txtDesc\").html();\n\n        if (code == \"\") {\n            swal(\"\", \"Code must be entered.\");\n            return;\n        }\n        var editor = CKEDITOR.instances.txtDesc;\n\n        var tempNote = editor.getData();\n        if (tempNote == \"\") {\n            swal(\"\", \"Description must be entered.\");\n            return;\n        }\n        var data = { RefTempCode: code, Description: tempNote };\n        AddEditSetupRefTemp_QueueLog(data, oldcode, type);\n    });\n    //End: Add Add or Update Template Action - Chee Yong 27082018\n\n    //Start: Add Function call for Add/Edit referral template - Chee Yong 27082018\n    function AddEditSetupRefTemp_QueueLog(_data, _oldcode, _type) {\n        var d = { setupreftemp: _data, oldreftempcode: _oldcode, type: _type };\n        $.ajax({\n            cache: false,\n            type: \"POST\",\n            url: \"/SetupReferralTemplate/InsUpdSetupRefTemp\",\n            data: JSON.stringify(d),\n            contentType: \"application/json; charset=utf-8\",\n            dataType: \"json\",\n            success: function (result) {\n                if (result.success) {\n                    $('#reftempGrid').trigger('reloadGrid');\n\n                    //Added by Daniel 2018-04-05, Once modal been close unable to key-in description\n                    CloseSetupRefTemplate();\n\n                    $(\"#reftempModal2\").appendTo('body').modal('hide');   //Edited by Shan , 2017-09-22 - UAT 611\n                }\n                else {\n                    swal(\"\",result.message,\"error\");\n                }\n            },\n            error: function (response) {\n            }\n        });\n    }\n    //End: Add Function call for Add/Edit referral template - Chee Yong 27082018\n\n    //Added by Jason 20210326 - add hover show menu\n    $( \".dropup .dropdown-menu\" ).hover(\n      function() {\n          $(this).prev().css(\"color\", \"#fff\");\n      }, function() {\n          if(!$(this).prev().parent().hasClass(\"open\")){\n              $(this).prev().css(\"color\", \"initial\");\n          }\n      }\n    );\n    //End added by Jason 20210326\n\n    function PatientAllergy() {\n        var PCNO = $('#hfPCNO').val();\n        //$('.fadeMe').show();\n        $(\"#tabAllergy_frame\").load('https://clinicassist.sg:1080/en/PatientMaster/TabPatientAllergy?pcno=' + PCNO);\n    }\n\n    $('#btnPatientSave').off(\"click\").click(function () {   //Edited by Chang Ching Ler 20211027 | Add .off('click') to prevent multiple call\n        savePatient();\n    })\n\n    function back(pcno) {\n        //Edited by Jason 20211022 - if detect user change patient info. prompt user want to save data before proceed back\n        if ($(\"#txtPatientNo\").val() != \"NEW\") {\n            newDataBiodata = JSON.stringify($('#CreateEditPatientForm').serializeArray());\n            newDataMedAlert = JSON.stringify($('#CreateEditPatientAllergyForm').serializeArray());\n            newDataPopup = JSON.stringify($('#CreateEditPatientPopUpForm').serializeArray());\n            newDataFamily = JSON.stringify($('#CreateEditPatientFamilyForm').serializeArray());\n\n            if (newDataBiodata != \"[]\" && newDataMedAlert != \"[]\" && newDataPopup != \"[]\" && newDataFamily != \"[]\") {\n                if ((oldDataBiodata != newDataBiodata) || (oldDataMedAlert != newDataMedAlert) || (oldDataPopup != newDataPopup) || (oldDataFamily != newDataFamily)) {\n                    infoChanged = \"Y\";\n                }\n                else if( true == true)\n                {\n                    newDataHistory = JSON.stringify($('#frmTabHistory').serializeArray());\n                    if(newDataHistory != \"[]\" && typeof oldDataHistory !==\"undefined\" && oldDataHistory != newDataHistory)\n                    {\n                        infoChanged = \"Y\";\n                    }\n                }\n            }\n\n            if($('#hfIsPaediatric').val() == \"Y\"){\n                newDataBirth = JSON.stringify($('#CreateEditPatientBirthForm').serializeArray());\n                if(newDataBirth != \"[]\"){\n                    if(oldDataBirth != newDataBirth){\n                        infoChanged = \"Y\";\n                    }\n                }\n            }\n\n        } else {\n            if ($(\"#txtPatientPName\").val() != \"\") {\n                infoChanged = \"Y\";\n            }\n        }\n\n        if (infoChanged == \"Y\") {\n            setTimeout(function() {\n                swal({ title: \"\", text: \"Detected Patient's info changed. \\nDo you want to save?\", type: \"warning\", showCancelButton: true, confirmButtonColor: \"#DD6B55\", cancelButtonText: \"No\", confirmButtonText: \"Yes\" },\n                function (confirm) {\n                    if (confirm) {\n                        setTimeout(function(){$('#btnPatientSave').trigger('click');}, 200);    //Edited by Chang Ching Ler 20211105 | Set timer to prevent new swal being close together with current swal\n                    }\n                    else {\n                        if ($(\"#hdQueryFrom\").val() == \"PatFamily\") {\n                            $(\"#patFamilyDetModal\").modal(\"hide\");\n                        } else if ($(\"#hdQueryFrom\").val() == \"AddEditCIDC\") {  //Added by Chang Ching Ler 20211026 | Call from CIDC submission\n                            $(\"#CIDCPatDetModal\").modal(\"hide\");\n                        } else {\n                            $(\"#patDetModal\").modal(\"hide\");\n                        }\n\n                        $(\".modal-backdrop\").remove();\n                    }\n                });\n            }, 500);\n        } else {\n            if ($(\"#hdQueryFrom\").val() == \"PatFamily\") {\n                $(\"#patFamilyDetModal\").modal(\"hide\");\n            } else if ($(\"#hdQueryFrom\").val() == \"AddEditCIDC\") {  //Added by Chang Ching Ler 20211026 | Call from CIDC submission\n                $(\"#CIDCPatDetModal\").modal(\"hide\");\n            } else if ($(\"#hdQueryFrom\").val() == \"ApptPatSumm\") {  //Added by Chang Ching Ler 20211027 | Call from Appointment > Add > Patient Summary\n                $(\".apptConfigMainBar #txtEmail\").val($(\"#txtPatientEmail\").val());\n                $(\".apptConfigMainBar #txtContact\").val($(\"#txtPatientHP\").val());\n                $(\".apptConfigMainBar #txtNRIC\").val($(\"#txtPatientNRIC\").val());\n\n                $(\"#patDetModal\").modal(\"hide\");\n            } else {\n                $(\"#patDetModal\").modal(\"hide\");\n            }\n\n            $(\".modal-backdrop\").remove();\n        }\n        //End edited by Jason 20211022\n    }\n\n    $('#tab-li-PatCaseNoteAccess').click(function () {\n        $(\"#tabPatCaseNoteAccess_frame\").load('https://clinicassist.sg:1080/en/Patient/PatientCaseNoteAccess');\n    });\n\n    $('#btnExpressReg').off('click').on('click', function() {\n        if ($(\"#txtPatientNRIC\").val() == \"\" || $(\"#txtPatientHP\").val() == \"\" ){\n            swal(\"\", \"Please input both NRIC/FIN/OTHERS and mobile number.\", \"warning\");\n            return;\n        }\n\n        let data = { nric: $('#txtPatientNRIC').val(), mobileno: $('#txtPatientHP').val() };\n        $.ajax({\n            cache: false,\n            url: \"/Patient/ExpressRegistration\",\n            data: data,\n            type: 'post',\n            success: function (response) {\n                if (response.success) {\n                    swal(\"\", \"Express registration success.\", \"success\");\n                }else{\n                    swal(\"\", \"Express registration failed.\", \"warning\");\n                }\n            },\n        });\n    });\n\n\n    function DownloadEhaPatient_ctrl(rowId) {\n        var rowid = $(this).closest(\"tr.jqgrow\").attr(\"id\");\n\n        $(\"#hfehaPatientNRIC\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'Nric'));\n        $(\"#hfehaPatientMobile\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'hp'));\n        $(\"#hfehaPatientApptNo\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'ApptNo'));\n\n        $(\"#txtPatientPName\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'PName'));\n        $(\"#txtPatientNRIC\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'Nric'));\n        $(\"#txtPatientDOB\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'DOB'));\n        $(\"#txtPatientNation\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'nation').trim());\n        $(\"#txtPatientSex\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'Sex'));\n        $(\"#txtPatientHP\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'hp'));\n        $(\"#txtPatientBlkHseNo\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'BlkHseNo'));\n        $(\"#txtPatientStreet\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'Street'));\n        $(\"#txtPatientBuildingName\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'BuildingName'));\n        $(\"#txtPatientUnitNo\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'UnitNo'));\n        $(\"#txtPatientEmail\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'Email'));\n        $(\"#txtPatientRace\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'race'));\n        $(\"#txtPatientMarital\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'Marital'));\n        $(\"#txtPatientCountry\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'country'));\n        $(\"#txtPatientNotifications\").val(($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'notifications') == \"Y\" ? \"True\" : \"False\"));\n        $(\"#txtPatientIDTypeCode\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'idTypeCode'));\n        $(\"#txtPatientPostal\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'PCode'));\n        $(\"#txtPatientTel\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'tel'));\n        $(\"#txtPatientLanguageSP\").val($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'languageSP'));\n        $(\"#select2-txtPatientOccupation-container\").text($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'occupation'));\n\n        var data = { Allergy: $(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'Allergy') };\n        var encoded = JSON.stringify(data)\n        $.ajax({\n            cache: false,\n            type: \"POST\",\n            data: encoded,\n            url: \"/Patient/InsertAllergy\",\n            contentType: \"application/json; charset=utf-8\",\n            dataType: \"json\",\n            success: function (result) {\n                if(result.success){\n                    $('#patientAllergyOtherGrid').trigger('reloadGrid');\n                }\n            }\n        });\n\n        let rows = jQuery(\"#patientConsentGrid\").getDataIDs();\n        for(a=0;a<rows.length;a++)\n        {\n            row=jQuery(\"#patientConsentGrid\").getRowData(rows[a]);\n            if(row[\"Type\"].toUpperCase()==\"PHONE\"){\n                row.Select1 = ($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'PhoneNoti') == \"Y\" ? \"True\" : \"False\");\n            }else if(row[\"Type\"].toUpperCase()==\"SMS\"){\n                row.Select1 = ($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'SMSNoti') == \"Y\" ? \"True\" : \"False\");\n            }else if(row[\"Type\"].toUpperCase()==\"EMSG\"){\n                row.Select1 = ($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'EMsgNoti') == \"Y\" ? \"True\" : \"False\");\n            }else if(row[\"Type\"].toUpperCase()==\"EMAIL\"){\n                row.Select1 = ($(\"#ehaPatientGrid\").jqGrid('getCell', rowid, 'EmailNoti') == \"Y\" ? \"True\" : \"False\");\n            }\n            $(\"#patientConsentGrid\").setRowData(rows[a],row);\n        }\n        $(\"#IsDownloadProfile\").val(\"Y\");\n\n        $(this).closest('.modal').modal('hide');\n    }\n\n    function AddEditOccupation(_data, _oldoccupation, _type) {\n        var d = { setupocc: _data, oldoccupation: _oldoccupation, type: _type };\n        $.ajax({\n            type: \"POST\",\n            url: \"/SetupOccupation/InsUpdSetupOccupation\",\n            data: JSON.stringify(d),\n            contentType: \"application/json; charset=utf-8\",\n            dataType: \"json\",\n            success: function (result) {\n                if (result.success) {\n                }\n                else {\n                    swal(\"\",result.message,\"error\");\n                }\n            },\n            error: function (response) {\n            }\n        });\n    }\n\n    function getlink(e) {\n        var href = e.href;\n        var pathname = e.download;\n        var filename = pathname.split(\"/\")[2];\n        var myData = { filepath: pathname, filename: filename };\n        var encoded = JSON.stringify(myData);\n        var sign = $.ajax({\n            cache: false,\n            type: \"POST\",\n            url: \"/CaseNote/getblob\",\n            data: encoded,\n            contentType: \"application/json; charset=utf-8\",\n            dataType: \"json\",\n            async: false,\n            beforeSend: function () {\n            },\n            success: function (response) {\n                var ori = location.origin;\n                var link = ori + response.path + filename;\n                return e.href = link;\n            },\n            error: function (response) {\n                swal('', response.responseText, 'error');\n            }\n        });\n    }\n\n    //Added by ChengYu 20211216 - copy past case note from case note page       //Added by Koh Chin Choong 20190513\n\n    $('#PastCaseNoteModal').on('hidden.bs.modal', function(){\n        $('#PastCaseNoteModalBody').empty();\n        $('#Pat-tab-li-PastNotes a').click();\n    })\n\n    $(\"#PastCaseNoteModal\").on('shown.bs.modal', function () {\n\n    });\n\n    $('#btnPast').click(function () {\n        past();\n    });\n\n    function past() {\n        if (true == false) {\n            swal({ title: Cookies.get(\"SWAL_Header_Msg\"), text: Cookies.get(\"SWAL_Body_Msg\"), type: Cookies.get(\"SWAL_Type\"), timer: Cookies.get(\"SWAL_Timer\") });\n            return;\n        }\n\n        $('.fadeMe').show();\n\n        var pcno = $('#hfPCNO').val();\n        var pname = $('#hfPName').val();\n        var NRIC = $('#hfNRIC').val();\n\n        $(\"#patDetModal\").css(\"display\", \"none\");\n        $('#tabPastNotes_frame').empty();\n        $('#PastCaseNoteModalLabel').text(\"Past Case Note - \" + pname + ' (' + pcno + ')');\n        $(\"#PastCaseNoteModalBody\").load('https://clinicassist.sg:1080/en/Patient/PastPatientDetails?pcno=' + pcno , function() {\n            $('#PastCaseNoteModal #divFilter').show();\n            $('#PastCaseNoteModal #divVisitNoteList').show();\n            $('#PastCaseNoteModal #divNormalPastNote').hide();\n        });\n        $(\"#PastCaseNoteModal\").modal('show').removeClass(\"fade\");\n    }\n\n    $('#btnPastPatientPrint1').click(function () {\n        var SearchPastPatientDateFrom = $('#SearchPastPatientDateFrom').val();\n        var SearchPastPatientDateTo = $('#SearchPastPatientDateTo').val();\n        var now = new Date();\n\n        var from = SearchPastPatientDateFrom.split(\"/\");\n        var selectedDateFrom = new Date(from[2], from[1] - 1, from[0]);\n\n        var to = SearchPastPatientDateTo.split(\"/\");\n        var selectedDateTo = new Date(to[2], to[1] - 1, to[0]);\n\n        if (selectedDateFrom > now) {\n            $('#SearchPastPatientDateFrom').focus(function () { $(this).select(); });\n            swal(\"\", \"Date From cannot exceed current date.\");\n            return;\n        }\n\n        if (selectedDateFrom > SearchPastPatientDateTo) {\n            $('#SearchPastPatientDateFrom').focus(function () { $(this).select(); });\n            swal(\"\", \"Date From cannot exceed Date To.\");\n            return;\n        }\n\n        var txtType = $('#txtType').val();\n        var txtClinic = $('#txtClinic').val();\n\n        if (txtType.indexOf(\"mc\") >= 0) {\n            var id = jQuery(\"#pastMCGrid\").jqGrid('getGridParam', 'selrow');\n\n            if (id != null) {\n                var visitNo = jQuery(\"#pastMCGrid\").jqGrid('getCell', id, 'VisitNo');\n                var itemNo = jQuery(\"#pastMCGrid\").jqGrid('getCell', id, 'ItemNo');\n                var docID = jQuery(\"#pastMCGrid\").jqGrid('getCell', id, 'DrID');\n                var docName = jQuery(\"#pastMCGrid\").jqGrid('getCell', id, 'DocName');\n                var clinic = jQuery('#pastMCGrid').jqGrid('getCell', id, 'Clinic');\n                var referenceno = jQuery('#pastMCGrid').jqGrid('getCell', id, 'Reference');\n\n                if (clinic.trim() == txtClinic.trim()) {\n                    var url = '/en/ReportViewer/Index?type=pastmc&param1=' + visitNo + '&param2=' + itemNo + '&param3=' + docID + '&param4=' + docName+ '&param5=' + referenceno;\n\n                    var left = (screen.width / 2) - (1000 / 2);\n                    var top = (screen.height / 2) - (500 / 2);\n                    var hei = screen.height - 110;\n\n\n\n                    newwindow = window.open(url, 'name', 'resizable,height=' + hei + ',width=900, top=0, left=' + left);\n                    if (window.focus) { newwindow.focus() }\n                }\n                else {\n                    swal('', 'You are not allowed to print MC that issued from other Clinic', 'warning');\n                }\n            }\n            else {\n                swal(\"\", \"Please Select a row\", \"error\");\n            }\n        }\n        else if (txtType.indexOf(\"timechit\") >= 0) {\n            var id = jQuery(\"#pastTimeChitGrid\").jqGrid('getGridParam', 'selrow');\n\n            if (id != null) {\n                var visitNo = jQuery(\"#pastTimeChitGrid\").jqGrid('getCell', id, 'VisitNo');\n                var url = '/en/ReportViewer/Index?type=timechit&param1=' + visitNo;\n\n                var left = (screen.width / 2) - (1000 / 2);\n                var top = (screen.height / 2) - (500 / 2);\n                var hei = screen.height - 110;\n                var a5height = screen.height - 180;\n                var printA5Size = $(\"#PrintA5Size\").val();\n\n                //Added by Daniel 2018-02-02 [PROD:81] Adjust pop up height and width\n                if (printA5Size == \"Y\") {\n                    newwindow = window.open(url, 'name', 'resizable,height=' + a5height + ',width=630, top=0, left=' + left);\n                } else {\n                    newwindow = window.open(url, 'name', 'resizable,height=' + hei + ',width=900, top=0, left=' + left);\n                }\n                if (window.focus) { newwindow.focus() }\n\n            }\n            else {\n                swal(\"\", \"Please Select a row\", \"error\");\n            }\n        }\n        else {\n            var id = jQuery(\"#pastCaseNoteGrid\").jqGrid('getGridParam', 'selrow');\n\n            if (id != null) {\n                var VisitNo = jQuery(\"#pastCaseNoteGrid\").jqGrid('getCell', id, 'VisitNo');\n\n                var url = '/en/ReportViewer/Index?type=pastcasenotelisting&param1=' + VisitNo + '&param2=' + $('#SearchPastPatientPCNO').val() + '&param3=' + $('#SearchPastPatientDateFrom').val() + '&param4=' + $('#SearchPastPatientDateTo').val() + '&param5=' + $('#SearchPastPatientDoctor').val();\n\n\n                var left = (screen.width / 2) - (1000 / 2);\n                var top = (screen.height / 2) - (500 / 2);\n                var hei = screen.height - 110;\n\n                newwindow = window.open(url, 'name', 'resizable,height=' + hei + ',width=900, top=0, left=' + left);\n                if (window.focus) { newwindow.focus() }\n\n            }\n            else {\n                swal(\"\", \"Please Select a row\", \"error\");\n            }\n        }\n    });\n\n    //End Added\n\n    function checkPatientModuleAccess() {\n        if (\"N\" == \"Y\") {\n            $(\"#IdPatientTab\").find(\"a[href='#tabFinancial']\").parent().remove();\n            //$(\"#IdPatientTab\").find(\"a[href='#tabReferral']\").parent().remove();\n            $(\"#IdPatientTab\").find(\"a[href='#tabPatientComm']\").parent().remove();\n            //$(\"#txtPatientHP\").parent().hide();\n            //$(\"#txtPatientTel\").parent().hide();\n            //$(\"#txtPatientTel2\").parent().hide();\n            //$(\"#txtPatientEmail\").parent().hide();\n            //$(\"#txtPatientBlkHseNo\").parent().hide();\n            //$(\"#txtPatientStreet\").parent().parent().parent().hide();\n            //$(\"#txtPatientUnitNo\").parent().hide();\n            //$(\"#txtPatientBuildingName\").parent().hide();\n            //$(\"#txtPatientPostal\").parent().parent().parent().hide();\n            //$(\"#txtPatientUseForAdd\").parent().hide();\n            //$(\"#txtPatientForeignAdd1\").parent().hide();\n            //$(\"#txtPatientForeignAdd2\").parent().hide();\n            //$(\"#txtPatientForeignAdd3\").parent().hide();\n            //$(\"#txtPatientForeignAdd4\").parent().hide();\n\n            setTimeout(function() {\n                $(\"#spRegionDiv\").css(\"margin-top\", -110);\n                $(\"#patientConsentDiv\").css(\"margin-top\", 0);\n                $(\"#groupRegionDiv\").css(\"margin-top\", -145);\n                $(\"#referralRegionDiv\").css(\"margin-top\", -85);\n                $(\"#doctorDivRegion\").css(\"margin-top\", -35);\n            }, 500);\n        }\n    }\n    function savePatient() {\n        var IsPopupEnabled = false,IsBirthEnabled = false,IsFamilyEnabled = false\n        if ($(\"#tabPopup_frame\").html().trim().length != 0) {\n            IsPopupEnabled = true\n        }\n        if ($(\"#tabBirth_frame\").html().trim().length != 0 ) {\n            IsBirthEnabled = true\n        }\n        if ($(\"#tabPatientFamily_frame\").html().trim().length != 0 && true == true) {\n            IsFamilyEnabled = true\n        }\n        var pnote  = $('#txtPatientNotes').val()\n        if(pnote.indexOf(\"&\") > 0)\n        {\n            pnote = pnote.replaceAll(\"&\",\"&amp;\")\n        }\n\n        $('#txtPatientNotes').val(pnote);\n\n        var txtIsVIP = $('#txtIsVIP').val();\n\n        if (txtIsVIP.length == 0) {\n            $('#txtIsVIP').val('false');\n        }\n\n        var href = jQuery(location).attr('href');\n\n        if ($(\"#txtPatientPName\").val() == \"\") {\n            swal(\"\", \"Please input patient's name.\", \"warning\");\n            return;\n        }\n\n        if ($(\"#txtPatientSex\").val() == \"\") {\n            swal(\"\", \"Please select patient's gender.\", \"warning\");\n            return;\n        }\n\n        if ($(\"#txtPatientNRIC\").val() == \"\") {\n            swal(\"\", \"Please input patient's NRIC.\", \"warning\");\n            return;\n        }\n\n        if($(\"#txtPatientDOB\").val() == \"\") {\n            swal(\"\", \"Please input patient's date of birth.\", \"warning\");\n            return;\n        }\n        if ($(\"#txtPatientNation\").val() == \"SINGAPORE PR\" && $(\"#txtPatientNation2\").val() == \"\") {\n            swal(\"\", \"Please input patient's nationality.\", \"warning\");\n            return;\n        }\n        if (\"False\" == \"True\"){\n            if($(\"#txtPatientState\").val() == \"\") {\n                swal(\"\", \"Please select patient's state.\", \"warning\");\n                return;\n            }\n            if($(\"#txtPatientCity\").val() == \"\") {\n                swal(\"\", \"Please input patient's city.\", \"warning\");\n                return;\n            }\n            if($(\"#txtPatientStreet\").val() == \"\") {\n                swal(\"\", \"Please input patient's street.\", \"warning\");\n                return;\n            }\n            if($(\"#txtPatientHP\").val() == \"\") {\n                swal(\"\", \"Please input patient's phone number.\", \"warning\");\n                return;\n            }\n        }\n\n        var PatientAllergyID = $(\"#patientAllergyGrid\").jqGrid('getDataIDs');\n        var PatientAllergyOtherID = $(\"#patientAllergyOtherGrid\").jqGrid('getDataIDs');\n\n        if (!($(\"#chkPatientAllergy\").is(\":checked\"))) {\n            if (PatientAllergyID.length <= 0 && PatientAllergyOtherID.length <= 0) {\n                swal(\"\", \"Patient has allergy? If no please tick No Allergy box\", \"warning\");\n                return;\n            }\n        }\n\n        if (PatientAllergyID.length > 0 || PatientAllergyOtherID.length > 0) {\n            $(\"#chkPatientAllergy\").prop('checked', false);\n        }\n\n        $('#txtPatientAllergy').prop('disabled', false);\n\n        var NRIC = $(\"#txtPatientNRIC\").val()\n        var IDType = $(\"#txtPatientIDTypeCode\").val()\n        var Nation = $(\"#txtPatientNation\").val()\n        var SGPRpattern = /^[ST]\\d{7}[A-Z]$/g;\n        var FINpattern = /^[FGM]\\d{7}[A-Z]$/g;\n        if (IDType == 'B' || IDType == 'P')\n        {\n            var result = SGPRpattern.test(NRIC);\n            if ( result == false){\n                swal('', \"Please verify patient's NRIC and ID Type.\",'error');\n                return;\n            }\n            if(!NRIC.includes(\"S22\") && !NRIC.includes(\"S21\") && !NRIC.includes(\"T00\") && !NRIC.includes(\"S25\") && !NRIC.includes(\"S23\") && !NRIC.includes(\"S24\") && !NRIC.includes(\"S26\") && !NRIC.includes(\"S27\") && !NRIC.includes(\"S28\") && !NRIC.includes(\"S29\")){  //Modified by Ray 20240205 - Add S23-S29  //Modified by Cheng Yu 20240119 - Add T00    //Modified by Cheng Yu 20240109 - Add S21     //Added by Cheng Yu 20240109 - by pass if NRIC is S22\n                var DOB = $(\"#txtPatientDOB\").val()\n                var DOBDate = new Date(moment(moment(DOB, \"DD/MM/YYYY\")).format(\"MM/DD/YYYY\"));\n                var DOBYear = DOBDate.getFullYear();\n                if (DOBYear > 1967){\n                    if ( NRIC.substring(1,3) != DOBYear.toString().substring(2,4)){\n                        swal('', \"Please verify patient's Date of birth.\",'error');\n                        return;\n                    }\n                }\n            }\n        }else if (IDType == 'F' || IDType == 'L'){      //Modified by Cheng Yu 20240125 - Add Long Term Visit Pass for Fin checking\n            var result = FINpattern.test(NRIC);\n            if ( result == false){\n                swal('', \"Please verify patient's NRIC and ID Type.\",'error');\n                return;\n            }\n        }\n\n        var result = SGPRpattern.test(NRIC);\n        if ( result == true){\n            if (IDType != 'B' || IDType != 'P'){\n                if (IDType == 'PP' && Nation != 'FILIPINO'){    //Edited by Lim Han Yong 20240521 - Add passport and Filipino for SGNRIC checking\n                    swal('', \"Please verify patient's NRIC and ID Type.\",'error');\n                    return;\n                }\n            }\n        }\n\n        var result = FINpattern.test(NRIC);\n        if ( result == true){\n            if (IDType != 'F' || IDType != 'L'){      //Modified by Cheng Yu 20240125 - Add Long Term Visit Pass for Fin checking\n                swal('', \"Please verify patient's NRIC and ID Type.\",'error');\n                return;\n            }\n        }\n\n        var PatientIDTypeCode = $(\"#txtPatientIDTypeCode\").val();\n\n        var pass = false;\n        var data = {\n            mobileDownloadAllergy: $('#hfpatientAllergy').val(),\n            SubmissionVisitNo: '',\n            IsDownloadProfile: $('#IsDownloadProfile').val(),\n            ProfileNRIC: $('#hfehaPatientNRIC').val(),\n            ProfileMobile: $('#hfehaPatientMobile').val(),\n            DownloadProfileType: $(\"#DownloadProfileType\").val(),\n            PreRegFilePath: $(\"#PreRegFilePath\").val(),\n            hfehaPatientApptNo: $(\"#hfehaPatientApptNo\").val(),\n            IsPopupEnabled :IsPopupEnabled,\n            IsBirthEnabled : IsBirthEnabled,\n            IsFamilyEnabled :IsFamilyEnabled\n        };\n\n        $.each($('#CreateEditPatientForm').serializeArray(), function () {\n            data[this.name] = (this.value.replace(/</g, '&lt;'));\n            if ($(\"#txtPatientNo\").val() != 'NEW'){\n                data.PCNO = ($(\"#txtPatientNo\").val());\n            }\n        });\n\n        if (IsPopupEnabled) {\n            $.each($('#CreateEditPatientPopUpForm').serializeArray(), function () {\n                data[this.name] = this.value.replace(/</g, '&lt;');\n            });\n        }\n\n        $.each($('#CreateEditPatientAllergyForm').serializeArray(), function () {\n            data[this.name] = this.value.replace(/</g, '&lt;');\n        });\n        if(IsFamilyEnabled)\n        {\n            $.each($('#CreateEditPatientFamilyForm').serializeArray(), function () {\n                data[this.name] = this.value.replace(/</g, '&lt;');\n            });\n        }\n        $.each($('#CreateEditPatientReferralForm').serializeArray(), function () {\n            data[this.name] = this.value.replace(/</g, '&lt;');\n        });\n        if(IsBirthEnabled)\n        {\n            $.each($('#CreateEditPatientBirthForm').serializeArray(), function () {\n                data[this.name] = this.value.replace(/</g, '&lt;');\n            });\n        }\n        if ('N' == \"Y\"){\n            $.each($('#CreateEditPatientTreatmentInfo').serializeArray(), function () {\n                data[this.name] = this.value.replace(/</g, '&lt;');\n            });\n            $.each($('#CreateEditPatientPaymentInfo').serializeArray(), function () {\n                data[this.name] = this.value.replace(/</g, '&lt;');\n            });\n\n            const days = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];\n\n            days.forEach(day => {\n                const checkbox = $(`#chk${day}`);\n                checkbox.val(checkbox.prop('checked') ? 'true' : 'false');\n                data[`DialysisDay_${day}`] = checkbox.val();\n            });\n        }\n        data.Email = $(\"#txtPatientEmail\").val();\n        data.Dummy = document.getElementById('chkPatientDummy').checked;\n        $('#txtPatientAllergy').prop('disabled', true);\n\n        if ($('#createEditpatientModal .modal-title').contents().first().text() == \"Edit Patient\") {\n            $('#txtPatientNRIC').prop('readonly', \"readonly\");\n        }\n        var ids = $(\"#patientConsentGrid\").jqGrid('getDataIDs');\n        var GetConsentType = [];\n\n        for (var a = 0; a < ids.length; a++) {\n            var row = jQuery(\"#patientConsentGrid\").getRowData(ids[a]);\n\n            if (row[\"Select1\"] == \"True\") {\n                pass = true;\n            }\n            GetConsentType.push(row);\n        }\n\n        //if (!pass) {\n        //    $(\"#btnPatientOk\").prop('disabled',false);\n        //    swal(\"\", \"Please select at least one notification!\", \"warning\");\n        //    return;\n        //}\n\n        var notf1 = $(\"#aNotificationSMS\").css(\"display\") !== \"none\" ? true : false;\n        var notf3 = $(\"#aNotificationEmail\").css(\"display\") !== \"none\" ? true : false;\n        var notf4 = $(\"#aNotificationWhatsApp\").css(\"display\") !== \"none\" ? true : false;\n\n        if (!notf1 && !notf3 && !notf4) {\n            swal(\"\", \"Please select at least one notification!\", \"warning\");\n            return;\n        }\n        else {\n            if(notf1){\n                var myRow = {\"Select1\": \"True\", \"Date1\": Date.now(), \"Type\": \"SMS\" , \"Preferred\": $(\"#aNotificationSMS\").hasClass(\"preferred-notif\") ? true : false }\n                GetConsentType.push(myRow)\n            }\n            else {\n                var myRow = {\"Select1\": \"False\", \"Date1\": Date.now(), \"Type\": \"SMS\", \"Preferred\": false  }\n                GetConsentType.push(myRow)\n            }\n\n            //Commented out by Xirlyn 20240126 - Not used\n            //if(notf2){\n            //    var myRow = {\"Select1\": \"True\", \"Date1\": Date.now(), \"Type\": \"ESMS\" }\n            //    GetConsentType.push(myRow)\n            //}\n\n            if(notf3){\n                var myRow = {\"Select1\": \"True\", \"Date1\": Date.now(), \"Type\": \"Email\", \"Preferred\": $(\"#aNotificationEmail\").hasClass(\"preferred-notif\") ? true : false  }\n                GetConsentType.push(myRow)\n            }\n            else {\n                var myRow = {\"Select1\": \"False\", \"Date1\": Date.now(), \"Type\": \"Email\", \"Preferred\": false  }\n                GetConsentType.push(myRow)\n            }\n            if(notf4){\n                var myRow = {\"Select1\": \"True\", \"Date1\": Date.now(), \"Type\": \"WhatsApp\", \"Preferred\": $(\"#aNotificationWhatsApp\").hasClass(\"preferred-notif\") ? true : false  }\n                GetConsentType.push(myRow)\n            }\n            else {\n                var myRow = {\"Select1\": \"False\", \"Date1\": Date.now(), \"Type\": \"WhatsApp\", \"Preferred\": false  }\n                GetConsentType.push(myRow)\n            }\n        }\n\n        if ($(\"#txtPatientPName\").val().indexOf(\"<\") >= 0 || $(\"#txtPatientPName\").val().indexOf(\">\") >= 0 || $(\"#txtPatientPName\").val().indexOf(\"&\") >= 0) {\n            setTimeout(function () {\n                swal(\"\", \"Patient name cannot contain special characters. (< > &)\", \"warning\");\n            }, 500);\n            return;\n        }\n\n        var postData = JSON.stringify(GetConsentType);\n        var pcno;\n        var chkPregnancy = $(\"#chkPregnancy\").prop('checked')\n        var PregnancyDueDate = $(\"#PregnancyDueDate\").val();\n        var chkMetalImplants = $('#chkMetalImplants').prop('checked') == undefined ? false : $(\"#chkMetalImplants\").prop('checked');\n        var chkClaustrophobia = $(\"#chkClaustrophobia\").prop('checked') == undefined ? false : $(\"#chkClaustrophobia\").prop('checked');\n        var PatientCompCode = $('#txtPatientCompCode').val();\n        var mednotes = $(\"#mednotes\").val();\n        var patientG6PD = $(\"#txtPatientG6PD\").val();\n\n        if (IsPopupEnabled) {\n            const esc = s => $(\"<div>\").text(s.trim() ?? \"\").html(); // Modified by Paul 30092025 - To allow <br> to be read as html while preventing script injection\n            let dispPopupVal = esc($(\"#txtPatientDispensePopUp\").val());\n            let payPopupVal = esc($(\"#txtPatientPaymentPopUp\").val());\n            let gap = (dispPopupVal && payPopupVal) ? \"<br><br>\" : \"\";\n\n            let disPayPopup = dispPopupVal ? \"Dispense: \" + dispPopupVal : \"\";\n            disPayPopup += gap;\n            disPayPopup += payPopupVal ? \" Payment: \" + payPopupVal : \"\";\n\n            if(disPayPopup.trim() == \"\") {\n                $(\"#divlblDispenseAndPaymentPopup\").hide();\n            }\n            else {\n                $(\"#divlblDispenseAndPaymentPopup\").show();\n                $(\"#lblDispenseAndPaymentPopup\").html(disPayPopup); // End modified by Paul 30092025 - To allow <br> to be read as html while preventing script injection\n            }\n\n            var casenotPopup = $(\"#txtPatientCaseNotePopUp\").val() != \"\" ? $(\"#txtPatientCaseNotePopUp\").val() : \"\";\n\n            if(casenotPopup.trim() == \"\") {\n                $(\"#divlblCasenotePopMsg\").hide();\n                $(\"#parentCaseNoteDiv\").css(\"height\",\"calc(100vh - 213px)\")\n            }\n            else {\n                $(\"#divlblCasenotePopMsg\").show();\n                $(\"#lblCasenotePopMsg\").text($(\"#txtPatientCaseNotePopUp\").val());\n                $(\"#parentCaseNoteDiv\").css(\"height\",\"calc(100vh - 260px)\")\n            }\n        }\n        $.ajax({\n            cache: false,\n            url: \"/Patient/InsertUpdate\",\n            data: data,\n            type: 'post',\n            dataType: 'json',\n            success: function (result) {\n                if (result.success) {\n                    if($(\"#txtPatientNo\").val() === \"NEW\") {\n                        swal(\"\", \"Patient info created successfully.\", \"success\");\n                    }\n                    else {\n                        swal(\"\", \"Patient info updated successfully.\", \"success\");\n                    }\n                    //2020-10-01 Kai : after insert/update success, then only proceed to insert/update to mailchimp\n                    if ($(\"#txtPatientNotifications\").val() == \"True\") {\n                        $.ajax({\n                            cache: false,\n                            url:\"/MailChimp/CallMailChimpApi\",\n                            type:'post',\n                            data :{\n                                'fname'     : $(\"#txtPatientPName\").val(),\n                                'emailAdd'  : $(\"#txtPatientEmail\").val(),\n                                'phoneNum'  : $(\"#txtPatientHP\").val(),\n                                'birthday'  : $(\"#txtPatientDOB\").val().substring(3,5) + \"/\" + $(\"#txtPatientDOB\").val().substring(0,2),\n                                //address followed patient master GUI, blk/hseno + street + unit + building name\n                                'address1'  : !($(\"#txtPatientBlkHseNo\").val().trim()) && !($(\"#txtPatientStreet\").val().trim())     ? \"n/a\" : $(\"#txtPatientBlkHseNo\").val() + \" \" + $(\"#txtPatientStreet\").val(),\n                                'address2'  : !($(\"#txtPatientUnitNo\").val().trim()) && !($(\"#txtPatientBuildingName\").val().trim()) ? \"n/a\" : $(\"#txtPatientUnitNo\").val() + \" \" + $(\"#txtPatientBuildingName\").val(),\n                                'postal'    : !($(\"#txtPatientPostal\").val().trim())    ? \"n/a\" : $(\"#txtPatientPostal\").val(),\n                                //'city'      : !($(\"#txtPatientDistricts\").val().trim()) ? \"n/a\" : $(\"#txtPatientDistricts\").val(), //2020-10-09 Kai - send country as city at the moment, dont have city in patient db.\n                                'city'      : !($(\"#txtPatientCountry\").val().trim()) ? \"n/a\" : $(\"#txtPatientCountry\").val(),\n                                'state'     : \" \", //2020-10-09 Kai - pass empty at the moment, dont have state in patient db.\n                                //'country'   : !($(\"#txtPatientCountry\").val().trim())   ? \"Singapore\" : $(\"#txtPatientCountry\").val()  //2020-10-12 Kai - send singapore as default if empty\n                                'country'   : \"Singapore\"   //2021-02-05 Kai - peter say all default as Singapore\n                            }\n                        })\n                    }\n                    //2020-10-01 END\n\n                    pcno = result.pcno;\n                    if (typeof pcno != 'undefined') {\n                        pcno = result.pcno;\n                    }\n                    else {\n                        pcno = result.editingpcno;\n                    }\n\n                    $(\"#txtPatientNo\").val(pcno);\n\n                    if(IsFamilyEnabled)\n                    {\n                        var SpOcc = $(\"#txtPatientSPJob\").val()\n\n                        if (SpOcc === \"\"){\n\n                        }else {\n                            var data1 = { Occupation: SpOcc, Editable: '1' };\n                            AddEditOccupation(data1, '', 'I');\n                        }\n\n                    }\n                    var Occ = $(\"#txtPatientOccupation\").val()\n\n                    //if (Occ === \"\"){\n\n                    //}else {\n                    //    var data = { Occupation: Occ, Editable: '1' };\n                    //    AddEditOccupation(data, '', 'I');\n                    //}\n\n                    if (chkPregnancy != undefined && PregnancyDueDate != undefined){\n                        $.ajax({\n                            cache: false,\n                            url: \"/CaseNote/SaveTabHistory?pPCNo=\" + pcno + \"&QueryType=I16\",\n                            data: { \"__RequestVerificationToken\": $('input[name=\"__RequestVerificationToken\"]', $(\"#CreateEditPatientAllergyForm\")).val(), \"Pregnancy\": chkPregnancy, \"PregnancyDue\": PregnancyDueDate, \"MetalImplants\": chkMetalImplants, \"Claustrophobia\": chkClaustrophobia, \"MedNotes\" :mednotes, \"G6PD\": patientG6PD },\n                            type: \"POST\",\n                            success: function (response) {\n                                if (!response.success){\n                                    swal(\"\", \"Error in Saving Patient Allergy\", \"error\");\n                                }\n                            },\n                            error: function (response) {\n                            }\n                        });\n                    }\n\n                    //Added by kenneth 2025-01-14 - If dispense page rendered before, to update the copayment for payment\n                    //if($(\"#mainTabDispensePayment_frame\").html().trim().length > 0)\n                    //{\n                    //Modified by Jia Yi 20250213- solve bug system does not close the \"Add New Patient\" screen after save\n                    var element = $(\"#mainTabDispensePayment_frame\");\n                    if (element.length > 0 && element.html().trim().length > 0) {\n                        if($(\"#txtPatientCopayPercent\").val() > 0 || $(\"#txtPatientCopayAmt\").val() > 0)\n                        {\n                            var rbcopayment = $('input[name=patientcopayment]:checked').val();\n                            if (rbcopayment == \"Percent\") {\n                                document.querySelector(`input[name=\"copayment\"][type=\"radio\"][value=\"Percent\"]`).click();\n                                $(\"#txtCopayPercentAmount\").val($(\"#txtPatientCopayPercent\").val())\n                                $(\"#txtCopayPercentAmount\").prop('disabled',false)\n                                $(\"#txtCopayPercentAmount\").css('background','')\n                                $(\"#txtCopayAmount\").val(0)\n                                $(\"#txtCopayAmount\").prop('disabled',true)\n                                $(\"#txtCopayAmount\").css('background','lightgrey')\n                            }\n                            else\n                            {\n                                document.querySelector(`input[name=\"copayment\"][type=\"radio\"][value=\"Amount\"]`).click();\n                                $(\"#txtCopayAmount\").val($(\"#txtPatientCopayAmt\").val())\n                                $(\"#txtCopayAmount\").prop('disabled',false)\n                                $(\"#txtCopayAmount\").css('background','')\n                                $(\"#txtCopayPercentAmount\").val(0)\n                                $(\"#txtCopayPercentAmount\").prop('disabled',true)\n                                $(\"#txtCopayPercentAmount\").css('background','lightgrey')\n                            }\n                        }\n                    }\n                    //End Added by kenneth 2025-01-14\n                    $.ajax({\n                        cache: false,\n                        url: \"/Patient/InsertConcent?pcno=\" + pcno,\n                        data: postData,\n                        type: 'post',\n                        contentType: \"application/json; charset=utf-8\",\n                        success: function (result1) {\n                            var queryFrom = $(\"#hdQueryFrom\").val();\n\n                            if (result1.success) {\n                                var urlLocation = jQuery(location).attr('href');\n                                if (urlLocation.toLowerCase().indexOf(\"queuelog\") >= 0) {\n                                    if (queryFrom == \"AddQ\") {\n                                        $('#AddPatientQueueSearchKeyword').val(result.pcno);\n                                        $('#AddPatientQueueSearchKeyword').trigger('keyup');\n\n                                        Cookies.set('IsAutoClick', 'Yes')\n\n                                        if (result.printerCaseNoteLabel) {\n                                            $('.fadeMe').show();\n                                            $(\"#printSetupLabelModalBody\").load('https://clinicassist.sg:1080/en/PrintingSetting/PrintCopies?pcno=' + result.pcno);\n                                            $(\"#printSetupLabelModal\").show().removeClass('fade');\n                                        }\n                                    }\n                                    else {\n                                        $('#queueLogGrid').trigger('reloadGrid', [{ current: true }]);\n                                    }\n                                }\n                                else if (urlLocation.toLowerCase().indexOf(\"searchpatient\") >= 0) {\n                                    if (result.printerCaseNoteLabel) {\n                                        $('.fadeMe').show();\n                                        $(\"#printSetupLabelModalBody\").load('https://clinicassist.sg:1080/en/PrintingSetting/PrintCopies?pcno=' + result.pcno);\n                                        $(\"#printSetupLabelModal\").show().removeClass('fade');\n                                    }\n                                    else {\n                                        $(\"#createEditpatientModal\").modal('hide');\n                                        $(\"#createEditpatientModal\").remove();\n                                        $('#searchpatientGrid').trigger('reloadGrid');\n\n                                        var ids = $(\"#searchpatientGrid\").jqGrid(\"getDataIDs\");\n\n                                        if (ids.length <= 100) {\n                                            $(\"#searchpatientGrid tr\").eq(1).trigger(\"click\");\n                                        }\n                                    }\n                                }\n                                else if (urlLocation.toLowerCase().indexOf(\"patient\") >= 0) {\n                                    var trans = $(\"#myCreateEditModalLabel\").text();\n\n                                    var code = result.pcno;\n                                    if (typeof code != 'undefined') {\n                                        Cookies.set('selrow', result.pcno);\n                                        $('#SearchKeyword').val(result.pcno);\n\n                                        var postDataValues = $(\"#patientGrid\").jqGrid('getGridParam', 'postData');\n                                        postDataValues['SearchKeyword'] = $(\"#SearchKeyword\").val();\n\n                                        $('#patientGrid').jqGrid().setGridParam({ postData: postDataValues, page: 1 }).trigger('reloadGrid');\n                                    }\n                                    else {\n                                        var txtsearchKeyword = $('#SearchKeyword').val();\n\n                                        Cookies.set('selrow', result.editingpcno);\n                                        $('#SearchKeyword').val(txtsearchKeyword);\n\n                                        var postDataValues = $(\"#patientGrid\").jqGrid('getGridParam', 'postData');\n                                        postDataValues['SearchKeyword'] = $(\"#SearchKeyword\").val();\n\n                                        $('#patientGrid').jqGrid().setGridParam({ postData: postDataValues, page: 1 }).trigger('reloadGrid');\n                                    }\n\n                                    if (result.printerCaseNoteLabel) {\n                                        $('.fadeMe').show();\n                                        $(\"#printSetupLabelModalBody\").load('https://clinicassist.sg:1080/en/PrintingSetting/PrintCopies?pcno=' + result.pcno);\n                                        $(\"#printSetupLabelModal\").show().removeClass('fade');    //Added by Jason 20211026 - show printSetupPatLabelModal\n                                    }\n\n                                    $('#patientGrid').trigger('reloadGrid');\n\n                                    $(\"#createEditpatientModal\").modal('hide');\n                                    $(\"#createEditpatientModal\").remove();\n\n                                    $(\"#createPatientFrmQueModal\").modal('hide');\n                                    $(\"#createPatientFrmQueModal\").remove();\n                                }\n                                else if (urlLocation.toLowerCase().indexOf(\"casenote\") >= 0) {\n                                    $(\"#createPatientFrmQueModal\").modal('hide');\n                                    $(\"#createPatientFrmQueModal\").remove();\n\n                                    $('#idPatient').empty();\n                                    $('#idPatient').load('https://clinicassist.sg:1080/en/CaseNote/TabBiodata?pcno=' + pcno);\n                                    $('#PatientInfoHeader').load('https://clinicassist.sg:1080/en/Patient/PatientInfoHeader?pcno=' + pcno);\n\n                                    var previousPayType = $('.patInfoPayType').text();\n                                    if(\"PatientDetails_Patient\" == 'PatientDetails_CaseNote' && previousPayType != PatientCompCode){\n                                        var d = { oldPayType: previousPayType, selectedPayType: PatientCompCode };\n                                        var editQueueData = {\n                                            VisitNo: $('#hfVisitNo').val(),\n                                            PayType: PatientCompCode\n                                        };\n                                        var error = patientDetUpdatePayType(d, editQueueData);\n\n                                        if(!error) {\n                                            return;\n                                        }\n                                    }\n                                }\n                                else if(urlLocation.toLowerCase().indexOf(\"appointment\") >= 0){\n\n                                    $('#PatientFrmQueSearchKeyword').val(result.pcno);\n                                    $('#PatientFrmQueSearchKeyword').trigger('keyup');\n                                    $('.fadeMe').hide();\n                                }\n                                else if (urlLocation.toLowerCase().indexOf(\"sms\") >= 0) {\n                                    $('#jqGridAppt').trigger('reloadGrid', [{ current: true }]);\n                                    $('#jqGridRecall').trigger('reloadGrid', [{ current: true }]);\n                                }\n                                else {\n                                    $('#btnPatientOk').closest('.modal').modal('hide'); $('#btnPatientOk').closest('.modal').remove(); $('.modal-backdrop').remove();\n\n                                    if($('#patientFrmQueGrid').length) {\n                                        var code = result.pcno;\n                                        if (typeof code != 'undefined') {\n                                            Cookies.set('selrow', result.pcno);\n                                            $('#PatientFrmQueSearchKeyword').val(result.pcno);\n\n                                            var postDataValues = $('patientFrmQueGrid').jqGrid('getGridParam', 'postData');\n                                            postDataValues['PatientFrmQueSearchKeyword'] = $('#PatientFrmQueSearchKeyword').val();\n\n                                            $('#patientFrmQueGrid').jqGrid().setGridParam({ postData: postDataValues, page: 1 }.trigger('reloadGrid'));\n                                        }\n                                    }\n                                }\n                                if (Cookies.get('xRayCheck') == \"S\") {\n                                    if ($(List_Xray_Externalprog).length > 0) {\n                                        if ($(\"#txtPatientNo\").val() == \"NEW\") {\n                                            call_Xray_Externalprog(\"I\", result.pcno);\n                                        } else {\n                                            call_Xray_Externalprog(\"U\", result.editingpcno);\n                                        }\n                                    }\n                                }\n                            }\n                            if (queryFrom == \"PatFamily\") {\n                                $(\"#patFamilyDetModal\").modal(\"hide\");\n                            } else if (queryFrom == \"AddEditCIDC\") {  //Added by Chang Ching Ler 20211026 | Call from CIDC submission\n                                $(\"#CIDCPatDetModal\").modal(\"hide\");\n                            } else if (queryFrom == \"ApptPatSumm\") {  //Added by Chang Ching Ler 20211027 | Call from Appointment > Add > Patient Summary\n                                $(\".apptConfigMainBar #txtEmail\").val($(\"#txtPatientEmail\").val());\n                                $(\".apptConfigMainBar #txtContact\").val($(\"#txtPatientHP\").val());\n                                $(\".apptConfigMainBar #txtNRIC\").val($(\"#txtPatientNRIC\").val());\n\n                                $(\"#patDetModal\").modal(\"hide\");\n                            } else {\n                                $(\"#patDetModal\").modal(\"hide\");\n                            }\n                            $(\".modal-backdrop\").remove();\n                        }\n                    });\n                    let isPNameExists = document.getElementById(\"txtName\");\n\n                    if(result.objPat !== undefined){\n                        if(isPNameExists != null){\n                            $(\"#txtName\").val(result.objPat.PName)\n                        }\n\n                        let txtNRICExists = document.getElementById(\"txtNRIC\");\n                        if(txtNRICExists != null){\n                            $(\"#txtNRIC\").val(result.objPat.NRIC)\n                        }\n\n                        let txtEmailExists = document.getElementById(\"txtEmail\");\n                        if(txtEmailExists != null){\n                            $(\"#txtEmail\").val(result.objPat.Email)\n                        }\n\n                        let txtContactExists = document.getElementById(\"txtContact\");\n                        if(txtContactExists != null){\n                            $(\"#txtContact\").val(result.objPat.HP)\n                        }\n                    }\n\n                    if (typeof refreshCalendarData !== \"undefined\") {\n                        // safe to use the function\n                        refreshCalendarData()\n                    }\n                }\n                else {\n                    //SetEditBioContactPermission(); //Commented by Zac 20211011 - move to complete only set disable.\n                    var patientError = stringToUnOrderlist(result.message);\n                    swal(\"\", patientError);\n                }\n            },\n            beforeSend: function() {\n\n            },\n            complete: function (xhr, status) {\n            },\n            error: function (xhr, status) {\n                swal(\"\",\"Error\",\"error\");\n            }\n        });\n        return false;\n    }\n\n    $('#btnHidePatientInfoVSDiv').click(function () {\n        if (newVitalSignToggled == 1) {\n            $(\"#PatientInfoVSDiv\").stop(true, true).fadeOut(function() {\n                $(\"#patientInfoDiv\").css(\"width\", \"100%\");\n                $(\"#patientInfoDiv\").css(\"position\", \"relative\");\n            });\n\n            newVitalSignToggled = 0;\n        }\n    });\n\n    function geteDocPat()\n    {\n        if ($('#tabEDoccontent').length) {\n            $('#tabEDoccontent').empty();\n        }\n\n        $(\"#tabPatEDoc_frame\").load('https://clinicassist.sg:1080/en/CaseNote/eDoc?qPCNO=' + $('#hfPCNO').val() + '&qVisitNo=0&qDate1=');     //Edited by Lim Han Yong 20240202 - change to match actionresult\n    }\n\n\n\n        \n            \n\n        \n\n        \n\n\n\n    \n                \n        \n        \n             \n        \n         \n             Save\n              \n             Back\n         \n    \n    \n    \n        \n            \n            \n            \n            \n                Reports\n                \n                    \n                        Statement\n                    \n                \n            \n            \n            \n            \n            \n                Reports\n                \n                    Statement\n                    Listing\n                    Listing O/S\n                \n            \n            \n            \n            \n            \n        \n        \n            \n        \n    \n    \n\n\n\n    \n        \n            \n                ×\n                Add File\n            \n            \n                \n                    \n                        \n                            \n                                \n                                    \n                                        \n                                                \n                                                    \n                                                \n                                                \nDrop file(s) here or click here to select file(s).                                        \n                                        \n                                    \n                                \n                            \n                            \n                                \n\n                                    *Note : Maximum 5 files per upload. Only 30MB allowed for each file.\n                                    \n\n                                        \n                                        \n                                    \n                                \n                            \n                        \n                    \n                \n\n            \n        \n    \n\n\n    \n        \n            \n                ×\n                \n            \n            \n                \n            \n        \n    \n\n\n\n    \n    \n        \n        \n            \n                ×\n                \n            \n            \n                \n            \n        \n    \n\n\n\n\n    \n        \n            \n                ×\n                Add to Case Note\n            \n            \n            \n        \n    \n\n\n\n\n\n\n\n\n\n\n\n\n\n \n\n\n\n\n\n \n\n\n    var annotationUploadDdl = [];\n    Dropzone.autoDiscover = false;\n    var target = \"\"\n    var previoustarget = \"\"\n\n    $(document).ready(function () {\n        sessionStorage.setItem('highlightVisitNo', '0');\n\n\n\n        \n\n        //Added by Xirlyn 20240130 - To display vital sign button\n        loadAnnotationUploadDdlCN()\n        isFromPatientSearch = 'N'\n        if (\"T\" == \"true\"){\n            isFromPatientSearch = 'Y'\n        }\n\n        if(\"N\" == \"Y\"){\n            swal({\n                title: \"\",\n                text: \"CaseNote Session Time Out\",\n                type: \"warning\",\n                showCancelButton: false,\n                confirmButtonColor: \"#DD6B55\",\n                confirmButtonText: \"Back to Queue Log\",\n                closeOnConfirm: true,\n            },\n            function (isConfirm) {\n                if (isConfirm) {\n                    window.parent.location.href = '/QueueLog/Index';\n                } else {\n                    return;\n                }\n            });\n        }\n\n         if ('T' === \"T\" || \"T\" == \"T\") {\n            isFromPatientSearch = 'Y'\n\n            if(\"78160\" == \"\"){\n\n                $('#hdmode').val(\"P\");\n                $(\"#lblCurrVisitInfo\").html(\"\");\n            }\n            else {\n\n                $('#hdmode').val(\"P\");\n                $(\"#lblCurrVisitInfo\").html(\"Patient: \" + \"78160\" + \" / \" + \"ENG CHAI PIN ELYNE XANDRIA\" + \" (\" + \"S8570522I\" + \")\" + \"&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;\" + \"F\" + \" : \" + \"40 y\");\n\n            }\n\n            $(\"title\").text(\"Patient Biodata\")\n        }\n        else {\n\n            isFromPatientSearch = 'N'\n            $('#hdmode').val(\"Q\");\n            $(\"#lblCurrVisitInfo\").html(\"Current Visit: \" + \"78160\" + \" / \" + \"ENG CHAI PIN ELYNE XANDRIA\" + \" (\" + \"S8570522I\" + \")\" + \"&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;\" + \"F\" + \" : \" + \"40 y\");\n        }\n\n        if ($('#hdmode').val() == 'Q')\n        {\n            $('#Pat-tab-li-History').hide();\n            $('#Pat-tab-li-PastMeds').hide();\n            $('#Pat-tab-li-LabResult').hide();\n        }else{\n            $('#Pat-tab-li-History').show();\n            $('#Pat-tab-li-PastMeds').show();\n            $('#Pat-tab-li-LabResult').show();\n        }\n\n        $(\"#lblCurrVisitInfo\").css('display', '');\n        //if ($(\"#mainTabPatientInfo_frame\").is(\":visible\")) {\n        //    $(\"#patientDivFooter\").show();\n        //}\n\n        if (\"Biodata\" == \"Biodata\") {\n            target = \"PatientInfo\";\n        }\n        else if (\"Biodata\" == \"Payment\") {\n            target = \"DispensePayment\";\n        }\n        else if (\"Biodata\" == \"Appt\") {\n            target = \"Appointment\";\n        }\n        else{\n            target = \"VisitNotes\";\n        }\n        previoustarget = target;\n\n        if (\"Biodata\" == \"Payment\") {\n                       //Edited by Lim Han Yong 20240116 - direct load dispense payment page\n            //loadDispensePayment();\n            //Edited by Lim Han Yong 20240529 - add Check Queue Payment AccessValidity copy from previous version\n            var visitNo = '0';\n            var newPCNO ='78160';\n            var newQDate = '';\n            var newCHAS = 'N';\n            var newNRIC = 'inc4ycpbori0zxvrej3ihi1o';\n            let newData = {\n                queryString: visitNo + '&' + newPCNO + '&' + newCHAS + '&Dispense_Queue' + '&' + newQDate+'&'+newNRIC\n            };\n            let newEncoded = JSON.stringify(newData);\n            $.ajax({\n                cache: false,\n                type: \"POST\",\n                url: \"/Home/EncryptionURL\",\n                data: newEncoded,\n                async: false,\n                contentType: \"application/json; charset=utf-8\",\n                success: function(result) {\n                    if (result.success) {\n                        //restructure locked mechanism\n                        let queryString = result.url;\n                        $.ajax({\n                            cache: false,\n                            type: \"GET\",\n                            url: \"/QueueLog/CheckQueuePaymentAccessValidity\",\n                            data: {\n                                VisitNo: visitNo\n                            },\n                            async: false,\n                            contentType: \"application/json; charset=utf-8\",\n                            success: function (result) {\n                                if (result.success) {\n                                    $(\"#mainTabDispensePayment_frame\").load('https://clinicassist.sg:1080/en/QueueDispense/Index?queryString=' + encodeURIComponent(queryString));\n                                    $('.fadeMe').hide();\n                                }\n                                else {\n                                    swal(\"\", result.message, \"error\");\n                                    $('#liVisit a').click();\n                                }\n                            },\n                            error: function (result) {\n                                swal(\"error at 1st load\", result.message, \"error\");\n                            }\n                        });\n                    } else {\n                        $('.fadeMe').hide();\n                        swal(\"\", result.message, \"error\");\n                    }\n                },\n                error: function(data) {}\n            });\n\n            //End Edited by Lim Han Yong 20240529\n            //End Edited by Lim Han Yong 20240116\n        }\n\n        if (\"Biodata\" == \"Biodata\") {\n\n            $(\"#patientDivFooter\").show();\n        }\n        //Added by Lim Han Yong 20240117 - when refresh, direct to biodata\n        if ((performance.navigation.type == performance.navigation.TYPE_RELOAD)) {\n            //Added by Lim Han Yong 20240228 - insert back queue lock\n            let innerData = {\n                VisitNo: 0,\n                Table: \"Queue\"\n            };\n            let innerEncoded = JSON.stringify(innerData);\n            $.ajax({\n                cache: false,\n                type: \"POST\",\n                url: \"/Authenticate/InsertLocked\",\n                data: innerEncoded,\n                async: true,\n                contentType: \"application/json; charset=utf-8\",\n                success: function(result) {\n\n                },\n                error: function(data) {}\n            });\n            //End Added by Lim Han Yong 20240228\n            if (\"Biodata\" != \"Biodata\") {\n                $('#liBiodata a').click();\n            }\n        }\n        //Added by Lim Han Yong 20240117\n    });\n\n    var isFirstTime1 = $(\"#mainTabPatientInfo_frame\").html().trim().length == 0 ? true : false;\n    var isFirstTime2 = $(\"#mainTabVisitNotes_frame\").html().trim().length == 0 ? true : false;\n    var isFirstTime3 = $(\"#mainTabDispensePayment_frame\").html().trim().length == 0 ? true : false;\n\n    $(\".mainTab\").find(\"a\").on(\"click\", function () {\n        //DeleteLockedCaseNoteAndDispense();   //Edited by Lim Han Yong 20240116 - delete lock for casenote and dispense 1st\n        previoustarget = target; //Added by kenneth 2024-1128 - To store previous tab\n        target = $(this).attr(\"tabTarget\");\n        //Added by kenneth 2024-1128 - To trigger save casenote if previous tab is visitnote\n        if(previoustarget == \"VisitNotes\" && \"Y\" == \"Y\")\n        {\n            SaveVisitNoteContent(\"N\",\"\");\n        }\n        $(\".mainTabContent\").hide();\n        $(\"#patientDivFooter\").hide();\n\n        let deleteinnerData = {lockID: \"inc4ycpbori0zxvrej3ihi1o\", Table: 'CaseNote'};\n        let deleteinnerEncoded = JSON.stringify(deleteinnerData);\n\n        $.ajax({\n            cache: false,\n            url: \"/Authenticate/DeleteLockedSessionID\",\n            type: 'POST',\n            data: deleteinnerEncoded,\n            contentType: \"application/json; charset=utf-8\",\n            dataType: \"json\",\n            success: function(result) {},\n            complete: function(data) {\n                let deleteinnerData2 = {lockID: \"inc4ycpbori0zxvrej3ihi1o\", Table: 'Dispense'};\n                let deleteinnerEncoded2 = JSON.stringify(deleteinnerData2);\n\n                $.ajax({\n                    cache: false,\n                    url: \"/Authenticate/DeleteLockedSessionID\",\n                    type: 'POST',\n                    data: deleteinnerEncoded2,\n                    contentType: \"application/json; charset=utf-8\",\n                    dataType: \"json\",\n                    success: function(result) {},\n                    complete: function(data) {\n                        if (target == \"PatientInfo\") {\n                            if (isFirstTime1) {\n                                loadPatientTabContent();    //Added by Lim Han Yong 20240116 - load tab content\n\n                                isFirstTime1 = false;\n                            }\n                            $(\"#mainTabPatientInfo_frame\").show();\n                            $(\"#patientDivFooter\").show();\n                            $(\"#divShowPastNote\").hide();\n                            $(\"#lblConsTime\").hide();\n\n                            if ($('#Pat-tab-li-Referral').hasClass('active')) {\n                                patientTabToggle('tabReferral');\n                            }\n\n                            if ($('#Pat-tab-li-PatEDoc').hasClass('active')) {\n                                geteDocPat();\n                            }\n                        }\n                        else if (target == \"VisitNotes\") {\n                            if (isFirstTime2) {\n\n                                $(\"#mainTabVisitNotes_frame\").html('');\n                                loadVisitNoteTabContent();  //Added by Lim Han Yong 20240116 - load tab content\n\n                                isFirstTime2 = false;\n                            }\n                            //Added by Lim Han Yong 20240228 - insert lock when change tab\n                            else{\n                                let insertinnerData = {visitno: '0', Table: 'CaseNote', myID: 'inc4ycpbori0zxvrej3ihi1o'};\n                                let insertinnerEncoded = JSON.stringify(insertinnerData);\n                                $.ajax({\n                                    cache: false,\n                                    type: \"POST\",\n                                    url: \"/Authenticate/InsertLocked\",\n                                    data: insertinnerEncoded,\n                                    async: false,\n                                    contentType: \"application/json; charset=utf-8\",\n                                    success: function (result) {\n                                        $(\".fadeMe\").show();\n                                        if (result.success) {\n                                            setTimeout(function () {\n                                                refreshMplanData();\n                                            }, 500)\n                                        } else {\n                                            $('.fadeMe').hide();\n                                            swal(\"\", result.message, \"error\");\n                                        }\n                                    },\n                                    error: function (data) {\n                                    }\n                                });\n\n                                if ($('#tab-li-Referral').hasClass('active')) {\n                                    getReferral();\n                                }\n\n                                if ($('#tab-li-edoc').hasClass('active')) {\n                                    geteDoc();\n                                }\n                            }\n                            //End Added by Lim Han Yong 20240228\n\n                            $(\"#mainTabVisitNotes_frame\").show();\n                            if(\"Y\" == \"Y\")\n                            {\n                                $(\"#divShowPastNote\").css(\"display\", \"flex\");\n                                $(\"#lblConsTime\").css(\"display\", \"flex\");\n                            }\n                        }\n                        else if (target == \"DispensePayment\") {\n                            //Edited by Lim Han Yong 20240529 - add Check Queue Payment AccessValidity\n                            var visitNo = '0';\n                            var CheckQueuePaymentAccessValidity = false;\n                            $.ajax({\n                                cache: false,\n                                type: \"GET\",\n                                url: \"/QueueLog/CheckQueuePaymentAccessValidity\",\n                                data: {\n                                    VisitNo: visitNo\n                                },\n                                async: false,\n                                contentType: \"application/json; charset=utf-8\",\n                                success: function (result) {\n                                    if (result.success) {\n                                        CheckQueuePaymentAccessValidity = true;\n                                    }\n                                    else {\n                                        swal(\"\", result.message, \"error\");\n                                        $('#liVisit a').click();\n                                    }\n                                },\n                                error: function (result) {\n                                    swal(\"error at loadDispensePayment\", result.message, \"error\");\n                                }\n                            });\n                            if (isFirstTime3 && CheckQueuePaymentAccessValidity) {\n                                loadDispensePayment();  //Added by Lim Han Yong 20240116 - load tab content\n\n                                isFirstTime3 = false;\n                            }\n                            else {\n                                //Added by Lim Han Yong 20240228 - insert lock when change tab\n                                //$(\"#queueDispenseGrid\").trigger(\"reloadGrid\");\n                                let insertinnerData = {visitno: '0', Table: 'Dispense', myID: 'inc4ycpbori0zxvrej3ihi1o'};\n                                let insertinnerEncoded = JSON.stringify(insertinnerData);\n                                $.ajax({\n                                    cache: false,\n                                    type: \"POST\",\n                                    url: \"/Authenticate/InsertLocked\",\n                                    data: insertinnerEncoded,\n                                    async: false,\n                                    contentType: \"application/json; charset=utf-8\",\n                                    success: function (result) {\n                                        $(\".fadeMe\").show();\n                                        if (result.success) {\n                                            $(\"#queueDispenseGrid\").trigger(\"reloadGrid\");\n                                            setTimeout(function () {\n                                                refreshMplanData();\n                                            }, 500)\n\n                                            if ('N' == \"Y\") {\n                                                GetNextApptRemark();\n                                            }\n                                        } else {\n                                            $('.fadeMe').hide();\n                                            swal(\"\", result.message, \"error\");\n                                        }\n                                    },\n                                    error: function (data) {\n                                    }\n                                });\n                                //End Added by Lim Han Yong 20240228\n                            }\n\n                            $(\"#mainTabDispensePayment_frame\").show();\n                            $(\"#divShowPastNote\").hide();\n                            $(\"#lblConsTime\").hide();\n                        }\n                        else if (target == \"Appt\") {\n                            $(\"#mainTabAppt_frame\").html('');\n                            loadApptTabContent();\n                            $(\"#mainTabAppt_frame\").show();\n                            $(\"#divShowPastNote\").hide();\n                            $(\"#lblConsTime\").hide();\n                        }\n                    }\n                });\n            }\n        });\n\n\n\n    });\n\n    $(\".subnavtab\").find(\"a\").on(\"click\", function () {\n\n        $(\".subnavtab\").find(\"a\").each(function () {\n            $(this).removeClass(\"tabActive\");\n        });\n\n        $(this).addClass(\"tabActive\");\n        var target = $(this).attr(\"tabTarget\");\n        $(\".patientTabContent\").hide();\n        $(\"#bioTabBtn\").show();\n        $(\"#financialTabBtn\").hide();\n\n        if (target == \"Biodata\") {\n            $(\"#tabBiodata_frame\").show();\n        }\n        else if (target == \"MedAlert\") {\n            $(\"#tabMedical_frame\").show();\n            $(\"#patientAllergyGrid\").jqGrid(\"setGridWidth\", $(\"#divAllergy\").width() - 10);\n            $(\"#patientAllergyOtherGrid\").jqGrid(\"setGridWidth\", $(\"#divOtherAllergy\").width() - 10);\n        }\n        else if (target == \"PopUp\") {\n            $(\"#tabPopup_frame\").show();\n        }\n        else if (target == \"Family\") {\n            $(\"#tabFamily_frame\").show();\n            if ($(\"#patientFamilyGridDiv\")[0].scrollHeight > $(\"#patientFamilyGridDiv\")[0].clientHeight) {\n                $('#patientFamilyGrid').jqGrid('setGridWidth', $(\"#patientFamilyGridDiv\").width() - 10);\n            }\n            else {\n                $('#patientFamilyGrid').jqGrid('setGridWidth', $(\"#patientFamilyGridDiv\").width());\n            }\n        }\n        else if (target == \"History\") {\n            $(\"#tabHistory_frame\").show();\n        }\n        else if (target == \"Financial\") {\n            if ($(\"#tabFinancial_frame\").is(':empty')) {\n                $(\".fadeMe\").show();\n                $(\"#tabFinancial_frame\").load('https://clinicassist.sg:1080/en/PatientMaster/Financial?PCNO=' + '78160');\n            }\n            $(\"#tabFinancial_frame\").show();\n            $(\"#bioTabBtn\").hide();         //Added by Xirlyn 20240117 - To hide default button\n            $(\"#financialTabBtn\").hide();   //Added by Xirlyn 20240117 - To display financial button\n        }\n        else if (target == \"TxHistory\") {\n            if ($(\"#tabTxHistory_frame\").is(':empty')) {\n                $(\".fadeMe\").show();\n                $(\"#tabTxHistory_frame\").load('https://clinicassist.sg:1080/en/PatientMaster/TabtxHistory?qpcno=' + '78160' + '&PName=' + encodeURIComponent('ENG CHAI PIN ELYNE XANDRIA'));\n            }\n            $(\"#tabTxHistory_frame\").show();\n        }\n        else if (target == \"PastNotes\") {\n            if ($('#tabPastNote_frame').is(':empty')) {\n                $(\".fadeMe\").show();\n                $(\"#tabPastNote_frame\").load('https://clinicassist.sg:1080/en/Patient/PastPatientDetails?pcno=' + '78160' + '&from=PatientMaster');\n            }\n            $(\"#tabPastNote_frame\").show();\n        }\n        else if (target == \"LabVitalSign\") {\n\n            if ($('#tabLabVitalSign_frame').is(':empty')) {\n                $(\".fadeMe\").show();\n                $(\"#tabLabVitalSign_frame\").load('https://clinicassist.sg:1080/en/PatientMaster/TabLabResult?pcno=' + '78160');\n            }\n\n        }\n        else if (target == \"Appt\") {\n            if ($('#tabAppt_frame').is(':empty')) {\n                $(\".fadeMe\").show();\n                $(\"#tabAppt_frame\").load('https://clinicassist.sg:1080/en/Appointment/ViewApptDet?PCNO=' + '78160' + '&PName=' + encodeURIComponent('ENG CHAI PIN ELYNE XANDRIA') + '&clinic=' + 'SSOC');\n            }\n            $(\"#tabAppt_frame\").show();\n        }\n        else if (target == \"Referral\") {\n            if ($(\"#tabReferral_frame\").is(':empty')) {\n                $(\".fadeMe\").show();\n                $(\"#tabReferral_frame\").load('https://clinicassist.sg:1080/en/PatientMaster/QueueReferral?PCNO=' + '78160' + '&PName=' + encodeURIComponent('ENG CHAI PIN ELYNE XANDRIA'));\n            }\n            $(\"#tabReferral_frame\").show();\n        }\n        else if (target == \"Comm\") {\n            if ($(\"#tabComm_frame\").is(':empty')) {\n                $(\".fadeMe\").show();\n                $(\"#tabComm_frame\").load('https://clinicassist.sg:1080/en/PatientComm/Index2?pcno=' + '78160');\n            }\n            $(\"#tabComm_frame\").show();\n        }\n        else if (target == \"Birth\") {\n            if ($(\"#tabBirth_frame\").is(':empty')) {\n                $(\".fadeMe\").show();\n                $(\"#tabBirth_frame\").load('https://clinicassist.sg:1080/en/PatientMaster/TabPatientBirth?pcno=' + '78160');\n            }\n            $(\"#tabBirth_frame\").show();\n        }\n        else if (target == \"Access\") {\n            if ($(\"#tabAccess_frame\").is(':empty')) {\n                $(\".fadeMe\").show();\n                $(\"#tabAccess_frame\").load('https://clinicassist.sg:1080/en/Patient/PatientCaseNoteAccess');\n            }\n            $(\"#tabAccess_frame\").show();\n        } else if (target == \"accessDenied\") {\n            $(\"#tabAccessDenied_frame\").show();\n        }\n    });\n\n    //Added by Lim Han Yong 20240116 - delete lock for casenote and dispense 1st\n    function DeleteLockedCaseNoteAndDispense(){\n        //var data = { lockID : \"inc4ycpbori0zxvrej3ihi1o\" };\n\n        //$.ajax({\n        //    cache: false,\n        //    data: JSON.stringify(data),\n        //    url: \"/Authenticate/DeleteLockedSessionID\",\n        //    type: 'post',\n        //    contentType: \"application/json; charset=utf-8\",\n        //    dataType: \"json\",\n        //    success: function (result) {\n        //    }\n        //});\n        let deleteinnerData = {key: '0', Table: 'CaseNote', Owner: \"Vincent\"};\n        let deleteinnerEncoded = JSON.stringify(deleteinnerData);\n        $.ajax({\n            cache: false,\n            url: \"/Authenticate/ClearAllLocked\",\n            type: 'POST',\n            data: deleteinnerEncoded,\n            contentType: \"application/json; charset=utf-8\",\n            dataType: \"json\",\n            success: function(result) {},\n            complete: function(data) {\n            }\n        });\n        let deleteinnerData2 = {key: '0', Table: 'Dispense', Owner: \"Vincent\"};\n        let deleteinnerEncoded2 = JSON.stringify(deleteinnerData2);\n        $.ajax({\n            cache: false,\n            url: \"/Authenticate/ClearAllLocked\",\n            type: 'POST',\n            data: deleteinnerEncoded2,\n            contentType: \"application/json; charset=utf-8\",\n            dataType: \"json\",\n            success: function(result) {},\n            complete: function(data) {\n            }\n        });\n\n    }\n    //End Added by Lim Han Yong 20240116\n\n    function loadPatientTabContent() {\n        if ($(\"#mainTabPatientInfo_frame\").html().trim().length == 0) {\n\n            let pname = (\"ENG CHAI PIN ELYNE XANDRIA\").replace(/\\\\u0027/g, \"'\");\n            $(\"#mainTabPatientInfo_frame\").load('https://clinicassist.sg:1080/en/PatientMaster/Index2?pcno=' + '78160'+'&pname=' + encodeURIComponent('ENG CHAI PIN ELYNE XANDRIA'));\n        }\n    }\n\n    //Edited by Lim Han Yong 20240116 - restructure locked mechanism\n    function loadVisitNoteTabContent() {\n        //console.log('visitnote tab clicked');\n\n        if(\"Y\" == \"N\"){\n            $(\".fadeMe\").show();\n            $(\"#mainTabVisitNotes_frame\").load('https://clinicassist.sg:1080/en/CaseNote/AccessDenied');\n            $(\"#divShowPastNote\").hide();\n            $(\"#btnStartConsTime\").hide();\n            $(\"#lblConsTime\").hide();\n        }else{\n            let data = {\n                queryString: '0' + '&' + '78160' + '&' + 'N' + '&Dispense_Queue' + '&' + '' + '&' + 'inc4ycpbori0zxvrej3ihi1o'\n            };\n\n            let encoded = JSON.stringify(data);\n            $.ajax({\n                cache: false,\n                type: \"POST\",\n                url: \"/Home/EncryptionURL\",\n                data: encoded,\n                //async: false,\n                contentType: \"application/json; charset=utf-8\",\n                success: function (result) {\n                    if (result.success) {\n                        var innerData = { VisitNo: '0' ,Table:\"CaseNote\"};\n                        var innerEncoded = JSON.stringify(innerData);\n\n                        let insertinnerData = {visitno: '0', Table: 'CaseNote', myID: 'inc4ycpbori0zxvrej3ihi1o'};\n                        let insertinnerEncoded = JSON.stringify(insertinnerData);\n                        $.ajax({\n                            cache: false,\n                            type: \"POST\",\n                            url: \"/Authenticate/CheckIsLocked\",\n                            data: innerEncoded,\n                            async: false,\n                            contentType: \"application/json; charset=utf-8\",\n                            success: function (result) {\n                                if(result.success){\n                                    if ($(\"#mainTabVisitNotes_frame\").html().trim().length == 0) {\n                                        //console.log('load visitnote frame');\n                                        $.ajax({\n                                            cache: false,\n                                            type: \"POST\",\n                                            url: \"/Authenticate/InsertLocked\",\n                                            data: insertinnerEncoded,\n                                            async: false,\n                                            contentType: \"application/json; charset=utf-8\",\n                                            success: function (result) {\n                                                //console.log('lock insert for casenote');\n                                                $(\".fadeMe\").show();\n                                                if (result.success) {\n                                                    $(\"#mainTabVisitNotes_frame\").load('https://clinicassist.sg:1080/en/CaseNote/InitCaseNote?queryString=' + encodeURIComponent('3Rv6/0utPL8a RcrqeZFhSBx3zDdaP0iMT1Uh3xNYi4bDNIqKn/9ixmbwTOb1x1q9Uu3Sr54D8ZOlozM7nbvz7AP9pTZKR6 Xka0nsHAQdVNXnyryqT4Hg=='));\n                                                } else {\n                                                    $('.fadeMe').hide();\n                                                    swal(\"\", result.message, \"error\");\n                                                }\n                                            },\n                                            error: function (data) {\n                                                //console.log('so many error');\n                                            }\n                                        });\n                                        //$(\".fadeMe\").show();\n                                        //$(\"#mainTabVisitNotes_frame\").load('https://clinicassist.sg:1080/en/CaseNote/InitCaseNote?queryString=' + encodeURIComponent('3Rv6/0utPL8a RcrqeZFhSBx3zDdaP0iMT1Uh3xNYi4bDNIqKn/9ixmbwTOb1x1q9Uu3Sr54D8ZOlozM7nbvz7AP9pTZKR6 Xka0nsHAQdVNXnyryqT4Hg=='));\n                                    }\n                                    else{\n                                        //console.log('visitnote tab delete lock and insert lock');\n                                        let deletedata = {key: '0', Table: 'CaseNote', Owner: \"Vincent\"};\n                                        let deleteEncoded =  JSON.stringify(deletedata);\n\n                                        $.ajax({\n                                            cache: false,\n                                            type: \"POST\",\n                                            url: \"/Authenticate/ClearAllLocked\",\n                                            data: deleteEncoded,\n                                            //async: false,\n                                            contentType: \"application/json; charset=utf-8\",\n                                            dataType: \"json\",\n                                            success: function (result) {\n                                                $.ajax({\n                                                    cache: false,\n                                                    type: \"POST\",\n                                                    url: \"/Authenticate/InsertLocked\",\n                                                    data: insertinnerEncoded,\n                                                    async: false,\n                                                    contentType: \"application/json; charset=utf-8\",\n                                                    success: function (result) {\n                                                        //console.log('lock insert for casenote')\n                                                        $(\".fadeMe\").show();\n                                                        if (result.success) {\n                                                            $(\"#mainTabVisitNotes_frame\").load('https://clinicassist.sg:1080/en/CaseNote/InitCaseNote?queryString=' + encodeURIComponent('3Rv6/0utPL8a RcrqeZFhSBx3zDdaP0iMT1Uh3xNYi4bDNIqKn/9ixmbwTOb1x1q9Uu3Sr54D8ZOlozM7nbvz7AP9pTZKR6 Xka0nsHAQdVNXnyryqT4Hg=='));\n                                                        } else {\n                                                            $('.fadeMe').hide();\n                                                            swal(\"\", result.message, \"error\");\n                                                        }\n                                                    },\n                                                    error: function (data) {\n                                                    }\n                                                });\n                                            },\n                                            error: function (data) {\n                                            }\n                                        });\n                                    }\n                                }else{\n                                    if(result.message.includes(\"Another \")){\n                                        swal({\n                                            title: \"\",\n                                            text: result.message + \" is accessing Visit Notes page. Do you want to take over access?\",\n                                            type: \"warning\",\n                                            showCancelButton: true,\n                                            confirmButtonColor: \"#DD6B55\",\n                                            confirmButtonText: \"Proceed\",\n                                            closeOnConfirm: true,\n                                        },\n                                        function (isConfirm) {\n                                            if (isConfirm) {\n                                                let deleteinnerData = {key: '0', Table: 'CaseNote', Owner: \"Vincent\"};\n                                                let deleteinnerEncoded = JSON.stringify(deleteinnerData);\n                                                $.ajax({\n                                                    cache: false,\n                                                    url: \"/Authenticate/ClearAllLocked\",\n                                                    type: 'POST',\n                                                    data: deleteinnerEncoded,\n                                                    contentType: \"application/json; charset=utf-8\",\n                                                    dataType: \"json\",\n                                                    success: function(result) {},\n                                                    complete: function(data) {\n                                                        $.ajax({\n                                                            cache: false,\n                                                            type: \"POST\",\n                                                            url: \"/Authenticate/InsertLocked\",\n                                                            data: insertinnerEncoded,\n                                                            async: false,\n                                                            contentType: \"application/json; charset=utf-8\",\n                                                            success: function(result) {\n                                                            },\n                                                            error: function(data) {}\n                                                        });\n                                                        $(\"#mainTabVisitNotes_frame\").load('https://clinicassist.sg:1080/en/CaseNote/InitCaseNote?queryString=' + encodeURIComponent('3Rv6/0utPL8a RcrqeZFhSBx3zDdaP0iMT1Uh3xNYi4bDNIqKn/9ixmbwTOb1x1q9Uu3Sr54D8ZOlozM7nbvz7AP9pTZKR6 Xka0nsHAQdVNXnyryqT4Hg=='));\n                                                    }\n                                                });\n                                            } else {\n                                                //Edited by Lim Han Yong 20240129 - direct to queue log\n                                                //$('#liBiodata a').click();\n                                                window.parent.location.href = '/QueueLog/Index';\n                                                //End Edited by Lim Han Yong 20240129\n                                            }\n                                        });\n                                    }\n                                    else{\n                                        swal({\n                                            title: \"\",\n                                            text: result.message + \" is accessing Visit Notes page, please try again later.\",\n                                            type: \"warning\",\n                                            showCancelButton: false,\n                                            confirmButtonColor: \"#DD6B55\",\n                                            confirmButtonText: \"OK\",\n                                            closeOnConfirm: true,\n                                        },\n                                        function (isConfirm) {\n                                            if (isConfirm) {\n                                                //Edited by Lim Han Yong 20240129 - direct to queue log\n                                                //$('#liBiodata a').click();\n                                                window.parent.location.href = '/QueueLog/Index';\n                                                //End Edited by Lim Han Yong 20240129\n                                            } else {\n                                                return;\n                                            }\n                                        });\n                                    }\n                                }\n                            },\n                            error: function (data) { }\n                        });\n                    } else {\n                        $('.fadeMe').hide();\n                        swal(\"\", result.message, \"error\");\n                    }\n                },\n                error: function (data) { }\n            });\n        }\n    }\n    //End Edited by Lim Han Yong 20240116\n\n    //Edited by Lim Han Yong 20240116 - restructure locked mechanism\n    function loadDispensePayment() {\n        var innerData = { VisitNo: '0' ,Table:\"Dispense\"};\n        var innerEncoded = JSON.stringify(innerData);\n\n        $.ajax({\n            cache: false,\n            type: \"POST\",\n            url: \"/Authenticate/CheckIsLocked\",\n            data: innerEncoded,\n            async: false,\n            contentType: \"application/json; charset=utf-8\",\n            success: function (result) {\n                if(result.success){\n                    //$(\"#navBar > li:not(:last-child)\").removeClass(\"active\");\n                    //$(\"#navBar > li:last-child\").addClass(\"active\");\n\n                    if ($(\"#mainTabDispensePayment_frame\").html().trim().length == 0) {\n                        $(\".fadeMe\").show();\n\n                        let data = {\n                            queryString: '0' + '&' + '78160' + '&' + 'N' + '&Dispense_Queue' + '&' + '' + '&' + 'inc4ycpbori0zxvrej3ihi1o'\n                        };\n\n                        let encoded = JSON.stringify(data);\n                        $.ajax({\n                            cache: false,\n                            type: \"POST\",\n                            url: \"/Home/EncryptionURL\",\n                            data: encoded,\n                            async: false,\n                            contentType: \"application/json; charset=utf-8\",\n                            success: function (result) {\n                                if (result.success) {\n                                    $(\"#mainTabDispensePayment_frame\").load('https://clinicassist.sg:1080/en/QueueDispense/Index?queryString=' + result.url);\n                                } else {\n                                    $('.fadeMe').hide();\n                                    swal(\"\", result.message, \"error\");\n                                }\n                            },\n                            error: function (data) { }\n                        });\n                    }\n                    else{\n                        let data = {\n                            key: '0',\n                            Table: 'Dispense',\n                            Owner: \"Vincent\"\n                        };\n                        let myData =  JSON.stringify(data);\n\n                        $.ajax({\n                            cache: false,\n                            type: \"POST\",\n                            url: \"/Authenticate/ClearAllLocked\",\n                            data: myData,\n                            //async: false,\n                            contentType: \"application/json; charset=utf-8\",\n                            dataType: \"json\",\n                            success: function (result) {\n\n                                let lock = {\n                                    visitno: '0',\n                                    Table: 'Dispense',\n                                    myID: 'inc4ycpbori0zxvrej3ihi1o'\n                                };\n                                let mylock =  JSON.stringify(lock);\n\n                                $.ajax({\n                                    cache: false,\n                                    type: \"POST\",\n                                    url: \"/Authenticate/InsertLocked\",\n                                    data: mylock,\n                                    async: false,\n                                    contentType: \"application/json; charset=utf-8\",\n                                    success: function (result) {\n                                        $(\".fadeMe\").show();\n\n                                        let data = {\n                                            queryString: '0' + '&' + '78160' + '&' + 'N' + '&Dispense_Queue' + '&' + '' + '&' + 'inc4ycpbori0zxvrej3ihi1o'\n                                        };\n\n                                        let encoded = JSON.stringify(data);\n                                        $.ajax({\n                                            cache: false,\n                                            type: \"POST\",\n                                            url: \"/Home/EncryptionURL\",\n                                            data: encoded,\n                                            async: false,\n                                            contentType: \"application/json; charset=utf-8\",\n                                            success: function (result) {\n                                                if (result.success) {\n                                                    $(\"#mainTabDispensePayment_frame\").load('https://clinicassist.sg:1080/en/QueueDispense/Index?queryString=' + result.url);\n                                                } else {\n                                                    $('.fadeMe').hide();\n                                                    swal(\"\", result.message, \"error\");\n                                                }\n                                            },\n                                            error: function (data) { }\n                                        });\n                                    },\n                                    error: function (data) {\n\n                                    }\n                                });\n                            },\n                            error: function (data) {\n\n                            }\n                        });\n                    }\n                }else{\n                    if(result.message.includes(\"Another \")){\n                        swal({\n                            title: \"\",\n                            text: result.message + \" is accessing Dispense & Payment page. Do you want to take over access?\",\n                            type: \"warning\",\n                            showCancelButton: true,\n                            confirmButtonColor: \"#DD6B55\",\n                            confirmButtonText: \"Proceed\",\n                            closeOnConfirm: true,\n                        },\n                        function (isConfirm) {\n                            if (isConfirm) {\n                                let deleteinnerData = {key: '0', Table: 'Dispense', Owner: \"Vincent\"};\n                                let deleteinnerEncoded = JSON.stringify(deleteinnerData);\n                                $.ajax({\n                                    cache: false,\n                                    url: \"/Authenticate/ClearAllLocked\",\n                                    type: 'POST',\n                                    data: deleteinnerEncoded,\n                                    contentType: \"application/json; charset=utf-8\",\n                                    dataType: \"json\",\n                                    success: function(result) {},\n                                    complete: function(data) {\n                                        let lock = {\n                                            visitno: '0',\n                                            Table: 'Dispense',\n                                            myID: 'inc4ycpbori0zxvrej3ihi1o'\n                                        };\n                                        let mylock =  JSON.stringify(lock);\n                                        $.ajax({\n                                            cache: false,\n                                            type: \"POST\",\n                                            url: \"/Authenticate/InsertLocked\",\n                                            data: mylock,\n                                            async: false,\n                                            contentType: \"application/json; charset=utf-8\",\n                                            success: function(result) {\n                                                let data = {\n                                                    queryString: '0' + '&' + '78160' + '&' + 'N' + '&Dispense_Queue' + '&' + '' + '&' + 'inc4ycpbori0zxvrej3ihi1o'\n                                                };\n\n                                                let encoded = JSON.stringify(data);\n                                                $.ajax({\n                                                    cache: false,\n                                                    type: \"POST\",\n                                                    url: \"/Home/EncryptionURL\",\n                                                    data: encoded,\n                                                    async: false,\n                                                    contentType: \"application/json; charset=utf-8\",\n                                                    success: function (result) {\n                                                        if (result.success) {\n                                                            $(\"#mainTabDispensePayment_frame\").load('https://clinicassist.sg:1080/en/QueueDispense/Index?queryString=' + result.url);\n                                                        } else {\n                                                            $('.fadeMe').hide();\n                                                            swal(\"\", result.message, \"error\");\n                                                        }\n                                                    },\n                                                    error: function (data) { }\n                                                });\n                                            },\n                                            error: function(data) {}\n                                        });\n                                    }\n                                 });\n                            } else {\n                                //Edited by Lim Han Yong 20240129 - direct to queue log\n                                //$('#liBiodata a').click();\n                                window.parent.location.href = '/QueueLog/Index';\n                                //End Edited by Lim Han Yong 20240129\n                            }\n                        });\n                    }\n                    else{\n                        swal({\n                            title: \"\",\n                            text: result.message + \" is accessing Dispense & Payment page, please try again later.\",\n                            type: \"warning\",\n                            showCancelButton: false,\n                            confirmButtonColor: \"#DD6B55\",\n                            confirmButtonText: \"OK\",\n                            closeOnConfirm: true,\n                        },\n                        function (isConfirm) {\n                            if (isConfirm) {\n                                //Edited by Lim Han Yong 20240129 - direct to queue log\n                                //$('#liBiodata a').click();\n                                window.parent.location.href = '/QueueLog/Index';\n                                //End Edited by Lim Han Yong 20240129\n                            } else {\n                                return;\n                            }\n                        });\n                    }\n                }\n            },\n            error: function (data) { }\n        });\n    }\n    //End Edited by Lim Han Yong 20240116\n\n    //Added by Lim Han Yong 20240117 - redirect to queuelog when loss lock VisitNotes and Dispense\n    function redirectqueuelog(table) {\n        var innerData = { VisitNo: '0' ,Table:table};\n        var innerEncoded = JSON.stringify(innerData);\n\n        $.ajax({\n            cache: false,\n            type: \"POST\",\n            url: \"/Authenticate/CheckIsLocked\",\n            data: innerEncoded,\n            async: false,\n            contentType: \"application/json; charset=utf-8\",\n            success: function (result) {\n                if(!result.success){\n                    console.log(result.message);\n                    //Added by Lim Han Yong 20240215 - log out when loss connection\n                    if(result.message == 'The ConnectionString property has not been initialized.' || result.message == 'undefined' || result.message == ''){\n                        window.location.href = result.redirectUrl;\n                   //End Added by Lim Han Yong 20240215\n                    }else{\n                        swal({\n                            title: \"\",\n                            text: \"Multiple simultaneous access to same \" + table + \".\",\n                            type: \"warning\",\n                            showCancelButton: true,\n                            confirmButtonColor: \"#DD6B55\",\n                            confirmButtonText: \"OK\",\n                            closeOnConfirm: true,\n                        },\n                        function (isConfirm) {\n                            if (isConfirm) {\n                                window.parent.location.href = '/QueueLog/Index';\n                            }\n                        });\n                    }\n                }else{\n                    return;\n                }\n            },\n            error: function (data) { }\n        });\n    }\n    //mainTabVisitNotes_frame.addEventListener(\"click\",function(){    //Edited by Lim Han Yong 20240228 - change from mousemove to click\n    //    var table = 'CaseNote';\n    //    redirectqueuelog(table);\n    //});\n\n    //mainTabVisitNotes_frame.addEventListener(\"keydown\",function(){\n    //    var table = 'CaseNote';\n    //    redirectqueuelog(table);\n    //});\n\n    //mainTabDispensePayment_frame.addEventListener(\"click\",function(){   //Edited by Lim Han Yong 20240228 - change from mousemove to click\n    //    var table = 'Dispense';\n    //    redirectqueuelog(table);\n    //});\n\n    //mainTabDispensePayment_frame.addEventListener(\"keydown\",function(){\n    //    var table = 'Dispense';\n    //    redirectqueuelog(table);\n    //});\n    //End Added by Lim Han Yong 20240117\n\n    function navigateBack() {\n            \n            var pcno = '78160';\n            while (pcno.length < 5) {\n                pcno = '0' + pcno;\n            }\n            localStorage.setItem('pcnoQuickSearch', pcno);\n            \n\n        history.back();\n    }\n\n    var countForFileUploaded = 0;\n    var countForFileUploadedFail = 0;\n    var strFailUpload = '';\n    var previewNode = document.querySelector(\"#template\");\n    previewNode.id = \"\";\n    var previewTemplate = previewNode.parentNode.innerHTML;\n    previewNode.parentNode.removeChild(previewNode);\n\n    var myDropzone = new Dropzone(\"#dropzoneJsForm\", {\n        dictDefaultMessage: \"Drop file(s) here or click here to select file(s).\",\n        previewTemplate: previewTemplate,\n        previewsContainer: \"#dropzoner2\",\n        autoDiscover: false,\n        addRemoveLinks: false,\n\n        // 20191230: AY change for 100 to 1 autoProcessQueue to true. To upload 1 at a time. This fixes the upload issue for\n        //           big files.\n        // 20191230: AY If set to true, second time do no need to click the upload button; cause validation issues.\n        // 20191230: Need to process another way.\n        autoProcessQueue: false,\n        parallelUploads: 1,\n        maxFiles: 5,\n        //acceptedFiles: \".jpeg,.jpg,.png,.gif,.pdf,.tiff,.tif\",\n        acceptedFiles: \".jpeg,.jpg,.png,.pdf\",      //Edited by Danny 20220217 - remove .gif,.tiff,.tif\n        thumbnailWidth: \"180\",\n        thumbnailHeight: \"180\",\n        dictRemoveFile: 'Delete',\n        paramName: 'userfile',\n        maxFilesize: 30,\n        dictResponseError: 'Error uploading file',\n        dictFileTooBig: 'File is bigger than 30MB',\n        init: function () {\n            var submitButton = document.querySelector(\"#btnCaseNFileUpload\");\n            var myDropzone = this; //closure\n\n            this.on(\"maxfilesexceeded\", function (file) {\n                for (var i = this.files.length - 1; i > 4; i--) {\n                    this.removeFile(this.files[i]);\n                }\n                //var count = 5;\n                //while(this.file.length > this.options.maxfiles) {\n                //    this.removeFile(this.files[count]);\n                //    count++;\n                //}\n                swal(\"\", \"Exceeded maximum file per upload.\", \"warning\");\n            });\n\n            submitButton.addEventListener(\"click\", function (e) {\n                e.preventDefault();\n\n                var folderEmpty = false;\n\n                var _txtFileName = document.getElementById(\"txtUploadDesc\");\n                var fileName = _txtFileName.value;\n                if (fileName == '') {\n                    $('#txt_fileName').focus();\n                    swal('', 'File Name must be entered.', 'warning');\n                    return;\n                }\n                else if ($('#ddcaseNAddFile').val() == \"\") {\n                    swal('', 'Folder Name must be selected.', 'warning');\n                    return;\n                }\n                else if ($(\".txtRptDate\").val().trim().length == 0) {\n                    swal('', 'Report date must be entered.', 'warning');\n                    return;\n                }\n\n                //(myDropzone.files.length <= 5 ||) Added by bryan - 20190806\n                if (myDropzone.files.length <= 5 && $(\"#dropzoneJsForm .error.text-danger\").text().length == 0) {\n                    if (myDropzone.files.length > 0) {\n                        $('.CaseNAddFile').each(function (i, obj) {\n                            if ($(obj).val() == \"\") {\n                                folderEmpty = true;\n                            }\n                        });\n                        //20190806 - Set files status to queued when files are equal or less than 5\n                        for (var i = 0; myDropzone.files.length > i; i++) {\n                            myDropzone.files[i].status = \"queued\";\n                        }\n                        if (folderEmpty) {\n                            swal(\"\", \"Please select folder to upload\", \"warning\");\n                            return;\n                        }\n                        else {\n                            swal({\n                                title: \"\",\n                                text: \"Are you sure you want to upload \" + myDropzone.files.length + \" file(s)?\",\n                                type: \"warning\",\n                                showCancelButton: true,\n                                confirmButtonColor: '#DD6B55',\n                                confirmButtonText: 'Yes',\n                                cancelButtonText: \"Cancel\",\n                                closeOnConfirm: true\n                            },\n                            function (isConfirm) {\n                                if (isConfirm) {\n                                    setTimeout(\n                                                function () {\n                                                    if (/^[a-zA-Z0-9-_().]*$/.test(fileName) == false) {\n                                                        swal({\n                                                            title: \"\",\n                                                            text: \"Filename contains illegal characters and will be replaced by system.\",\n                                                            type: \"warning\",\n                                                            showCancelButton: true,\n                                                            confirmButtonColor: \"#DD6B55\",\n                                                            confirmButtonText: \"Yes\",\n                                                            cancelButtonText: \"No\",\n                                                            closeOnConfirm: true,\n                                                            closeOnCancel: true\n                                                        },\n                                                        function (isConfirm) {\n                                                            if (isConfirm) {\n                                                                // 20191230: Need to process another way.\n                                                                myDropzone.options.autoProcessQueue= true;\n                                                                $(\".fadeMe\").show();\n\n\n                                                                setTimeout(\n                                                                           function () {\n                                                                               myDropzone.processQueue();\n                                                                           }, 1000);\n                                                                // 20191230: Need to process another way.\n                                                                myDropzone.on(\"queuecomplete\", function () {\n                                                                    myDropzone.options.autoProcessQueue= false;\n                                                                });\n                                                            } else {\n                                                                return;\n                                                            }\n                                                        });\n                                                    }\n                                                    else {\n                                                        // 20191230: Need to process another way.\n                                                        myDropzone.options.autoProcessQueue= true;\n                                                        $(\".fadeMe\").show();\n                                                        setTimeout(\n                                                            function () {\n                                                                myDropzone.processQueue();\n                                                            }, 1000);\n                                                        // 20191230: Need to process another way.\n                                                        myDropzone.on(\"queuecomplete\", function () {\n                                                            myDropzone.options.autoProcessQueue= false;\n                                                        });\n\n                                                    }\n                                                }, 500);\n                                }\n                            });\n                        }\n                    }\n                    else {\n                        swal(\"\", \"Please file(s) to upload.\", \"warning\");\n                    }\n                }\n                else {\n                    swal(\"\", \"Please remove error occured upload file(s) in order to proceed.\", \"warning\");\n                }\n            });\n\n            this.on(\"addedfile\", function (file) {\n                var _this = this;\n                var ext = file.name.split('.').pop();\n\n                if (ext == \"pdf\") {\n                    this.emit(\"thumbnail\", file, \"/Content/images/reader.png\");\n                } else if (ext.indexOf(\"doc\") != -1) {\n                    this.emit(\"thumbnail\", file, \"/Content/images/word.png\");\n                } else if (ext.indexOf(\"xls\") != -1) {\n                    this.emit(\"thumbnail\", file, \"/Content/images/excel.png\");\n                } else if (ext.indexOf(\"txt\") != -1) {\n                    this.emit(\"thumbnail\", file, \"/Content/images/notepad.png\");\n                }\n\n                var removeButton = Dropzone.createElement('<a style=\"float: right;align:center;width:15px;padding-left:3px;\" title=\"Remove\" ><span class=\"glyphicon glyphicon-trash\" style=\"color:red;\"></span></button>');\n                var rotateButton = Dropzone.createElement('<a style=\"float: right;width:15px;\" title=\"Rotate Image\"><span class=\"glyphicon glyphicon-repeat\"></span></button>');\n\n                // Listen to the click event\n                removeButton.addEventListener(\"click\", function (e) {\n                    e.preventDefault();\n                    e.stopImmediatePropagation();\n                    // Remove the file preview.\n                    swal({ title: \"\", text: \"Confirm to delete \" + file.name + \"?\", type: \"warning\", showCancelButton: true, confirmButtonColor: \"#DD6B55\", cancelButtonText: \"No\", confirmButtonText: \"Yes\", closeOnConfirm: false },\n                    function () {\n                        swal.close();\n                        isAllowRemove = true;\n                        _this.removeFile(file);\n                        //Remove Error text when files are equal or less than 5\n\n                        //$(\"#dropzoneJsForm .error.text-danger\").remove();\n                        for (var i = 0; myDropzone.files.length > i; i++) {\n                            if (i > 4) {\n                                myDropzone.files[i].status = \"error\";\n                                myDropzone.files[i].accepted = \"false\";\n                                //myDropzone.files[i].previewElement.innertext = \"\";\n                                //myDropzone.files[i].previewTemplate.innertext = \"\";\n                            } else {\n                                myDropzone.files[i].status = \"queued\";\n                                myDropzone.files[i].accepted = \"true\";\n\n                            }\n                        }\n\n\n                    });\n                });\n\n                rotateButton.addEventListener(\"click\", function (e) {\n                    e.preventDefault();\n                    e.stopImmediatePropagation();\n\n\n                    var targetElement = e.target || e.srcElement;\n                    var targetimg = $(targetElement).closest(\".dz-image-preview\").find(\".img-responsive\");\n\n                    var imgHeight = $(targetimg).height();\n                    var imgWeight = $(targetimg).width();\n\n                    if ($(targetimg).hasClass(\"rotate90\")) {\n                        $(targetimg).removeClass(\"rotate90\").addClass(\"rotate180\");\n                        $(file.previewElement).find(\".CaseNAddFileorientation\").val(\"180\");\n                        $(targetimg).css(\"margin\", \"0\");\n                    } else if ($(targetimg).hasClass(\"rotate180\")) {\n                        $(targetimg).removeClass(\"rotate180\").addClass(\"rotate270\");\n                        $(file.previewElement).find(\".CaseNAddFileorientation\").val(\"270\");\n                        if (imgWeight > imgHeight) {\n                            var margin = ((imgWeight - imgHeight) / 2).toString();\n                            $(targetimg).css(\"margin\", margin + \"px 0px\");\n                        }\n                    } else if ($(targetimg).hasClass(\"rotate270\")) {\n                        $(targetimg).removeClass(\"rotate270\");\n                        $(targetimg).css(\"margin\", \"0\");\n                        $(file.previewElement).find(\".CaseNAddFileorientation\").val(\"0\");\n                    } else {\n                        $(targetimg).addClass(\"rotate90\");\n                        $(file.previewElement).find(\".CaseNAddFileorientation\").val(\"90\");\n                        if (imgWeight > imgHeight) {\n                            var margin = ((imgWeight - imgHeight) / 2).toString();\n                            $(targetimg).css(\"margin\", margin + \"px 0px\");\n                        }\n                    }\n\n                });\n\n                $(file.previewElement).find(\".CaseNAddFile\").empty();\n                $(file.previewElement).find(\".CaseNAddFile\").append('<option value=\"\"></option>');\n\n                $(annotationUploadDdl).each(function (index, item) {\n                    $(file.previewElement).find(\".CaseNAddFile\").append('<option value=\"' + item + '\">' + item + '</option>');\n                });\n\n                if ($(\".list-group.list-CaseNFolder .list-group-item.selected\").length) {\n                    //\n                    //if ($(obj).attr(\"folder\") != 'Annotation') {\n                    $(file.previewElement).find(\".CaseNAddFile\").val($(\".list-group.list-CaseNFolder .list-group-item.selected\").attr(\"folder\"));\n                    //}\n                }\n\n\n                $(file.previewElement).find(\".CaseNAddFileDesc\").val(file.name);\n\n                var fileName = file.name;\n                var pcno = $('#txtPCNO').val();\n                var clinic = $('#txtClinic').val();\n                var type = $(\"#ddcaseNAddFile\").val();\n                var medGroup = $('#txtMedGroup').val();\n                var url = '/' + medGroup + '/' + pcno + '/' + type + '/' + fileName;\n                var xhr = new XMLHttpRequest();\n\n                //xhr.open('HEAD', url, false);\n                //xhr.send();\n\n                //$(file.previewElement.children[0].children[0].children[1]).removeClass(\"caption\").addClass(\"captionhide\");\n                file.previewElement.children[1].children[\"UploadDetailPanel\"].appendChild(removeButton);\n                file.previewElement.children[1].children[\"UploadDetailPanel\"].appendChild(rotateButton);\n\n                countForFileUploaded = 0;\n                countForFileUploadedFail = 0;\n                strFailUpload = '';\n\n                var today = new Date();\n                var dd = today.getDate();\n                var mm = today.getMonth() + 1; //January is 0!\n                var yyyy = today.getFullYear();\n                file.previewElement.children[1].children[4].children[0].checked = true;\n                file.previewElement.children[1].children[4].children[2].value = yyyy + \"_\" + mm + \"_\" + dd + \"_\"\n\n                $(\".txtRptDate\").datepicker({\n                    format: 'dd/mm/yyyy',\n                    useCurrent: true,\n                    todayHighlight: true,\n                    autoclose: true\n                }).datepicker(\"setDate\", \"now\");\n\n                $('.Icon_Date').click(function () {\n                    $(this).parent().find(\".txtRptDate\").datepicker('show');\n                    $(this).parent().find(\".txtRptDate\").focus();\n                });\n\n                $(\".txtRptDate\").mask(\"99/99/9999\", { \"clearIncomplete\": true });\n            });\n            this.on(\"sending\", function (file, xhr, formData) {\n                formData.append(\"fileType\", file.previewElement.children[1].children[3].value);\n                formData.append(\"desc\", file.previewElement.children[1].children[4].children[2].value + file.previewElement.children[1].children[4].children[3].value.replace(/[^a-zA-Z0-9-_().]/g, ''));\n                formData.append(\"orientation\", $(file.previewElement).find(\".CaseNAddFileorientation\").val());\n                formData.append(\"remark\", $(file.previewElement).find(\".CaseNAddRemarks\").val());\n                formData.append(\"rptDate\", $(file.previewElement).find(\".txtRptDate\").val());\n            });\n            this.on(\"complete\", function (file, xhr, formData) {\n                if (typeof file.xhr != 'undefined' && file.status != 'error') {\n                    var obj = jQuery.parseJSON(file.xhr.response);\n\n                    if (obj.success) {\n                        countForFileUploaded += 1;\n                    }\n                    else {\n                        strFailUpload += \"<li style='font-size:11px;'>\" + file.name + \"</li>\";\n                        countForFileUploadedFail += 1;\n                    }\n\n                    if (this.getUploadingFiles().length === 0 && this.getQueuedFiles().length === 0) {\n                        myDropzone.removeAllFiles();\n\n                        $(\".fadeMe\").hide();\n                        $('#caseNAddFileModal').modal('hide');\n\n                        var strMessage = '';\n\n                        strMessage = \"<p>\" + countForFileUploaded + \" file(s) uploaded successfully</p>\"\n\n                        if (strFailUpload.length > 0) {\n                            strMessage += \"<p>\" + countForFileUploadedFail + \" files failed to upload </p>\"\n                            strMessage += strFailUpload\n                        }\n\n                        swal({\n                            title: \"\",\n                            text: strMessage,\n                            type: \"\",\n                            html: true,\n                            showCancelButton: false,\n                            confirmButtonColor: '#DD6B55',\n                            confirmButtonText: 'OK',\n                            closeOnConfirm: false\n                        },\n                        function () {\n                            swal.close();\n                            getTab_2(\"P\");\n                            $(\".fadeMe\").show();\n                        });\n                    }\n                }\n            });\n            this.on(\"reset\", function (file) {\n                $(\"#btnCaseNFileUpload\").prop(\"disabled\", true);\n            });\n        },\n        accept: function (file, done) {\n            done();\n            $(\"#btnCaseNFileUpload\").prop(\"disabled\", false);\n        },\n    });\n\n    $(\"#btnUploadCaseNAdd\").click(function () {\n        $('#caseNAddFileModal').modal('show').removeClass(\"fade\");\n        myDropzone.removeAllFiles();\n        $(\"#dropzoneJsForm\").click();\n    });\n\n    $('#btnEhaDownload').off(\"click\").click(function () {\n        //$.when( ehaPatientDownload() ).done(function() {\n        //    setTimeout(function(){\n        //        var ids = jQuery(\"#ehaPatientGrid\").jqGrid('getDataIDs');\n        //        console.log(ids.length)\n        //        if(ids.length > 0){\n        //            $(\"#ehaPatientModal\").modal('show')\n        //        }\n        //        else{\n        //            swal(\"\", \"No available profile to download\", \"warning\");\n        //        }\n        //    }, 300);\n\n        //});\n        $(\"#ehaPatientGrid\").jqGrid(\"GridUnload\");\n\n        var url = \"/Patient/DownloadProfile\";\n        $(\"#ehaPatientGrid\").jqGrid({\n            url: url,\n            datatype: 'json',\n            mtype: 'Get',\n            colNames: ['ID','Patient Name', 'NRIC', 'Mobile No','','ClinicID','Sex','DOB','','','','','','','','','','BlkHseNo','Street','BuildingName','UnitNo','PCode','Tel1','Email','Allergy','SMSNoti','UseForeignAdd','ForeignAdd1','ForeignAdd2','ForeignAdd3','ForeignAdd4','PhoneNoti','EMsgNoti','EmailNoti','ApptNo', 'FilePath', 'DownloadType'],\n            colModel: [\n                { key: false, name: 'ID', index: 'ID', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'PName', index: 'PName', width: 220, sortable: false},\n                { key: false, name: 'Nric', index: 'Nric', width: 130, sortable: false},\n                { key: false, name: 'hp', index: 'hp', width: 100, sortable: false},\n                { key: false, name: 'Download',index:'Download', width:120,sortable:false, align: 'center', formatter: formatdownload },\n                { key: false, name: 'ClinicID', index: 'ClinicID', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'Sex', index: 'Sex', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'DOB', index: 'DOB', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'race', index: 'race', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'occupation', index: 'occupation', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'Marital', index: 'Marital', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'country', index: 'country', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'nation', index: 'nation', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'hp', index: 'hp', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'notifications', index: 'notifications', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'languageSP', index: 'languageSP', width: 100, sortable: false, hidden: true},\n\n                { key: false, name: 'idTypeCode', index: 'idTypeCode', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'BlkHseNo', index: 'BlkHseNo', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'Street', index: 'Street', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'BuildingName', index: 'BuildingName', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'UnitNo', index: 'UnitNo', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'PCode', index: 'PCode', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'tel', index: 'tel', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'Email', index: 'Email', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'Allergy', index: 'Allergy', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'UseForeignAdd', index: 'UseForeignAdd', width: 100, sortable: false, hidden: true },\n                { key: false, name: 'ForeignAdd1', index: 'ForeignAdd1', width: 100, sortable: false, hidden: true },\n                { key: false, name: 'ForeignAdd2', index: 'ForeignAdd2', width: 100, sortable: false, hidden: true },\n                { key: false, name: 'ForeignAdd3', index: 'ForeignAdd3', width: 100, sortable: false, hidden: true },\n                { key: false, name: 'ForeignAdd4', index: 'ForeignAdd4', width: 100, sortable: false, hidden: true },\n                { key: false, name: 'SMSNoti', index: 'SMSNoti', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'PhoneNoti', index: 'PhoneNoti', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'EMsgNoti', index: 'EMsgNoti', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'EmailNoti', index: 'EmailNoti', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'ApptNo', index: 'ApptNo', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'FilePath', index: 'FilePath', width: 100, sortable: false, hidden: true},\n                { key: false, name: 'DownloadType', index: 'DownloadType', width: 100, sortable: false, hidden: true}\n            ],\n            rowNum: -1,\n            rowList: ['All', '100', '500', '1000'],\n            gridview: true,\n            width: \"auto\",\n            height: \"auto\",\n            scroll: true,\n            loadError: function (xhr, status, error) {\n            },\n            loadComplete: function () {\n                var ele = $(\"#ehaPatientModal\").find(\".ui-jqgrid-bdiv\");\n                $(ele).height(200);\n                $(ele).width($(ele).width() + 16);\n                $(ele).css(\"overflow-x\", \"hidden\");\n\n                var ids = jQuery(\"#ehaPatientGrid\").jqGrid('getDataIDs');\n                if(ids.length > 0){\n                    $(\"#ehaPatientModal\").modal('show')\n                }\n                else{\n                    swal(\"\", \"No available profile to download\", \"warning\");\n                }\n            },\n            jsonReader: {\n                root: \"rows\",\n                page: \"page\",\n                total: \"total\",\n                records: \"records\",\n                repeatitems: false,\n                Id: \"0\"\n            },\n            shrinkToFit: false,\n            multiselect: false\n        });\n    })\n\n    $(\"#btnSingPassDownload\").click(function() {\n        if ($(\"#txtPatientNo\").val() != \"NEW\") {\n            swal(\"\", \"Only when create new patient will need to use this button.\", \"warning\");\n        }\n        $.ajax({\n            cache: false,\n            url: \"/PatientMaster/GetSPPatient\",   //Modified by Lim Han Yong 20240528 - change Singpass to SP (GovTech block SingPass/CorpPass/Myinfo keyword)\n            type: 'post',\n            success: function (response) {\n                if (response.success) {\n                    if (response.Person == null) {\n                        swal(\"\", \"Please direct the patient to re-scan Clinic SingPass QR and give the patient's details.\", \"warning\");\n                    }\n                    else {\n                        var Person = JSON.parse(response.Person);\n                        //Modified by Cheng Yu 20220909 - if field from singpass has value then need to set the field to readonly\n                        if($(\"#txtPatientPName\").val(Person[0].PName).val() != ''){\n                            $(\"#txtPatientPName\").prop(\"readonly\",true).css(\"background\",\"lightgrey\").css(\"cursor\",\"not-allowed\");\n                        }\n                        if($(\"#txtPatientNRIC\").val(Person[0].NRIC).val() != ''){\n                            $(\"#txtPatientNRIC\").prop(\"readonly\",true).css(\"background\",\"lightgrey\").css(\"cursor\",\"not-allowed\");\n                        }\n                        if($(\"#txtPatientDOB\").val(Person[0].DOB).val() != ''){\n                            $(\"#txtPatientDOB\").prop(\"readonly\",true).css(\"background\",\"lightgrey\").css(\"cursor\",\"not-allowed\").focusout();\n                        }\n                        if($(\"#txtPatientHP\").val(Person[0].HP).val() != ''){\n                            $(\"#txtPatientHP\").prop(\"readonly\",true).css(\"background\",\"lightgrey\").css(\"cursor\",\"not-allowed\");\n                        }\n                        if($(\"#txtPatientBlkHseNo\").val(Person[0].BlkHseNo).val() != ''){\n                            $(\"#txtPatientBlkHseNo\").prop(\"readonly\",true).css(\"background\",\"lightgrey\").css(\"cursor\",\"not-allowed\");\n                        }\n                        if($(\"#txtPatientStreet\").val(Person[0].Street).val() != ''){\n                            $(\"#txtPatientStreet\").prop(\"readonly\",true).css(\"background\",\"lightgrey\").css(\"cursor\",\"not-allowed\");\n                        }\n                        if($(\"#txtPatientUnitNo\").val(Person[0].UnitNo).val() != ''){\n                            $(\"#txtPatientUnitNo\").prop(\"readonly\",true).css(\"background\",\"lightgrey\").css(\"cursor\",\"not-allowed\");\n                        }\n                        if($(\"#txtPatientBuildingName\").val(Person[0].BuildingName).val() != ''){\n                            $(\"#txtPatientBuildingName\").prop(\"readonly\",true).css(\"background\",\"lightgrey\").css(\"cursor\",\"not-allowed\");\n                        }\n                        if($(\"#txtPatientPostal\").val(Person[0].Postal).val() != ''){\n                            $(\"#txtPatientPostal\").prop(\"readonly\",true).css(\"background\",\"lightgrey\").css(\"cursor\",\"not-allowed\");\n                        }\n                        if($(\"#txtPatientEmail\").val(Person[0].Email).val() != ''){\n                            $(\"#txtPatientEmail\").prop(\"readonly\",true).css(\"background\",\"lightgrey\").css(\"cursor\",\"not-allowed\");\n                        }\n                        if($(\"#txtPatientSex\").val(Person[0].Sex).val() && $(\"#txtPatientSex\").val() != ''){\n                            $('#txtPatientSex').attr(\"style\", \"pointer-events: none;width:74.7969px;background:lightgrey;\");\n                            $('#txtPatientSex option:not(:selected)').remove();\n                        }\n                        if($(\"#txtPatientNation\").val(Person[0].Nation).val() && $(\"#txtPatientNation\").val() != ''){\n                            $('#txtPatientNation').attr(\"style\", \"pointer-events: none;width:205.688px;background:lightgrey;\");\n                            $('#txtPatientNation option:not(:selected)').remove();\n                        }\n                        //console.log(Person[0].Country);\n                        if($(\"#txtPatientCountry\").val(Person[0].Country).val() && $(\"#txtPatientCountry\").val() != ''){\n                            $('#txtPatientCountry').attr(\"style\", \"pointer-events: none;width:216.906px;background:lightgrey;\");\n                            $('#txtPatientCountry option:not(:selected)').remove();\n                        }\n                        if($(\"#txtPatientIDTypeCode\").val(Person[0].IDTypeCode).val() && $(\"#txtPatientIDTypeCode\").val() != ''){\n                            $('#txtPatientIDTypeCode').attr(\"style\", \"pointer-events: none;width:209.438px;background:lightgrey;\");\n                            $('#txtPatientIDTypeCode option:not(:selected)').remove();\n                        }\n\n                        var RaceInOptions = $('#txtPatientRace option').filter(function () {\n                            return this.value.toUpperCase() === Person[0].Race;\n                        } ).attr('value');\n\n                        if($(\"#txtPatientRace\").val(RaceInOptions).val() && $(\"#txtPatientRace\").val() != ''){\n                            $('#txtPatientRace').attr(\"style\", \"pointer-events: none;width:149.594px;background:lightgrey;\");\n                            $('#txtPatientRace option:not(:selected)').remove();\n                        }\n                        $(\"#btnPostal\").css(\"pointer-events\", \"none\").unbind(\"click\");\n                        $(\"#btnStreet\").css(\"pointer-events\", \"none\").unbind(\"click\");\n                        //End Modified by Cheng Yu 20220909\n                    }\n                }\n            },\n        });\n    });\n\n    function loadAnnotationUploadDdlCN() {\n        var data = { Type: \"P\", PCNO: \"78160\" };\n        $.ajax({\n            cache: false,\n            url: \"/CaseNote/getTab\",\n            type: \"POST\",\n            data: JSON.stringify(data),\n            contentType: 'application/json; charset=utf-8',\n            success: function (response) {\n                if (response.success) {\n                    annotationUploadDdl = [];\n                    var html = '';\n                    var List_Contained = Enumerable.From(response.list).ToArray();\n                    $.each(List_Contained, function (i, sp) {\n                        annotationUploadDdl.push(sp.Description);\n                    });\n                }\n            },\n            error: function (response) {\n                console.log(response);\n            }\n        });\n    }\n\n    //Added by Xirlyn 20240126 - Pop up vital sign modal to allow input\n    $(document).on(\"click\", \"#vitalSignBtn\", function(){\n        //Added by Cooper 20180717 - Patient (ACCESS CONTROL)\n        if (true == false) {\n            swal({\n                title: Cookies.get(\"SWAL_Header_Msg\"),\n                text: Cookies.get(\"SWAL_Body_Msg\"),\n                type: Cookies.get(\"SWAL_Type\"),\n                timer: Cookies.get(\"SWAL_Timer\")\n            });\n            return;\n        }\n\n        let rowIds = \"0\";\n\n        if (rowIds != null) {\n            $(\".fadeMe\").show();\n            let visitNo = \"0\";\n            let selectedPCNO = \"78160\";\n            let selectedClinic = $(\"#hdUserClinic\").val();\n            let selectedQDate = \"\";\n            let selectedAge = \"40 y\";\n            let selectedPName = \"ENG CHAI PIN ELYNE XANDRIA\";\n            let selectedGender = \"F\";\n            let selectedNRIC = \"S8570522I\";\n            let selectedDated = selectedQDate.split(\" \");\n            let SelectedActiveTab = \"DataEntry\"\n            let param = selectedPCNO + '&' + visitNo + '&' + selectedDated[0];\n            let VitalSignTitle = \"Vital Sign - \" + selectedPCNO + \"/\" + selectedPName + \"(\" + selectedNRIC + \")   \" + selectedGender + \"/\" + selectedAge;\n\n            queryString = encodeURI(param);\n\n            let data = {\n                age: selectedAge,\n                activeTab: SelectedActiveTab,\n                queryString: queryString\n            };\n            let encoded = JSON.stringify(data);\n\n            $.ajax({\n                cache: false,\n                type: \"POST\",\n                url: \"/QueueLog/GetChartView\",\n                data: encoded,\n                contentType: \"application/json; charset=utf-8\",\n                dataType: \"json\",\n                success: function(result) {\n                    if (result.success) {\n                        arrFooterBtnList = [];\n                        arrFooterBtnList2 = [];\n\n                        let appendDetail = {\n                            style: \"width:80vw;height:45vw;margin-top:1%;\",\n                            contentType: \"typeSimple\",\n                            cancelID: \"\",\n                            footerLayout: \"R\"\n                        };\n                        \n                        AppendModal2Body_Load(\"PatientMaster_VSModal\", VitalSignTitle, \"/ChartView/DataEntry?queryString=\" + result.url, arrFooterBtnList, arrFooterBtnList2, appendDetail);\n                        //End Added by Chang Ching Ler 20210921\n\n                        $('#PatientMaster_VSModal').on('hidden.bs.modal', function() { //Added by Chang Ching Ler 20211028 | Prevent crash with QLog > Vital sign\n                            $('#PatientMaster_VSModalBody').html('');\n                        });\n                        $(\".fadeMe\").hide();\n                    }\n                },\n                error: function(data) {}\n            });\n        } else {\n            swal(\"\", \"No record selected\", \"warning\");\n        }\n    });\n    //End added by Xirlyn 20240126\n\n    function refreshMplanData(){\n        let mplanData = {visitno: '0', pcno:'78160'};\n        let mplanDataEncoded = JSON.stringify(mplanData);\n        $.ajax({\n            cache: false,\n            type: \"POST\",\n            url: \"/QueueDispense/GetMPlanData\",\n            data: mplanDataEncoded,\n            async: false,\n            contentType: \"application/json; charset=utf-8\",\n            success: function (result) {\n                if (result.success) {\n                    let cleanedPersonalData = result.personalMPlan.replace(/^[\\s\\S]*?<br\\/>/, \"\").replace(/(<br\\/>)+$/, '');;\n                    \n                    if($(\"#liPayment\").hasClass(\"active\")){\n                        $(\"#txtPersonalMPlanDispense\").html(cleanedPersonalData);\n\n                        // Combine all MPlan data with separators\n                        let cleanedData = result.data.map(note => note.mplan);\n                        $(\"#txtMPlanDispense\").html(cleanedData);\n\n                        // Combine all CaseNote data with separators\n                        let cleanedCaseNote = result.data.map(note => {\n                            return '<div style=\"margin-bottom:20px;\">' +\n                                   note.casenote+\n                                   '</div>';\n                        }).join('');\n\n                        // Build combined note display\n                        let combinedNote = cleanedCaseNote;\n\n                        $(\"#txtCasenoteDispense\").html(combinedNote);\n\n                        //Update to the latest TCU value\n                        $('#TCUDay').val(result.personalTCUDay)                          \n                        $('#TCUWeek').val(result.personalTCUWeek)                       \n                        $('#TCUMonth').val(result.personalTCUMonth)                     \n                        $('#TCUYear').val(result.personalTCUYear)                         \n                        $('#TCURemark').val(result.personalTCURemarks)\n                    } \n                    else if($(\"#liVisit\").hasClass(\"active\")) {\n                        if (froalaEditor_MPlan) {\n                            froalaEditor_MPlan.html.set(cleanedPersonalData);\n                        }\n                    }                \n                }\n            },\n            error: function (data) {\n            }\n        });\n\n    }\n\n    function loadApptTabContent() {\n        $(\"#mainTabAppt_frame\").load('https://clinicassist.sg:1080/en/QueueLog/Appointment?PCNO=' + \"78160\" + '&VisitNo=' + '0');\n    }\n\n\n\n\n            \n        \n        \n    \n    \n\n\n\n\n    \n        \n\n            \n                \n                    ×\n                \n                \n                    \n                    \n                        Update User Info\n                        \n                            Please enter your login information.\n                        \n                    \n                \n\n                \n                    \n                        \n                            \n                                User ID\n                                \n                            \n                            \n                                Full Name\n                                \n                            \n                            \n\n                            \n                                New Password\n                                \n                                \n                                \n                                    \n                                          \n                            \n                            \n                                Retype Password\n                                \n                                \n                            \n                            \n                                Email\n                                \n                            \n                            \n                                Mobile\n                                \n                                \n\n                            \n                            \n                                Confirm\n                                Cancel\n                            \n                        \n                    \n                \n\n            \n\n        \n    \n\n\n\n\n    \n\n        \n        \n            ×\n            \n\n                \n                    Inventory\n                \n\n\n                \n                    \n                        \n                            Drug\n                        \n                        \n                            Stock\n                        \n                        \n                            Consumable\n                        \n                        \n                            Vendor\n                        \n                        \n\n                    \n                \n\n\n\n            \n\n        \n\n    \n\n\n\n    \n\n        \n        \n            ×\n            \n\n                \n                    Finance\n                \n\n                \n                    \n                        \n                        \n                            Company\n                        \n                        \n                            Expenses\n                        \n\n\n                    \n                \n\n\n            \n\n        \n\n    \n\n\n\n    \n\n        \n        \n            ×\n            \n\n                \n                    Patient\n                \n\n\n                \n                    \n                        \n                            Patient\n                        \n                        \n                            Finance\n                        \n\n\n\n                    \n                \n\n\n\n\n            \n\n        \n\n    \n\n\n\n    \n\n        \n        \n            ×\n            \n\n                \n                    Reception\n                \n\n\n                \n                    \n                        \n                            Reception\n                        \n                        \n                        \n                            Submission\n                        \n                    \n                \n\n\n\n\n            \n\n        \n\n    \n\n\n\n    \n\n        \n        \n            ×\n            \n\n                \n                    Reports\n                \n\n\n                \n                    \n                        \n                            Daily\n                        \n                        \n                            Inventory\n\n                        \n                        \n                            Finance\n                        \n                        \n                        \n                            Consumable\n                        \n                        \n                        \n                            Company\n                        \n                        \n                            GST\n                        \n                        \n                        \n                            Patient\n                        \n                        \n                            Audit\n                        \n                    \n                \n\n\n\n\n            \n\n        \n\n    \n\n\n\n    \n\n        \n        \n            ×\n            \n\n                \n                    Business Intelligence\n                \n\n\n\n                \n                    \n                        \n                            Treatment\n                        \n                        \n                            Visit\n                        \n                        \n                            Revenue\n                        \n                        \n                            Cost\n                        \n                        \n                            Commission\n                        \n                        \n                            Patient\n                        \n                        \n                            Package\n                        \n                        \n                            Membership\n                        \n                        \n                            Marketing\n                        \n                        \n                            Others\n                        \n                    \n                \n            \n\n        \n\n    \n\n\n\n    \n\n        \n        \n            ×\n            \n\n                \n                    HR\n                \n\n\n\n                \n                    \n                        \n                            Staff\n                        \n                    \n                \n            \n        \n\n    \n\n\n\n    \n\n        \n        \n            ×\n            \n\n                \n                    Setup\n                \n\n                \n                    \n                        \n                            Program\n                        \n                        \n                            Forms\n                        \n                        \n                            Patient\n                        \n                        \n                            Charges\n                        \n                        \n                            Appointment\n                        \n                        \n                            Inventory\n                        \n                        \n                            Payment\n                        \n                        \n                            Referral\n                        \n                        \n                        \n                            Memo\n                        \n                        \n                            Case Note\n                        \n                        \n                            Media\n                        \n                        \n                            Service Provider \n                        \n                        \n                            Surgical\n                        \n                        \n                            Queue\n                        \n                        \n                            Access Control\n                        \n                        \n                            Lab\n                        \n                        \n                            Other\n                        \n                    \n                \n\n\n\n            \n\n        \n\n    \n\n\n\n    \n\n        \n        \n            Email Us\n            ×\n            \n                Browser not compatible.\n                \n            \n\n        \n\n    \n\n\n\n    \n        \n            \n                ×\n                Staff Clock In / Out\n            \n            \n            \n        \n    \n\n\n\n\n    \n        \n            \n                ×\n                Add Ticket\n            \n            \n            \n        \n    \n\n\n\n\n\n    \n        \n        \n            \n                ×\n                View Ticket\n            \n            \n            \n        \n    \n\n\n\n    \n        \n            \n                ×\n                Queue Request\n            \n            \n            \n        \n    \n\n\n    \n        \n            \n                ×\n                \n            \n            \n            \n        \n    \n\n\n    \n        \n            \n                ×\n                \n            \n            \n                \n            \n        \n    \n\n\n\n    \n    \n    \n    \n    \n\n\n\n\n\n    var CKEDITOR_BASEPATH = \"/Scripts/ckeditor/\";\n    var myWaiting;\n    var ViewAppt_Interval;\n    var SideMenu;\n    var timeout_RefreshSessionState = null;       //Added by Kenneth 2022-01-13 | Refresh session state in Case Note / Dispense / Payment\n    var isFromPatientSearch = 'N'\n    let isRedirectPage = false;\n    var isTimedOut = 'N'\n\n    myWaiting = myWaiting || (function () {\n        var pleaseWaitDiv = $('<div class=\"modal fade\" id=\"pleaseWaitDialog\" data-backdrop=\"static\" data-keyboard=\"true\" role=\"dialog\" aria-labelledby=\"basicModal\" aria-hidden=\"true\" tabindex=\"-1\"><div class=\"modal-dialog modal-sm\"><div class=\"modal-content\"><div class=\"modal-header\"><h4> Wait </h4></div><div class=\"\"><br/>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<img id=\"imgInfo\" src=\"/Content/images/info.png\" style=\"width:20px;height:20px;\" />&nbsp;&nbsp; Please wait, loading in progress ..... <br/><br/></div></div></div></div></div></div>');\n        return {\n            showPleaseWait: function () {\n                pleaseWaitDiv.modal('show').removeClass(\"fade\");\n            },\n            hidePleaseWait: function () {\n                pleaseWaitDiv.modal('hide');\n            },\n        };\n    })();\n\n    var myPrinting;\n    myPrinting = myPrinting || (function () {\n        var pleasePrintDiv = $('<div class=\"modal fade\" id=\"pleasePrintDialog\" data-backdrop=\"static\" data-keyboard=\"true\" role=\"dialog\" aria-labelledby=\"basicModal\" aria-hidden=\"true\" tabindex=\"-1\"><div class=\"modal-dialog modal-sm\"><div class=\"modal-content\"><div class=\"modal-header\"><h4> Wait </h4></div><div class=\"\"><br/>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<img id=\"imgInfo\" src=\"/Content/images/info.png\" style=\"width:20px;height:20px;\" />&nbsp;&nbsp; Printing in Progress...Please wait.... <br/><br/></div></div></div></div></div></div>');\n        return {\n            showPleaseWait: function () {\n                pleasePrintDiv.modal('show').removeClass(\"fade\");\n            },\n            hidePleaseWait: function () {\n                pleasePrintDiv.modal('hide');\n            },\n        };\n    })();\n\n\n    function getHQMenu() {\n        event.preventDefault();\n        $('#Reports_Daily').css(\"display\", \"none\");\n        $('#Reports_Consumable').css(\"display\", \"none\");\n        $('#Reports_Company').css(\"display\", \"none\");\n        $('#Reports_GST').css(\"display\", \"none\");\n        $('#Reports_Patient').css(\"display\", \"none\");\n        $('#Reports_Audit').css(\"display\", \"none\");\n        $(\"body\").toggleClass(\"nav-toggle\");\n        $(\".content\").toggleClass(\"content_marginleft200\");\n\n        if ($(\"body\").hasClass(\"nav-toggle\")) {\n            insertDataToggle();\n            //Added by Koh Chin Choong 20211019 - if has hide-menulabel class will remove it else will show\n            $(\".menulabelid\").addClass(\"hide-menulabel\");\n            //End Added by Koh Chin Choong 20211019\n\n            //Added by Koh Chin Choong 20211020 - set More menu to default if close menu\n            if ($('#Others').hasClass(\"in\")) {\n                $('#liOthers').click();\n            }\n            //End Added by Koh Chin Choong 20211020\n        } else {\n            $('#leftNavPanel li a').removeAttr('data-original-title');\n            $('#liOthers div').removeAttr('data-original-title');\n\n            //Added by Koh Chin Choong 20211019 - if has hide-menulabel class will remove it else will show\n            $(\".menulabelid\").removeClass(\"hide-menulabel\");\n            //End Added by Koh Chin Choong 20211019\n        }\n\n        getHQMenuList();\n    }\n\n    function getMenu() {\n        event.preventDefault();\n\n        $(\"body\").toggleClass(\"nav-toggle\");\n        $(\".content\").toggleClass(\"content_marginleft200\");\n\n        if ($(\"body\").hasClass(\"nav-toggle\")) {\n            insertDataToggle();\n            //Added by Koh Chin Choong 20211019 - if has hide-menulabel class will remove it else will show\n            $(\".menulabelid\").addClass(\"hide-menulabel\");\n            //End Added by Koh Chin Choong 20211019\n\n            //Added by Koh Chin Choong 20211020 - set More menu to default if close menu\n            if ($('#Others').hasClass(\"in\")) {\n                $('#liOthers').click();\n            }\n\n            if ($('#Hospital').hasClass(\"in\")) {\n                $('#liHospital').click();\n            }\n            //End Added by Koh Chin Choong 20211020\n\n        } else {\n            $('#leftNavPanel li a').removeAttr('data-original-title');\n            $('#liOthers div').removeAttr('data-original-title');\n\n            //Added by Koh Chin Choong 20211019 - if has hide-menulabel class will remove it else will show\n            $(\".menulabelid\").removeClass(\"hide-menulabel\");\n            //End Added by Koh Chin Choong 20211019\n        }\n\n        getMenuList();\n    }\n\n    function insertDataToggle() {\n        $('#SidebarmenuHome a').attr('data-original-title', 'Home');\n        $('#SidebarmenuQueue a').attr('data-original-title', 'Queue');\n        $('#SidebarmenuPatient a').attr('data-original-title', 'Patient');\n        $('#SidebarmenuAppointment a').attr('data-original-title', 'Appointment');\n        $('#SidebarmenuSubmission a').attr('data-original-title', 'Submission');\n        $('#SidebarmenuInventory a').attr('data-original-title', 'Inventory');\n        $('#SidebarmenuFinance a').attr('data-original-title', 'Finance');\n        $('#SidebarmenuCommunication a').attr('data-original-title', 'Communication');\n        $('#SidebarmenuReports a').attr('data-original-title', 'Reports');\n        $('#liOthers div').attr('data-original-title', 'More');\n        $('#SidebarmenuInventory a').attr('data-original-title', 'Inventory');\n        $('#SidebarmenuLMS a').attr('data-original-title', 'LMS');//Added by Jia Yi 20250225 - Add for learn Management Page\n        $('#SidebarmenuPurchase a').attr('data-original-title', 'IMS');//Added by Jia Yi 20250912 -Add for IMS\n    }\n\n    $('#liOthers').click(function () {\n        if ($('#Others').hasClass(\"in\")) {\n            $(\"#imgArrow\").removeClass(\"rotate45\");\n        }\n        else {\n            $(\"#imgArrow\").addClass(\"rotate45\");\n            //$(\"body\").removeClass(\"nav-toggle\");\n\n            //$('#nav-icon3').toggleClass('open');\n        }\n\n        //if ($('#Hospital').hasClass(\"in\")) {\n        //    $('#liHospital').click();\n        //}\n\n        if ($(\"body\").hasClass(\"nav-toggle\")) {\n            $('#leftNavPanel li a').removeAttr('data-original-title');\n            $('#liOthers div').removeAttr('data-original-title');\n\n            //Added by Koh Chin Choong 20211019 - if has hide-menulabel class will remove it else will show\n            $(\".menulabelid\").addClass(\"hide-menulabel\");\n            //End Added by Koh Chin Choong 20211019\n\n            if ($('#Others').hasClass(\"in\")) {\n                $(\"body\").addClass(\"nav-toggle\");\n                $(\".menulabelid\").removeClass(\"hide-menulabel\");\n                $('#nav-icon3').toggleClass('open');\n                $(\".content\").toggleClass(\"content_marginleft200\");\n            }\n        } else {\n            insertDataToggle();\n            //Added by Koh Chin Choong 20211019 - if has hide-menulabel class will remove it else will show\n            $(\".menulabelid\").removeClass(\"hide-menulabel\");\n            //End Added by Koh Chin Choong 20211019\n\n            if ($(\"#nav-icon3\").hasClass(\"open\")) {\n                $('#nav-icon3').toggleClass('open');\n            }\n        }\n    })\n\n    $('#liHospital').click(function () {\n        if ($('#Hospital').hasClass(\"in\")) {\n            $(\"#imgHospitalArrow\").removeClass(\"rotate45\");\n        }\n        else {\n            $(\"#imgHospitalArrow\").addClass(\"rotate45\");\n            $(\"body\").removeClass(\"nav-toggle\");\n\n            $('#nav-icon3').addClass('open');\n        }\n\n        if ($(\"body\").hasClass(\"nav-toggle\")) {\n            $('#leftNavPanel li a').removeAttr('data-original-title');\n            $('#liHospital div').removeAttr('data-original-title');\n\n            //Added by Koh Chin Choong 20211019 - if has hide-menulabel class will remove it else will show\n            $(\".menulabelid\").addClass(\"hide-menulabel\");\n            //End Added by Koh Chin Choong 20211019\n\n            if ($('#Hospital').hasClass(\"in\")) {\n                $(\"body\").addClass(\"nav-toggle\");\n                $(\".menulabelid\").removeClass(\"hide-menulabel\");\n                $('#nav-icon3').addClass('open');\n                $(\".content\").toggleClass(\"content_marginleft200\");\n            }\n        } else {\n            insertDataToggle();\n            //Added by Koh Chin Choong 20211019 - if has hide-menulabel class will remove it else will show\n            $(\".menulabelid\").removeClass(\"hide-menulabel\");\n            $('#nav-icon3').addClass('open');\n        }\n    })\n\n    function getAlertNotification() {\n        if('False' == \"True\" && 'False' == \"True\") {\n            var startTime = convertDateToInt('');\n            var endTime = convertDateToInt('');\n            var timerInMilli = parseInt('', 10) * 60000;\n            var timeDifference = Math.round((startTime - Date.now()) / 60000);\n            if(endTime > Date.now()) {\n                if ((Math.round((startTime - Date.now()) / 60000)) < 0 ){\n                    swal({ title: \"\", text: \"System Maintenance in progress, Current session will be closed\", type: \"warning\", confirmButtonColor: \"#DD6B55\", confirmButtonText: \"OK\", closeOnConfirm: false },\n                       function () {\n                           swal.close();\n                           SessionEnd();\n                       });\n                }\n                else if(Date.now() > startTime - timerInMilli) {\n                    var timeDifference = Math.round((startTime - Date.now()) / 60000);\n                    $(\"#redAnnouncementMessage\").text(\"Maintaince in \"+ timeDifference + \" min(s)\")\n                }\n                else if (Date.now() < endTime){\n                    $(\"#redAnnouncementMessage\").text('');\n                    $(\"#redAnnouncementTimeFrame\").text(\"Date: \" + ('') + \" to \" + (''));\n                }\n                $(\"#redAnnouncement\").css(\"margin-left\", $(\"#nav-icon3\").hasClass(\"open\") ? \"220px\" : \"55px\");\n                $(\"#redAnnouncement\").css(\"display\", \"flex\");\n                $(\".content\").css(\"margin-top\", \"15px\");\n            }\n        }\n    }\n\n    function convertDateToInt(dateString) {\n        var formattedDateString = dateString.replace(/(\\d{2})\\/(\\d{2})\\/(\\d{4}) (\\d{2}:\\d{2}:\\d{2})/, \"$2/$1/$3 $4\");\n        var dateObject = new Date(formattedDateString);\n\n        return dateObject.getTime();\n    }\n\n    $(document).ready(function () {\n        getAlertNotification();\n        loadBranch();\n\n        //Added by Kenneth 2022-01-13 | Refresh session state in Case Note / Dispense / Payment\n        clearTimeout(timeout_RefreshSessionState);\n\n        if (typeof RefreshSessionState == 'function') {\n            RefreshSessionState();\n        }\n        //End Added by Kenneth 2022-01-13\n\n        $('#ClinicCodeHeader').css(\"color\", $(\"#ClinicHeaderColor\").val())\n        var pwdlength = '12';\n        document.getElementById('ttooltip').setAttribute('data-original-title', 'Use ' + pwdlength + ' or more characters with a mix of capital letters,</br> small letters, numbers & symbols');\n        //Modified by Chee Yong on 03092018 - To hide menus based on user role\n        switch (true) {\n            case (($('#hdUserClinic').val()) == \"HQ\" || ($('#hdUserClinic').val()) == \"HEADQUARTER\"):\n                //Modified by Kenneth 2021-05-11 HTML control display to avoid flashing\n                //$('#btnMainReception').css(\"padding-top\", 6);\n                //$('#btnMainReception').css(\"padding-bottom\", 18);\n                //$('#navbarhome').css(\"margin-left\", 10);\n                //$('#btnSearchPatient').css(\"display\", \"none\");\n                //$('#btnMainQueueLog').css(\"display\", \"none\");\n                //$('#btnMainAppointment').css(\"display\", \"none\");\n                //$('#btnMainPatient').css(\"display\", \"none\");\n                //$('#btnEmail').css(\"display\", \"none\");\n                //$('#btnTraining').css(\"display\", \"none\");\n                //$('#btnTodayAppt').css(\"display\", \"none\");\n                //$('#btnMainEndDay').css(\"display\", \"none\");\n                //$('#btnQueueLog').css(\"display\", \"none\");\n                //End Modified\n                $('#homebutton').css(\"margin-left\", 7);\n                $('#SidebarmenuHome').css(\"display\", \"block\");\n                $('#SidebarmenuInventory').css(\"display\", \"block\");\n                $('#SidebarmenuFinance').css(\"display\", \"block\");\n                $('#SidebarmenuITAdmin').css(\"display\", \"block\");\n                $('#SidebarmenuChart').css(\"display\", \"block\");\n                $('#SidebarmenutCAS').css(\"display\", \"block\");\n                $('#SidebarmenuReports').css(\"display\", \"block\");\n                $('#SidebarmenuOthers').css(\"display\", \"none\");    //Edited by Xirlyn 20240115 - Hide the entire 'More' side menu\n                //$('#SidebarmenuHR').css(\"display\", \"block\");      //Commented out by Xirlyn 20240115 - Not used\n                //$('#SidebarmenuEHA').css(\"display\", \"block\");     //Commented out by Xirlyn 20240115 - Not used\n                $('#SidebarmenuLMS').css(\"display\", \"block\");//Added by Jia Yi 20250225 - Add for learn Management Page\n                $('#SidebarmenuSetup').css(\"display\", \"block\");\n                $('#SidebarmenuEClinicSupport').css(\"display\", \"block\");\n                $('#SidebarmenuHealthScreen').css(\"display\", \"none\");\n                $('#SidebarmenuInPatient').css(\"display\", \"none\");\n                $('#SidebarmenuClock').css(\"display\", \"block\");   //Added by Xirlyn 20240115\n\n                //Added by Jia Yi 20250911\n                var IMS = 'False'\n                if (IMS == \"True\") {\n                    $('#SidebarmenuPurchase').css(\"display\", \"block\");\n                }\n                else{\n                    $('#SidebarmenuPurchase').css(\"display\", \"none\");\n                }\n                //End aded by Jia Yi 20250911\n\n                getHQMenuList();\n                $('[data-toggle=\"tooltipShared\"]').tooltip();\n                $('#left-nav-toggle').on('click', function (event) {\n                    getHQMenu(event);\n                });\n\n                $('.navbar-brand').on('click', function (event) {\n                    //getHQMenu(event);\n                    //$('#nav-icon3').toggleClass('open');\n                    //$(window).trigger(\"resize\");\n                    $(\"body\").toggleClass(\"nav-toggle\");\n                    $(\".menulabelid\").toggleClass(\"hide-menulabel\");\n                    $('#nav-icon3').toggleClass(\"open\");\n                    $(\".content\").toggleClass(\"content_marginleft200\");\n                    Cookies.set(\"navStatus\", $('#nav-icon3').attr(\"class\"));\n                    //$(window).trigger(\"resize\");\n                });\n                break;\n            case (($('#hdUserClinic').val()) == \"\" || ($('#hdUserClinic').val()) != \"\" || ($('#hdUserClinic').val()) != \"HEADQUARTER\" || ($('#hdUserClinic').val()) != \"HQ\"):\n\n                if ($('#hdEORDER_RAD').val() == \"False\") {\n                    $('#sidebarmenu03').css(\"display\", \"none\");\n                }\n\n                $('#SidebarmenuHome').css(\"display\", \"block\");\n                $('#SidebarmenuQueue').css(\"display\", \"block\");\n                $('#SidebarmenuPatient').css(\"display\", \"block\");\n                $('#SidebarmenuAppointment').css(\"display\", \"block\");\n                $('#SidebarmenuSubmission').css(\"display\", \"block\");\n                $('#SidebarmenuInventory').css(\"display\", \"block\");\n                $('#SidebarmenuFinance').css(\"display\", \"block\");\n                $('#SidebarmenuCommunication').css(\"display\", \"block\");\n                $('#SidebarmenuReports').css(\"display\", \"block\");\n                $('#SidebarmenuOthers').css(\"display\", \"none\");     //Edited by Xirlyn 20240115 - Hide the entire 'More' side menu\n                //$('#SidebarmenuHR').css(\"display\", \"block\");       //Commented out by Xirlyn 20240115 - Not used\n                //$('#SidebarmenuEHA').css(\"display\", \"block\");      //Commented out by Xirlyn 20240115 - Not used\n                $('#SidebarmenuLMS').css(\"display\", \"block\");//Added by Jia Yi 20250225 - Add for learn Management Page\n                $('#SidebarmenuSetup').css(\"display\", \"block\");\n                $('#SidebarmenuEClinicSupport').css(\"display\", \"block\");\n                $('#SidebarmenuHospital').css(\"display\", \"block\");\n                $('#SidebarmenuInPatient').css(\"display\", \"block\");\n                $('#SidebarmenuSurgery').css(\"display\", \"block\");\n                $('#SidebarmenuSetupMaster').css(\"display\", \"block\");\n                $('#SidebarmenuClock').css(\"display\", \"block\");   //Added by Xirlyn 20240115\n\n                //Added by Jia Yi 20250911\n                var IMS = 'False'\n                if (IMS == \"True\") {\n                    $('#SidebarmenuPurchase').css(\"display\", \"block\");\n                }\n                else{\n                    $('#SidebarmenuPurchase').css(\"display\", \"none\");\n                }\n                //End aded by Jia Yi 20250911\n\n                var healthScreenReportSetup = 'False'\n                if (healthScreenReportSetup == \"True\") {\n                    $('#SidebarmenuHealthScreen').css(\"display\", \"block\");\n                }\n                else{\n                    $('#SidebarmenuHealthScreen').css(\"display\", \"none\");\n                }\n\n                var InPatient = 'False'\n                if (InPatient == \"True\") {\n                    $('#SidebarmenuInPatient').css(\"display\", \"block\");\n                }\n                else{\n                    $('#SidebarmenuInPatient').css(\"display\", \"none\");\n                }\n\n                getMenuList();\n                $('[data-toggle=\"tooltipShared\"]').tooltip();\n                $('#left-nav-toggle').on('click', function (event) {\n                    getMenu(event);\n                });\n\n                $('.navbar-brand').on('click', function (event) {\n                    //getMenu(event);\n                    //$('#nav-icon3').toggleClass('open');\n                    //$(window).trigger(\"resize\");\n                    if ($('#Hospital').hasClass(\"in\")) {\n                        $('#liHospital').click();\n                    }\n\n                    $(\"body\").toggleClass(\"nav-toggle\");\n                    $(\".menulabelid\").toggleClass(\"hide-menulabel\");\n                    $('#nav-icon3').toggleClass(\"open\");\n                    $(\".content\").toggleClass(\"content_marginleft200\");\n                    $(\"#redAnnouncement\").css(\"margin-left\", $(\"#nav-icon3\").hasClass(\"open\") ? \"220px\" : \"55px\");\n                    Cookies.set(\"navStatus\", $('#nav-icon3').attr(\"class\"));\n                    //$(window).trigger(\"resize\");\n                });\n                break;\n        }\n\n        //$('#btnSearchPatient').click(function () {\n        //    if (!checkFP(Cookies.get(\"Pat_Listing\"))) {\n        //        swal({ title: Cookies.get(\"SWAL_Header_Msg\"), text: Cookies.get(\"SWAL_Body_Msg\"), type: Cookies.get(\"SWAL_Type\"), timer: Cookies.get(\"SWAL_Timer\") });\n        //        return;\n        //    }\n        //    $('.header-patient-search-wrap').fadeToggle(\"slow\");\n        //    $('#txtMainSearchPatient').focus();\n        //});\n\n        $('.header-patient-search-close').click(function () {\n            $('.header-patient-search-wrap').fadeToggle(\"slow\");\n        });\n\n        if ('True' == \"True\" && 'Y' == \"Y\") {  //Added by Chang Ching Ler 20201102 | Only trigger when EHA API & EHA appointment request is enabled (Requested by Koh)\n            ViewAppt_Interval = setInterval((function x() {\n                EHA_ViewAppt();\n                return x;\n            })(), 60000);\n        }\n\n        var isChrome = /Chrome/.test(navigator.userAgent) && /Google Inc/.test(navigator.vendor);\n        if (!isChrome) {\n            //$(\"#txtOldPassword_update\").attr(\"type\", \"password\");\n            $(\"#txtNewPassword_update\").attr(\"type\", \"password\");\n            $(\"#txtReTypePassword_update\").attr(\"type\", \"password\");\n        }\n\n        $(\".floatIcon\").draggable({\n            stop: function (event, ui) {\n                $(event.originalEvent.target).one('click', function (e) { e.stopImmediatePropagation(); });\n            }\n        });\n    });\n\n    function EHA_ViewAppt() {\n        getevents_Pending_Layout();\n\n        //$.ajax({\n        //    cache: false,\n        //    url: \"/Appointment/EHA_ViewAppt\",\n        //    type: 'POST',\n        //    contentType: 'application/json; charset=utf-8',\n        //    success: function (result) {\n        //        if (result.success) {\n        //        }\n        //        else {\n        //            console.log(result.message);\n        //        }\n        //    },\n        //    complete: function () {\n        //        getevents_Pending_Layout();\n        //    },\n        //    error: function (result) {\n        //        console.log(result);\n        //    }\n        //});\n    }\n\n    function getevents_Pending_Layout() {\n\n        var data = { drid: \"\", ApptInterval: 15 };\n\n        $.ajax({\n            cache: false,\n            url: \"/Appointment/getevents_Pending\",\n            data: JSON.stringify(data),\n            type: \"POST\",\n            contentType: 'application/json; charset=utf-8',\n            beforeSend: function () {\n            },\n            success: function (response) {\n                if (response.success) {\n                    if (response.list.length > 0) {\n                        $(\"#spin-noti-pending-main\").show();\n                        $(\"#btnMainAppointment\").attr(\"data-original-title\", \"Pending Appointment found\");\n                    } else {\n                        $(\"#spin-noti-pending-main\").hide();\n                        $(\"#btnMainAppointment\").attr(\"data-original-title\", \"Appointment\");\n                    }\n                }\n            },\n            error: function (response) {\n            }\n        });\n    }\n\n    function popitup(url) {\n        var left = (screen.width / 2) - (1000 / 2);\n        var top = (screen.height / 2) - (500 / 2);\n        var hei = screen.height - 110;\n\n        newwindow = window.open(url, 'name', 'resizable,height=' + hei + ',width=900, top=0, left=' + left);\n        newwindow.focus();\n        return false;\n    }\n\n\n    $('#txtMainSearchPatient').keypress(function (event) {\n        if (event.keyCode == 13) {\n            searchPatient();\n        }\n    });\n\n    //Added by Shan , 2017-08-15 - To fix UAT 328\n    function searchPatient() {\n        var txtMainSearchPatient = $('#txtMainSearchPatient').val();\n\n        if (txtMainSearchPatient.length > 0) {\n            $('.fadeMe').show();\n\n            var data = { queryString: encodeURIComponent(txtMainSearchPatient) };\n            var encoded = JSON.stringify(data);\n\n            $.ajax({\n                cache: false,\n                type: \"POST\",\n                url: \"/Home/EncryptionURL\",\n                data: encoded,\n                contentType: \"application/json; charset=utf-8\",\n                success: function (result) {\n                    if (result.success) {\n                        checkAP(\"/Patient/Index?queryString=\" + result.url);\n                        //window.location.href = \"/Patient/Index?queryString=\" + result.url;\n                    }\n                    else {\n                        swal(\"\", result.message, \"error\");\n                    }\n                },\n                error: function (data) {\n                }\n            });\n\n            //$.ajax({\n            //    cache: false,\n            //    url: \"/Home/CheckSearchPatientPermission\",\n            //    type: \"POST\",\n            //    data: encoded,\n            //    contentType: 'application/json; charset=utf-8',\n            //    success: function (response) {\n            //        if (response.success) {\n            //            window.location.href = \"/Patient/Index?queryString=\" + response.url;\n            //        }\n            //        else {\n            //            swal({ title: \"\", text: \"You have no access\", type: \"warning\", confirmButtonColor: \"#DD6B55\", confirmButtonText: \"OK\", closeOnConfirm: false },\n            //            function () {\n            //                swal.close();\n            //                window.location.href = '/Home/Reception';\n            //            });\n            //        }\n            //    },\n            //    error: function (response) {\n            //    }\n            //});\n        }\n    }\n\n    function getMenuList() {\n        $.ajax({\n            cache: false,\n            type: \"POST\",\n            url: \"/Authenticate/getMenuList\",\n            contentType: \"application/json; charset=utf-8\",\n            success: function (result) {\n                if (result.success) {\n\n                    SideMenu = result.data;\n                    //var parentmenu = Enumerable.From(result.data)\n                    //    .Distinct(\"$.ParentMenu\")\n                    //    .Select(\"$.ParentMenu\")\n                    //    .OrderBy(\"$.ParentMenu\")\n                    //    .ToArray();\n\n                    //for (var i = 0; i < parentmenu.length; i++) {\n\n                    //    var childmenu = Enumerable.From(result.data)\n                    //   .Where(function (item) { return item.ParentMenu == parentmenu[i]; })\n                    //   .Distinct(\"$.Menu\")\n                    //   .OrderBy(\"$.Menu\")\n                    //   .ToArray();\n\n                    //    var appendstr = '';\n\n                    //    appendstr += '<td style=\"padding: 10px 0px;\">';\n\n                    //    for (var c = 0; c < childmenu.length; c++) {\n\n                    //        var MenuAllow = ' class=\"cls_' + childmenu[c].Menu.toString() + ' notallow\" ';\n                    //        var url = '#';\n                    //        if (childmenu[c].MenuAllow.toString() == 'True') {\n                    //            MenuAllow = ' class=\"cls_' + childmenu[c].Menu.toString() + '\" ';\n                    //            url = childmenu[c].url;\n                    //        }\n\n                    //        if (url == '#') {\n                    //            appendstr += '<div style=\"display:none;\" class=\"megamenu-wrap\"><a href=\"' + url + '\" ' + MenuAllow + '>' + childmenu[c].MenuDesc + '</a></div>';\n                    //        } else {\n                    //            appendstr += '<div class=\"megamenu-wrap\"><a href=\"' + url + '\" ' + MenuAllow + '>' + childmenu[c].MenuDesc + '</a></div>';\n                    //        }\n                    //        //appendstr += '<li><a href=\"' + childmenu[c].url + '\" ' + MenuAllow + '>' + childmenu[c].MenuDesc + '</a></li>';\n\n                    //    }\n\n                    //    appendstr += '</td>';\n\n                    //    $('td#' + parentmenu[i]).after(appendstr);\n\n                    //}\n\n\n                } else {\n                    swal(\"\", result.message, \"error\");\n                }\n            },\n            error: function (data) {\n            }\n        });\n    }\n    //Added by Chee Yong on 06092018\n    function getHQMenuList() {\n        $.ajax({\n            cache: false,\n            type: \"POST\",\n            url: \"/Authenticate/getHQMenuList\",\n            contentType: \"application/json; charset=utf-8\",\n            success: function (result) {\n                if (result.success) {\n\n                    SideMenu = result.data;\n\n                } else {\n                    swal(\"\", result.message, \"error\");\n                }\n            },\n            error: function (data) {\n            }\n        });\n    }\n    function LoadAppointment() {    //Edited by Chang Ching Ler 20211027 | Change click event to function to avoid double trigger\n        $('.fadeMe').show();\n\n        //Cookies.set('urlback', '/QueueLog/Index');\n        //window.location.href = '/Appointment/Index?queryString=';\n\n        //Edited by Sylvest 20210712\n        var currentPath = window.location.pathname;\n        if (currentPath == \"/QueueLog/Index\") {\n            var rowIds = jQuery(\"#queueLogGrid\").jqGrid('getGridParam', 'selrow');\n            if (rowIds != null) {\n                var visitNo = jQuery(\"#queueLogGrid\").jqGrid('getGridParam', 'selrow');\n                var queueLogPCNO = jQuery(\"#queueLogGrid\").jqGrid('getCell', visitNo, 'PCNO');\n\n                var data = { queryString: queueLogPCNO };\n                var encoded = JSON.stringify(data);\n                $.ajax({\n                    cache: false,\n                    type: \"POST\",\n                    url: \"/Home/EncryptionURL\",\n                    data: encoded,\n                    contentType: \"application/json; charset=utf-8\",\n                    success: function (result) {\n                        if (result.success) {\n                            Cookies.set('urlback', '/QueueLog/Index?highlight=' + visitNo);\n                            //checkAP(\"/Appointment/Index?queryString=\" + result.url);\n                            checkAP(\"02012\", \"?queryString=\" + result.url, \"\");\n                        } else {\n                            swal(\"\", result.message, \"error\");\n                        }\n                    },\n                    error: function (data) {\n                    }\n                });\n            } else {\n                //checkAP(\"/Appointment/Index?queryString=\");\n                checkAP(\"02012\", \"\", \"\");\n            }\n        }\n        else {\n            //checkAP(\"/Appointment/Index?queryString=\");\n            checkAP(\"02012\", \"\", \"\");\n        }\n    }\n\n    $('#btnMainAppointment').click(function () {\n        $('.fadeMe').show();\n        //Cookies.set('urlback', '/QueueLog/Index');\n        //window.location.href = '/Appointment/Index?queryString=';\n\n        checkAP(\"/Appointment/Index?queryString=\");\n    });\n\n    $('#btnMainQueueLog').click(function () {\n        $('.fadeMe').show();\n\n        //window.location.href = '/QueueLog/Index';\n\n        // Added by Shan , 2017-08-15 - To fix UAT 328\n        //CheckPermissionQueueLog();\n\n        checkAP(\"/QueueLog/Index\");\n    });\n\n    $('#btnMainPatient').click(function () {\n        $('.fadeMe').show();\n\n        //window.location.href = '/Patient/Index';\n\n        // Added by Shan , 2017-08-15 - To fix UAT 328\n        //CheckPermissionPatient();\n\n        checkAP(\"/Patient/Index\");\n    });\n\n    $('#btnMainReception').click(function () {\n        //Issues key:CAS_WEB_SP-92\n        $('.fadeMe').show();\n        checkAP('/Home/Reception');\n        //window.location.href = '/Home/Reception';\n    });\n\n    $('#btnEmail').click(function (e) {\n        //$(\"#iframe-email\").attr('src', '/Home/Email?queryString=EmailUs|0|');\n        ////$(\"#iframe-email\").attr('src', '/Home/Email?queryString=SMS|1001|vincent.law@acmesis.com');\n        //$(\"#modal-Email\").modal(\"show\");\n        //$(\"#emailLoad\").show();\n        //Edited by Zac 20210225 - show add ticket when click Contact Us\n        $('.DocumentList ul#tab-list li a[href=\"#tabTicket\"]').trigger('click');\n        $(\"#AddTicketModalBody\").load('https://clinicassist.sg:1080/en/Ticket/Index?');\n        $(\"#AddTicketModal\").modal('show').removeClass(\"fade\");\n        //End edited by Zac 20210225\n    });\n\n\n\n    $('.SideMenuList').click(function (e) {\n        e.preventDefault();\n        var cat = $(this).attr(\"Cat\");\n        var Clinic = 'SSOC';\n        var currentPath = window.location.pathname;\n        var urlback = Cookies.get('urlback');\n\n        var suburlback = \"\"\n\n        if (typeof urlback !== 'undefined') {\n            suburlback = urlback.substr(0, urlback.indexOf('?'));\n        }\n        $(\".fadeMe\").show(); //Added by HaoWen 20210922 | Display loading screen when menu is clicked\n        var AllowAccess = false\n        if (currentPath == \"/QueueLog/PatientVisit\" || currentPath == \"/QueueDispense/Index\" || currentPath == \"/QueueLog/Index\") {     //Added by Lim Han Yong 20240229 - Add QueuLog/Index\n            //checkAccessRightDirectly('04002', currentPath).then(function (response) {\n            //    AllowAccess = true;\n            //})\n            //if(AllowAccess)\n            //{\n            //    if (checkFP(Cookies.get(\"CaseN_Add\"))) {\n\n            //        Cookies.set('urlQueueback', url);\n            //        $('#btnCaseNoteClose').trigger(\"click\");\n\n            //        if ($(\"#tab-li-text_Anno\").hasClass(\"active\")) {\n            //            ddsave_4PromptOut();\n            //        }\n\n            //    } else {\n            //        checkAP_step2(url);\n            //    }\n            //}\n            if (currentPath == \"/QueueLog/PatientVisit\") {\n                if(isFromPatientSearch == 'N' && isTimedOut == \"N\"){\n                    if($('.mainTab .active').find(\"a\").attr(\"tabtarget\") == \"VisitNotes\")\n                    {\n                        savetabs_SessionEnd();\n                        DeleteLockedSessionID();    //Edited by Lim Han Yong 20240118 | change to Session ID\n                        if ($(\"#tab-li-text_Anno\").hasClass(\"active\")) {\n                            ddsave_4PromptOut();\n                        }\n                    }\n                }\n            }\n\n            //Added by Lim Han Yong 20240229 - deletelockedsession when currentpath is /QueueLog/Index\n            if (currentPath == \"/QueueLog/Index\") {\n                DeleteLockedSessionID();\n            }\n            //End Added by Lim Han Yong 20240229\n            //else if (currentPath == \"/QueueDispense/Index\") {\n            //    SaveVisitNoteContent();\n            //}\n        }\n        //else if (urlLocation.indexOf(\"QueueDispense/Index\") > 0) {\n        //    AllowAccess = checkAP_ByAccessRight(url)\n        //    if(AllowAccess)\n        //    {\n        //        if (checkFP(Cookies.get(\"CaseN_Add\"))) {\n\n        //            Cookies.set('urlQueueback', url);\n\n        //            $('#btnDispenseClose').trigger(\"click\");\n\n        //        } else {\n        //            checkAP_step2(url);\n        //        }\n        //    }\n        //    else\n        //    {\n        //        swal({ title: Cookies.get(\"SWAL_Header_Msg\"), text: Cookies.get(\"SWAL_Body_Msg\"), type: Cookies.get(\"SWAL_Type\"), timer: Cookies.get(\"SWAL_Timer\") });\n        //        return;\n        //    }\n        //}\n\n        //Edited by Chang Ching Ler 20200106 | Menu UI enhancement - Report & Business Intelligence\n        if (cat == \"Reports\") {\n            checkAP('0', '', '/ReportsMenu/ReportsMenu');\n        }\n        else if (cat == \"Queue\") {\n            //Added by MiaoRu 20211005 - Add access right for queue log\n            //if (!checkFP(Cookies.get(\"Q_View\"))) {\n            //    swal({ title: Cookies.get(\"SWAL_Header_Msg\"), text: Cookies.get(\"SWAL_Body_Msg\"), type: Cookies.get(\"SWAL_Type\"), timer: Cookies.get(\"SWAL_Timer\") });\n            //    $(\".fadeMe\").hide();\n            //}\n            //else {\n            //checkAP('/Queuelog/Index');\n\n            checkAP(\"03014\", \"\", \"/Queuelog/Index\");\n            //}\n            //End Added by MiaoRu 20211005 - Add access right for queue log\n        }\n        else if (cat == \"PastQueue\") {\n            //checkAP('/QueueHistory/Index');\n            checkAP(\"60021\", \"\", \"/QueueHistory/Index\");\n        }\n        else if (cat == \"Home\" && Clinic != \"HQ\") {\n            checkAP('0', '', '/Home/Reception');\n        }\n        else if (cat == \"Home\" && Clinic == \"HQ\") {\n            checkAP('0', '', '/Dashboard/Dashboard');\n        }\n        else if (cat == \"Business Intelligence\") {\n            //checkAP('/BusinessIntelligenceMenu/BIMenu');\n            checkAP('0', '', '/BusinessIntelligenceMenu/BIMenu');\n        }\n        else if (cat == \"Chart\") {\n            //checkAP('/Chart/Menu');\n            checkAP('0', '', '/Chart/Menu');\n        } else if (cat == \"Patient\") {\n            //Added by MiaoRu 20211005 - Add access right for patient\n            //if (!checkFP(Cookies.get(\"Pat_Listing\"))) { //Edited by Zac 20211005 - Pat_View_View not working, change to Pat_Listing\n            //    swal({ title: Cookies.get(\"SWAL_Header_Msg\"), text: Cookies.get(\"SWAL_Body_Msg\"), type: Cookies.get(\"SWAL_Type\"), timer: Cookies.get(\"SWAL_Timer\") });\n            //    $(\".fadeMe\").hide();\n            //}\n            //else {\n            //    checkAP('/Patient/PatientSearch');\n            //    //checkAP('/Patient/Index');\n            //}\n            checkAP('01029', '', '/Patient/PatientSearch');\n            //End Added by MiaoRu 20211005 - Add access right for patient\n        } else if (cat == \"Appointment\") {\n            LoadAppointment();  //Added by Chang Ching Ler 20211027 | Change click event to function to avoid double trigger\n        } else if (cat == \"eSupport\") {\n            //checkAP('/Home/Training');\n            checkAP('0', '', '/Home/Training');\n        } else if (cat == \"Radiology\") {\n            //checkAP('/Patient/DocumentCollection');\n            checkAP('0', '', '/Patient/DocumentCollection');\n        } else if (cat == \"HealthScreen\"){\n            //checkAP('/HealthScreenReport/Index');\n            checkAP('16005', '', '/HealthScreenReport/Index');\n        } else if (cat == \"InPatient\"){\n            //checkAP('/InPatient/Index');\n            checkAP('0', '', '/InPatient/Index');\n        } else if (cat == \"Surgery\"){\n            //checkAP('/Surgery/Index');\n            checkAP('0', '', '/Surgery/Index');\n        } else if (cat == \"PreAdmission\") {\n            checkAP('68000', '', '/PreAdmission/Index');\n        }\n            else if (cat == \"LMS\") {\n                checkAP('0', '', '/LearningManagement/Index');//Added by Jia YI 20250225 - Add for learn Management Page\n            }\n\n\n        else if (cat == \"Clock\"){     //Added by Xirlyn 20240115\n            popOutReport(\"#ClockInOut\", \"\");\n        }\n        else if (cat== \"Logo\"){\n\n        }\n        else if (cat== \"SetupMaster\"){\n            checkAP('0', '', '/SetupMaster/Index');\n        }\n        else if (cat == \"Setup\") {  //Added by MiaoRu 20211216  - check access right of setup\n            checkCategoryAccess(cat);\n        }\n        else {\n            LoadSideMenu(cat);\n            $(\".fadeMe\").hide();\n        }\n        //End Edited by Chang Ching Ler 20200106\n    });\n\n    //Added by MiaoRu 20211216  - function to check access right of category\n    function checkCategoryAccess(cat) {\n        var role = \"ADMIN\";\n        $.ajax({\n            cache: false,\n            type: \"POST\",\n            data: JSON.stringify({ Role: role }),\n            url: \"/Permission/GetUserModule_All\",\n            contentType: \"application/json; charset=utf-8\",\n            success: function (result) {\n                if (result.success) {\n                    if (role != 'ADMIN') {\n                        AccessMenuList = result.list;\n                        var checkAccess = false;\n                        for (let i = 0; i < AccessMenuList.length; i++) {\n                            if (AccessMenuList[i]['Category'] == cat || AccessMenuList[i]['Category'] == \"Access Control\") { //Modified by Veronica 20211227 -  If category = 'Setup or 'Access Control', either one access is true, shouldn't block from setup menu\n                                if (AccessMenuList[i]['Access'] != 'False'){\n                                    checkAccess = true;\n                                    break;\n                                }\n                            }\n                        }\n                        if (checkAccess == false) {\n                            swal({ title: Cookies.get(\"SWAL_Header_Msg\"), text: Cookies.get(\"SWAL_Body_Msg\"), type: Cookies.get(\"SWAL_Type\"), timer: Cookies.get(\"SWAL_Timer\") });\n                            $(\".fadeMe\").hide();\n                            return;\n                        }\n                        else {\n                            LoadSideMenu(cat);\n                            $(\".fadeMe\").hide();\n                        }\n                    } else {\n                        LoadSideMenu(cat);\n                        $(\".fadeMe\").hide();\n                    }\n                }\n                else {\n                    swal(\"\", result.message, \"error\")\n                }\n            },\n            error: function (data) {\n                console.log(data)\n            }\n        });\n    }\n    //End Added by MiaoRu 20211216  - function to check access right of category\n\n    $('#btnTraining').click(function () {\n        //Issues key:CAS_WEB_SP-92\n        $(\".fadeMe\").show();\n        //window.location.href = '/Home/Training';\n        checkAP('/Home/Training');\n    });\n\n    $(document).on('click', '.icon_SideMenuSearch', function () {\n        $(this).closest(\".modal\").find(\".wrap_SideMenuSearch\").show();\n        $(this).closest(\".modal\").find(\".input_SideMenuSearch\").val(\"\");\n        $(this).closest(\".modal\").find(\".input_SideMenuSearch\").focus();\n    });\n\n    $(document).on('click', '.close_SideMenuSearch', function () {\n        $(this).closest(\".modal\").find(\".wrap_SideMenuSearch\").hide();\n        $(this).closest(\".modal\").find(\"table\").empty();\n\n        $(this).closest(\".modal\").find(\"table\").append(getSideMenu_TableContent($(this).closest(\".modal\").attr(\"category\"), \"\"));\n    });\n\n    $(document).on('keyup', '.input_SideMenuSearch', function () {\n        $(this).closest(\".modal\").find(\"table\").empty();\n        if ($(this).val() == \"\") {\n            $(this).closest(\".modal\").find(\"table\").append(getSideMenu_TableContent($(this).closest(\".modal\").attr(\"category\"), \"\"));\n        } else {\n            $(this).closest(\".modal\").find(\"table\").append(getSideMenu_TableContent($(this).closest(\".modal\").attr(\"category\"), $(this).val()));\n        }\n    });\n\n    function LoadSideMenu(cat) {\n        $(\"div.modal[category='\" + cat + \"']\").remove();\n\n        var html = \"\";\n\n        //html += '<div id=\"sideMenuModal\" class=\"modal fade sideMenuModal\" category=\"' + cat + '\" role=\"dialog\" aria-hidden=\"true\">';\n        //html += '<div class=\"modal-dialog modal-lg\" style=\"width:1100px;max-width:95%;\">';\n        //html += '<div class=\"modal-content\">';\n        //html += '<button type=\"button\" class=\"close megamenu-close\" data-dismiss=\"modal\">×</button>';\n        //html += '<div class=\"modal-body megamenu-body\">';\n        //html += '<div class=\"magamenu-header-wrap\">';\n        //html += '<span class=\"glyphicon glyphicon-search icon_SideMenuSearch\"></span>';\n        //html += '<div class=\"wrap_SideMenuSearch\"><input type=\"text\" placeholder=\"Search Menu by Keyword\" class=\"input_SideMenuSearch\"><span class=\"close_SideMenuSearch\">x</span></div>';\n        //html += '<span class=\"magamenu-header\">' + cat + '</span>';\n        //html += '</div>';\n        //html += '<table>';\n\n\n        html += '<div id=\"sideMenuModal\" class=\"modal fade sideMenuModal\" category=\"' + cat + '\" role=\"dialog\" aria-hidden=\"true\">';\n        html += '<div class=\"modal-dialog modal-lg\" style=\"width:1100px;max-width:95%;\">';\n        //html += '<div class=\"modal-content\" style=\"background-image: -webkit-radial-gradient(left, circle cover, #ffffff 0%, #dcdcdc 80%);\">';\n        html += '<div class=\"modal-content\">';\n        //html += '<button type=\"button\" class=\"close megamenu-close\" data-dismiss=\"modal\">×</button>';\n        html += '<div class=\"magamenu-header-wrap\" style=\"margin: 10px 10px 0px 10px\">';\n        html += '<span class=\"lblcomingsoon\" style=\"display: none;padding-top: 1.2%;font-size: 20px;position: absolute;left:20px;;color: white;\">( * Coming Soon )</span><span class=\"magamenu-header\">' + cat + '</span>';\n        html += '<button type=\"button\" class=\"close megamenu-close\" data-dismiss=\"modal\" style=\"font-size: 45px;\">&times;</button>';\n        html += '</div>';\n        html += '<div class=\"searchbar\"><i class=\"fa fa-search\" style=\"position:absolute;line-height:3.5rem;padding-left:18px;color:#aaa;\"></i><input style=\"color:var(--bs-primary);display:block;width:280px;height:35px !important;font-size:14px;margin-left:5px;margin-bottom:5px;outline:none;border-radius:30px;\" class=\"input_SideMenuSearch\" placeholder=\"Search Menu by Keyword\" type=\"text\"></div>';\n        html += '<div class=\"modal-body megamenu-body\">';\n        html += '<table>';\n\n        var content = getSideMenu_TableContent(cat, \"\");\n\n        if (content == \"\") {\n            alert(\"empty\");\n        }\n\n        html += getSideMenu_TableContent(cat, \"\");\n        html += '</table>';\n        html += '</div>';\n        html += '</div>';\n        html += '</div>';\n        html += '</div>';\n\n        $(\"body\").append(html);\n        $(\"div.modal[category='\" + cat + \"']\").modal('show').removeClass(\"fade\");\n\n        if (gotComingSoon) {\n            $(\".lblcomingsoon\").css(\"display\", \"\");\n            gotComingSoon = false;\n        }\n\n        setTimeout(function () {\n            $('.input_SideMenuSearch').focus();\n        }, 150);\n    }\n\n    var gotComingSoon = false\n\n    function getSideMenu_TableContent(cat, keyword) {\n        var html = \"\";\n        var parentmenu;\n        var sort;\n\n        html += '<tbody>';\n\n        if (cat != \"\" && keyword == \"\") {\n            sort = Enumerable.From(SideMenu).Where(function (item) { return item.Category == cat; })\n                                            .OrderBy(\"$.ParentMenu\")\n                                            .ToArray();\n        } else {\n            sort = Enumerable.From(SideMenu).Where(function (item) { return item.Category == cat && (item.MenuDesc.toLowerCase().indexOf(keyword.toLowerCase()) >= 0 || item.ParentMenu.toLowerCase().indexOf(keyword.toLowerCase()) >= 0); })\n                                            .OrderBy(\"$.ParentMenu\")\n                                            .ToArray();\n        }\n\n        parentmenu = Enumerable.From(sort)\n                            .Distinct(\"$.ParentMenu\")\n                            .Select(\"$.ParentMenu\")\n                            .ToArray();\n\n        for (var i = 0; i < parentmenu.length; i++) {\n            var arrParentmenu = parentmenu[i].split('_');\n            var ParentmenuDesc = \"\";\n\n            for (var pa = 1; pa < arrParentmenu.length; pa++) {\n                ParentmenuDesc += arrParentmenu[pa] + \"\";\n            }\n\n            if (ParentmenuDesc == \"OTNotes\" && 'N' !== \"Y\") {\n                continue;\n            }\n\n            if (keyword != \"\") {\n                ParentmenuDesc = ParentmenuDesc;\n            }\n\n            html += '<tr>';\n            html += '<td id=\"Patient_Patient\" class=\"megamenu-lbl-wrap\"><span>' + ParentmenuDesc + '</span></td>';\n\n            var childmenu;\n\n            if (keyword != \"\") {\n                childmenu = Enumerable.From(SideMenu)\n                                          .Where(function (item) { return item.ParentMenu == parentmenu[i]; })\n                                          .Distinct(\"$.Menu\")\n                                          .OrderBy(\"$.Menu\")\n                                          .ToArray();\n            } else {\n                childmenu = Enumerable.From(SideMenu)\n                                         .Where(function (item) { return item.ParentMenu == parentmenu[i] })\n                                         .Distinct(\"$.Menu\")\n                                         .OrderBy(\"$.Menu\")\n                                         .ToArray();\n            }\n\n\n            html += '<td style=\"padding: 10px 0px;\">';\n\n            for (var c = 0; c < childmenu.length; c++) {\n                //var MenuAllow = ' class=\"cls_' + childmenu[c].Menu.toString() + ' notallow\" ';\n                //var url = '#';\n\n                var MenuAllow = ' class=\"cls_' + childmenu[c].Menu.toString() + ' UnLocked\" ';\n                var url = childmenu[c].url;\n\n                //if (childmenu[c].MenuAllow.toString() == 'True') {\n                //    MenuAllow = ' class=\"cls_' + childmenu[c].Menu.toString() + '\" ';\n                //    url = childmenu[c].url;\n                //}\n\n                //if (url == '#') {\n                //    html += '<div style=\"display:none;\" class=\"megamenu-wrap\"><a href=\"' + url + '\" ' + MenuAllow + '>' + childmenu[c].MenuDesc + '</a></div>';\n                //} else {\n                //    html += '<div class=\"megamenu-wrap\"><a href=\"' + url + '\" ' + MenuAllow + '>' + childmenu[c].MenuDesc + '</a></div>';\n                //}\n\n                //Commented and added by kenneth 2021-06-20 acas admin only can export patientlist\n                //html += '<div class=\"megamenu-wrap\"><a onclick=\"checkAP(\\'' + url + '\\')\" ' + MenuAllow + ' style=\"cursor:pointer;\">' + childmenu[c].MenuDesc + '</a></div>';\n                if(childmenu[c].Menu.toString() == \"Patient_Patient_ExportPatientList\")\n                {\n                    let userID = \"Vincent\";\n                    if(userID.trim().toLowerCase() == \"acas_admin\") {\n                        //html += '<div class=\"megamenu-wrap\"><a onclick=\"checkAP(\\'' + url + '\\')\" ' + MenuAllow + ' style=\"cursor:pointer;\">' + childmenu[c].MenuDesc + '</a></div>';\n                        html += '<div class=\"megamenu-wrap\"><a id=\"' + childmenu[c].ModuleKey + '\" onclick=\"checkAP(this)\" ' + MenuAllow + ' data-url=\"' + url + '\" style=\"cursor:pointer;\">' + childmenu[c].MenuDesc + '</a></div>';\n                    }\n                }\n                else if(childmenu[c].Menu.toString() == \"eHealthAssist_Banner\") { //Added by JiunWei 20230301 - Check if banner setting is enabled.\n                    if (\"False\" == \"True\") {\n                        html += '<div class=\"megamenu-wrap\"><a id=\"' + childmenu[c].ModuleKey + '\" onclick=\"checkAP(this)\" ' + MenuAllow + ' data-url=\"' + url + '\" style=\"cursor:pointer;\">' + childmenu[c].MenuDesc + '</a></div>';\n                    }\n                }\n                else if(childmenu[c].Menu.toString() == \"eHealthAssist_Doctor\") {\n                    if (\"N\" == \"Y\") {\n                        html += '<div class=\"megamenu-wrap\"><a id=\"' + childmenu[c].ModuleKey + '\" onclick=\"checkAP(this)\" ' + MenuAllow + ' data-url=\"' + url + '\" style=\"cursor:pointer;\">' + childmenu[c].MenuDesc + '</a></div>';\n                    }\n                }\n                else if (childmenu[c].Menu.toString() == \"eHealthAssist_Event\") {\n                    if (\"N\" == \"Y\") {\n                        html += '<div class=\"megamenu-wrap\"><a id=\"' + childmenu[c].ModuleKey + '\" onclick=\"checkAP(this)\" ' + MenuAllow + ' data-url=\"' + url + '\" style=\"cursor:pointer;\">' + childmenu[c].MenuDesc + '</a></div>';\n                    }\n                }\n                else if (childmenu[c].Menu.toString() == \"Reception_Submission_EInvoice\") {\n                    if (\"False\" == \"True\") {\n                        html += '<div class=\"megamenu-wrap\"><a id=\"' + childmenu[c].ModuleKey + '\" onclick=\"checkAP(this)\" ' + MenuAllow + ' data-url=\"' + url + '\" style=\"cursor:pointer;\">' + childmenu[c].MenuDesc + '</a></div>';\n                    }\n                }   \n                else\n                {\n                    html += '<div class=\"megamenu-wrap\"><a id=\"' + childmenu[c].ModuleKey + '\" onclick=\"checkAP(this)\" ' + MenuAllow + ' data-url=\"' + url + '\" style=\"cursor:pointer;\">' + childmenu[c].MenuDesc + '</a></div>';\n                }\n\n\n\n                if (childmenu[c].MenuDesc.includes('*')) {\n                    gotComingSoon = true\n                }\n                //appendstr += '<li><a href=\"' + childmenu[c].url + '\" ' + MenuAllow + '>' + childmenu[c].MenuDesc + '</a></li>';\n            }\n\n            html += '</td>';\n            html += '</tr>';\n        }\n\n        html += '</tbody>';\n\n        return html;\n    }\n\n    function hideemailLoad() {\n        $(\"#emailLoad\").hide();\n    }\n\n    function hideemailModal() {\n        $(\"#modal-Email\").modal(\"hide\");\n        $(\"#iframe-email\").attr('src', '');\n    }\n\n\n    function popOutReport(url,urlparameter) {\n        switch (url) {\n            case \"#QuestionnaireListing\":\n                window.location.href = \"/ReportInquiry/ViewReport?type=\"+urlparameter;\n                break;\n            case \"#PatientVisitDetailListing\":\n                window.location.href = \"/ReportInquiry/ViewReport?type=\"+urlparameter;\n                break;\n            case \"#ReportsInventoryListing\":\n                //Comment by Koh Chin Choong 20210610 - Use window.location.href for new report\n                \n                //End Comment by Koh Chin Choong 20210613\n\n                window.location.href = \"/ReportInquiry/ViewReport?type=\"+urlparameter; //Added by Koh Chin Choong 20210613 - New Method to show the Drug Listing\n                break;\n            case \"#ClockInOut\":\n                $(\".sideMenuModal\").modal('hide');\n                $(\".fadeMe\").show();\n                $(\"#ClockModalBody\").load('https://clinicassist.sg:1080/en/Staff/Clock');\n                $(\"#ClockModal\").modal('show').removeClass('fade');\n                break;\n            case \"#CompEndMonth\":\n\n                $.ajax({\n                    cache: false,\n                    url: \"/Company/CompEndMonth_LastDayOfMonth\",\n                    type: \"POST\",\n                    contentType: 'application/json; charset=utf-8',\n                    beforeSend: function () {\n                    },\n                    success: function (response) {\n\n                        if (response.success) {\n\n                            swal({\n                                title: \"\",\n                                text: response.message,\n                                type: \"warning\",\n                                showCancelButton: true,\n                                confirmButtonColor: \"#DD6B55\",\n                                confirmButtonText: \"Yes\",\n                                cancelButtonText: \"No\",\n                                closeOnConfirm: false,\n                                closeOnCancel: true\n                            }, function (isConfirm) {\n                                if (isConfirm) {\n\n                                    $.ajax({\n                                        cache: false,\n                                        url: \"/Company/CompEndMonth\",\n                                        type: \"POST\",\n                                        contentType: 'application/json; charset=utf-8',\n                                        beforeSend: function () {\n                                        },\n                                        success: function (response) {\n                                            if (response.success) {\n\n                                                swal({\n                                                    title: \"\",\n                                                    text: \"End Month success, print invoice?\",\n                                                    type: \"success\",\n                                                    showCancelButton: true,\n                                                    confirmButtonColor: \"#DD6B55\",\n                                                    confirmButtonText: \"Yes\",\n                                                    cancelButtonText: \"No\",\n                                                    closeOnConfirm: true,\n                                                    closeOnCancel: true\n                                                }, function (isConfirm) {\n                                                    if (isConfirm) {\n\n                                                        $(\"iframe.ClientPrintEndMonth\").remove();\n\n                                                        var _src = '/en/Company/ClientPrintEndMonth?clinic=' + response.clinic + '&invoiceNoList=' + response.InvoiceNoList\n                                                        $(\"body\").append('<iframe class=\"ClientPrintEndMonth\" src=\"' + _src + '\" style=\"display:none;\"></iframe>');\n\n                                                    }\n                                                });\n                                            } else {\n                                                swal(\"\", response.message, \"error\");\n                                            }\n                                        },\n                                        error: function (response) {\n\n                                        }\n                                    });\n                                } else {\n                                    return;\n                                }\n                            });\n                        } else {\n                            swal(\"\", response.message, \"error\");\n                        }\n                    },\n                    error: function (response) {\n\n                    }\n                });\n                break;\n            default:\n                if (urlparameter.length > 0) {\n                    var url = '/en/ReportViewer/Index?type=' + urlparameter;\n                    popitup(url);\n                }\n        }\n    }\n    //}\n\n    //Issues key:CAS_WEB_SP-92\n    \n\n    function CheckHQReportAccess(ModuleKey,url){\n        var hasHash = false\n        var URLParam = \"\"\n        var AccessURL = \"\"\n        AccessURL = url\n        if (url.indexOf('#') > -1) {\n            hasHash = true\n            var splitStrURL = url.split(\"#\");\n            if (splitStrURL[1] === \"ComingSoon\") {\n                swal({ title: \"\", text: \"Coming Soon\", type: \"success\", timer: 2000 });\n                return false;\n            }\n            if (url == \"#QuestionnaireListing\" || url == \"#PatientVisitDetailListing\") {\n                ModuleKey =\"10008\"\n            }\n            URLParam= splitStrURL[1];\n        }\n        if(ModuleKey ==\"00000\") {\n            window.location.href = url;\n        }\n        else\n        {\n            //if(hasHash)\n            //{\n                $.ajax({\n                    cache: false,\n                    url: \"/Authenticate/CheckHQReportAccessRight?ModuleKey=\" + ModuleKey +\"&CurrURL=\"+encodeURIComponent(AccessURL),\n                    contentType: 'application/json; charset=utf-8',\n                    type: \"POST\",\n                    success: function (response) {\n                        if (response.success) {\n                            if(hasHash)\n                            {\n                                popOutReport(url, response.UrlParameter);\n                            }\n                            else\n                            {\n                                window.location.href = response.url;\n                            }\n\n                        }\n                        else {\n                            swal({ title: Cookies.get(\"SWAL_Header_Msg\"), text: Cookies.get(\"SWAL_Body_Msg\"), type: Cookies.get(\"SWAL_Type\"), timer: Cookies.get(\"SWAL_Timer\") });\n                            return;\n                        }\n                    },\n                    error: function (response) {\n                        window.location.href = \"/Authenticate/Login\";\n                        return false;\n                    }\n                });\n\n            //}\n            //else\n            //{\n            //    $.ajax({\n            //        cache: false,\n            //        url: \"/Authenticate/CheckAccessRight?ModuleKey=\" + ModuleKey,\n            //        contentType: 'application/json; charset=utf-8',\n            //        type: \"POST\",\n            //        success: function (response) {\n            //            if (response.success) {\n            //                window.location.href = url;\n            //            }\n            //            else if (response.success == false) {\n            //                swal({ title: Cookies.get(\"SWAL_Header_Msg\"), text: Cookies.get(\"SWAL_Body_Msg\"), type: Cookies.get(\"SWAL_Type\"), timer: Cookies.get(\"SWAL_Timer\") });\n            //                $('.fadeMe').hide();\n            //            }\n            //        },\n            //        error: function (response) {\n            //            window.location.href = \"/Authenticate/Login\";\n            //        }\n            //    });\n            //}\n        }\n    }\n\n    //Issues key:CAS_WEB_SP-92\n    //From menu\n    function checkAP(e, queryString, redirectUrl) {\n        var urlParameter = \"\";\n        var moduleKey = \"\";\n        var type = \"\";\n        var isHashTag = false;\n\n        if (typeof queryString == 'undefined') {\n            queryString = \"\";\n        }\n\n        if (typeof e === 'string' || e instanceof String) {\n            if (e == \"0\") {\n                window.location.href = redirectUrl;\n                return;\n            } else {\n                moduleKey = e;\n            }\n        }\n        else\n        {\n            var strURL = ($(e).attr(\"data-url\")).split(\"?\");\n            var URLPage = strURL[0]\n            moduleKey = $(e).attr('id');\n\n            if (($('#hdUserClinic').val()) == \"HQ\" || ($('#hdUserClinic').val()) == \"HEADQUARTER\")\n            {\n                CheckHQReportAccess(moduleKey,$(e).attr(\"data-url\"))\n                return;\n            }\n            if (strURL[0].indexOf('#') > -1) {\n                var splitStrURL = strURL[0].split(\"#\");\n                if (splitStrURL[1] === \"ComingSoon\") {\n                    swal({ title: \"\", text: \"Coming Soon\", type: \"success\", timer: 2000 });\n                    return false;\n                }\n            }\n            if (moduleKey != \"00000\") {\n                if (strURL.length > 1) {\n                    if (strURL[1].trim().length > 0) {\n                        var splitType = strURL[1].split(\"=\");\n                        type = splitType[1];\n\n                        urlParameter = \"?\" + strURL[1];\n                    }\n                }\n                else {\n                    if (strURL[0].indexOf('#') > -1) {\n                        var splitStrURL = strURL[0].split(\"#\");\n\n                        if (splitStrURL[1] === \"ComingSoon\") {\n                            swal({ title: \"\", text: \"Coming Soon\", type: \"success\", timer: 2000 });\n                            return false;\n                        }\n                        else {\n                            isHashTag = true;\n                        }\n                    }\n                }\n            }\n            else {\n                if ($(e).attr(\"data-url\") == \"#ClockInOut\") {\n                    popOutReport($(e).attr(\"data-url\"), \"\");\n                    return;\n                }\n                else {\n                    window.location.href = $(e).attr(\"data-url\");\n                    return;\n                }\n            }\n        }\n\n        $.ajax({\n            cache: false,\n            url: \"/Authenticate/CheckAccessRight?ModuleKey=\" + moduleKey + \"&Type=\" + type + \"&IsHashTag=\" + isHashTag,\n            contentType: 'application/json; charset=utf-8',\n            type: \"POST\",\n            success: function (response) {\n                if (response.success) {\n                if (response.url == \"/WellAway/Index\") {      //Added by Remus 20250408 - if WellAway not turn on, prompt msg\n                    if ('False' == \"False\") {\n                        swal({ html: true, title: Cookies.get(\"SWAL_Header_Msg\"), text: \"If you haven’t subscribed yet, just head to: \\n <a href='/Home/AddOnFeatures?Route=Others' target='_blank'>Home > Add-On Features > Others > WellAway</a>\\nand subscribe now!\", type: Cookies.get(\"SWAL_Type\") });        //Edited by Jason 20250526 - auto Route to Others\n                        return;\n                    }\n                }\n                    if (response.otnotes != 'Y' && type == 'Anaesthetist') {\n                        swal(\"\", \"OTNotes setting has been turned off.\", \"warning\");\n                        $('.fadeMe').hide();\n                        return;\n                    }\n\n                    if (isHashTag == false) {\n                        var targetUrl = response.url || (redirectUrl || $(e).attr(\"data-url\"));\n                        window.location.href = targetUrl + (queryString || \"\");\n                    }\n                    else {\n                        if (response.url == \"#CompEndMonth\" && \"SSOC\" != \"HQ\") {\n                            response.url = \"#CompEndMonth\"\n                        }\n                        popOutReport(response.url, response.urlparameter);\n                    }\n                }\n                else if (response.success == false) {\n                    swal({ title: Cookies.get(\"SWAL_Header_Msg\"), text: Cookies.get(\"SWAL_Body_Msg\"), type: Cookies.get(\"SWAL_Type\"), timer: Cookies.get(\"SWAL_Timer\") });\n                    $('.fadeMe').hide();\n                }\n            },\n            error: function (response) {\n                window.location.href = \"/Authenticate/Login\";\n            }\n        });\n    }\n\n    function checkAccessRightDirectly(moduleKey, currentUrl) {\n        if (currentUrl == \"/CaseNote/InitCaseNote\" || currentUrl == \"/QueueDispense/Index\") {\n            return $.ajax({\n                cache: false,\n                url: \"/Authenticate/CheckFunctionAccessRight?ModuleKey=\" + moduleKey,\n                contentType: 'application/json; charset=utf-8',\n                type: \"POST\",\n                success: function (response) {\n                    if (response.success) {\n                        if (currentUrl == \"/CaseNote/InitCaseNote\") {\n                            //Cookies.set('urlQueueback', currentUrl);\n                            //$('#btnCaseNoteExit').trigger(\"click\");\n                            savetabs_SessionEnd();\n                            if ($(\"#tab-li-text_Anno\").hasClass(\"active\")) {\n                                ddsave_4PromptOut();\n                            }\n                        }\n                        else if (currentUrl == \"/QueueDispense/Index\") {\n                            //Cookies.set('urlQueueback', currentUrl);\n                            $('#btnDispenseClose').trigger(\"click\");\n                        }\n                    }\n                    else {\n                        return false;\n                    }\n                },\n                error: function (response) {\n                    window.location.href = \"/Authenticate/Login\";\n                    return false;\n                }\n            });\n        }\n        else {\n            return $.ajax({\n                cache: false,\n                url: \"/Authenticate/CheckFunctionAccessRight?ModuleKey=\" + moduleKey + \"&CurrURL=\"+currentUrl,\n                contentType: 'application/json; charset=utf-8',\n                type: \"POST\",\n                success: function (response) {\n                    if (response.success) {\n                        return true;\n                    }\n                    else {\n                        return false;\n                    }\n                },\n                error: function (response) {\n                    window.location.href = \"/Authenticate/Login\";\n                    return false;\n                }\n            });\n        }\n    }\n\n    \n\n    $(\".toggle-password\").click(function () {\n\n        var input = $($(this).attr(\"toggle\"));\n\n        if(this.id === \"NewPasswordHideShowIcon\"){\n            if ($(\"#txtNewPassword_update\").hasClass('passwordhideshow')) {\n                $(this).attr('src', \"/Content/images/eyeopen.png\");\n                $(\"#txtNewPassword_update\").removeClass('passwordhideshow');\n            }\n            else {\n                $(this).attr('src', \"/Content/images/eyeclosed.png\");\n                $(\"#txtNewPassword_update\").addClass('passwordhideshow');\n            }\n        }\n\n        if(this.id === \"ReTypePasswordHideShowIcon\"){\n            if ($(\"#txtReTypePassword_update\").hasClass('passwordhideshow')) {\n                $(this).attr('src', \"/Content/images/eyeopen.png\");\n                $(\"#txtReTypePassword_update\").removeClass('passwordhideshow');\n            }\n            else {\n                $(this).attr('src', \"/Content/images/eyeclosed.png\");\n                $(\"#txtReTypePassword_update\").addClass('passwordhideshow');\n            }\n        }\n\n    });\n\n\n\n\n    //session end\n    \n\n    var urlLocation = jQuery(location).attr('href');\n\n    var timeout_Locked = null;\n    var sTimeout = 7200000; //2 hour\n\n    $(document).on('mousemove keydown', function () {\n        clearTimeout(timeout_Locked);\n\n        timeout_Locked = setTimeout(function () {\n            SessionEnd();\n        },sTimeout);\n    });\n\n    function SessionEnd() {\n\n        ClientErrorLog(\"Session Logout\", \"SessionEnd Prompt\", window.location.pathname,\"\");\n        var\n        closeInSeconds = 10,\n        displayText = \"You will be leading to Login page in #1 seconds.\",\n        SessionAlerttimer;\n\n        swal({\n            title: \"Session expiring\",\n            text: displayText.replace(/#1/, closeInSeconds),\n            type: \"warning\",\n            timer: closeInSeconds * 1000,\n            showCancelButton: false,\n            confirmButtonColor: \"#DD6B55\",\n            confirmButtonText: \"Remain session\",\n            closeOnConfirm: true\n        },\n        function (isConfirm) {\n            if (isConfirm) {\n\n                clearInterval(SessionAlert);\n                //setTimeout('SessionEnd()', sTimeout);\n                clearTimeout(timeout_Locked);\n            }\n        });\n\n        SessionAlert = setInterval(function () {\n\n            closeInSeconds--;\n\n            if (closeInSeconds < 0) {\n\n                var temp = window.location.pathname;\n                if (getPageName(window.location.pathname) == \"PatientVisit\") {\n                    if($('.mainTab .active').find(\"a\").attr(\"tabtarget\") == \"VisitNotes\")\n                    {\n                        savetabs_SessionEnd();\n                    }\n                }\n                else if (window.location.pathname == \"/QueueLog/Index\") {\n                    if ($('#EyeModal').hasClass('in')) {\n                        $(\"#btnSaveTabEye\").click();\n                    }\n                }\n\n                ClientErrorLog(\"Logout\", \"SessionEnd\", window.location.pathname, \"\");\n\n                $.ajax({\n                    cache: false,\n                    url: \"/Authenticate/DeleteLocked\",\n                    type: 'post',\n                    success: function (result) {\n                    }\n                });\n\n                window.location = \"/Authenticate/Login\";\n            }\n\n            $('.sweet-alert > p').text(displayText.replace(/#1/, closeInSeconds));\n\n        }, 1000);\n    }\n\n    function getPageName(url) {\n        var index = url.lastIndexOf(\"/\") + 1;\n        var filenameWithExtension = url.substr(index);\n        var filename = filenameWithExtension.split(\"?\")[0];\n        return filename;\n    }\n\n    // Added by Shan , 2017-08-15 - To fix UAT 328\n    function CheckPermissionPatient() {\n        $.ajax({\n            cache: false,\n            url: \"/Patient/CheckPatientPermission\",\n            type: \"GET\",\n            contentType: 'application/json; charset=utf-8',\n            success: function (response) {\n                if (response.success) {\n                    window.location.href = '/Patient/Index';\n                }\n                else {\n                    swal({ title: \"\", text: \"You have no access\", type: \"warning\", confirmButtonColor: \"#DD6B55\", confirmButtonText: \"OK\", closeOnConfirm: false },\n                    function () {\n                        swal.close();\n                        window.location.href = '/Home/Reception';\n                    });\n                }\n            },\n            error: function (response) {\n            }\n        });\n    }\n\n    function CheckPermissionQueueLog() {\n        $.ajax({\n            cache: false,\n            url: \"/QueueLog/CheckQueueLogPermission\",\n            type: \"GET\",\n            contentType: 'application/json; charset=utf-8',\n            success: function (response) {\n                if (response.success) {\n                    window.location.href = '/QueueLog/Index';\n                }\n                else {\n                    swal({ title: \"\", text: \"You have no access\", type: \"warning\", confirmButtonColor: \"#DD6B55\", confirmButtonText: \"OK\", closeOnConfirm: false },\n                    function () {\n                        swal.close();\n                        window.location.href = '/Home/Reception';\n                    });\n                }\n            },\n            error: function (response) {\n            }\n        });\n    }\n\n    //$(document).ready(function () {\n\n    //    if (urlLocation.indexOf(\"QueuePayment/Index\") > 0 || urlLocation.indexOf(\"QueueDispense/Index\") > 0 || urlLocation.indexOf(\"CaseNote/InitCaseNote\") > 0) {\n    //        //keep locked\n    //    } else {\n    //        $.ajax({\n    //            cache: false,\n    //            url: \"/QueueDispense/DeleteLocked\",\n    //            type: 'post',\n    //            success: function (result) {\n    //            }\n    //        });\n    //    }\n\n        //Added by Michael 20171129\n    //    $('#idRoom').css('display', 'inline-block');\n    //    //prevent chrome continue where you off\n\n    //    if (!Cookies.get('PassLogin') || Cookies.get('PassLogin') != 'Y') {\n    //        var st = moment(Cookies.get('UserLastAccessCasTime'), 'MM/DD/YYYY HH:mm:ss').toDate();\n\n    //        var diff = moment().diff(moment(st), 'seconds');\n\n    //        if (diff > 20) {\n    //            console.log(st);\n    //            console.log(moment());\n\n    //            swal({ title: \"\", text: \"Your session end, please re-login again\", type: \"warning\", confirmButtonColor: \"#DD6B55\", confirmButtonText: \"OK\", closeOnConfirm: false },\n    //               function () {\n    //                   swal.close();\n    //                   window.location.href = '/Authenticate/Login';\n    //               });\n    //        } else {\n    //            console.log(st);\n    //            console.log(moment());\n    //        }\n\n    //    } else {\n    //        //user access to this page from login\n    //        Cookies.set('PassLogin', '');\n    //    }\n\n    //    setUserLastAccessCasTime();\n    //});\n\n    //function setUserLastAccessCasTime() {\n    //    setInterval(function () {\n    //        Cookies.set('UserLastAccessCasTime', moment().format('MM/DD/YYYY HH:mm:ss'));\n    //    }, 1000);\n        //}\n\n        //Added by bryan 20200911 - followed by Gp version\n    $(document).ready(function () {\n        //Added by Michael 20171129\n        var pageNow = window.location.pathname\n        var link = pageNow.split('/');\n\n        if (link[1] == \"Home\") {\n            if (link[2] == \"Training\") {\n                UpdateEClinicSupportSideBar();\n            }\n            else {\n                UpdateHomeSideBar();\n            }\n\n        }\n        else if (link[1] == \"Queuelog\" || link[1] == \"QueueLog\") {\n            if('T' == 'T' || isFromPatientSearch == \"Y\") {\n                UpdatePatientSideBar();\n                return;\n            }\n            else {\n                UpdateQueuelogSideBar();\n            }\n        }\n        else if (link[1] == \"Patient\" || link[1] == \"PatientMaster\") {\n            UpdatePatientSideBar();\n        }\n        else if (link[1] == \"Appointment\") {\n            UpdateAppointmentSideBar();\n        }\n        else if (link[1] == \"ReportsMenu\" || link[1] == \"ReportTemplate\" || link[1] == \"Report\") {\n            UpdateReportsSideBar();\n        }\n        else if (link[1] == \"QueueHistory\") {\n            UpdateHomeSideBar();\n        }\n        else if (link[1] == \"Submission\" || link[1] == \"QueueVaccination\" || link[1] == \"PCN\" || link[1] == \"CDMP\") {\n            if (link[2] == \"CIDCSubmission\") {\n                UpdateInventorySideBar();\n            } else {\n                UpdateSubmissionSideBar();\n            }\n        }\n        else if (link[1] == \"SMS\") {\n            UpdateCommunicationSideBar(); // Added by Zhi Ying 20240112 - new Menu Item filter\n        }\n        else if (link[1] == \"Consumable\" || link[1] == \"Drug\" || link[1] == \"StkAdjustment\" || link[1] == \"BatchExpiry\" || link[1] == \"StockTransfer\" || link[1] == \"Inventory\" || link[1] == \"ConsumablePurchase\" || link[1] == \"ConsumableUsage\" || link[1] == \"InventoryOrderArrival\") { // Added by Zhi Ying 20240112 - ConsumableUsage, InventoryOrderArrival\n            UpdateInventorySideBar();\n        }\n        else if (link[1] == \"FinCRNoteList\" || link[1] == \"Income\" || link[1] == \"FinInvoiceList\" || link[1] == \"Company\" || link[1] == \"ProfitLoss\" || link[1] == \"DrugVendor\" || link[1] == \"Expenditure\" || link[1] == \"ExpenseGrp\" || link[1] == \"Deposit\" || link[1] == \"Offset\") {\n            UpdateFinanceSideBar();\n        }\n        else if (link[1] == \"TelephoneList\" || link[1] == \"MainSetup\" || link[1] == \"InventoryMaintenance\" || link[1] == \"BranchList\" || link[1] == \"Authenticate\") {\n            UpdateSetupSideBar();\n        }\n        else if (link[1] == \"HealthScreenReport\"){\n            UpdateHealthScreenSideBar();\n        }\n        else if (link[1] == \"SetupMaster\" || link[1] == \"Setup\"){\n            UpdateSetupMasterSideBar();\n        }\n        else if (link[1] == \"OTNotes\"){\n            UpdateOTNotesSideBar();\n        }\n        else if (link[1] == \"LearningManagement\") {\n            UpdateLearnManagementSideBar(); //Added by Jia Yi 20250225 - Add for learn Management Page\n        }\n        else if (link[1] == \"Purchase\" || link[1] ==\"PurchaseRequest\" || link[1]==\"PurchaseOrder\") {\n            UpdatePurchaseSideBar(); //Added by Jia Yi 20250225 - Add for IMS\n        }\n\n        $('#idRoom').css('display', 'inline-block');\n        //prevent chrome continue where you off\n        //UserLastAccessCasTime(); //Comment by Koh Chin Choong 20210524 - Follow SP, prevent session timeout\n\n    });\n\n    function UpdateHomeSideBar() {\n        $('#SidebarmenuHome .RedIcon').css('display', 'inline-block');\n        $('#SidebarmenuHome .GreyIcon').css('display', 'none');\n        $('#SidebarmenuHome a').css('color', 'rgba(255, 119, 119, 1) !important;');\n    }\n\n    function UpdateQueuelogSideBar() {\n        $('#SidebarmenuQueue .RedIcon').css('display', 'inline-block');\n        $('#SidebarmenuQueue .GreyIcon').css('display', 'none');\n        $('#SidebarmenuQueue a').css('color', 'rgba(255, 119, 119, 1) !important;');\n    }\n\n    function UpdatePatientSideBar() {\n        $('#SidebarmenuPatient .RedIcon').css('display', 'inline-block');\n        $('#SidebarmenuPatient .GreyIcon').css('display', 'none');\n        $('#SidebarmenuPatient a').css('color', 'rgba(255, 119, 119, 1) !important;');\n    }\n\n    function UpdateAppointmentSideBar() {\n        $('#SidebarmenuAppointment .RedIcon').css('display', 'inline-block');\n        $('#SidebarmenuAppointment .GreyIcon').css('display', 'none');\n        $('#SidebarmenuAppointment a').css('color', 'rgba(255, 119, 119, 1) !important;');\n    }\n\n    function UpdateReportsSideBar() {\n        $('#SidebarmenuReports .RedIcon').css('display', 'inline-block');\n        $('#SidebarmenuReports .GreyIcon').css('display', 'none');\n        $('#SidebarmenuReports a').css('color', 'rgba(255, 119, 119, 1) !important;');\n    }\n\n    function UpdatePastQueueSideBar() {\n        $('#SidebarmenuPastQueue .RedIcon').css('display', 'inline-block');\n        $('#SidebarmenuPastQueue .GreyIcon').css('display', 'none');\n        $('#SidebarmenuPastQueue a').css('color', 'rgba(255, 119, 119, 1) !important;');\n    }\n\n    function UpdateSubmissionSideBar() {\n        $('#SidebarmenuSubmission .RedIcon').css('display', 'inline-block');\n        $('#SidebarmenuSubmission .GreyIcon').css('display', 'none');\n        $('#SidebarmenuSubmission a').css('color', 'rgba(255, 119, 119, 1) !important;');\n    }\n\n    // Added by Zhi Ying 20240112 - new Menu Item filter\n    function UpdateCommunicationSideBar() {\n        $('#SidebarmenuCommunication .RedIcon').css('display', 'inline-block');1\n        $('#SidebarmenuCommunication .GreyIcon').css('display', 'none');\n        $('#SidebarmenuCommunication a').css('color', 'rgba(255, 119, 119, 1) !important;');\n    }\n    // End added by Zhi Ying 20240112\n\n    function UpdateInventorySideBar() {\n        $('#SidebarmenuInventory .RedIcon').css('display', 'inline-block');1\n        $('#SidebarmenuInventory .GreyIcon').css('display', 'none');\n        $('#SidebarmenuInventory a').css('color', 'rgba(255, 119, 119, 1) !important;');\n    }\n\n    function UpdateFinanceSideBar() {\n        $('#SidebarmenuFinance .RedIcon').css('display', 'inline-block');\n        $('#SidebarmenuFinance .GreyIcon').css('display', 'none');\n        $('#SidebarmenuFinance a').css('color', 'rgba(255, 119, 119, 1) !important;');\n    }\n    //Added by Jia Yi 20250911\n    function UpdatePurchaseSideBar () {\n        $('#SidebarmenuPurchase .RedIcon').css('display', 'inline-block');\n        $('#SidebarmenuPurchase .GreyIcon').css('display', 'none');\n        $('#SidebarmenuPurchase a').css('color', 'rgba(255, 119, 119, 1) !important;');\n    }\n    //End added by Jia Yi 20250911\n    function UpdateSetupSideBar() {\n        $('#SidebarmenuSetup .RedIcon').css('display', 'inline-block');\n        $('#SidebarmenuSetup .GreyIcon').css('display', 'none');\n        $('#SidebarmenuSetup a').css('color', 'rgba(255, 119, 119, 1) !important;');\n    }\n\n    function UpdateEClinicSupportSideBar() {\n        $('#SidebarmenuEClinicSupport .RedIcon').css('display', 'inline-block');\n        $('#SidebarmenuEClinicSupport .GreyIcon').css('display', 'none');\n        $('#SidebarmenuEClinicSupport a').css('color', 'rgba(255, 119, 119, 1) !important;');\n    }\n\n    function UpdateHealthScreenSideBar() {\n        $('#SidebarmenuHealthScreen .RedIcon').css('display', 'inline-block');\n        $('#SidebarmenuHealthScreen .GreyIcon').css('display', 'none');\n        $('#SidebarmenuHealthScreen a').css('color', 'rgba(255, 119, 119, 1) !important;');\n    }\n\n    function UpdateOTNotesSideBar() {\n        $('#SidebarmenuOTNotes .RedIcon').css('display', 'inline-block');\n        $('#SidebarmenuOTNotes .GreyIcon').css('display', 'none');\n        $('#SidebarmenuOTNotes a').css('color', 'rgba(255, 119, 119, 1) !important;');\n    }\n\n    function UpdateSetupMasterSideBar() {\n        $('#SidebarmenuSetupMaster .RedIcon').css('display', 'inline-block');\n        $('#SidebarmenuSetupMaster .GreyIcon').css('display', 'none');\n        $('#SidebarmenuSetupMaster a').css('color', 'rgba(255, 119, 119, 1) !important;');\n    }\n\n     //Added by Jia Yi  - Add for learn Management Page\n    function UpdateLearnManagementSideBar() {\n        $('#SidebarmenuLMS .RedIcon').css('display', 'inline-block');\n        $('#SidebarmenuLMS .GreyIcon').css('display', 'none');\n        $('#SidebarmenuLMS a').css('color', 'rgba(255, 119, 119, 1) !important;');\n    }\n    //End Added by Jia Yi 20250225\n\n\n        function UserLastAccessCasTime() {\n            var st = moment(Cookies.get('UserLastAccessCasTime'), 'MM/DD/YYYY HH:mm:ss').toDate();\n\n            var diff = moment().diff(moment(st), 'seconds');\n\n            if (diff > 1500) {   //25 minutes\n\n                swal({ title: \"\", text: \"Your session end, please re-login again\", type: \"warning\", confirmButtonColor: \"#DD6B55\", confirmButtonText: \"OK\", closeOnConfirm: false },\n                   function () {\n\n                       swal.close();\n                       window.location.href = '/Authenticate/Login';\n                   });\n            } else {\n                Cookies.set('UserLastAccessCasTime', moment().format('MM/DD/YYYY HH:mm:ss'));\n            }\n        }\n\n        var isOnIOS = navigator.userAgent.match(/iPad/i);\n        var eventName = isOnIOS ? \"pagehide\" : \"beforeunload\";\n\n        window.addEventListener(eventName, function (event) {\n\n            Cookies.set('UserLastAccessCasTime', moment().format('MM/DD/YYYY HH:mm:ss'));\n        });\n\n\n    //Added by Daniel 20180730 - Focus on textbox after modal pop up\n    $('#md-UserProfile').on('shown.bs.modal', function () {\n        $('#txtNewPassword_update').focus();\n    });\n\n    //Added by Daniel 20180730 - clear textbox after close modal pop up\n    $('#md-UserProfile').on('hidden.bs.modal', function () {\n        //$('#txtOldPassword_update').val('');\n        $('#txtNewPassword_update').val('');\n        $('#txtReTypePassword_update').val('');\n        $('#txtEmail_update').val('');\n        $('#txtMobileNo_update').val('');\n    });\n\n    $('#btnUpdateProfile').click(function () {\n        var txtUserID_update = $('#txtUserID_update').val();\n        //var txtOldPassword_update = $('#txtOldPassword_update').val();\n        var txtNewPassword_update = $('#txtNewPassword_update').val();\n        var txtReTypePassword_update = $('#txtReTypePassword_update').val();\n        var txtEmail_update = $('#txtEmail_update').val();\n        var txtMobileNo_update = $('#txtMobileNo_update').val();\n\n        if (txtNewPassword_update.length == 0) {\n            $(\"#msgErrorUpdateProfile\").text(\"Please key in your new password\");\n            $(\"#msgErrorUpdateProfile\").show();\n            $('#txtNewPassword_update').focus();\n        }\n        else if (txtReTypePassword_update.length == 0) {\n            $(\"#msgErrorUpdateProfile\").text(\"Please key in your retype password\");\n            $(\"#msgErrorUpdateProfile\").show();\n            $('#txtReTypePassword_update').focus();\n        }\n        else if (txtNewPassword_update != txtReTypePassword_update) {\n            $(\"#msgErrorUpdateProfile\").text(\"Plase re-enter your confirmation password.\");\n            $(\"#msgErrorUpdateProfile\").show();\n            $('#txtReTypePassword_update').focus();\n        }\n        else {\n            $(\"#msgErrorUpdateProfile\").hide();\n            $(\"#msgErrorUpdateProfile\").text(\"\");\n            userupdate_post(txtUserID_update, txtNewPassword_update, txtReTypePassword_update, txtEmail_update, txtMobileNo_update);\n        }\n    });\n\n    //Edited by Shan, 2018-04-17 - Password Pattern\n    function userupdate_post(txtUserID_update, txtNewPassword_update, txtReTypePassword_update, txtEmail_update, txtMobileNo_update) {\n        var myData = { txtUserID_update: txtUserID_update, txtNewPassword_update: txtNewPassword_update, txtReTypePassword_update: txtReTypePassword_update, txtEmail_update: txtEmail_update, txtMobileNo_update: txtMobileNo_update };\n        var encoded = JSON.stringify(myData);\n\n        var password = { Password: txtNewPassword_update, Type: \"Icon\", oldPassword: \"\", Email: txtEmail_update, MobileNo: txtMobileNo_update, LoginID: txtUserID_update };\n        $.ajax({\n            cache: false,\n            type: \"POST\",\n            data: encoded,\n            url: \"/Home/UpdateUserProfile\",\n            contentType: \"application/json; charset=utf-8\",\n            dataType: \"json\",\n            async: false,\n            success: function (result) {\n                if (result.success) {\n                    var sign = $.ajax({\n                        cache: false,\n                        type: \"POST\",\n                        url: \"/Authenticate/PwdPattern\",\n                        data: JSON.stringify(password),\n                        contentType: \"application/json; charset=utf-8\",\n                        success: function (response) {\n                            if (response.success) {\n                                swal({ title: \"\", text: \"Password has been updated\", type: \"success\", type: \"success\", timer: 2000 });\n                                //$('#txtOldPassword_update').val(\"\");\n                                $('#txtNewPassword_update').val(\"\");\n                                $('#txtReTypePassword_update').val(\"\");\n                                //$('#md-UserProfile').modal('hide'); // if need to hide after updated.\n                            }\n                            else {\n                                swal(\"\", response.message, \"error\");\n                                $('#txtNewPassword').val(\"\");\n                                $('#txtConfirmPassword').val(\"\");\n                            }\n                        }\n                    });\n                } else {\n                    $(\"#msgErrorUpdateProfile\").text(result.message);\n                    $(\"#msgErrorUpdateProfile\").show();\n\n                    if (typeof result.controlId != 'undefined') {\n                        if (result.controlId.length > 0) {\n                            var control = '#' + result.controlId\n\n                            $(control).focus();\n                            $(control).focus(function () { $(this).select(); });\n                        }\n                    }\n                }\n            },\n            error: function (xhr, status) {\n            }\n        });\n\n    }\n\n    //$(\"#txtOldPassword_update\").keydown(function (e) {\n    //    var code = e.which;\n\n    //    if (code == 13) {\n    //        $('#txtNewPassword_update').focus();\n    //        $(\"#txtNewPassword_update\").focus(function () { $(this).select(); });\n    //        e.Handled = true;\n    //    }\n    //});\n\n    $(\"#txtNewPassword_update\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#txtReTypePassword_update').focus();\n            $(\"#txtReTypePassword_update\").focus(function () { $(this).select(); });\n            e.Handled = true;\n        }\n    });\n\n    $(\"#txtReTypePassword_update\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#txtEmail_update').focus();\n            $(\"#txtEmail_update\").focus(function () { $(this).select(); });\n            e.Handled = true;\n        }\n    });\n\n    $(\"#txtEmail_update\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#txtMobileNo_update').focus();\n            $(\"#txtMobileNo_update\").focus(function () { $(this).select(); });\n            e.Handled = true;\n        }\n    });\n\n    $(\"#txtMobileNo_update\").keydown(function (e) {\n        var code = e.which;\n\n        if (code == 13) {\n            $('#btnUpdateProfile').focus();\n            e.Handled = true;\n        }\n    });\n\n    $(\"#ddlBranchClinicList\").change(function () {\n        var room = \"\"\n        var medgroup = 'SSOC'\n        if (medgroup == \"JPN\") {\n            room = \"受付 REGISTRATION\"\n        }\n        else {\n            room = \"RECEPTION\"\n        }\n        var data = { Clinic: $(this).val(), ClinicName: $(\"#ddlBranchClinicList option:selected\").text(), Room: room };\n        //var data = { Clinic: $(this).val(), ClinicName: $(\"#ddlBranchClinicList option:selected\").text(), Room: \"RECEPTION\" };\n\n        $.ajax({\n            cache: false,\n            url: \"/Authenticate/LoginSuccess\",\n            data: JSON.stringify(data),\n            type: \"POST\",\n            contentType: 'application/json; charset=utf-8',\n            beforeSend: function () {\n                $(\".fadeMe\").show();\n            },\n            success: function (response) {\n                if (response.success) {\n\n                    //restructure locked mechanism\n                    $.ajax({\n                        cache: false,\n                        url: \"/Authenticate/DeleteLocked\",\n                        type: 'post',\n                        success: function (result) {\n                        }\n                    });\n\n                    window.location.href = response.gourl;\n                }\n            },\n            error: function (response) {\n\n            },\n            complete: function () {\n                $(\".fadeMe\").hide();\n            }\n        });\n    });\n\n    function loadBranch() {\n        $.ajax({\n            cache: false,\n            url: \"/Authenticate/LoadBranch\",\n            type: 'GET',\n            async: true,\n            contentType: 'application/json; charset=utf-8',\n            success: function (result) {\n                if (result.success) {\n                    $.each(result.list, function (i, sp) {\n                        $(\"#ddlBranchClinicList\").append('<option title=\"' + sp.ClinicDesc + '\" value=\"' + sp.Clinic + '\">' + sp.Clinic + '</option>');\n                    });\n\n                    $(\"#ddlBranchClinicList\").val(result.Clinic);\n                }\n                else {\n\n                }\n            },\n            complete: function () {\n            },\n            error: function (result) {\n            }\n        });\n    }\n\n\n    $(window).on(\"beforeunload\", function () {\n        Cookies.set('UserLastAccessCasTime', moment().format('MM/DD/YYYY HH:mm:ss'));\n\n        let SharedURL = jQuery(location).attr('href');\n        if (!isRedirectPage) {\n            $.ajax({\n                cache: false,\n                url: \"/QueueDispense/DeleteLocked\",\n                type: 'post',\n                success: function (result) {\n                }\n            });\n        }\n\n        ////Added by Koh Chin Choong 20211029 - Move all close browser tab or window delete locked to parent layout.\n        //if (performance.navigation.type == performance.navigation.TYPE_RELOAD) {\n        //    console.info(\"This page is reloaded\");\n        //} else {\n        //    if (!isRedirectPage) {\n        //        $.ajax({\n        //            cache: false,\n        //            url: \"/QueueDispense/DeleteLocked\",\n        //            type: 'post',\n        //            success: function (result) {\n        //            }\n        //        });\n        //    }\n        //}\n        ////End Added by Koh Chin Choong 20211029\n    });\n\n    function showProfileModal() {\n        $(\"#md-UserProfile\").modal('show');\n    }\n\n    function hideAlert() {\n        $.ajax({\n            cache: false,\n            url: \"/Authenticate/hideAlertForThisSession\",\n            type: 'post',\n            success: function (result) {\n                if(result.success) {\n                    $(\"#redAnnouncement\").fadeOut();\n                    $(\".content\").css(\"margin-top\", \"-10px\");\n                }\n                else {\n                }\n            }\n        });\n    }\n\n    function convertDateAndTime(dateString) {\n        const d = new Date(parseInt(dateString.match(/\\d+/)[0], 10));\n        const pad = (n) => String(n).padStart(2, '0');\n        return { date: `${pad(d.getDate())}-${['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'][d.getMonth()]}-${d.getFullYear()}`, time: `${pad(d.getHours())}:${pad(d.getMinutes())}` };\n    }\n\n    function showAlertDetails() {\n        $(\"#alertDetailsModal\").modal('show').removeClass(\"fade\");\n    }\n\n    //Added by Lim Han Yong 20240229 - deletelockedsession\n    function DeleteLockedSessionID(){\n        var data = { lockID : 'inc4ycpbori0zxvrej3ihi1o' };\n\n        $.ajax({\n            cache: false,\n            data: JSON.stringify(data),\n            url: \"/Authenticate/DeleteLockedSessionID\",\n            type: 'post',\n            contentType: \"application/json; charset=utf-8\",\n            dataType: \"json\",\n            success: function (result) {\n            }\n        });\n    }\n    //End Added by Lim Han Yong 20240229\n    //Added by Kenneth 2025-01-22 To block multiple tab\n    //Modified by Jia Yi 20250219 - add setup for block multiple tab\n    window.addEventListener('storage', (event) => {\n        if('True' == \"True\")\n        {\n            if ((event.url.toLowerCase().indexOf(\"reportviewer\") < 0) && (event.url.toLowerCase().indexOf(\"casenote/scannerupload\") < 0) && (event.url.toLowerCase().indexOf(\"home/addonfeatures\") < 0) && (event.url.toLowerCase().indexOf(\"casenote/tabdatatemplate\") < 0) && (event.url.toLowerCase().indexOf(\"casenote/tabdatadocument\") < 0) && (event.url.toLowerCase().indexOf(\"chartview/\") < 0) && (event.url.toLowerCase().indexOf(\"pcnannotation/pcnanno\") < 0) && (event.url.toLowerCase().indexOf(\"clientprintendmonth\") < 0) && (event.url.toLowerCase().indexOf(\"pcnannotation/pcnattachment\") < 0)) {    //Edited by Veronica 20231026 - Add pcnAttachment   |   //Edited by Jason 20230207 - add chartview and pcnaano and change lowercase //Modified by Cheng YU 20230202 - add Casenote/TabDataTemplate and change tolowercase //Modified by JiaCheng 20230207 - add Casenote/TabDataDocument and change tolowercase //Modified by JiaCheng 20230223 - add clientprintendmonth and change tolowercase\n                $(\".PageDisabled\").show();\n                swal({\n                    title: \"\",\n                    text: \"Clinic Assist is open in another window/tab. Click 'Use Here' to use Clinic Assist in this window or close this window.\",\n                    type: \"error\",\n                    confirmButtonText: \"Use Here\"\n                }, function (isConfirm) {\n                    if (isConfirm) {\n                        document.location.reload(true);\n                    }\n                });\n            }\n        }\n    }, false)\n    //End Added by Kenneth 2025-01-22",
