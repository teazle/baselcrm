l00_MainContent_uc_MakeClaim_txtprimarydiagnosisCode'); var txtChronicDiagnosis1Code = document.getElementById('ctl00_MainContent_uc_MakeClaim_txtChronicDiagnosis1Code'); var ddlFeeType = document.getElementById('ctl00_MainContent_uc_MakeClaim_ddlFeeType'); var primaryDiagnosisCode = txtprimarydiagnosisCode.value; var chronicDiagnosisCode = txtChronicDiagnosis1Code.value; var nurseConsultationItem = findDropDownItem(ddlFeeType, \"Nurse_Consultation\"); var drugRefillItem = findDropDownItem(ddlFeeType, \"Drug_Refill\"); if (primaryDiagnosisCode && chronicDiagnosisCode) { // Both have values, hide both items nurseConsultationItem.style.display = 'none'; nurseConsultationItem.disabled = true; drugRefillItem.style.display = 'none'; drugRefillItem.disabled = true; } else if (primaryDiagnosisCode) { // Only primary diagnosis has value, hide both items nurseConsultationItem.style.display = 'none'; nurseConsultationItem.disabled = true; drugRefillItem.style.display = 'none'; drugRefillItem.disabled = true; } else if (chronicDiagnosisCode) { // Only chronic diagnosis has value, show both items nurseConsultationItem.style.display = 'block'; nurseConsultationItem.disabled = false; drugRefillItem.style.display = 'block'; drugRefillItem.disabled = false; } else { // Neither has value, show both items nurseConsultationItem.style.display = 'block'; nurseConsultationItem.disabled = false; drugRefillItem.style.display = 'block'; drugRefillItem.disabled = false; } } // AHG-3269: Nursing Consultation Fee function findDropDownItem(dropdown, value) { for (var i = 0; i < dropdown.options.length; i++) { if (dropdown.options[i].value === value) { return dropdown.options[i]; } } return { disabled: false } ; } function clearPairedTextBox(value, id, txtid) { if (!value) { document.getElementById(id).value = \"\"; document.getElementById(txtid).value = \"\"; } } function autoextendfunctionwithParameters(id, url, contextKey, hfID, txtid, inputType = \"\", isICDCode = false) { $(\"#\" + id).auto