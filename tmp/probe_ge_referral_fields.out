  "referralLabel": [
    "HOME CLAIMMANAGEMENT CLAIMS Add Claim List Claims INPATIENT Add Pre-Admission Form List Pre-Admission Form Add Specialist Claim Draft Specialist Claim Submitted Specialist Claim Inpatient Panel Specialist List REPORTS Payment Advice DOWNLOADS PUAF for SupremeCare SRF e-form Alliance Doctor LOG Request FormAlliance Healthcare Programme Guide - SP (as of 31 Jan 2026)Great Eastern Member LOG Request Form PROGRAMME TEMPLATE GEL Card Template SP clinic - SINGAPORE SPORTS & ORTHOPAEDIC CLINIC PTE LTD function SelectXrayReferralClinicClick() { var visitdate = document.getElementById(\"ctl00_MainContent_uc_MakeClaim_txtVisitDate\"); var MCMID = document.getElementById(\"ctl00_MainContent_uc_MakeClaim_hfMemberCompanyMapID\"); var CPID = document.getElementById(\"ctl00_MainContent_uc_MakeClaim_hfCompanyPanelID\"); if (visitdate.value == \"\") { alert(\"Please enter Visit Date\"); return; } var url = \"/Views/Provider/SearchClinic.aspx?vd=\" + visitdate.value + \"&MCMID=\" + MCMID.value + \"&ppid=\" + CPID.value + \"&source=xrayrefclinic&callback=reloadPageOnItemSelected&keepThis=true&TB_iframe=true&height=450&width=600\"; tb_show(\"Select Referring Clinic\", url); } function SelectLabReferralClinicClick() { var visitdate = document.getElementById(\"ctl00_MainContent_uc_MakeClaim_txtVisitDate\"); var MCMID = document.getElementById(\"ctl00_MainContent_uc_MakeClaim_hfMemberCompanyMapID\"); if (visitdate.value == \"\") { alert(\"Please enter Visit Date\"); return; } var url = \"/Views/Provider/SearchClinic.aspx?vd=\" + visitdate.value + \"&MCMID=\" + MCMID.value + \"&source=labrefclinic&callback=reloadPageOnItemSelected&keepThis=true&TB_iframe=true&height=450&width=600\"; tb_show(\"Select Referring Clinic\", url); } function getCookie(c_name) { if (document.cookie.length > 0) { c_start = document.cookie.indexOf(c_name + \"=\"); if (c_start != -1) { c_start = c_start + c_name.length + 1; c_end = document.cookie.indexOf(\";\", c_start); if (c_end == -1) c_end = document.cookie.length; return unescape(document.cookie.substring(c_start, c_end)); } } return \"\"; } function reloadPageOnItemSelected() { var ReloadDataObject = document.getElementById(\"ctl00_MidContent_uc_MakeClaim_btnReloadData\"); var ReloadDataObject1 = document.getElementById(\"ctl00_MainContent_uc_ClinicAdminControls_uc_MakeClaim_btnReloadData\"); var ReloadDataObject2 = document.getElementById(\"ctl00_MainContent_uc_MemberCDMFirstVisit_uc_MemberInputData_uc_MakeClaim_btnReloadData\"); var ItemSelectedCookie = getCookie(\"CLAIMITEMSELECTEDDATA\"); if (ItemSelectedCookie == \"\") { return; } if (ReloadDataObject != null) { ReloadDataObject.click(); return; } if (ReloadDataObject1 != null) { ReloadDataObject1.click(); return; } if (ReloadDataObject2 != null) { ReloadDataObject2.click(); return; } } function ddlSurgical_Changed() { document.getElementById('ctl00_MainContent_uc_MakeClaim_txtProcedurePrice').value = document.getElementById('ctl00_MainContent_uc_MakeClaim_ddlSurgical').value; document.getElementById('ctl00_MainContent_uc_MakeClaim_hfSurgeonFee').value = document.getElementById('ctl00_MainContent_uc_MakeClaim_ddlSurgical').value; } function ddlMCDay_Changed() { document.getElementById('ctl00_MainContent_uc_MakeClaim_txtMcDays').value = document.getElementById('ctl00_MainContent_uc_MakeClaim_ddlMcDay').value; } function putintextbox(source, destination, hiddenField) { if (document.getElementById(source).value == '') { document.getElementById(destination).value = ''; } else { document.getElementById(destination).value = document.getElementById(source).options[document.getElementById(source).selectedIndex].text; } if (hiddenField != null) { document.getElementById(hiddenField).value = document.getElementById(source).value; } //GetVisitType(); } function setCookie(name, value) { document.cookie = name + '=' + escape(value); } function DurgError(message) { alert(message); } function onVisitDateChange() { var visitdate = document.getElementById('ctl00_MainContent_uc