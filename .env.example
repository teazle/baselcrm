IXCHANGE_PORTAL_USERNAME=your_username
IXCHANGE_PORTAL_PASSWORD=your_password

# GE / NTUC IM Configuration (tags: GE, NTUC_IM)
# Keep empty if not yet finalized.
GE_NTUC_PORTAL_URL=
GE_NTUC_PORTAL_USERNAME=
GE_NTUC_PORTAL_PASSWORD=

# Optional runtime override:
# You can manage portal URL/username/password from RPA frontend settings (/rpa/settings).
# Flow 3 reads table `rpa_portal_credentials` first, then falls back to env values above.
# Required for encrypted credential-at-rest in portal settings API:
# - raw passphrase (will be SHA-256 derived), or
# - 32-byte key in base64 with `base64:` prefix, or
# - 64-char hex key.
RPA_CREDENTIALS_ENCRYPTION_KEY=

# Browser Configuration
HEADLESS=false
SLOW_MO=500
TIMEOUT=30000

# Proxy Configuration (for accessing Singapore-restricted sites like MHC Asia)
# Enable proxy to access sites that require Singapore IP address
PROXY_ENABLED=true

# Option 1: Auto-discover free Singapore proxies (recommended for free solution)
# Set PROXY_AUTO_DISCOVER=true (default) to automatically find and use free Singapore proxies
PROXY_AUTO_DISCOVER=true
PROXY_MAX_RETRIES=3

# Option 2: Manually configure a proxy server
# Uncomment and set these if you have a specific proxy server
# PROXY_SERVER=http://proxy.example.com:8080
# PROXY_USERNAME=optional_username
# PROXY_PASSWORD=optional_password

# Proxy bypass rules (comma-separated)
PROXY_BYPASS=localhost,127.0.0.1

# Note: If you prefer using a system-level VPN instead of proxy:
# 1. Install a free VPN with Singapore servers (e.g., Falcon VPN, VeePN)
# 2. Connect to Singapore server
# 3. Set PROXY_ENABLED=false

# Flow 2 diagnosis fallback (optional)
# When enabled, unresolved/low-confidence diagnosis can fall back to:
# - R52 "Pain, unspecified" if pain-like symptom hints exist
# - R69 "Illness, unspecified" otherwise
FLOW2_ENABLE_GENERIC_DIAG_FALLBACK=1

# Portal-first diagnosis matching (optional)
# Lower values are more permissive; higher values are stricter.
DIAGNOSIS_MATCH_MIN_SCORE=90
